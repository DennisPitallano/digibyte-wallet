@page "/settings"
@inject ThemeService Theme
@inject NavigationManager Nav
@inject MemoryCacheService Cache
@inject ISecureStorage Storage
@inject IWebAssemblyHostEnvironment HostEnv

<PageTitle>Settings</PageTitle>

@if (showLanguageToast)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm scale-in" @onclick="() => showLanguageToast = false">
        <div class="bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl p-6 mx-6 max-w-xs text-center shadow-2xl flex flex-col items-center gap-3" @onclick:stopPropagation="true">
            <div class="w-12 h-12 rounded-full bg-dgb-50 dark:bg-dgb-800 flex items-center justify-center">
                <svg class="w-6 h-6 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802" />
                </svg>
            </div>
            <h3 class="text-base font-bold text-slate-900 dark:text-white">Coming Soon</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Multi-language support is coming in a future update.</p>
            <button class="mt-1 px-5 py-2 bg-dgb-500 hover:bg-dgb-600 text-white text-sm font-semibold rounded-xl transition-colors press-effect"
                    @onclick="() => showLanguageToast = false">Got it</button>
        </div>
    </div>
}

<div class="flex flex-col gap-4">
    <h2 class="text-xl font-bold text-slate-900 dark:text-white slide-up">Settings</h2>

    <div class="flex flex-col gap-2">
        @* Theme Toggle *@
        <div class="slide-up-delay-1 flex items-center justify-between p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 card-hover">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-slate-100 dark:bg-dgb-800 flex items-center justify-center">
                    @if (Theme.IsDark)
                    {
                        <svg class="w-5 h-5 text-dgb-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
                        </svg>
                    }
                    else
                    {
                        <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
                        </svg>
                    }
                </div>
                <div>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white">Appearance</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400">@(Theme.IsDark ? "Dark mode" : "Light mode")</p>
                </div>
            </div>
            <button class="relative w-12 h-7 rounded-full transition-colors duration-200 @(Theme.IsDark ? "bg-dgb-500" : "bg-slate-300")"
                    @onclick="ToggleTheme">
                <span class="absolute top-0.5 left-0.5 w-6 h-6 bg-white rounded-full shadow-sm transition-transform duration-200 @(Theme.IsDark ? "translate-x-5" : "translate-x-0")"></span>
            </button>
        </div>

        @* Display Mode *@
        <div class="slide-up-delay-2 flex items-center justify-between p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 card-hover">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-slate-100 dark:bg-dgb-800 flex items-center justify-center">
                    <svg class="w-5 h-5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6Zm0 9.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25Zm9.75-9.75A2.25 2.25 0 0 1 15.75 3.75H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6Z" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white">Display Mode</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400">@(AppState.IsSimpleMode ? "Simple" : "Advanced")</p>
                </div>
            </div>
            <select value="@(AppState.IsSimpleMode ? "true" : "false")" @onchange="OnDisplayModeChanged"
                    class="bg-slate-100 dark:bg-dgb-800 border-0 text-sm text-slate-700 dark:text-slate-300 rounded-lg px-3 py-1.5 outline-none">
                <option value="true">Simple</option>
                <option value="false">Advanced</option>
            </select>
        </div>

        @* Currency *@
        <div class="slide-up-delay-3 flex items-center justify-between p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 card-hover">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-slate-100 dark:bg-dgb-800 flex items-center justify-center">
                    <svg class="w-5 h-5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white">Currency</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400">@AppState.FiatCurrency</p>
                </div>
            </div>
            <select value="@AppState.FiatCurrency" @onchange="OnCurrencyChanged"
                    class="bg-slate-100 dark:bg-dgb-800 border-0 text-sm text-slate-700 dark:text-slate-300 rounded-lg px-3 py-1.5 outline-none">
                <option value="USD">USD</option>
                <option value="EUR">EUR</option>
                <option value="GBP">GBP</option>
                <option value="PHP">PHP</option>
                <option value="JPY">JPY</option>
            </select>
        </div>

        @* Network *@
        <div class="slide-up-delay-4 flex items-center justify-between p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 card-hover">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl @NetworkIconBg flex items-center justify-center">
                    <svg class="w-5 h-5 @NetworkIconColor" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white">Network</p>
                    <p class="text-xs @NetworkIconColor font-medium">@AppState.NetworkMode</p>
                </div>
            </div>
            <select value="@AppState.NetworkMode" @onchange="OnNetworkChanged"
                    class="bg-slate-100 dark:bg-dgb-800 border-0 text-sm text-slate-700 dark:text-slate-300 rounded-lg px-3 py-1.5 outline-none">
                <option value="regtest">Regtest</option>
                <option value="testnet">Testnet</option>
                <option value="mainnet">Mainnet</option>
            </select>
        </div>

        @* Language (continued) *@
        <div class="slide-up-delay-5 flex items-center justify-between p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 card-hover">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-slate-100 dark:bg-dgb-800 flex items-center justify-center">
                    <svg class="w-5 h-5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white">Language</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400">English</p>
                </div>
            </div>
            <button @onclick="ShowLanguageComingSoon"
                    class="bg-slate-100 dark:bg-dgb-800 text-sm text-slate-700 dark:text-slate-300 rounded-lg px-3 py-1.5">
                English
                <svg class="w-3 h-3 inline ml-1 opacity-50" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
            </button>
        </div>

        @* Backup *@
        <button class="slide-up-delay-5 flex items-center gap-3 w-full p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 hover:bg-slate-50 dark:hover:bg-dgb-800 transition-all card-hover text-left"
                @onclick="GoToBackup">
            <div class="w-9 h-9 rounded-xl bg-amber-50 dark:bg-amber-900/20 flex items-center justify-center">
                <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-semibold text-slate-900 dark:text-white">Back Up Seed Phrase</p>
                <p class="text-xs text-slate-500 dark:text-slate-400">View your recovery phrase</p>
            </div>
        </button>
        @* About & Info *@
        <div class="mt-4 pt-4 border-t border-slate-200 dark:border-dgb-800">
            <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-2 px-1">About & Info</p>
            <div class="flex flex-col gap-2">
                <a href="/about" class="flex items-center gap-3 w-full p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 hover:bg-slate-50 dark:hover:bg-dgb-800 transition-all card-hover text-left no-underline">
                    <div class="w-9 h-9 rounded-xl bg-dgb-50 dark:bg-dgb-900/40 flex items-center justify-center">
                        <svg class="w-5 h-5 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-slate-900 dark:text-white">About</p>
                        <p class="text-xs text-slate-500 dark:text-slate-400">Version, tech stack & credits</p>
                    </div>
                </a>
                <a href="/roadmap" class="flex items-center gap-3 w-full p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 hover:bg-slate-50 dark:hover:bg-dgb-800 transition-all card-hover text-left no-underline">
                    <div class="w-9 h-9 rounded-xl bg-green-50 dark:bg-green-900/20 flex items-center justify-center">
                        <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-slate-900 dark:text-white">Roadmap</p>
                        <p class="text-xs text-slate-500 dark:text-slate-400">Development progress & plans</p>
                    </div>
                </a>
                <a href="/analytics" class="flex items-center gap-3 w-full p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 hover:bg-slate-50 dark:hover:bg-dgb-800 transition-all card-hover text-left no-underline">
                    <div class="w-9 h-9 rounded-xl bg-purple-50 dark:bg-purple-900/20 flex items-center justify-center">
                        <svg class="w-5 h-5 text-purple-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-slate-900 dark:text-white">Analytics</p>
                        <p class="text-xs text-slate-500 dark:text-slate-400">DGB price, market cap & network stats</p>
                    </div>
                </a>
                <a href="/deployment" class="flex items-center gap-3 w-full p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 hover:bg-slate-50 dark:hover:bg-dgb-800 transition-all card-hover text-left no-underline">
                    <div class="w-9 h-9 rounded-xl bg-slate-100 dark:bg-dgb-800 flex items-center justify-center">
                        <svg class="w-5 h-5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008ZM6.75 14.25h.008v.008H6.75v-.008Z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-slate-900 dark:text-white">Deployment</p>
                        <p class="text-xs text-slate-500 dark:text-slate-400">Infrastructure status & costs</p>
                    </div>
                </a>
            </div>
        </div>

        @* Developer Tools — only in Development *@
        @if (HostEnv.IsDevelopment())
        {
        <div class="mt-4 pt-4 border-t border-slate-200 dark:border-dgb-800">
            <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-2 px-1">Developer Tools</p>
            <button class="w-full flex items-center gap-3 p-4 bg-amber-50 dark:bg-amber-900/10 rounded-2xl border border-amber-200 dark:border-amber-900/30 hover:bg-amber-100 dark:hover:bg-amber-900/20 transition-colors text-left disabled:opacity-50"
                    @onclick="ClearAllCaches" disabled="@isCacheClearing">
                <div class="w-9 h-9 rounded-xl bg-amber-100 dark:bg-amber-900/20 flex items-center justify-center">
                    <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-semibold text-amber-700 dark:text-amber-400">@(isCacheClearing ? "Clearing..." : cacheCleared ? "Cache Cleared ✓" : "Clear All Caches")</p>
                    <p class="text-xs text-amber-500 dark:text-amber-600">Purge in-memory & IndexedDB cache data</p>
                </div>
            </button>
        </div>
        }

        @* Delete Wallet — Danger Zone *@
        <div class="mt-4 pt-4 border-t border-red-200 dark:border-red-900/30">
            @if (!showDeleteConfirm)
            {
                <button class="w-full flex items-center gap-3 p-4 bg-red-50 dark:bg-red-900/10 rounded-2xl border border-red-200 dark:border-red-900/30 hover:bg-red-100 dark:hover:bg-red-900/20 transition-colors text-left"
                        @onclick="() => showDeleteConfirm = true">
                    <div class="w-9 h-9 rounded-xl bg-red-100 dark:bg-red-900/20 flex items-center justify-center">
                        <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-red-600 dark:text-red-400">Delete Wallet</p>
                        <p class="text-xs text-red-400 dark:text-red-500">Remove all wallet data from this device</p>
                    </div>
                </button>
            }
            else
            {
                <div class="scale-in bg-red-50 dark:bg-red-900/10 rounded-2xl border border-red-200 dark:border-red-900/30 p-4 flex flex-col gap-3">
                    <p class="text-xs text-red-600 dark:text-red-400 font-medium leading-relaxed">
                        This will permanently delete your wallet and all data. Make sure you have backed up your recovery phrase first.
                    </p>
                    <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-center">Enter PIN to confirm</p>
                    <PinInput @ref="deletePinInput" ValueChanged="(v) => deletePin = v" Error="@deleteError" />
                    <div class="flex gap-2">
                        <button class="flex-1 py-2.5 bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-300 text-sm font-semibold rounded-xl press-effect"
                                @onclick="CancelDelete">Cancel</button>
                        <button class="flex-1 py-2.5 bg-red-500 text-white text-sm font-semibold rounded-xl press-effect disabled:opacity-50"
                                @onclick="ConfirmDelete" disabled="@(deletePin.Length < 6)">Delete Wallet</button>
                    </div>
                </div>
            }
        </div>
    </div>

    @* Version footer *@
    <div class="text-center pt-2 pb-4">
        <p class="text-[10px] text-slate-400 dark:text-slate-500">DigiByte Wallet v@(AppVersion.Version)</p>
    </div>
</div>

@code {
    [Inject] private AppState AppState { get; set; } = default!;
    [Inject] private LocalizationService L10n { get; set; } = default!;
    [Inject] private WalletService WalletService { get; set; } = default!;

    // Delete wallet state
    private bool showDeleteConfirm;
    private string deletePin = "";
    private string? deleteError;
    private PinInput? deletePinInput;

    // Cache clear state
    private bool isCacheClearing;
    private bool cacheCleared;
    private bool showLanguageToast;

    private string NetworkIconBg => AppState.NetworkMode switch
    {
        "mainnet" => "bg-green-50 dark:bg-green-900/20",
        "testnet" => "bg-amber-50 dark:bg-amber-900/20",
        _ => "bg-blue-50 dark:bg-blue-900/20",
    };

    private string NetworkIconColor => AppState.NetworkMode switch
    {
        "mainnet" => "text-green-500",
        "testnet" => "text-amber-500",
        _ => "text-blue-500",
    };

    private async Task ToggleTheme() => await Theme.ToggleAsync();

    private void GoToBackup() => Nav.NavigateTo("/backup-seed");

    private async Task OnDisplayModeChanged(ChangeEventArgs e)
    {
        AppState.IsSimpleMode = e.Value?.ToString() == "true";
        await AppState.SavePreferenceAsync("dgb-display-mode", AppState.IsSimpleMode ? "simple" : "advanced");
    }

    private async Task OnCurrencyChanged(ChangeEventArgs e)
    {
        var currency = e.Value?.ToString() ?? "USD";
        AppState.FiatCurrency = currency;
        await AppState.SavePreferenceAsync("dgb-currency", currency);
        Cache.RemoveByPrefix("price");
        Cache.Remove("lastFetchTime");
        await Storage.RemoveAsync("cache:dgbPrice");
        await Storage.RemoveAsync("cache:lastFetch");
        AppState.NotifyStateChanged();
    }

    private async Task OnNetworkChanged(ChangeEventArgs e)
    {
        var mode = e.Value?.ToString() ?? "regtest";
        AppState.NetworkMode = mode;
        AppState.IsTestnet = mode != "mainnet";
        await AppState.SavePreferenceAsync("dgb-network", mode);
        AppState.NotifyStateChanged();
    }

    private void ShowLanguageComingSoon()
    {
        showLanguageToast = true;
        StateHasChanged();
        _ = DismissLanguageToast();
    }

    private async Task DismissLanguageToast()
    {
        await Task.Delay(2500);
        showLanguageToast = false;
        StateHasChanged();
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deletePin = "";
        deleteError = null;
    }

    private async Task ConfirmDelete()
    {
        if (deletePin.Length < 6) return;
        deleteError = null;

        // Verify PIN is correct first
        var walletId = await WalletService.GetActiveWalletIdAsync();
        if (walletId == null) return;

        var success = await WalletService.UnlockWalletAsync(walletId, deletePin);
        if (!success)
        {
            deleteError = "Incorrect PIN.";
            deletePin = "";
            deletePinInput?.Clear();
            return;
        }

        // PIN verified — delete everything
        Cache.Clear();
        await WalletService.WipeAllDataAsync();
        AppState.IsWalletCreated = false;
        AppState.IsWalletUnlocked = false;
        Nav.NavigateTo("/welcome");
    }

    private async Task ClearAllCaches()
    {
        isCacheClearing = true;
        StateHasChanged();

        Cache.Clear();
        await Storage.RemoveAsync("cache:balance");
        await Storage.RemoveAsync("cache:transactions");
        await Storage.RemoveAsync("cache:dgbPrice");
        await Storage.RemoveAsync("cache:lastFetch");

        isCacheClearing = false;
        cacheCleared = true;
        StateHasChanged();

        await Task.Delay(2000);
        cacheCleared = false;
        StateHasChanged();
    }
}
