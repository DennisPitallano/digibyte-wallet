@page "/create-wallet"
@inject WalletService WalletService
@inject AppState AppState
@inject NavigationManager Nav

<PageTitle>@(isAddWalletMode ? "Add" : "Create") Wallet</PageTitle>

<div class="flex flex-col gap-5">
    @if (isAddWalletMode)
    {
        <button class="self-start flex items-center gap-1.5 text-xs text-slate-400 hover:text-dgb-500 font-medium transition-colors"
                @onclick="GoBack">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
            Back
        </button>
    }

    @* Step Indicator *@
    <div class="flex items-center justify-center gap-2 mb-2 fade-in">
        @for (int i = 0; i < totalSteps; i++)
        {
            var idx = i;
            <div class="h-1.5 rounded-full transition-all duration-500 ease-out @(idx <= currentStepIndex ? "bg-dgb-500 w-10" : "bg-slate-200 dark:bg-dgb-800 w-6")"></div>
        }
    </div>

    @if (step == Step.NameWallet)
    {
        <div class="slide-up">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white">Name Your Wallet</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Give this wallet a name so you can identify it easily.</p>
        </div>

        <div class="flex flex-col gap-3">
            <input type="text" @bind="walletName" @bind:event="oninput"
                   placeholder="e.g. Savings, Trading, Cold Storage..."
                   maxlength="30" autocomplete="off"
                   class="w-full px-4 py-3.5 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl text-slate-900 dark:text-white text-base outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
            <p class="text-xs text-slate-400 dark:text-slate-500 text-right">@walletName.Length / 30</p>
        </div>

        @* Color Picker *@
        <div class="flex flex-col gap-2">
            <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Wallet Color</p>
            <div class="flex flex-wrap gap-2.5">
                @foreach (var c in WalletInfo.ColorPalette)
                {
                    var color = c;
                    <button class="w-9 h-9 rounded-full transition-all duration-200 press-effect ring-offset-2 ring-offset-white dark:ring-offset-dgb-950 @(walletColor == color ? "ring-2 scale-110" : "hover:scale-105")"
                            style="background-color: @color; @(walletColor == color ? $"box-shadow: 0 0 0 2px {color}40; --tw-ring-color: {color};" : "")"
                            @onclick="() => walletColor = color">
                        @if (walletColor == color)
                        {
                            <svg class="w-4 h-4 mx-auto text-white drop-shadow" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                            </svg>
                        }
                    </button>
                }
            </div>
        </div>

        <button class="w-full py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 transition-all press-effect disabled:opacity-50"
                @onclick="NameContinue" disabled="@string.IsNullOrWhiteSpace(walletName)">
            Continue
        </button>
    }
    else if (step == Step.GenerateMnemonic)
    {
        <div class="slide-up">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white">Your Recovery Phrase</h2>
            <p class="text-sm text-amber-600 dark:text-amber-400 mt-2 leading-relaxed bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800/30 rounded-xl p-3">
                Write these 24 words down and store them safely. They are the <strong>only</strong> way to recover your wallet.
            </p>
        </div>

        <div class="grid grid-cols-3 gap-2">
            @for (int i = 0; i < words.Length; i++)
            {
                var idx = i;
                <div class="flex items-center gap-1.5 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl px-2.5 py-2.5 shadow-sm">
                    <span class="text-[10px] font-bold text-slate-400 dark:text-slate-500 w-4 text-right">@(idx + 1)</span>
                    <span class="text-sm font-semibold text-slate-800 dark:text-slate-200">@words[idx]</span>
                </div>
            }
        </div>

        <button class="w-full py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 hover:shadow-xl hover:shadow-dgb-500/30 transition-all press-effect slide-up-delay-2"
                @onclick="GoToConfirm">
            I've Written It Down
        </button>
    }
    else if (step == Step.ConfirmMnemonic)
    {
        <div class="slide-up">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white">Confirm Recovery Phrase</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Enter word <strong class="text-dgb-500">#@(confirmWordIndex + 1)</strong> from your recovery phrase</p>
        </div>

        <div class="flex flex-col gap-3">
            <input type="text" @bind="confirmInput" @bind:event="oninput"
                   placeholder="Enter word #@(confirmWordIndex + 1)" autocomplete="off"
                   class="w-full px-4 py-3.5 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl text-slate-900 dark:text-white text-base outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
            @if (confirmError != null)
            {
                <p class="text-sm text-red-500 font-medium">@confirmError</p>
            }
        </div>

        <div class="flex flex-col gap-2 slide-up-delay-2">
            <button class="w-full py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 hover:shadow-xl hover:shadow-dgb-500/30 transition-all press-effect disabled:opacity-50"
                    @onclick="VerifyWord" disabled="@string.IsNullOrWhiteSpace(confirmInput)">
                @(confirmStep < 2 ? "Next" : "Confirm")
            </button>
            <button class="text-sm text-dgb-500 hover:text-dgb-600 font-medium py-2" @onclick="BackToMnemonic">
                Show phrase again
            </button>
        </div>
    }
    else if (step == Step.SetPin)
    {
        <div class="slide-up text-center">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white">Set Your PIN</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Choose a 6-digit PIN to secure your wallet</p>
        </div>

        <div class="flex flex-col gap-4 items-center">
            @if (!isConfirmingPin)
            {
                <p class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Enter PIN</p>
                <PinInput @ref="pinInput1" ValueChanged="(v) => pin = v" OnComplete="GoToConfirmPin" Error="@pinError" />
            }
            else
            {
                <p class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Confirm PIN</p>
                <PinInput @ref="pinInput2" ValueChanged="(v) => pinConfirm = v" OnComplete="CreateWalletAsync" Error="@pinError" />
                <button class="text-sm text-dgb-500 hover:text-dgb-600 font-medium" @onclick="BackToSetPin">Change PIN</button>
            }
        </div>

        <button class="w-full py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 hover:shadow-xl hover:shadow-dgb-500/30 transition-all press-effect disabled:opacity-50 slide-up-delay-3 flex items-center justify-center gap-2"
                @onclick="OnPinButtonClick"
                disabled="@(isCreating || (!isConfirmingPin && pin.Length < 6) || (isConfirmingPin && pinConfirm.Length < 6))">
            @if (isCreating)
            {
                <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                <span>Creating...</span>
            }
            else if (!isConfirmingPin)
            {
                <span>Continue</span>
            }
            else
            {
                <span>Create Wallet</span>
            }
        </button>
    }

    <div class="flex items-center gap-3 text-xs text-slate-400 dark:text-slate-500 mt-2">
        <a href="/help" class="hover:text-dgb-500 transition-colors">Help</a>
        <span>·</span>
        <a href="/about" class="hover:text-dgb-500 transition-colors">About</a>
    </div>

    <div class="flex flex-col items-center gap-1.5 mt-4">
        <VersionBadge />
        <p class="text-[10px] text-slate-400 dark:text-slate-500">Speed · Security · Scalability</p>
    </div>
</div>

@code {
    private enum Step { NameWallet, GenerateMnemonic, ConfirmMnemonic, SetPin }
    private Step step = Step.GenerateMnemonic;
    private string[] words = [];
    private string mnemonic = "";
    private int confirmStep;
    private int confirmWordIndex;
    private string confirmInput = "";
    private string? confirmError;
    private readonly int[] confirmIndices = new int[3];
    private string pin = "";
    private string pinConfirm = "";
    private string? pinError;
    private bool isCreating;
    private bool isConfirmingPin;
    private PinInput? pinInput1;
    private PinInput? pinInput2;
    private bool isAddWalletMode;
    private string walletName = "";
    private string walletColor = WalletInfo.ColorPalette[0];

    private int totalSteps => isAddWalletMode ? 4 : 3;
    private int currentStepIndex => step switch
    {
        Step.NameWallet => 0,
        Step.GenerateMnemonic => isAddWalletMode ? 1 : 0,
        Step.ConfirmMnemonic => isAddWalletMode ? 2 : 1,
        Step.SetPin => isAddWalletMode ? 3 : 2,
        _ => 0
    };

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        isAddWalletMode = uri.Query.Contains("addWallet=true");
        step = isAddWalletMode ? Step.NameWallet : Step.GenerateMnemonic;

        GenerateMnemonicPhrase();
    }

    private void GenerateMnemonicPhrase()
    {
        var m = DigiByte.Crypto.KeyGeneration.MnemonicGenerator.Generate();
        mnemonic = m.ToString();
        words = mnemonic.Split(' ');
        var rng = new Random();
        var indices = Enumerable.Range(0, words.Length).OrderBy(_ => rng.Next()).Take(3).OrderBy(i => i).ToArray();
        Array.Copy(indices, confirmIndices, 3);
        confirmWordIndex = confirmIndices[0];
    }

    private void GoBack()
    {
        if (isAddWalletMode)
            Nav.NavigateTo("/welcome?addWallet=true");
        else
            Nav.NavigateTo("/welcome");
    }

    private void NameContinue()
    {
        if (string.IsNullOrWhiteSpace(walletName)) return;
        step = Step.GenerateMnemonic;
    }

    private void GoToConfirm() { confirmStep = 0; confirmWordIndex = confirmIndices[0]; confirmInput = ""; confirmError = null; step = Step.ConfirmMnemonic; }
    private void BackToMnemonic() { step = Step.GenerateMnemonic; }

    private void VerifyWord()
    {
        if (!string.Equals(confirmInput.Trim(), words[confirmWordIndex], StringComparison.OrdinalIgnoreCase)) { confirmError = "Incorrect word. Please try again."; return; }
        confirmError = null; confirmInput = ""; confirmStep++;
        if (confirmStep >= 3) { step = Step.SetPin; } else { confirmWordIndex = confirmIndices[confirmStep]; }
    }

    private async Task OnPinButtonClick()
    {
        if (isConfirmingPin) await CreateWalletAsync();
        else GoToConfirmPin();
    }

    private void GoToConfirmPin()
    {
        if (pin.Length < 6) { pinError = "Enter all 6 digits"; return; }
        pinError = null;
        pinConfirm = "";
        isConfirmingPin = true;
    }

    private void BackToSetPin()
    {
        isConfirmingPin = false;
        pin = "";
        pinConfirm = "";
        pinError = null;
        pinInput1?.Clear();
    }

    private async Task CreateWalletAsync()
    {
        pinError = null;
        if (pin.Length < 6) { pinError = "Enter all 6 digits"; return; }
        if (pin != pinConfirm) { pinError = "PINs don't match. Try again."; pinConfirm = ""; pinInput2?.Clear(); return; }
        isCreating = true;
        StateHasChanged();
        await Task.Yield();
        try
        {
            var name = isAddWalletMode ? walletName.Trim() : "My Wallet";
            var color = isAddWalletMode ? walletColor : null;
            WalletService.SetNetworkMode(AppState.NetworkMode);
            await WalletService.CreateWalletAsync(name, mnemonic, pin, color);
            AppState.IsWalletCreated = true; AppState.IsWalletUnlocked = true; AppState.NotifyStateChanged();
            Nav.NavigateTo("/");
        }
        catch (Exception ex) { pinError = $"Failed to create wallet: {ex.Message}"; }
        finally { isCreating = false; }
    }
}
