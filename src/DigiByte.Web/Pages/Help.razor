@page "/help"
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Help Center — DigiByte Wallet</PageTitle>

<div class="flex flex-col gap-4">
    <button class="flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-dgb-500 transition-colors w-fit -mb-2" @onclick="GoBack">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
        Back
    </button>
    <div class="slide-up">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Help Center</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Tutorials, how-tos, and support for DigiByte Wallet.</p>
    </div>

    @* Search / Filter *@
    <div class="slide-up-delay-1">
        <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
            <input type="text" @bind="searchQuery" @bind:event="oninput" placeholder="Search help topics..."
                   class="w-full pl-10 pr-4 py-2.5 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl text-sm text-slate-900 dark:text-white placeholder-slate-400 outline-none focus:ring-2 focus:ring-dgb-500/30 focus:border-dgb-500 transition-all" />
        </div>
    </div>

    @* Sections *@
    <div class="flex flex-col gap-2 slide-up-delay-2">
        @foreach (var section in FilteredSections)
        {
            var isOpen = openSections.Contains(section.Id);
            <div class="bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 overflow-hidden transition-all">
                <button class="w-full flex items-center gap-3 p-4 text-left hover:bg-slate-50 dark:hover:bg-dgb-800/50 transition-colors"
                        @onclick="() => ToggleSection(section.Id)">
                    <div class="w-9 h-9 rounded-xl @(section.IconBg) flex items-center justify-center flex-shrink-0">
                        @((MarkupString)section.IconSvg)
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold text-slate-900 dark:text-white">@(section.Title)</p>
                        <p class="text-xs text-slate-500 dark:text-slate-400 truncate">@(section.Subtitle)</p>
                    </div>
                    <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 flex-shrink-0 @(isOpen ? "rotate-180" : "")"
                         fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                    </svg>
                </button>

                @if (isOpen)
                {
                    <div class="px-4 pb-4 border-t border-slate-100 dark:border-dgb-800">
                        <div class="flex flex-col gap-3 pt-3">
                            @foreach (var qa in section.Items)
                            {
                                <div>
                                    <p class="text-xs font-semibold text-slate-800 dark:text-slate-200 mb-1">@qa.Question</p>
                                    <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">@((MarkupString)qa.Answer)</p>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* Report Issue / Suggest Feature *@
    <div class="slide-up-delay-3 mt-2">
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-2 px-1">Feedback & Support</p>

        <div class="bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 p-4 flex flex-col gap-3">
            <div class="flex gap-2">
                <button class="flex-1 py-2 text-xs font-semibold rounded-xl transition-colors @(feedbackType == "bug" ? "bg-red-500 text-white" : "bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-300") press-effect"
                        @onclick='() => feedbackType = "bug"'>
                    Report Bug
                </button>
                <button class="flex-1 py-2 text-xs font-semibold rounded-xl transition-colors @(feedbackType == "feature" ? "bg-dgb-500 text-white" : "bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-300") press-effect"
                        @onclick='() => feedbackType = "feature"'>
                    Suggest Feature
                </button>
            </div>

            <input type="text" @bind="feedbackTitle" placeholder="@(feedbackType == "bug" ? "What went wrong?" : "What would you like to see?")"
                   class="w-full px-3 py-2 bg-slate-50 dark:bg-dgb-800 border border-slate-200 dark:border-dgb-700 rounded-xl text-sm text-slate-900 dark:text-white placeholder-slate-400 outline-none focus:ring-2 focus:ring-dgb-500/30 focus:border-dgb-500" />

            <textarea @bind="feedbackBody" rows="3" placeholder="Describe in detail..."
                      class="w-full px-3 py-2 bg-slate-50 dark:bg-dgb-800 border border-slate-200 dark:border-dgb-700 rounded-xl text-sm text-slate-900 dark:text-white placeholder-slate-400 outline-none focus:ring-2 focus:ring-dgb-500/30 focus:border-dgb-500 resize-none"></textarea>

            <button class="w-full py-2.5 bg-dgb-500 hover:bg-dgb-600 text-white text-sm font-semibold rounded-xl transition-colors press-effect disabled:opacity-50"
                    disabled="@(string.IsNullOrWhiteSpace(feedbackTitle))"
                    @onclick="SubmitFeedback">
                Open on GitHub
            </button>

            <a href="https://github.com/DennisPitallano/digibyte-wallet/issues" target="_blank" rel="noopener"
               class="text-center text-[11px] text-dgb-500 hover:text-dgb-600 font-medium transition-colors">
                Or browse existing issues on GitHub &rarr;
            </a>
        </div>
    </div>

    <div class="pb-4"></div>
</div>

@code {
    private string searchQuery = "";
    private string feedbackType = "bug";
    private string feedbackTitle = "";
    private string feedbackBody = "";
    private HashSet<string> openSections = [];

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private void ToggleSection(string id)
    {
        if (!openSections.Remove(id))
            openSections.Add(id);
    }

    private async Task SubmitFeedback()
    {
        var label = feedbackType == "bug" ? "bug" : "enhancement";
        var title = Uri.EscapeDataString(feedbackTitle);
        var body = Uri.EscapeDataString(feedbackBody);
        var url = $"https://github.com/DennisPitallano/digibyte-wallet/issues/new?title={title}&body={body}&labels={label}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private IEnumerable<HelpSection> FilteredSections =>
        string.IsNullOrWhiteSpace(searchQuery)
            ? sections
            : sections.Where(s =>
                s.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                s.Subtitle.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                s.Items.Any(i =>
                    i.Question.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    i.Answer.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)));

    private record QA(string Question, string Answer);
    private record HelpSection(string Id, string Title, string Subtitle, string IconBg, string IconSvg, QA[] Items);

    private HelpSection[] sections = [
        new("getting-started", "Getting Started", "Install, create wallet, set PIN", "bg-green-50 dark:bg-green-900/20",
            "<svg class=\"w-5 h-5 text-green-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z\" /></svg>",
            [
                new("How do I install the wallet?", "Visit <b>dgbwallet.app</b> in your browser. On Chrome/Edge, tap the install banner or use the browser menu → \"Install app\". On iOS Safari, tap Share → \"Add to Home Screen\". The wallet works offline once installed."),
                new("How do I create a new wallet?", "Tap <b>Create New Wallet</b> on the welcome screen. The app generates 24 secret words (your recovery phrase). Write them down on paper — this is your only backup. Confirm 3 random words, then set a 6-digit PIN."),
                new("What is a recovery phrase?", "A 24-word BIP39 mnemonic that can restore your wallet on any compatible app. <b>Never share it</b> with anyone. If you lose it and forget your PIN, your funds are permanently lost."),
                new("What does the PIN do?", "The 6-digit PIN encrypts your wallet data with AES-256-GCM. You need it to unlock the app and authorize transactions. After 3 wrong attempts, there's an exponential lockout (15s → 30s → 60s → 120s)."),
                new("How do I recover a wallet from a seed phrase?", "Tap <b>Recover Existing Wallet</b> on the welcome screen. You have two input modes:<br/><b>Paste All</b> — paste your entire phrase into a single text area (accepts space, comma, or newline-separated words).<br/><b>Word by Word</b> — enter each word in a numbered grid with BIP39 auto-suggest. As you type, matching words appear in a dropdown — use arrow keys and Enter to select. Toggle between 12 and 24 words. Both modes support a show/hide toggle to mask your phrase for privacy."),
            ]),

        new("sending-receiving", "Sending & Receiving", "Send DGB, batch send, receive, QR codes, fees", "bg-dgb-50 dark:bg-dgb-900/30",
            "<svg class=\"w-5 h-5 text-dgb-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5\" /></svg>",
            [
                new("How do I send DigiByte?", "Tap <b>Send</b> → enter the recipient's address (or scan a QR code, or pick a contact). Enter the amount — tap the currency badge to switch between DGB and fiat. Tap <b>Review</b>, confirm the details, then <b>Send</b>. The transaction is signed locally and broadcast to the network."),
                new("What is Batch Send?", "Batch Send lets you send DGB to <b>up to 20 recipients in a single transaction</b>. On the Send page, tap <b>Multiple Recipients</b> to switch to batch mode. Add addresses and amounts for each recipient, then review and confirm. All payments are combined into one transaction."),
                new("What are the benefits of Batch Send?", "<b>Lower fees</b> — one transaction with 10 outputs costs far less than 10 separate transactions (you pay for only one set of inputs and overhead). <b>Faster</b> — all recipients are paid in one broadcast instead of waiting for each to confirm. <b>Simpler</b> — manage payroll, donations, or group payments from a single screen with no copy-paste repetition."),
                new("When should I use Batch Send?", "<b>Payroll &amp; freelancer payments</b> — pay your entire team or multiple contractors in a single transaction instead of sending one by one. <b>Donations &amp; tips</b> — split a donation across several causes or tip multiple content creators at once. <b>Group payments</b> — splitting a dinner bill, collecting dues, or sending holiday gifts to friends and family. <b>Treasury distribution</b> — DAOs, clubs, or small businesses distributing funds to members or shareholders. <b>Consolidation</b> — moving funds to your own addresses (e.g. cold storage split) in one go."),
                new("Are there limits on Batch Send?", "Maximum <b>20 recipients</b> per transaction. Each recipient must receive at least <b>0.0001 DGB</b>. Duplicate addresses are not allowed. Your total (all amounts + fee) must not exceed your balance."),
                new("How do I receive DigiByte?", "Tap <b>Receive</b> → show the QR code to the sender, or copy your address. Toggle between <b>Legacy</b> (D...) and <b>SegWit</b> (dgb1...) formats. SegWit addresses have lower fees."),
                new("What are fee rates?", "Fees are measured in sat/vB (satoshis per virtual byte). Choose <b>Low</b> (100), <b>Normal</b> (200), or <b>Fast</b> (400). Higher fees get confirmed faster. In Advanced mode, you can set a custom fee rate."),
                new("Why did my transaction fail?", "Common reasons: insufficient balance (amount + fee exceeds balance), network congestion, or too many unconfirmed UTXOs (too-long-mempool-chain). Wait for pending transactions to confirm and try again."),
                new("How do I get a PDF receipt?", "Tap any transaction on the Home page to open the detail modal, then tap <b>PDF Receipt</b>. This generates a downloadable PDF via <a href='https://blockchair.com' target='_blank' class='text-dgb-500 underline'>Blockchair</a>, a third-party blockchain explorer. The PDF includes the transaction ID, amounts, addresses, confirmations, and timestamp."),
            ]),

        new("contacts-payments", "Contacts & Payments", "Address book, BIP21 payment requests", "bg-indigo-50 dark:bg-indigo-900/20",
            "<svg class=\"w-5 h-5 text-indigo-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z\" /></svg>",
            [
                new("How do I add a contact?", "Go to <b>Contacts</b> → tap <b>+</b>. Enter a name and DGB address (or scan a QR code). You can also add contacts directly from the transaction detail modal."),
                new("How do I create a payment request?", "Go to <b>Pay</b> tab → tap <b>Create Request</b>. Set the amount, label, and message. A BIP21 URI and QR code are generated. Share the QR or copy the URI for the sender to scan."),
                new("What is a BIP21 URI?", "A standard format: <code>digibyte:ADDRESS?amount=X&amp;label=Y</code>. When scanned, it auto-fills the send form with the address, amount, and label."),
            ]),

        new("security-backup", "Security & Backup", "Seed phrase, PIN reset, delete wallet", "bg-amber-50 dark:bg-amber-900/20",
            "<svg class=\"w-5 h-5 text-amber-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z\" /></svg>",
            [
                new("How do I back up my seed phrase?", "Go to <b>Settings</b> → <b>Back Up Seed Phrase</b>. Enter your PIN to reveal the 24 words. Write them on paper and store in a secure location. <b>Never take a screenshot or store digitally.</b>"),
                new("I forgot my PIN — what do I do?", "On the unlock screen, tap <b>Forgot PIN?</b> → <b>Reset PIN with recovery phrase</b>. Enter your 24 words and set a new PIN. If you've lost both your PIN and seed phrase, the wallet cannot be recovered."),
                new("How do I delete my wallet?", "Go to <b>Settings</b> → <b>Delete Wallet</b> → enter your PIN to confirm. This permanently removes all wallet data from the device. Make sure you've backed up your seed phrase first. <b>If you have multisig wallets, back up their redeem scripts too</b> — your seed phrase alone cannot restore them."),
                new("Is my data encrypted?", "Yes. Your seed phrase and private keys are encrypted with <b>AES-256-GCM</b>, using a key derived from your PIN via PBKDF2. Encrypted data is stored in the browser's IndexedDB. Keys are never sent to any server."),
            ]),

        new("spending-limits", "Spending Limits", "Daily, weekly & monthly send limits", "bg-red-50 dark:bg-red-900/20",
            "<svg class=\"w-5 h-5 text-red-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285ZM12 15.75h.007v.008H12v-.008Z\" /></svg>",
            [
                new("How do I set up spending limits?", "Go to <b>Settings</b> → <b>Spending Limits</b>. Enter your PIN to access the controls. Toggle <b>Enable Spending Limits</b>, then set Daily (24h), Weekly (7d), and/or Monthly (30d) limits in DGB. Changes auto-save instantly."),
                new("What happens when I approach or exceed a limit?", "When your total sends reach the <b>alert threshold</b> (default 80%) of any limit, an amber warning appears on the send review screen. If <b>Block Sends</b> is enabled, the transaction is blocked entirely when you exceed the limit. If Block Sends is off, you see a warning but can still proceed."),
                new("Can I set different limits for each wallet?", "Yes. Spending limits are <b>per-wallet</b> — each wallet has independent daily, weekly, and monthly limits. Watch-only (xpub) wallets don't show spending limits since they can't send."),
                new("What counts toward my spending limit?", "All <b>sent transactions</b> within the rolling time window (24 hours, 7 days, or 30 days from now) are totalled. Received transactions are not counted. The limit is checked against DGB amounts, not fiat values."),
            ]),

        new("biometric", "Biometric Unlock & Send Confirmation", "Fingerprint/face unlock, confirm sends, security model", "bg-emerald-50 dark:bg-emerald-900/20",
            "<svg class=\"w-5 h-5 text-emerald-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a48.667 48.667 0 0 0-1.418 8.773 7.498 7.498 0 0 1-1.332-5.023A7.5 7.5 0 0 1 7.864 4.243ZM14.25 14.25a2.25 2.25 0 0 0-4.5 0v.75a2.25 2.25 0 0 0 4.5 0v-.75Zm-2.25-6.75a4.5 4.5 0 0 0-4.5 4.5v.75a4.5 4.5 0 0 0 9 0v-.75a4.5 4.5 0 0 0-4.5-4.5Z\" /></svg>",
            [
                new("What is biometric unlock?", "Biometric unlock lets you use your device's <b>fingerprint sensor or face recognition</b> instead of typing your 6-digit PIN. It uses the <b>WebAuthn</b> standard supported by modern browsers and devices. A single biometric setup covers <b>all your wallets</b> — no need to enroll each one separately. Your PIN still works as a backup."),
                new("How do I enable biometric unlock?", "After your first successful PIN unlock, a prompt asks \"<b>Enable Biometric Unlock?</b>\" Tap <b>Enable Biometric</b> and authenticate with your fingerprint/face. You can also enable it later from <b>Settings</b> → <b>Biometric Unlock</b> toggle (requires PIN verification)."),
                new("How does biometric unlock keep my wallet secure?", "When you enroll, the app creates a <b>WebAuthn credential</b> tied to your device's biometric sensor and generates a random <b>AES-256 encryption key</b>. Each wallet's seed is encrypted with this key and stored in IndexedDB. To unlock, you must pass a biometric assertion (fingerprint/face) before the app decrypts. The encryption key is <b>origin-bound</b> — only this website on this device can access it."),
                new("What is 'Confirm Sends with Biometric'?", "An optional setting (under <b>Settings</b> → <b>Confirm Sends</b>) that adds a biometric check before every transaction. When enabled, tapping \"<b>Send Now</b>\" triggers a fingerprint/face prompt — if you cancel or fail, the send is blocked. This prevents unauthorized sends if someone gains access to your unlocked wallet."),
                new("When should I enable 'Confirm Sends'?", "<b>Real-life scenarios where this helps:</b><ul class='mt-1 ml-2 list-disc list-inside flex flex-col gap-1'><li><b>Shared device:</b> You share a tablet with family — confirm-send ensures only you can authorize transactions, even if the wallet is unlocked.</li><li><b>Large transactions:</b> You're sending a significant amount and want a second layer of confirmation beyond the review screen.</li><li><b>Business use:</b> You manage a team treasury from your phone — biometric confirmation adds accountability to every outgoing payment.</li><li><b>Child safety:</b> Your child uses the device — they can view balances but can't send funds without your fingerprint.</li><li><b>Auto-lock timeout:</b> If your auto-lock is set to a long interval (e.g., 30 minutes), confirm-send protects during that window.</li></ul>"),
                new("Is biometric shared across wallets?", "Yes. A single biometric enrollment works for <b>all your wallets</b>. When you enable biometric and unlock another wallet with its PIN for the first time, that wallet's seed is automatically added to biometric unlock. Disabling biometric removes it for all wallets."),
                new("What if biometric fails?", "If your fingerprint/face isn't recognized or the platform authenticator is unavailable, the wallet falls back to <b>PIN entry</b>. Biometric is a convenience layer — your PIN always works."),
                new("What devices support biometric unlock?", "Any device with a <b>platform authenticator</b> (built-in fingerprint scanner or face recognition) and a browser supporting <b>WebAuthn</b>. This includes most modern Android devices (Chrome), Windows Hello (Edge/Chrome), macOS Touch ID (Safari/Chrome), and iOS (Safari). You can use any authenticator your browser offers — Google Password Manager, Windows Hello, or native fingerprint/face."),
                new("Can someone bypass biometric with my PIN?", "Yes — that's by design. Your PIN is the primary authentication method; biometric is a faster alternative. If you're concerned about PIN security, choose a non-obvious PIN and consider enabling <b>Confirm Sends with Biometric</b> as an additional layer for outgoing transactions."),
                new("What happens to biometric when I delete my wallet?", "All biometric data (credential, encrypted keys, preferences) is <b>permanently removed</b> when you delete a wallet. If you restore the wallet from your seed phrase, you'll need to re-enroll biometric from Settings."),
            ]),

        new("watch-only", "Watch-Only Wallets", "Import xpub, view balances", "bg-cyan-50 dark:bg-cyan-900/20",
            "<svg class=\"w-5 h-5 text-cyan-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z\" /><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z\" /></svg>",
            [
                new("What is a watch-only wallet?", "A wallet created from an extended public key (xpub) that can view balances and transaction history but <b>cannot sign or send</b> transactions. Useful for monitoring cold storage."),
                new("How do I create a watch-only wallet?", "On the welcome screen, choose <b>Recover</b> → paste your <b>xpub</b> key. The wallet derives addresses from the xpub and tracks balances from the blockchain."),
                new("Can I send from a watch-only wallet?", "No. Watch-only wallets don't have private keys, so they cannot sign transactions. You'll need the full wallet (with seed phrase or private key) to send funds."),
            ]),

        new("multisig", "Multisig Wallets", "M-of-N wallets, PSBT signing, real-time rooms", "bg-purple-50 dark:bg-purple-900/20",
            "<svg class=\"w-5 h-5 text-purple-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z\" /></svg>",
            [
                new("What is a multisig wallet?", "A wallet that requires <b>M-of-N</b> signatures to spend funds. For example, a 2-of-3 multisig needs 2 out of 3 co-signers to approve a transaction. This adds an extra layer of security — no single key can move funds alone."),
                new("How do I create a multisig wallet?", "Tap the <b>Multisig</b> button on the Home screen → <b>Create</b>. Choose the threshold (e.g., 2-of-3). Your public key is auto-added. Add other co-signers by pasting their compressed public key (hex). Review and confirm to create the wallet."),
                new("How do I send from a multisig wallet?", "Open your multisig wallet → <b>Send</b>. Enter the destination and amount. A <b>PSBT</b> (Partially Signed Transaction) is created. Sign it with your key, then share the PSBT with co-signers. Once enough signatures are collected, the transaction can be finalized and broadcast."),
                new("What is a PSBT?", "A <b>Partially Signed Transaction</b> (BIP174) — a standard format originally from Bitcoin, also used by DigiByte, for passing unsigned or partially signed transactions between co-signers. Each signer adds their signature to the PSBT, and when the threshold is met, it can be finalized into a complete transaction."),
                new("How do I import an existing multisig wallet?", "Go to <b>Multisig</b> → <b>Import</b>. Paste the redeem script (hex). The wallet detects the threshold, co-signers, and whether your key is among them. If your key is found, you can sign transactions; otherwise, it's imported as watch-only."),
                new("How do co-signers exchange PSBTs?", "After creating a PSBT, copy the base64-encoded string and share it with co-signers (via secure messaging, email, etc.). Co-signers paste the signed PSBT back into the <b>Pending Transactions</b> page. Signatures are combined automatically."),
                new("What is a Multisig Room?", "A real-time collaborative room where co-signers join together to create a multisig wallet. One person creates the room and gets a <b>6-character invite code</b>. Others join using the code — everyone's public key is shared automatically via SignalR. When all participants are ready, the wallet is created simultaneously on all devices."),
                new("How do I create a multisig wallet in real-time?", "Go to <b>Multisig</b> → <b>Create</b> → <b>Create Together in Real-Time</b>. Create a room, set the wallet name and M-of-N threshold, then share the invite code with your co-signers. Once everyone joins and taps <b>Ready</b>, the wallet is created on all devices at once — no need to manually exchange public keys."),
                new("What happens to my multisig if I delete and recover my wallet?", "<b>Multisig wallets are NOT recovered by your seed phrase.</b> Your 24-word mnemonic only restores your personal HD wallet. Multisig configurations (redeem script, co-signer keys, threshold) are stored locally and wiped when you delete the wallet. <b>Always back up the redeem script</b> — you can download it from the multisig wallet detail page. To restore: go to <b>Multisig → Import</b> and paste the redeem script."),
                new("Where can I learn more?", "Read our <a href='/help/multisig' class='text-purple-500 underline'>complete Multisig Guide</a> — it includes visual flowcharts, real-world scenarios, step-by-step walkthroughs for beginners, and technical details for developers."),
            ]),

        new("recovery", "Recovery Tools", "Sweep old paths, external seeds, WIF keys", "bg-cyan-50 dark:bg-cyan-900/20",
            "<svg class=\"w-5 h-5 text-cyan-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.678 48.678 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3-3 3\" /></svg>",
            [
                new("What are Recovery Tools?", "A permanent utility page (Settings → Recovery Tools) for sweeping funds from old derivation paths, another wallet's seed phrase, or a standalone private key (WIF). It scans the blockchain for any balance and lets you move everything into your current wallet in one transaction."),
                new("When should I use Recovery Tools?", "<b>Real-life scenarios:</b><ul class='mt-1 ml-2 list-disc list-inside flex flex-col gap-1'><li><b>Wallet upgrade:</b> You used an older DGB wallet that generated addresses on BIP44 or BIP49 paths — Recovery Tools finds and sweeps those funds.</li><li><b>Paper backup import:</b> You have a 24-word seed phrase written on paper from an old wallet or a friend's wallet and want to move the funds here.</li><li><b>Private key sweep:</b> Someone sent you a WIF private key (e.g., from a paper wallet, a giveaway, or a DigiSweep card) and you want to claim the funds.</li><li><b>Multi-wallet consolidation:</b> You have DGB spread across multiple seed phrases and want to consolidate everything into one wallet.</li><li><b>Post-migration cleanup:</b> After the v0.3.1 BIP84 migration, your old BIP44 addresses may still hold funds — this tool finds and moves them.</li></ul>"),
                new("How does 'Current Wallet — Old Paths' work?", "If you have an HD wallet, this scans your current seed's old derivation paths (<b>BIP44</b> and <b>BIP49</b>) without needing to re-enter your seed phrase. It checks all three address types (Legacy, SegWit-P2SH, SegWit) for each key to catch funds regardless of how the addresses were originally generated. If funds are found, tap <b>Move to Wallet</b> to sweep them to your current BIP84 address."),
                new("How does 'External Sweep' work?", "Enter a <b>seed phrase</b> (12 or 24 words) or a <b>WIF private key</b>. For seed phrases, the tool scans BIP44, BIP49, and BIP84 paths across all address types. For WIF keys, it checks Legacy, SegWit-P2SH, and SegWit encodings. Found funds can be swept to your current wallet in one tap."),
                new("Is it safe to enter another seed phrase?", "Yes. The seed phrase or private key is used <b>only in memory</b> for address derivation and transaction signing. It is <b>never stored</b> — not in IndexedDB, not in local storage, not sent to any server. Close the page when you're done for maximum safety."),
                new("What does the progress bar show?", "During a scan, the progress bar shows the percentage completion and the current derivation path being checked (e.g., \"BIP44 · Legacy · m/44'/20'/0'/0\" or \"BIP49 · SegWit-P2SH\"). This helps you understand which paths have been scanned and how much remains."),
                new("Can I scan the same seed again?", "Yes. After a scan completes (whether funds are found or not), you can tap <b>Scan again</b> to re-run the scan. This is useful if you've received funds on old addresses since the last scan."),
                new("What if someone gave me a paper wallet or DigiSweep card?", "Switch to the <b>Private Key (WIF)</b> tab, enter the key (starts with K, L, or 5), and tap <b>Scan for Funds</b>. If the key has a balance on any address type, you'll see it and can sweep it to your wallet. This is the fastest way to claim funds from paper wallets, promotional giveaways, or physical DGB cards."),
            ]),

        new("digi-id", "Digi-ID", "Passwordless authentication, signing flow, troubleshooting", "bg-blue-50 dark:bg-blue-900/20",
