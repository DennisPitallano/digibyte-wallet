@page "/multisig/import"
@inject MultisigWalletService MultisigService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Import Multisig</PageTitle>

<AuthGuard>
<div class="flex flex-col gap-5">
    <div class="slide-up">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Import Multisig Wallet</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
            Paste the redeem script shared by a co-signer, or restore from a backup file.
        </p>
    </div>

    @* Import from file *@
    <div class="slide-up-delay-1 rounded-2xl bg-indigo-50 dark:bg-indigo-900/10 border border-indigo-200 dark:border-indigo-800/30 p-4">
        <div class="flex items-start gap-2.5">
            <svg class="w-5 h-5 text-indigo-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m6.75 12-3-3m0 0-3 3m3-3v6m-1.5-15H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
            <div class="flex-1">
                <p class="text-xs font-bold text-indigo-800 dark:text-indigo-300">Have a backup file?</p>
                <p class="text-[11px] text-indigo-700 dark:text-indigo-400 leading-relaxed mt-0.5">
                    Upload the <code class="text-[10px]">.txt</code> backup file exported from the multisig wallet detail page.
                </p>
                <label class="inline-flex items-center gap-1.5 mt-2 px-3 py-1.5 bg-indigo-500 hover:bg-indigo-600 text-white text-xs font-semibold rounded-xl cursor-pointer transition-colors press-effect">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13" /></svg>
                    Choose File
                    <InputFile OnChange="OnFileSelected" accept=".txt" class="hidden" />
                </label>
                @if (!string.IsNullOrEmpty(fileName))
                {
                    <p class="text-[10px] text-indigo-600 dark:text-indigo-400 mt-1">@fileName loaded</p>
                }
            </div>
        </div>
    </div>

    <div class="flex items-center gap-3 slide-up-delay-1">
        <div class="flex-1 border-t border-slate-200 dark:border-dgb-800"></div>
        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500">or paste manually</span>
        <div class="flex-1 border-t border-slate-200 dark:border-dgb-800"></div>
    </div>

    <div class="flex flex-col gap-4">
        @* Wallet Name *@
        <div class="flex flex-col gap-1.5 slide-up-delay-1">
            <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Wallet Name</label>
            <input type="text" @bind="walletName" placeholder="e.g. Shared Fund"
                   class="w-full px-4 py-3 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
        </div>

        @* Redeem Script *@
        <div class="flex flex-col gap-1.5 slide-up-delay-1">
            <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Redeem Script (Hex)</label>
            <textarea @bind="redeemScriptHex" @bind:event="oninput" rows="4"
                      placeholder="Paste the multisig redeem script hex..."
                      class="w-full px-4 py-3 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl text-[11px] font-mono text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all resize-none"></textarea>
        </div>

        @* Own Key Index *@
        <div class="flex flex-col gap-1.5 slide-up-delay-1">
            <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Your Key Position (optional)</label>
            <input type="number" @bind="ownKeyIndex" min="-1" max="14"
                   placeholder="-1 for watch-only"
                   class="w-full px-4 py-3 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
            <p class="text-[11px] text-slate-400 dark:text-slate-500">
                Enter -1 for watch-only, or 0-based index of your key in the script.
            </p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(error))
    {
        <p class="text-sm text-red-500 font-medium">@error</p>
    }

    <div class="flex flex-col gap-2 slide-up-delay-2">
        <button class="w-full py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 transition-all press-effect disabled:opacity-50"
                @onclick="ImportWallet" disabled="@(isImporting || string.IsNullOrWhiteSpace(walletName) || string.IsNullOrWhiteSpace(redeemScriptHex))">
            @if (isImporting)
            {
                <div class="flex items-center justify-center gap-2">
                    <div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                    <span>Importing...</span>
                </div>
            }
            else
            {
                <span>Import Wallet</span>
            }
        </button>
        <button class="text-sm text-dgb-500 hover:text-dgb-600 font-medium py-2"
                @onclick='() => Nav.NavigateTo("/multisig")'>Cancel</button>
    </div>
</div>
</AuthGuard>

@code {
    private string walletName = "";
    private string redeemScriptHex = "";
    private int ownKeyIndex = -1;
    private string? error;
    private bool isImporting;
    private string? fileName;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        error = null;
        try
        {
            var file = e.File;
            if (file.Size > 50_000) // 50KB max for a text backup
            {
                error = "File too large. Backup files should be under 50KB.";
                return;
            }

            fileName = file.Name;
            using var stream = file.OpenReadStream(maxAllowedSize: 50_000);
            using var reader = new System.IO.StreamReader(stream);
            var content = await reader.ReadToEndAsync();

            // Parse the backup file format
            ParseBackupFile(content);
        }
        catch (Exception ex)
        {
            error = $"Failed to read file: {ex.Message}";
        }
    }

    private void ParseBackupFile(string content)
    {
        var lines = content.Split('\n').Select(l => l.Trim()).ToArray();

        // Look for "Label:" line
        var labelLine = lines.FirstOrDefault(l => l.StartsWith("Label:", StringComparison.OrdinalIgnoreCase));
        if (labelLine != null && string.IsNullOrWhiteSpace(walletName))
            walletName = labelLine["Label:".Length..].Trim();

        // Look for redeem script — the line after "Redeem Script (hex):"
        for (int i = 0; i < lines.Length; i++)
        {
            if (lines[i].StartsWith("Redeem Script", StringComparison.OrdinalIgnoreCase) && i + 1 < lines.Length)
            {
                var script = lines[i + 1].Trim();
                if (!string.IsNullOrEmpty(script) && script.All(c => "0123456789abcdefABCDEF".Contains(c)))
                {
                    redeemScriptHex = script;
                    break;
                }
            }
        }

        if (string.IsNullOrWhiteSpace(redeemScriptHex))
        {
            // Fallback: look for any long hex string in the file
            var hexLine = lines.FirstOrDefault(l => l.Length > 40 && l.All(c => "0123456789abcdefABCDEF".Contains(c)));
            if (hexLine != null)
                redeemScriptHex = hexLine;
            else
                error = "Could not find a redeem script in the backup file.";
        }
    }

    private async Task ImportWallet()
    {
        isImporting = true;
        error = null;
        StateHasChanged();
        await Task.Yield();

        try
        {
            await MultisigService.ImportMultisigWalletAsync(walletName, redeemScriptHex.Trim(), ownKeyIndex);
            Nav.NavigateTo("/multisig");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isImporting = false;
        }
    }
}
