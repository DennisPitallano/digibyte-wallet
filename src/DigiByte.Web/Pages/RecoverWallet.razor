@page "/recover-wallet"
@inject WalletService WalletService
@inject AppState AppState
@inject NavigationManager Nav

<PageTitle>@(isAddWalletMode ? "Add" : "Recover") Wallet</PageTitle>

<div class="flex flex-col gap-5">
    @if (isAddWalletMode)
    {
        <button class="self-start flex items-center gap-1.5 text-xs text-slate-400 hover:text-dgb-500 font-medium transition-colors"
                @onclick="GoBack">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
            Back
        </button>
    }

    @* Step Indicator *@
    <div class="flex items-center justify-center gap-2 mb-2 fade-in">
        @for (int i = 0; i < totalSteps; i++)
        {
            var idx = i;
            <div class="h-1.5 rounded-full transition-all duration-500 ease-out @(idx <= currentStepIndex ? "bg-dgb-500 w-10" : "bg-slate-200 dark:bg-dgb-800 w-6")"></div>
        }
    </div>

    @if (step == Step.NameWallet)
    {
        <div class="slide-up">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white">Name Your Wallet</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Give this wallet a name so you can identify it easily.</p>
        </div>

        <div class="flex flex-col gap-3">
            <input type="text" @bind="walletName" @bind:event="oninput"
                   placeholder="e.g. Savings, Trading, Cold Storage..."
                   maxlength="30" autocomplete="off"
                   class="w-full px-4 py-3.5 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl text-slate-900 dark:text-white text-base outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
            <p class="text-xs text-slate-400 dark:text-slate-500 text-right">@walletName.Length / 30</p>
        </div>

        @* Color Picker *@
        <div class="flex flex-col gap-2">
            <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Wallet Color</p>
            <div class="flex flex-wrap gap-2.5">
                @foreach (var c in WalletInfo.ColorPalette)
                {
                    var color = c;
                    <button class="w-9 h-9 rounded-full transition-all duration-200 press-effect ring-offset-2 ring-offset-white dark:ring-offset-dgb-950 @(walletColor == color ? "ring-2 scale-110" : "hover:scale-105")"
                            style="background-color: @color; @(walletColor == color ? $"box-shadow: 0 0 0 2px {color}40; --tw-ring-color: {color};" : "")"
                            @onclick="() => walletColor = color">
                        @if (walletColor == color)
                        {
                            <svg class="w-4 h-4 mx-auto text-white drop-shadow" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                            </svg>
                        }
                    </button>
                }
            </div>
        </div>

        <button class="w-full py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 transition-all press-effect disabled:opacity-50"
                @onclick="NameContinue" disabled="@string.IsNullOrWhiteSpace(walletName)">
            Continue
        </button>
    }
    else if (step == Step.EnterMnemonic)
    {
        <div class="slide-up">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white">Recover Your Wallet</h2>
        </div>

        @* Recovery method toggle *@
        <div class="slide-up-delay-1 flex bg-slate-100 dark:bg-dgb-900 rounded-xl p-1 gap-0.5">
            <button class="flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all duration-200 @(!isPrivateKeyMode ? "bg-white dark:bg-dgb-800 text-dgb-500 shadow-sm" : "text-slate-500 dark:text-slate-400")"
                    @onclick="() => isPrivateKeyMode = false">Recovery Phrase</button>
            <button class="flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all duration-200 @(isPrivateKeyMode ? "bg-white dark:bg-dgb-800 text-dgb-500 shadow-sm" : "text-slate-500 dark:text-slate-400")"
                    @onclick="() => isPrivateKeyMode = true">Private Key</button>
        </div>

        @if (!isPrivateKeyMode)
        {
            @* Mnemonic input *@
            <div class="flex flex-col gap-3 slide-up-delay-1">
                <p class="text-sm text-slate-500 dark:text-slate-400">Enter your 12 or 24-word recovery phrase.</p>
                <textarea @bind="mnemonicInput" rows="4"
                          placeholder="Enter your recovery phrase separated by spaces..."
                          autocomplete="off" spellcheck="false"
                          class="w-full px-4 py-3.5 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl text-sm text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all resize-none leading-relaxed"></textarea>
                @if (mnemonicError != null)
                {
                    <p class="text-sm text-red-500 font-medium">@mnemonicError</p>
                }
            </div>

            <div class="flex flex-col gap-2">
                <button class="w-full py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 transition-all press-effect disabled:opacity-50"
                        @onclick="ValidateMnemonic" disabled="@string.IsNullOrWhiteSpace(mnemonicInput)">
                    Continue
                </button>
                <button class="text-sm text-dgb-500 hover:text-dgb-600 font-medium py-2" @onclick="GoBack">Back</button>
            </div>
        }
        else
        {
            @* Private Key (WIF) input *@
            <div class="flex flex-col gap-3 slide-up-delay-1">
                <p class="text-sm text-slate-500 dark:text-slate-400">Enter your WIF private key from a paper wallet or export.</p>
                <div class="flex gap-1.5">
                    <input type="password" @bind="wifInput" @bind:event="oninput"
                           placeholder="5... or K... or L..."
                           autocomplete="off" spellcheck="false"
                           class="flex-1 px-4 py-3.5 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl text-sm font-mono text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
                    <button type="button" class="w-12 h-12 rounded-xl bg-dgb-500 text-white flex items-center justify-center hover:bg-dgb-600 transition-all flex-shrink-0 press-effect"
                            @onclick="() => showScanner = true" title="Scan QR">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 3.75 9.375v-4.5Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5Z" />
                        </svg>
                    </button>
                </div>

                @* Address preview *@
                @if (previewAddress != null)
                {
                    <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800/30 rounded-xl p-3">
                        <p class="text-xs text-green-600 dark:text-green-400 font-semibold mb-1">Address Preview</p>
                        <p class="text-xs font-mono text-green-700 dark:text-green-300 break-all">@previewAddress</p>
                    </div>
                }

                @if (wifError != null)
                {
                    <p class="text-sm text-red-500 font-medium">@wifError</p>
                }
            </div>

            <div class="flex flex-col gap-2">
                <button class="w-full py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 transition-all press-effect disabled:opacity-50"
                        @onclick="ValidateWif" disabled="@string.IsNullOrWhiteSpace(wifInput)">
                    Continue
                </button>
                <button class="text-sm text-dgb-500 hover:text-dgb-600 font-medium py-2" @onclick="GoBack">Back</button>
            </div>
        }
    }
    else if (step == Step.SetPin)
    {
        <div class="slide-up text-center">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white">Set Your PIN</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Choose a 6-digit PIN to secure your wallet</p>
        </div>

        <div class="flex flex-col gap-4 items-center">
            @if (!isConfirmingPin)
            {
                <p class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Enter PIN</p>
                <PinInput @ref="rPinInput1" ValueChanged="(v) => pin = v" OnComplete="GoToConfirmPin" Error="@pinError" />
            }
            else
            {
                <p class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Confirm PIN</p>
                <PinInput @ref="rPinInput2" ValueChanged="(v) => pinConfirm = v" OnComplete="RecoverAsync" Error="@pinError" />
                <button class="text-sm text-dgb-500 hover:text-dgb-600 font-medium" @onclick="BackToSetPin">Change PIN</button>
            }
        </div>

        <button class="w-full py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 hover:shadow-xl hover:shadow-dgb-500/30 transition-all press-effect disabled:opacity-50 slide-up-delay-2 flex items-center justify-center gap-2"
                @onclick="OnPinButtonClick"
                disabled="@(isRecovering || (!isConfirmingPin && pin.Length < 6) || (isConfirmingPin && pinConfirm.Length < 6))">
            @if (isRecovering)
            {
                <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                <span>Recovering...</span>
            }
            else if (!isConfirmingPin)
            {
                <span>Continue</span>
            }
            else
            {
                <span>Recover Wallet</span>
            }
        </button>
    }

    @* QR Scanner for WIF *@
    <QrScannerModal IsOpen="@showScanner" OnScanned="OnQrScanned" OnClosed="() => showScanner = false" />
</div>

@code {
    private enum Step { NameWallet, EnterMnemonic, SetPin }
    private Step step = Step.EnterMnemonic;

    // Mnemonic fields
    private string mnemonicInput = "";
    private string? mnemonicError;

    // Private Key fields
    private bool isPrivateKeyMode;
    private string wifInput = "";
    private string? wifError;
    private string? previewAddress;
    private bool showScanner;

    // PIN fields
    private string pin = "";
    private string pinConfirm = "";
    private string? pinError;
    private bool isRecovering;
    private bool isConfirmingPin;
    private PinInput? rPinInput1;
    private PinInput? rPinInput2;

    // Add-wallet mode
    private bool isAddWalletMode;
    private string walletName = "";
    private string walletColor = WalletInfo.ColorPalette[0];

    private int totalSteps => isAddWalletMode ? 3 : 2;
    private int currentStepIndex => step switch
    {
        Step.NameWallet => 0,
        Step.EnterMnemonic => isAddWalletMode ? 1 : 0,
        Step.SetPin => isAddWalletMode ? 2 : 1,
        _ => 0
    };

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        isAddWalletMode = uri.Query.Contains("addWallet=true");
        step = isAddWalletMode ? Step.NameWallet : Step.EnterMnemonic;
    }

    private void GoBack()
    {
        if (isAddWalletMode)
            Nav.NavigateTo("/welcome?addWallet=true");
        else
            Nav.NavigateTo("/welcome");
    }

    private void NameContinue()
    {
        if (string.IsNullOrWhiteSpace(walletName)) return;
        step = Step.EnterMnemonic;
    }

    private void ValidateMnemonic()
    {
        mnemonicError = null;
        var cleaned = string.Join(' ', mnemonicInput.Trim().ToLower()
            .Split(' ', StringSplitOptions.RemoveEmptyEntries));
        var wordCount = cleaned.Split(' ').Length;
        if (wordCount != 12 && wordCount != 24) { mnemonicError = $"Expected 12 or 24 words, got {wordCount}."; return; }
        if (!DigiByte.Crypto.KeyGeneration.MnemonicGenerator.IsValid(cleaned)) { mnemonicError = "Invalid recovery phrase. Please check your words."; return; }
        mnemonicInput = cleaned;
        step = Step.SetPin;
    }

    private void ValidateWif()
    {
        wifError = null;
        previewAddress = null;

        if (string.IsNullOrWhiteSpace(wifInput))
        {
            wifError = "Enter a WIF private key.";
            return;
        }

        if (!DigiByte.Crypto.KeyGeneration.PrivateKeyImporter.IsValidWif(wifInput.Trim()))
        {
            wifError = "Invalid private key format. Expected WIF format (starts with 5, K, or L).";
            return;
        }

        // Show address preview
        try
        {
            var network = DigiByte.Crypto.KeyGeneration.PrivateKeyImporter.DetectNetwork(wifInput.Trim()) ?? WalletService.CurrentNetworkPublic;
            previewAddress = DigiByte.Crypto.KeyGeneration.PrivateKeyImporter.GetAddress(
                wifInput.Trim(), network, NBitcoin.ScriptPubKeyType.Segwit);
        }
        catch { }

        step = Step.SetPin;
    }

    private void OnQrScanned(string data)
    {
        showScanner = false;
        wifInput = data.Trim();
        // Try to show preview immediately
        try
        {
            if (DigiByte.Crypto.KeyGeneration.PrivateKeyImporter.IsValidWif(wifInput))
            {
                var network = DigiByte.Crypto.KeyGeneration.PrivateKeyImporter.DetectNetwork(wifInput.Trim()) ?? WalletService.CurrentNetworkPublic;
                previewAddress = DigiByte.Crypto.KeyGeneration.PrivateKeyImporter.GetAddress(
                    wifInput, network, NBitcoin.ScriptPubKeyType.Segwit);
            }
        }
        catch { }
        StateHasChanged();
    }

    private async Task OnPinButtonClick()
    {
        if (isConfirmingPin) await RecoverAsync();
        else GoToConfirmPin();
    }

    private void GoToConfirmPin()
    {
        if (pin.Length < 6) { pinError = "Enter all 6 digits"; return; }
        pinError = null; pinConfirm = ""; isConfirmingPin = true;
    }

    private void BackToSetPin()
    {
        isConfirmingPin = false; pin = ""; pinConfirm = ""; pinError = null;
        rPinInput1?.Clear();
    }

    private async Task RecoverAsync()
    {
        pinError = null;
        if (pin.Length < 6) { pinError = "Enter all 6 digits"; return; }
        if (pin != pinConfirm) { pinError = "PINs don't match. Try again."; pinConfirm = ""; rPinInput2?.Clear(); return; }
        isRecovering = true;
        StateHasChanged();
        await Task.Yield();
        try
        {
            WalletService.SetNetworkMode(AppState.NetworkMode);
            if (isPrivateKeyMode)
            {
                var name = isAddWalletMode ? walletName.Trim() : "Imported Wallet";
                var color = isAddWalletMode ? walletColor : null;
                await WalletService.CreateWalletFromWifAsync(name, wifInput.Trim(), pin, color);
            }
            else
            {
                var name = isAddWalletMode ? walletName.Trim() : "My Wallet";
                var color = isAddWalletMode ? walletColor : null;
                await WalletService.CreateWalletAsync(name, mnemonicInput, pin, color);
            }
            AppState.IsWalletCreated = true; AppState.IsWalletUnlocked = true; AppState.NotifyStateChanged();
            Nav.NavigateTo("/");
        }
        catch (Exception ex) { pinError = $"Failed to recover wallet: {ex.Message}"; }
        finally { isRecovering = false; }
    }
}
