@page "/multisig/{WalletId}"
@inject MultisigWalletService MultisigService
@inject IBlockchainService Blockchain
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Multisig Details</PageTitle>

<AuthGuard>
@if (isLoading)
{
    <div class="flex flex-col gap-4">
        <div class="h-6 w-48 skeleton rounded"></div>
        <div class="h-32 skeleton rounded-2xl"></div>
        <div class="h-20 skeleton rounded-2xl"></div>
    </div>
}
else if (config == null)
{
    <div class="flex flex-col items-center justify-center gap-4 py-12 text-center">
        <h2 class="text-lg font-bold text-slate-900 dark:text-white">Wallet Not Found</h2>
        <button class="py-2.5 px-6 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl press-effect"
                @onclick='() => Nav.NavigateTo("/multisig")'>Back to Wallets</button>
    </div>
}
else
{
    <div class="flex flex-col gap-4">
        @* Header *@
        <div class="flex items-center gap-3 slide-up">
            <button class="p-2 rounded-xl bg-slate-100 dark:bg-dgb-800 hover:bg-slate-200 dark:hover:bg-dgb-700 transition-colors"
                    @onclick='() => Nav.NavigateTo("/multisig")'>
                <svg class="w-4 h-4 text-slate-600 dark:text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
                </svg>
            </button>
            <div>
                <h2 class="text-xl font-bold text-slate-900 dark:text-white">@config.Label</h2>
                <p class="text-xs text-slate-500 dark:text-slate-400">Multisig Wallet</p>
            </div>
        </div>

        @* Balance Card *@
        <div class="slide-up-delay-1 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200/80 dark:border-dgb-800 p-4">
            <p class="text-xs text-slate-500 dark:text-slate-400">Balance</p>
            @if (isLoadingBalance)
            {
                <div class="h-8 w-36 skeleton rounded-lg mt-1"></div>
            }
            else
            {
                <p class="text-2xl font-extrabold text-slate-900 dark:text-white mt-0.5">@FormatDgb(balanceSatoshis) DGB</p>
            }
        </div>

        @* Address Card *@
        <div class="slide-up-delay-1 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200/80 dark:border-dgb-800 p-4">
            <div class="flex items-center justify-between mb-2">
                <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Address</p>
                <button class="text-xs text-dgb-500 hover:text-dgb-600 font-medium" @onclick="CopyAddress">
                    @(copied ? "Copied!" : "Copy")
                </button>
            </div>
            <p class="text-[11px] font-mono text-slate-700 dark:text-slate-300 break-all leading-relaxed">@config.Address</p>
        </div>

        @* Redeem Script (shareable) *@
        <div class="slide-up-delay-1 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200/80 dark:border-dgb-800 p-4">
            <div class="flex items-center justify-between mb-2">
                <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Redeem Script</p>
                <button class="text-xs text-dgb-500 hover:text-dgb-600 font-medium" @onclick="CopyRedeemScript">
                    @(copiedScript ? "Copied!" : "Copy")
                </button>
            </div>
            <p class="text-[10px] font-mono text-slate-500 dark:text-slate-500 break-all leading-relaxed max-h-16 overflow-y-auto">@config.RedeemScriptHex</p>
            <p class="text-[10px] text-slate-400 mt-1">Share this with co-signers to import this wallet.</p>
        </div>

        @* Co-Signers *@
        <div class="slide-up-delay-1 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200/80 dark:border-dgb-800 p-4">
            <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-3">
                Co-Signers (@config.RequiredSignatures required of @config.TotalSigners)
            </p>
            <div class="flex flex-col gap-2">
                @foreach (var signer in config.CoSigners)
                {
                    <div class="flex items-center gap-2 p-2 rounded-xl bg-slate-50 dark:bg-dgb-800/50">
                        <div class="w-7 h-7 rounded-lg @(signer.IsLocal ? "bg-dgb-100 dark:bg-dgb-700" : "bg-slate-100 dark:bg-dgb-800") flex items-center justify-center">
                            <span class="text-[10px] font-bold @(signer.IsLocal ? "text-dgb-600 dark:text-dgb-400" : "text-slate-500")">@signer.Name[..1].ToUpper()</span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-slate-900 dark:text-white">@signer.Name</p>
                            <p class="text-[10px] font-mono text-slate-400 truncate">@signer.PublicKeyHex[..16]...</p>
                        </div>
                        @if (signer.IsLocal)
                        {
                            <span class="text-[9px] font-bold text-dgb-600 dark:text-dgb-400 bg-dgb-100 dark:bg-dgb-800 px-1.5 py-0.5 rounded-full">YOU</span>
                        }
                    </div>
                }
            </div>
        </div>

        @* Actions *@
        <div class="flex flex-col gap-2 slide-up-delay-2">
            <button class="w-full py-3 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl transition-all press-effect"
                    @onclick="CreateTransaction">
                Create Transaction
            </button>
            <button class="w-full py-3 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 text-slate-900 dark:text-white font-semibold rounded-2xl transition-all press-effect"
                    @onclick="ViewPendingTxs">
                Pending Transactions
                @if (pendingCount > 0)
                {
                    <span class="ml-1 text-xs bg-amber-500 text-white px-1.5 py-0.5 rounded-full">@pendingCount</span>
                }
            </button>
        </div>
    </div>
}
</AuthGuard>

@code {
    [Parameter] public string WalletId { get; set; } = "";

    private MultisigWalletConfig? config;
    private bool isLoading = true;
    private bool isLoadingBalance;
    private long balanceSatoshis;
    private bool copied;
    private bool copiedScript;
    private int pendingCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            config = await MultisigService.GetConfigAsync(WalletId);
            if (config != null)
            {
                var pending = await MultisigService.GetPendingTransactionsAsync(WalletId);
                pendingCount = pending.Count(p => p.Status == PendingTxStatus.AwaitingSignatures || p.Status == PendingTxStatus.ReadyToFinalize);
                _ = LoadBalance();
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadBalance()
    {
        isLoadingBalance = true;
        StateHasChanged();
        try
        {
            balanceSatoshis = await MultisigService.GetBalanceAsync(config!);
        }
        catch { }
        finally
        {
            isLoadingBalance = false;
            StateHasChanged();
        }
    }

    private async Task CopyAddress()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", config!.Address);
        copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        copied = false;
    }

    private async Task CopyRedeemScript()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", config!.RedeemScriptHex);
        copiedScript = true;
        StateHasChanged();
        await Task.Delay(2000);
        copiedScript = false;
    }

    private void CreateTransaction() => Nav.NavigateTo($"/multisig/{WalletId}/send");
    private void ViewPendingTxs() => Nav.NavigateTo($"/multisig/{WalletId}/pending");

    private static string FormatDgb(long satoshis) => (satoshis / 100_000_000m).ToString("N8");
}
