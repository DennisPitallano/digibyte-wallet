@page "/unlock"
@inject WalletService WalletService
@inject AppState AppState
@inject NavigationManager Nav
@inject MemoryCacheService Cache

<PageTitle>Unlock Wallet</PageTitle>

<div class="flex flex-col items-center justify-center min-h-[75vh] gap-8">
    <div class="flex flex-col items-center gap-3 float-in">
        <div class="relative">
            <div class="absolute inset-0 bg-dgb-500/15 rounded-full blur-2xl scale-150 glow-pulse"></div>
            <DigiLogo Size="72" Class="relative" />
        </div>
        <h2 class="text-lg font-bold text-slate-900 dark:text-white">Welcome back</h2>
            <p class="text-sm text-slate-400 dark:text-slate-500">Enter your 6-digit PIN</p>
        </div>

    <div class="flex flex-col items-center gap-5 slide-up-delay-2">
        <PinInput @ref="pinInput"
                  ValueChanged="OnPinChanged"
                  OnComplete="UnlockAsync"
                  Error="@error" />

        <button class="w-full max-w-[280px] py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 hover:shadow-xl hover:shadow-dgb-500/30 transition-all press-effect disabled:opacity-50"
                @onclick="UnlockAsync" disabled="@(isUnlocking || pin.Length < 6)">
            @if (isUnlocking)
            {
                <span class="flex items-center justify-center gap-2">
                    <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                    </svg>
                    Unlocking...
                </span>
            }
            else
            {
                <span>Unlock</span>
            }
        </button>
        @* Forgot PIN link *@
        <button class="text-xs text-slate-400 hover:text-dgb-500 font-medium mt-2 transition-colors"
                @onclick="() => showForgotPin = true">
            Forgot PIN?
        </button>
    </div>

    @* Forgot PIN expanded section *@
    @if (showForgotPin)
    {
        <div class="w-full max-w-[340px] flex flex-col gap-3 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl p-4 scale-in">
            <div class="flex items-center justify-between">
                <h3 class="text-sm font-bold text-slate-900 dark:text-white">Recovery Options</h3>
                <button class="w-7 h-7 rounded-lg bg-slate-100 dark:bg-dgb-800 flex items-center justify-center hover:bg-slate-200 dark:hover:bg-dgb-700 transition-colors"
                        @onclick="CancelForgot">
                    <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            @if (!showSeedInput && !showDeleteConfirm)
            {
                <button class="flex items-center gap-3 p-3 rounded-xl bg-slate-50 dark:bg-dgb-950 hover:bg-slate-100 dark:hover:bg-dgb-800 transition-colors text-left"
                        @onclick="() => showSeedInput = true">
                    <div class="w-8 h-8 rounded-lg bg-dgb-50 dark:bg-dgb-800 flex items-center justify-center flex-shrink-0">
                        <svg class="w-4 h-4 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-slate-900 dark:text-white">Reset PIN with recovery phrase</p>
                        <p class="text-[10px] text-slate-400">Enter your seed phrase to set a new PIN</p>
                    </div>
                </button>

                <button class="flex items-center gap-3 p-3 rounded-xl bg-red-50 dark:bg-red-900/10 hover:bg-red-100 dark:hover:bg-red-900/20 transition-colors text-left"
                        @onclick="() => showDeleteConfirm = true">
                    <div class="w-8 h-8 rounded-lg bg-red-100 dark:bg-red-900/20 flex items-center justify-center flex-shrink-0">
                        <svg class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-red-600 dark:text-red-400">Delete wallet & start over</p>
                        <p class="text-[10px] text-red-400 dark:text-red-500">This cannot be undone</p>
                    </div>
                </button>
            }

            @* Seed phrase input for PIN reset *@
            @if (showSeedInput)
            {
                <textarea @bind="seedInput" rows="3" placeholder="Enter your 24-word recovery phrase..."
                          autocomplete="off" spellcheck="false"
                          class="w-full px-3 py-2.5 bg-slate-50 dark:bg-dgb-950 border border-slate-200 dark:border-dgb-800 rounded-xl text-xs text-slate-900 dark:text-white outline-none focus:border-dgb-500 resize-none leading-relaxed"></textarea>
                @if (resetError != null)
                {
                    <p class="text-xs text-red-500 font-medium">@resetError</p>
                }
                @if (showNewPin)
                {
                    <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-center">New PIN</p>
                    <PinInput @ref="resetPinInput" ValueChanged="(v) => newPin = v" OnComplete="ConfirmResetPin" Error="@resetError" />
                }
                <div class="flex gap-2">
                    <button class="flex-1 py-2 bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-300 text-sm font-semibold rounded-xl press-effect"
                            @onclick="CancelForgot">Cancel</button>
                    @if (!showNewPin)
                    {
                        <button class="flex-1 py-2 bg-dgb-500 text-white text-sm font-semibold rounded-xl press-effect disabled:opacity-50"
                                @onclick="VerifySeed" disabled="@string.IsNullOrWhiteSpace(seedInput)">Verify</button>
                    }
                </div>
            }

            @* Delete confirmation *@
            @if (showDeleteConfirm)
            {
                <div class="bg-red-50 dark:bg-red-900/10 rounded-xl p-3">
                    <p class="text-xs text-red-600 dark:text-red-400 font-medium leading-relaxed">
                        This will permanently delete your wallet and all data. If you don't have your recovery phrase, your funds will be lost forever.
                    </p>
                </div>
                <input type="text" @bind="deleteConfirmText" placeholder="Type DELETE to confirm"
                       class="w-full px-3 py-2.5 bg-slate-50 dark:bg-dgb-950 border border-red-300 dark:border-red-800 rounded-xl text-sm text-slate-900 dark:text-white outline-none text-center uppercase tracking-widest" />
                <div class="flex gap-2">
                    <button class="flex-1 py-2 bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-300 text-sm font-semibold rounded-xl press-effect"
                            @onclick="CancelForgot">Cancel</button>
                    <button class="flex-1 py-2 bg-red-500 text-white text-sm font-semibold rounded-xl press-effect disabled:opacity-50"
                            @onclick="DeleteWallet" disabled="@(deleteConfirmText?.ToUpper() != "DELETE")">Delete Forever</button>
                </div>
            }
        </div>
    }

    <div class="flex items-center gap-3 text-xs text-slate-400 dark:text-slate-500 slide-up-delay-3">
        <a href="/help" class="hover:text-dgb-500 transition-colors">Help</a>
        <span>·</span>
        <a href="/about" class="hover:text-dgb-500 transition-colors">About</a>
        <span>·</span>
        <a href="/roadmap" class="hover:text-dgb-500 transition-colors">Roadmap</a>
        <span>·</span>
        <a href="/analytics" class="hover:text-dgb-500 transition-colors">Analytics</a>
        <span>·</span>
        <a href="/deployment" class="hover:text-dgb-500 transition-colors">Deployment</a>
    </div>

    <div class="flex flex-col items-center gap-1 slide-up-delay-3">
        <p class="text-[10px] text-slate-400 dark:text-slate-500">Speed · Security · Scalability</p>
        <p class="text-[10px] text-slate-400 dark:text-slate-500">DigiByte Wallet v@(AppVersion.Version)</p>
    </div>
</div>

@code {
    private PinInput? pinInput;
    private string pin = "";
    private string? error;
    private bool isUnlocking;
    private string? walletId;

    // Brute-force protection
    private int failedAttempts;
    private DateTime? lockedUntil;
    private bool isLockedOut => lockedUntil.HasValue && DateTime.UtcNow < lockedUntil.Value;
    private string? lockoutMessage;

    // Forgot PIN state
    private bool showForgotPin;
    private bool showSeedInput;
    private bool showDeleteConfirm;
    private bool showNewPin;
    private string seedInput = "";
    private string newPin = "";
    private string? resetError;
    private string deleteConfirmText = "";
    private PinInput? resetPinInput;

    protected override async Task OnInitializedAsync()
    {
        walletId = await WalletService.GetActiveWalletIdAsync();
        if (walletId == null) Nav.NavigateTo("/welcome");
    }

    private void OnPinChanged(string value) => pin = value;

    private async Task UnlockAsync()
    {
        if (walletId == null || pin.Length < 6 || isUnlocking) return;

        // Check lockout
        if (isLockedOut)
        {
            var remaining = lockedUntil!.Value - DateTime.UtcNow;
            lockoutMessage = $"Too many attempts. Try again in {(int)Math.Ceiling(remaining.TotalSeconds)}s.";
            error = lockoutMessage;
            pin = "";
            pinInput?.Clear();
            return;
        }

        error = null; lockoutMessage = null; isUnlocking = true;
        StateHasChanged();
        try
        {
            WalletService.SetNetworkMode(AppState.NetworkMode);
            var success = await WalletService.UnlockWalletAsync(walletId, pin);
            if (success)
            {
                failedAttempts = 0;
                lockedUntil = null;
                AppState.IsWalletCreated = true;
                AppState.IsWalletUnlocked = true;
                AppState.NotifyStateChanged();
                Nav.NavigateTo("/");
            }
            else
            {
                failedAttempts++;
                if (failedAttempts >= 3)
                {
                    // Exponential backoff: 15s, 30s, 60s, 120s, ...
                    var delaySec = 15 * (int)Math.Pow(2, Math.Min(failedAttempts - 3, 5));
                    lockedUntil = DateTime.UtcNow.AddSeconds(delaySec);
                    error = $"Incorrect PIN. Locked for {delaySec}s after {failedAttempts} failed attempts.";
                }
                else
                {
                    error = $"Incorrect PIN. {3 - failedAttempts} attempts remaining before lockout.";
                }
                pin = "";
                pinInput?.Clear();
            }
        }
        catch (Exception ex) { error = $"Error: {ex.Message}"; }
        finally { isUnlocking = false; }
    }

    private void CancelForgot()
    {
        showForgotPin = false;
        showSeedInput = false;
        showDeleteConfirm = false;
        showNewPin = false;
        seedInput = "";
        newPin = "";
        resetError = null;
        deleteConfirmText = "";
    }

    private void VerifySeed()
    {
        resetError = null;
        if (string.IsNullOrWhiteSpace(seedInput)) { resetError = "Enter your recovery phrase."; return; }

        var cleaned = string.Join(' ', seedInput.Trim().ToLower().Split(' ', StringSplitOptions.RemoveEmptyEntries));
        if (!DigiByte.Crypto.KeyGeneration.MnemonicGenerator.IsValid(cleaned)
            && !DigiByte.Crypto.KeyGeneration.PrivateKeyImporter.IsValidWif(seedInput.Trim()))
        {
            resetError = "Invalid recovery phrase or private key.";
            return;
        }

        showNewPin = true;
    }

    private async Task ConfirmResetPin()
    {
        if (walletId == null || newPin.Length < 6) return;
        resetError = null;

        var seed = seedInput.Trim();
        var success = await WalletService.ResetPinAsync(walletId, seed, newPin);
        if (success)
        {
            // Auto-unlock with new PIN
            WalletService.SetNetworkMode(AppState.NetworkMode);
            var unlocked = await WalletService.UnlockWalletAsync(walletId, newPin);
            if (unlocked)
            {
                AppState.IsWalletCreated = true;
                AppState.IsWalletUnlocked = true;
                AppState.NotifyStateChanged();
                Nav.NavigateTo("/");
            }
        }
        else
        {
            resetError = "Could not verify. Check your recovery phrase.";
            newPin = "";
            resetPinInput?.Clear();
        }
    }

    private async Task DeleteWallet()
    {
        if (deleteConfirmText?.ToUpper() != "DELETE") return;
        Cache.Clear();
        await WalletService.WipeAllDataAsync();
        AppState.IsWalletCreated = false;
        AppState.IsWalletUnlocked = false;
        Nav.NavigateTo("/welcome");
    }
}
