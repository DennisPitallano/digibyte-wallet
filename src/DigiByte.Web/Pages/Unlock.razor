@page "/unlock"
@inject WalletService WalletService
@inject AppState AppState
@inject NavigationManager Nav

<PageTitle>Unlock Wallet</PageTitle>

<div class="flex flex-col items-center justify-center min-h-[75vh] gap-8">
    <div class="flex flex-col items-center gap-3 float-in">
        <div class="relative">
            <div class="absolute inset-0 bg-dgb-500/15 rounded-full blur-2xl scale-150 glow-pulse"></div>
            <DigiLogo Size="72" Class="relative" />
        </div>
        <h2 class="text-lg font-bold text-slate-900 dark:text-white">Welcome back</h2>
        <p class="text-sm text-slate-400 dark:text-slate-500">Enter your 6-digit PIN</p>
    </div>

    <div class="flex flex-col items-center gap-5 slide-up-delay-2">
        <PinInput @ref="pinInput"
                  ValueChanged="OnPinChanged"
                  OnComplete="UnlockAsync"
                  Error="@error" />

        <button class="w-full max-w-[280px] py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 hover:shadow-xl hover:shadow-dgb-500/30 transition-all press-effect disabled:opacity-50"
                @onclick="UnlockAsync" disabled="@(isUnlocking || pin.Length < 6)">
            @if (isUnlocking)
            {
                <span class="flex items-center justify-center gap-2">
                    <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                    </svg>
                    Unlocking...
                </span>
            }
            else
            {
                <span>Unlock</span>
            }
        </button>
    </div>
</div>

@code {
    private PinInput? pinInput;
    private string pin = "";
    private string? error;
    private bool isUnlocking;
    private string? walletId;

    protected override async Task OnInitializedAsync()
    {
        walletId = await WalletService.GetActiveWalletIdAsync();
        if (walletId == null) Nav.NavigateTo("/welcome");
    }

    private void OnPinChanged(string value) => pin = value;

    private async Task UnlockAsync()
    {
        if (walletId == null || pin.Length < 6 || isUnlocking) return;
        error = null; isUnlocking = true;
        StateHasChanged();
        try
        {
            WalletService.SetNetworkMode(AppState.NetworkMode);
            var success = await WalletService.UnlockWalletAsync(walletId, pin);
            if (success)
            {
                AppState.IsWalletCreated = true;
                AppState.IsWalletUnlocked = true;
                AppState.NotifyStateChanged();
                Nav.NavigateTo("/");
            }
            else
            {
                error = "Incorrect PIN. Please try again.";
                pin = "";
                pinInput?.Clear();
            }
        }
        catch (Exception ex) { error = $"Error: {ex.Message}"; }
        finally { isUnlocking = false; }
    }
}
