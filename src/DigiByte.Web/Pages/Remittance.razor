@page "/remittance"
@inject NavigationManager Nav
@inject HttpClient Http

<PageTitle>Send Money</PageTitle>

<div class="flex flex-col gap-4">
    <h2 class="text-xl font-bold text-slate-900 dark:text-white slide-up">Send Money</h2>
    <p class="text-sm text-slate-500 dark:text-slate-400 slide-up-delay-1">Send DGB to anyone by username or phone number — no address needed.</p>

    @* Recipient lookup *@
    <div class="flex flex-col gap-2 slide-up-delay-2">
        <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Recipient</label>
        <div class="flex gap-2">
            <input type="text" @bind="recipientInput" @bind:event="oninput"
                   placeholder="Username or phone number"
                   class="flex-1 px-4 py-3 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl text-sm text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
            <button class="px-4 py-3 bg-dgb-500 hover:bg-dgb-600 text-white text-sm font-semibold rounded-xl press-effect disabled:opacity-50"
                    @onclick="LookupRecipient" disabled="@(string.IsNullOrWhiteSpace(recipientInput) || isLooking)">
                @(isLooking ? "..." : "Find")
            </button>
        </div>
        @if (lookupError != null)
        {
            <p class="text-xs text-red-500 font-medium">@lookupError</p>
        }
        @if (resolvedEntry != null)
        {
            <div class="scale-in flex items-center gap-3 p-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800/30 rounded-xl">
                <div class="w-9 h-9 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
                    <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-green-700 dark:text-green-400">@@resolvedEntry.Username</p>
                    <p class="text-xs font-mono text-green-600/70 dark:text-green-500/70 truncate">@resolvedEntry.Address</p>
                </div>
                <button class="px-3 py-1.5 bg-dgb-500 hover:bg-dgb-600 text-white text-xs font-semibold rounded-lg press-effect"
                        @onclick="SendToResolved">
                    Send
                </button>
            </div>
        }
    </div>

    @* Amount for fee comparison *@
    <div class="flex flex-col gap-2 slide-up-delay-3">
        <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Compare fees for</label>
        <div class="flex items-center bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl focus-within:border-dgb-500 focus-within:ring-2 focus-within:ring-dgb-500/20 transition-all">
            <span class="pl-4 text-sm text-slate-400">$</span>
            <input type="number" @bind="compareAmount" @bind:event="oninput" min="1" placeholder="200"
                   class="flex-1 px-2 py-3 bg-transparent text-sm text-slate-900 dark:text-white outline-none" />
            <span class="pr-4 text-sm font-bold text-slate-400">USD</span>
        </div>
    </div>

    @* Fee Comparison Table *@
    <div class="slide-up-delay-4 flex flex-col gap-1.5">
        <h3 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Fee Comparison</h3>
        @foreach (var fee in feeComparisons)
        {
            var isDigiByte = fee.ServiceName == "DigiByte";
            <div class="flex items-center gap-3 p-3 rounded-2xl border transition-all card-hover
                        @(isDigiByte ? "bg-dgb-50 dark:bg-dgb-900 border-dgb-200 dark:border-dgb-700" : "bg-white dark:bg-dgb-900/50 border-slate-200 dark:border-dgb-800")">
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                        <p class="text-sm font-semibold @(isDigiByte ? "text-dgb-600 dark:text-dgb-400" : "text-slate-900 dark:text-white")">
                            @fee.ServiceName
                        </p>
                        @if (isDigiByte)
                        {
                            <span class="text-[10px] font-bold text-dgb-500 bg-dgb-100 dark:bg-dgb-800 px-1.5 py-0.5 rounded-full">BEST</span>
                        }
                    </div>
                    <p class="text-xs text-slate-400 dark:text-slate-500 mt-0.5">@FormatTime(fee.EstimatedTime)</p>
                </div>
                <div class="text-right">
                    <p class="text-sm font-bold @(isDigiByte ? "text-dgb-500" : "text-slate-900 dark:text-white")">
                        $@fee.FeeAmount.ToString("N2")
                    </p>
                    <p class="text-[10px] text-slate-400 dark:text-slate-500">@fee.FeePercent.ToString("N2")%</p>
                </div>
            </div>
        }
    </div>

    @* Savings callout *@
    @if (savings > 0)
    {
        <div class="scale-in bg-gradient-to-r from-dgb-500 to-dgb-600 rounded-2xl p-4 text-white text-center">
            <p class="text-lg font-extrabold">Save $@savings.ToString("N2")</p>
            <p class="text-sm text-dgb-200 mt-0.5">by sending with DigiByte instead of traditional services</p>
        </div>
    }

    @* Register username *@
    <div class="slide-up-delay-5 bg-white dark:bg-dgb-900 rounded-2xl border border-dashed border-dgb-300 dark:border-dgb-700 p-4 flex flex-col gap-3 relative overflow-hidden">
        <div class="absolute top-3 right-3 inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-50 dark:bg-amber-500/10 border border-amber-200 dark:border-amber-500/20">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
            <span class="text-[9px] font-semibold text-amber-600 dark:text-amber-400 uppercase tracking-wider">Coming Soon</span>
        </div>
        <h3 class="text-sm font-semibold text-slate-900 dark:text-white">Register Your Username</h3>
        <p class="text-xs text-slate-500 dark:text-slate-400">Let others send you DGB by name instead of an address.</p>
        <div class="flex gap-2 opacity-50 pointer-events-none">
            <input type="text" placeholder="Choose a username"
                   class="flex-1 px-3 py-2.5 bg-slate-50 dark:bg-dgb-950 border border-slate-200 dark:border-dgb-800 rounded-xl text-sm text-slate-900 dark:text-white outline-none" />
            <button class="px-4 py-2.5 bg-dgb-500 text-white text-sm font-semibold rounded-xl opacity-50" disabled>
                Register
            </button>
        </div>
    </div>
</div>

@code {
    private string recipientInput = "";
    private bool isLooking;
    private string? lookupError;
    private DirectoryEntry? resolvedEntry;
    private decimal compareAmount = 200;

    private List<FeeComparison> feeComparisons => RemittanceFeeData.GetComparisons(compareAmount > 0 ? compareAmount : 200);
    private decimal savings => feeComparisons.Count > 1
        ? Math.Round(feeComparisons.Where(f => f.ServiceName != "DigiByte").Average(f => f.FeeAmount) - feeComparisons.First(f => f.ServiceName == "DigiByte").FeeAmount, 2)
        : 0;

    private async Task LookupRecipient()
    {
        lookupError = null;
        resolvedEntry = null;
        isLooking = true;

        try
        {
            // Try username lookup first, then phone
            var input = recipientInput.Trim();
            var isPhone = input.StartsWith("+") || input.All(c => char.IsDigit(c) || c == '-' || c == ' ');
            var url = isPhone
                ? $"api/directory/lookup/phone/{Uri.EscapeDataString(input)}"
                : $"api/directory/lookup/{Uri.EscapeDataString(input)}";

            var response = await Http.GetAsync(url);
            if (response.IsSuccessStatusCode)
            {
                resolvedEntry = await response.Content.ReadFromJsonAsync<DirectoryEntry>();
            }
            else
            {
                lookupError = $"'{input}' not found. They may not have registered yet.";
            }
        }
        catch
        {
            lookupError = "Unable to connect to directory service. Send by address instead.";
        }
        finally
        {
            isLooking = false;
        }
    }

    private void SendToResolved()
    {
        if (resolvedEntry == null) return;
        Nav.NavigateTo($"/send?address={Uri.EscapeDataString(resolvedEntry.Address)}&name={Uri.EscapeDataString(resolvedEntry.Username)}");
    }

    private static string FormatTime(TimeSpan ts)
    {
        if (ts.TotalSeconds < 60) return $"~{(int)ts.TotalSeconds}s";
        if (ts.TotalMinutes < 60) return $"~{(int)ts.TotalMinutes} min";
        if (ts.TotalHours < 24) return $"~{(int)ts.TotalHours}h";
        return $"~{(int)ts.TotalDays} days";
    }
}
