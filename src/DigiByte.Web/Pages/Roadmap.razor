@page "/roadmap"
@inject IJSRuntime JS

<PageTitle>Roadmap — DigiByte Wallet</PageTitle>

<div class="flex flex-col gap-4">
    <button class="flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-dgb-500 transition-colors w-fit -mb-2" @onclick="GoBack">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
        Back
    </button>
    <div class="slide-up">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Roadmap</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">What's built, what's next, and what's planned.</p>
    </div>

    @* Timeline *@
    <div class="relative ml-3">
        @* Vertical line *@
        <div class="absolute left-[7px] top-2 bottom-2 w-[2px] bg-gradient-to-b from-green-400 via-dgb-500 to-slate-300 dark:to-dgb-800"></div>

        @foreach (var milestone in milestones)
        {
            var dotColor = milestone.Status switch
            {
                Status.Done => "bg-green-500",
                Status.InProgress => "bg-dgb-500 animate-pulse",
                _ => "bg-slate-300 dark:bg-dgb-700"
            };
            var cardBorder = milestone.Status switch
            {
                Status.Done => "border-green-100 dark:border-green-900/20",
                Status.InProgress => "border-dgb-200 dark:border-dgb-800",
                _ => "border-slate-100 dark:border-dgb-800/40"
            };
            var cardBg = milestone.Status switch
            {
                Status.Done => "bg-green-50/50 dark:bg-green-900/10",
                Status.InProgress => "bg-dgb-50/50 dark:bg-dgb-900/20",
                _ => "bg-slate-50/50 dark:bg-dgb-900/10"
            };
            var dateBadge = milestone.Status switch
            {
                Status.Done => "text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20",
                Status.InProgress => "text-dgb-600 dark:text-dgb-300 bg-dgb-50 dark:bg-dgb-900/30",
                _ => "text-slate-400 dark:text-slate-500 bg-slate-100 dark:bg-dgb-800/50"
            };

            <div class="relative flex gap-3 pb-5">
                @* Dot *@
                <div class="relative z-10 mt-1.5">
                    <div class="w-4 h-4 rounded-full border-2 border-white dark:border-dgb-950 @dotColor shadow-sm"></div>
                </div>

                @* Card *@
                <div class="flex-1 rounded-xl border @cardBorder @cardBg px-3 py-2.5">
                    <div class="flex items-center gap-2 mb-1">
                        <span class="text-[10px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded-md @dateBadge">@milestone.Date</span>
                        @if (milestone.Status == Status.InProgress)
                        {
                            <span class="text-[9px] font-bold text-dgb-500 uppercase tracking-widest">In Progress</span>
                        }
                    </div>
                    <p class="text-xs font-semibold text-slate-800 dark:text-slate-200 leading-relaxed">@milestone.Title</p>
                    @if (milestone.Items.Length > 0)
                    {
                        <ul class="mt-1.5 flex flex-col gap-0.5">
                            @foreach (var item in milestone.Items)
                            {
                                <li class="flex items-start gap-1.5">
                                    @if (milestone.Status == Status.Done)
                                    {
                                        <svg class="w-3 h-3 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                                    }
                                    else if (milestone.Status == Status.InProgress)
                                    {
                                        <div class="w-3 h-3 border-[1.5px] border-dgb-500 border-t-transparent rounded-full animate-spin flex-shrink-0 mt-0.5"></div>
                                    }
                                    else
                                    {
                                        <div class="w-3 h-3 rounded-full border-[1.5px] border-slate-300 dark:border-dgb-700 flex-shrink-0 mt-0.5"></div>
                                    }
                                    <span class="text-[11px] text-slate-600 dark:text-slate-400 leading-snug">@item</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
