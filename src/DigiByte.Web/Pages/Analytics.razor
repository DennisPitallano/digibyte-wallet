@page "/analytics"
@inject HttpClient Http
@inject IJSRuntime JS
@inject MemoryCacheService Cache
@inject AppState AppState

<PageTitle>DigiByte Analytics</PageTitle>

<div class="flex flex-col gap-4">
    <button class="flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-dgb-500 transition-colors w-fit -mb-2" @onclick="GoBack">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
        Back
    </button>
    <h2 class="text-xl font-bold text-slate-900 dark:text-white slide-up">DigiByte Analytics</h2>

    @* Price Card *@
    <div class="slide-up-delay-1 bg-gradient-to-br from-dgb-900 to-dgb-700 rounded-2xl p-5 text-white">
        <p class="text-xs text-dgb-200 font-medium">DGB / @AppState.FiatCurrency</p>
        @if (price > 0)
        {
            <h2 class="text-3xl font-extrabold mt-1">@AppState.FiatSymbol@price.ToString("N6")</h2>
            <p class="text-sm mt-1 @(priceChange >= 0 ? "text-green-400" : "text-red-400")">
                @(priceChange >= 0 ? "+" : "")@priceChange.ToString("N2")% (24h)
            </p>
        }
        else
        {
            <div class="h-9 w-32 skeleton mt-1 rounded-lg" style="background:rgba(255,255,255,0.1)"></div>
        }
    </div>

    @* Market Stats *@
    <div class="slide-up-delay-2 grid grid-cols-2 gap-2">
        <div class="bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800 p-3">
            <p class="text-[10px] text-slate-400 dark:text-slate-500 uppercase font-semibold">Market Cap</p>
            <p class="text-sm font-bold text-slate-900 dark:text-white mt-0.5">@FormatLarge(marketCap)</p>
        </div>
        <div class="bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800 p-3">
            <p class="text-[10px] text-slate-400 dark:text-slate-500 uppercase font-semibold">24h Volume</p>
            <p class="text-sm font-bold text-slate-900 dark:text-white mt-0.5">@FormatLarge(volume24h)</p>
        </div>
        <div class="bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800 p-3">
            <p class="text-[10px] text-slate-400 dark:text-slate-500 uppercase font-semibold">Circulating Supply</p>
            <p class="text-sm font-bold text-slate-900 dark:text-white mt-0.5">@FormatNumber(circulatingSupply) DGB</p>
        </div>
        <div class="bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800 p-3">
            <p class="text-[10px] text-slate-400 dark:text-slate-500 uppercase font-semibold">Block Height</p>
            <p class="text-sm font-bold text-slate-900 dark:text-white mt-0.5">@blockHeight.ToString("N0")</p>
        </div>
    </div>

    @* Network Stats *@
    <div class="slide-up-delay-3">
        <h3 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Network</h3>
        <div class="flex flex-col gap-1.5">
            <div class="flex justify-between p-3 bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800">
                <span class="text-xs text-slate-500 dark:text-slate-400">Block Time</span>
                <span class="text-xs font-bold text-slate-900 dark:text-white">~15 seconds</span>
            </div>
            <div class="flex justify-between p-3 bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800">
                <span class="text-xs text-slate-500 dark:text-slate-400">Mining Algorithms</span>
                <span class="text-xs font-bold text-slate-900 dark:text-white">5 (MultiAlgo)</span>
            </div>
            <div class="flex justify-between p-3 bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800">
                <span class="text-xs text-slate-500 dark:text-slate-400">Max Supply</span>
                <span class="text-xs font-bold text-slate-900 dark:text-white">21,000,000,000 DGB</span>
            </div>
            <div class="flex justify-between p-3 bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800">
                <span class="text-xs text-slate-500 dark:text-slate-400">SegWit</span>
                <span class="text-xs font-bold text-green-500">Active</span>
            </div>
        </div>
    </div>

    @* Live Chart *@
    <div class="slide-up-delay-4">
        <h3 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Price Chart (7d)</h3>
        <div class="bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800 p-3 overflow-hidden">
            @if (sparklinePath != null)
            {
                <svg viewBox="0 0 300 60" preserveAspectRatio="none" class="w-full h-20">
                    <defs>
                        <linearGradient id="sparkFill" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="#0066cc" stop-opacity="0.3" />
                            <stop offset="100%" stop-color="#0066cc" stop-opacity="0.02" />
                        </linearGradient>
                    </defs>
                    <path d="@sparklineFillPath" fill="url(#sparkFill)" />
                    <path d="@sparklinePath" fill="none" stroke="#0066cc" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            }
            else if (chartLoaded)
            {
                <div class="h-20 flex items-center justify-center">
                    <p class="text-xs text-slate-400 dark:text-slate-500">Chart data unavailable</p>
                </div>
            }
            else
            {
                <div class="h-20 flex items-center justify-center">
                    <div class="w-5 h-5 border-2 border-dgb-500 border-t-transparent rounded-full animate-spin"></div>
                </div>
            }
        </div>
        <p class="text-[10px] text-slate-400 dark:text-slate-500 text-center mt-1">Data from CoinGecko</p>
    </div>
</div>

@code {
    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private decimal price;
    private decimal priceChange;
    private decimal marketCap;
    private decimal volume24h;
    private decimal circulatingSupply;
    private int blockHeight;
    private string? sparklinePath;
    private string? sparklineFillPath;
    private bool chartLoaded;

    protected override async Task OnInitializedAsync()
    {
        // Load from cache instantly, then refresh in background
        if (Cache.TryGet<decimal>("analytics:price", out var cp)) price = cp;
        if (Cache.TryGet<int>("analytics:blockHeight", out var ch)) blockHeight = ch;
        if (price > 0 || blockHeight > 0) StateHasChanged();

        _ = LoadPrice();
        _ = LoadBlockHeight();
    }

    private async Task LoadPrice()
    {
        try
        {
            var currency = AppState.FiatCurrency.ToLower();
            var data = await Http.GetFromJsonAsync<System.Text.Json.JsonElement>(
                $"https://api.coingecko.com/api/v3/coins/digibyte?localization=false&tickers=false&community_data=false&developer_data=false&sparkline=true");

            if (data.TryGetProperty("market_data", out var md))
            {
                if (md.TryGetProperty("current_price", out var cp) && cp.TryGetProperty(currency, out var p))
                    price = p.GetDecimal();
                if (md.TryGetProperty("price_change_percentage_24h", out var pc))
                    priceChange = pc.GetDecimal();
                if (md.TryGetProperty("market_cap", out var mc) && mc.TryGetProperty(currency, out var m))
                    marketCap = m.GetDecimal();
                if (md.TryGetProperty("total_volume", out var tv) && tv.TryGetProperty(currency, out var v))
                    volume24h = v.GetDecimal();
                if (md.TryGetProperty("circulating_supply", out var cs))
                    circulatingSupply = cs.GetDecimal();
                if (md.TryGetProperty("sparkline_7d", out var sp) && sp.TryGetProperty("price", out var prices))
                    BuildSparkline(prices);
            }
            Cache.Set("analytics:price", price, TimeSpan.FromSeconds(60));
            chartLoaded = true;
            StateHasChanged();
        }
        catch { chartLoaded = true; StateHasChanged(); }
    }

    private async Task LoadBlockHeight()
    {
        try
        {
            var heightStr = await Http.GetStringAsync("https://digiexplorer.info/api/blocks/tip/height");
            if (int.TryParse(heightStr, out var h))
            {
                blockHeight = h;
                Cache.Set("analytics:blockHeight", blockHeight, TimeSpan.FromSeconds(60));
            }
            StateHasChanged();
        }
        catch { }
    }

    private string FormatLarge(decimal n) => n switch
    {
        >= 1_000_000_000 => $"{AppState.FiatSymbol}{(n / 1_000_000_000):N2}B",
        >= 1_000_000 => $"{AppState.FiatSymbol}{(n / 1_000_000):N2}M",
        >= 1_000 => $"{AppState.FiatSymbol}{(n / 1_000):N1}K",
        > 0 => $"{AppState.FiatSymbol}{n:N0}",
        _ => "..."
    };

    private static string FormatNumber(decimal n) => n switch
    {
        >= 1_000_000_000 => $"{(n / 1_000_000_000):N2}B",
        >= 1_000_000 => $"{(n / 1_000_000):N2}M",
        >= 1_000 => $"{(n / 1_000):N1}K",
        > 0 => $"{n:N0}",
        _ => "..."
    };

    private void BuildSparkline(System.Text.Json.JsonElement prices)
    {
        var points = new List<double>();
        foreach (var p in prices.EnumerateArray())
        {
            if (p.TryGetDouble(out var v)) points.Add(v);
        }
        if (points.Count < 2) return;

        // Downsample to ~150 points for performance
        var step = Math.Max(1, points.Count / 150);
        var sampled = new List<double>();
        for (int i = 0; i < points.Count; i += step)
            sampled.Add(points[i]);
        if (sampled.Count < 2) return;

        var min = sampled.Min();
        var max = sampled.Max();
        var range = max - min;
        if (range == 0) range = 1;

        const double w = 300;
        const double h = 60;
        const double pad = 2;

        var pathParts = new List<string>();
        for (int i = 0; i < sampled.Count; i++)
        {
            var x = (i / (double)(sampled.Count - 1)) * w;
            var y = pad + (1 - (sampled[i] - min) / range) * (h - 2 * pad);
            pathParts.Add(string.Format(System.Globalization.CultureInfo.InvariantCulture, "{0:F1},{1:F1}", x, y));
        }

        sparklinePath = "M" + string.Join(" L", pathParts);
        sparklineFillPath = sparklinePath + string.Format(System.Globalization.CultureInfo.InvariantCulture, " L{0:F1},{1:F1} L0,{1:F1} Z", w, h);
    }
}
