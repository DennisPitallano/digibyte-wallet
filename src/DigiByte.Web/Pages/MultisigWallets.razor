@page "/multisig"
@inject MultisigWalletService MultisigService
@inject NavigationManager Nav
@inject AppState AppState

<PageTitle>Multisig Wallets</PageTitle>

<AuthGuard>
<div class="flex flex-col gap-4">
    <div class="flex items-center justify-between slide-up">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Multisig Wallets</h2>
        <button class="p-2 rounded-xl bg-dgb-500 hover:bg-dgb-600 text-white transition-colors press-effect"
                @onclick='() => Nav.NavigateTo("/multisig/create")'>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
        </button>
    </div>

    @if (isLoading)
    {
        <div class="flex flex-col gap-3">
            @for (int i = 0; i < 2; i++)
            {
                <div class="p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800">
                    <div class="h-5 w-40 skeleton rounded"></div>
                    <div class="h-4 w-60 skeleton rounded mt-2"></div>
                </div>
            }
        </div>
    }
    else if (wallets.Count == 0)
    {
        <div class="flex flex-col items-center justify-center gap-4 py-12 text-center slide-up-delay-1">
            <div class="w-16 h-16 rounded-full bg-dgb-50 dark:bg-dgb-900/50 flex items-center justify-center">
                <svg class="w-8 h-8 text-dgb-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                </svg>
            </div>
            <div>
                <h3 class="text-base font-bold text-slate-900 dark:text-white">No Multisig Wallets</h3>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1 max-w-[260px]">
                    Create a shared wallet that requires multiple signatures to spend funds.
                </p>
            </div>
            <button class="py-2.5 px-6 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl transition-all press-effect"
                    @onclick='() => Nav.NavigateTo("/multisig/create")'>
                Create Multisig Wallet
            </button>
        </div>
    }
    else
    {
        <div class="flex flex-col gap-2">
            @foreach (var (wallet, config) in wallets)
            {
                <button class="slide-up-delay-1 p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 card-hover text-left w-full"
                        @onclick="() => OpenWallet(wallet.Id)">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-xl bg-dgb-50 dark:bg-dgb-800 flex items-center justify-center shrink-0">
                            <svg class="w-5 h-5 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" />
                            </svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-semibold text-slate-900 dark:text-white">@wallet.Name</p>
                            <p class="text-xs text-slate-500 dark:text-slate-400">
                                @(config?.RequiredSignatures)-of-@(config?.TotalSigners) multisig
                            </p>
                        </div>
                        <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                        </svg>
                    </div>
                    @if (config != null)
                    {
                        <p class="text-[11px] font-mono text-slate-400 dark:text-slate-500 mt-2 truncate">@config.Address</p>
                    }
                </button>
            }
        </div>
    }

    @* Import option *@
    <div class="slide-up-delay-2">
        <button class="w-full py-3 text-sm text-dgb-500 hover:text-dgb-600 font-medium"
                @onclick='() => Nav.NavigateTo("/multisig/import")'>
            Import Existing Multisig Wallet
        </button>
    </div>
</div>
</AuthGuard>

@code {
    private record WalletEntry(string Id, string Name);

    private bool isLoading = true;
    private List<(WalletEntry Wallet, MultisigWalletConfig? Config)> wallets = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var rawList = await MultisigService.ListWalletsAsync();
            foreach (var (id, name) in rawList)
            {
                var config = await MultisigService.GetConfigAsync(id);
                wallets.Add((new WalletEntry(id, name), config));
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenWallet(string walletId)
    {
        Nav.NavigateTo($"/multisig/{walletId}");
    }
}
