@page "/send"
@inject WalletService WalletService
@inject ContactService ContactService
@inject IBlockchainService Blockchain
@inject AppState AppState
@inject NavigationManager Nav
@inject MemoryCacheService Cache
@inject ISecureStorage Storage

<PageTitle>Send DGB</PageTitle>

<AuthGuard>
@if (WalletService.ActiveWallet?.WalletType == "xpub")
{
    <div class="flex flex-col items-center justify-center gap-4 py-12 text-center">
        <div class="w-16 h-16 rounded-full bg-sky-100 dark:bg-sky-900/30 flex items-center justify-center">
            <svg class="w-8 h-8 text-sky-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
        </div>
        <h2 class="text-lg font-bold text-slate-900 dark:text-white">Watch-Only Wallet</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 max-w-[260px]">This wallet can only view balances and receive funds. Sending requires a wallet with private keys.</p>
        <button class="py-2.5 px-6 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl transition-all press-effect"
                @onclick='() => Nav.NavigateTo("/")'>
            Back to Home
        </button>
    </div>
}
else
{
<div class="flex flex-col gap-4">
    <h2 class="text-xl font-bold text-slate-900 dark:text-white slide-up">Send DigiByte</h2>

    @* Batch Mode Toggle *@
    <div class="flex items-center justify-between slide-up">
        <div class="flex items-center gap-1.5">
            <button type="button" @onclick="ToggleBatchMode"
                    class="flex items-center gap-2 text-xs font-semibold px-3 py-1.5 rounded-lg transition-all @(isBatchMode ? "bg-dgb-500 text-white" : "bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-dgb-700")">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
                </svg>
                Multiple Recipients
            </button>
            <button type="button" @onclick="() => showBatchInfo = true"
                    class="w-6 h-6 rounded-full bg-slate-100 dark:bg-dgb-800 flex items-center justify-center hover:bg-slate-200 dark:hover:bg-dgb-700 transition-all flex-shrink-0"
                    title="What is Batch Send?">
                <svg class="w-3.5 h-3.5 text-slate-400 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                </svg>
            </button>
        </div>
        @if (isBatchMode)
        {
            <span class="text-xs text-slate-400 dark:text-slate-500">@batchRecipients.Count / 20 recipients</span>
        }
    </div>

    @if (isBatchMode)
    {
        @* === BATCH MODE === *@
        <div class="flex flex-col gap-3 slide-up-delay-1">
            @for (int i = 0; i < batchRecipients.Count; i++)
            {
                var index = i;
                var r = batchRecipients[index];
                <div class="bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl p-3 flex flex-col gap-2 @(index > 0 ? "slide-up" : "")">
                    <div class="flex items-center justify-between">
                        <span class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Recipient @(index + 1)</span>
                        @if (batchRecipients.Count > 2)
                        {
                            <button type="button" @onclick="() => RemoveBatchRecipient(index)"
                                    class="text-slate-400 hover:text-red-500 transition-colors p-0.5" title="Remove">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                                </svg>
                            </button>
                        }
                    </div>
                    <div class="flex gap-1.5">
                        <input type="text" value="@r.Address" @oninput="(e) => OnBatchAddressChanged(index, e)"
                               placeholder="D... or dgb1..."
                               autocomplete="off" spellcheck="false"
                               class="flex-1 px-3 py-2 bg-slate-50 dark:bg-dgb-950 border border-slate-100 dark:border-dgb-800 rounded-lg text-xs text-slate-900 dark:text-white outline-none focus:border-dgb-500 transition-all" />
                        <button type="button" @onclick="() => ShowBatchScanner(index)"
                                class="w-8 h-8 rounded-lg bg-dgb-500 text-white flex items-center justify-center hover:bg-dgb-600 transition-all flex-shrink-0"
                                title="Scan QR">
                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 3.75 9.375v-4.5ZM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5ZM13.5 14.625v2.625m3.375-2.625v2.625" />
                            </svg>
                        </button>
                        <button type="button" @onclick="() => ShowBatchContactPicker(index)"
                                class="w-8 h-8 rounded-lg bg-slate-50 dark:bg-dgb-950 border border-slate-100 dark:border-dgb-800 flex items-center justify-center hover:border-dgb-300 dark:hover:border-dgb-600 transition-all flex-shrink-0"
                                title="Pick contact">
                            <svg class="w-3.5 h-3.5 text-slate-400 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0" />
                            </svg>
                        </button>
                    </div>
                    @if (batchContactPickerIndex == index && contactList.Count > 0)
                    {
                        <div class="scale-in bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-lg max-h-28 overflow-y-auto">
                            @foreach (var c in contactList)
                            {
                                var contact = c;
                                <button class="w-full flex items-center gap-2 px-2.5 py-1.5 hover:bg-slate-50 dark:hover:bg-dgb-800 transition-colors text-left"
                                        @onclick="() => SelectBatchContact(index, contact)">
                                    <div class="w-5 h-5 rounded-full bg-dgb-100 dark:bg-dgb-800 flex items-center justify-center flex-shrink-0">
                                        <span class="text-[9px] font-bold text-dgb-600 dark:text-dgb-400">@contact.Name[..1].ToUpper()</span>
                                    </div>
                                    <div class="min-w-0">
                                        <p class="text-xs font-medium text-slate-900 dark:text-white truncate">@contact.Name</p>
                                    </div>
                                </button>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(r.Name))
                    {
                        <div class="flex items-center gap-1.5">
                            <div class="w-4 h-4 rounded-full bg-dgb-100 dark:bg-dgb-800 flex items-center justify-center">
                                <span class="text-[8px] font-bold text-dgb-600 dark:text-dgb-400">@r.Name[..1].ToUpper()</span>
                            </div>
                            <span class="text-[10px] font-medium text-dgb-600 dark:text-dgb-400">@r.Name</span>
                        </div>
                    }
                    <div class="flex items-center bg-slate-50 dark:bg-dgb-950 border border-slate-100 dark:border-dgb-800 rounded-lg">
                        <input type="number" value="@r.Amount" @oninput="(e) => OnBatchAmountChanged(index, e)"
                               step="0.00000001" min="0" placeholder="0.00" inputmode="decimal"
                               class="flex-1 px-3 py-2 bg-transparent text-xs text-slate-900 dark:text-white outline-none" />
                        <span class="text-xs font-bold text-dgb-500 pr-3">DGB</span>
                    </div>
                    @if (!string.IsNullOrEmpty(r.Error))
                    {
                        <p class="text-[10px] text-red-500 font-medium">@r.Error</p>
                    }
                </div>
            }

            @* Add Recipient button *@
            @if (batchRecipients.Count < 20)
            {
                <button type="button" @onclick="AddBatchRecipient"
                        class="w-full py-2.5 border-2 border-dashed border-slate-200 dark:border-dgb-800 rounded-xl text-xs font-semibold text-slate-400 dark:text-slate-500 hover:border-dgb-300 dark:hover:border-dgb-600 hover:text-dgb-500 transition-all">
                    + Add Recipient
                </button>
            }

            @* Batch Summary *@
            <div class="bg-slate-50 dark:bg-dgb-900/50 rounded-xl border border-slate-100 dark:border-dgb-800 p-3 flex flex-col gap-1.5">
                <div class="flex justify-between">
                    <span class="text-xs text-slate-500 dark:text-slate-400 font-medium">Total Amount</span>
                    <span class="text-xs font-bold text-slate-900 dark:text-white">@BatchTotal.ToString("N8") DGB</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-xs text-slate-500 dark:text-slate-400 font-medium">Estimated Fee</span>
                    <span class="text-xs font-semibold text-slate-700 dark:text-slate-300">~@estimatedFee.ToString("N4") DGB</span>
                </div>
                <div class="h-px bg-slate-200 dark:bg-dgb-800"></div>
                <div class="flex justify-between">
                    <span class="text-xs text-slate-500 dark:text-slate-400 font-medium">Grand Total</span>
                    <span class="text-xs font-bold text-dgb-500">~@((BatchTotal + estimatedFee).ToString("N8")) DGB</span>
                </div>
                @if (!isLoadingBalance)
                {
                    <div class="flex justify-between">
                        <span class="text-xs text-slate-500 dark:text-slate-400 font-medium">Remaining</span>
                        <span class="text-xs font-medium @(availableBalance - BatchTotal - estimatedFee < 0 ? "text-red-500" : "text-slate-600 dark:text-slate-300")">
                            @((availableBalance - BatchTotal - estimatedFee).ToString("N4")) DGB
                        </span>
                    </div>
                }
            </div>

            @if (batchError != null)
            {
                <p class="text-xs text-red-500 font-medium text-center">@batchError</p>
            }
        </div>
    }
    else
    {
    <div class="flex flex-col gap-1.5 slide-up-delay-1">
        <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Recipient</label>
        @if (!string.IsNullOrEmpty(recipientName))
        {
            <div class="flex items-center gap-2 bg-dgb-50 dark:bg-dgb-900 border border-dgb-200 dark:border-dgb-700 rounded-xl px-3 py-2.5">
                <div class="w-7 h-7 rounded-full bg-dgb-100 dark:bg-dgb-800 flex items-center justify-center">
                    <span class="text-xs font-bold text-dgb-600 dark:text-dgb-400">@recipientName[..1].ToUpper()</span>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-dgb-700 dark:text-dgb-300">@recipientName</p>
                    <p class="text-xs font-mono text-dgb-500/70 truncate">@destinationAddress</p>
                </div>
                <button class="text-dgb-400 hover:text-dgb-600 p-1" @onclick="ClearRecipient">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        }
        else
        {
            <div class="flex gap-1.5">
                <input type="text" @bind="destinationAddress" @bind:event="oninput" @bind:after="RecalcFee"
                       placeholder="D... or dgb1... or search contact"
                       autocomplete="off" spellcheck="false"
                       class="flex-1 px-4 py-3 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl text-sm text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
                <button class="w-11 h-11 rounded-xl bg-dgb-500 text-white flex items-center justify-center hover:bg-dgb-600 transition-all flex-shrink-0 press-effect"
                        @onclick="() => showScanner = true" title="Scan QR">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 3.75 9.375v-4.5ZM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5ZM13.5 14.625v2.625m3.375-2.625v2.625" />
                    </svg>
                </button>
                <button class="w-11 h-11 rounded-xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center hover:border-dgb-300 dark:hover:border-dgb-600 transition-all flex-shrink-0"
                        @onclick="() => showContactPicker = !showContactPicker" title="Contacts">
                    <svg class="w-5 h-5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                    </svg>
                </button>
            </div>
            @* Contact Picker *@
            @if (showContactPicker && contactList.Count > 0)
            {
                <div class="scale-in bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl max-h-40 overflow-y-auto">
                    @foreach (var c in contactList)
                    {
                        var contact = c;
                        <button class="w-full flex items-center gap-2 px-3 py-2 hover:bg-slate-50 dark:hover:bg-dgb-800 transition-colors text-left"
                                @onclick="() => SelectContact(contact)">
                            <div class="w-7 h-7 rounded-full bg-dgb-100 dark:bg-dgb-800 flex items-center justify-center flex-shrink-0">
                                <span class="text-xs font-bold text-dgb-600 dark:text-dgb-400">@contact.Name[..1].ToUpper()</span>
                            </div>
                            <div class="min-w-0">
                                <p class="text-sm font-medium text-slate-900 dark:text-white truncate">@contact.Name</p>
                                <p class="text-xs font-mono text-slate-400 truncate">@contact.Address</p>
                            </div>
                        </button>
                    }
                </div>
            }
        }
        @if (addressError != null) { <p class="text-xs text-red-500 font-medium">@addressError</p> }
    </div>

    @* Amount *@
    <div class="flex flex-col gap-1.5 slide-up-delay-2">
        <div class="flex items-center justify-between">
            <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Amount</label>
            @if (isLoadingBalance)
            {
                <span class="flex items-center gap-1.5 text-xs text-dgb-500">
                    <span>Available:</span>
                    <span class="inline-block w-16 h-3.5 skeleton rounded"></span>
                </span>
            }
            else
            {
                <button type="button" @onclick="SetMaxAmount"
                        class="text-xs font-semibold text-dgb-500 hover:text-dgb-400 transition-colors">
                    Available: @availableBalance.ToString("N4") DGB
                </button>
            }
        </div>
        <div class="flex items-center bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl focus-within:border-dgb-500 focus-within:ring-2 focus-within:ring-dgb-500/20 transition-all @(isFormDisabled ? "opacity-50" : "")">
            <input type="number" @bind="amount" @bind:after="UpdateAmountWarning" step="0.00000001" min="0" placeholder="0.00" inputmode="decimal"
                   disabled="@isFormDisabled"
                   class="flex-1 px-4 py-3 bg-transparent text-sm text-slate-900 dark:text-white outline-none disabled:cursor-not-allowed" />
            <button type="button" @onclick="ToggleAmountMode" disabled="@isFormDisabled"
                    class="flex items-center gap-1 mr-2 px-2.5 py-1.5 rounded-lg bg-slate-100 dark:bg-dgb-800 hover:bg-slate-200 dark:hover:bg-dgb-700 transition-colors press-effect disabled:cursor-not-allowed">
                <span class="text-sm font-bold text-dgb-500">@(isAmountInFiat ? AppState.FiatCurrency : "DGB")</span>
                <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                </svg>
            </button>
        </div>
        <p class="text-xs text-slate-400 dark:text-slate-500">
            @if (isLoadingPrice)
            {
                <span class="inline-block w-24 h-3.5 skeleton rounded align-middle"></span>
            }
            else if (isAmountInFiat)
            {
                <span>~ @amountDgb.ToString("N8") DGB</span>
            }
            else
            {
                <span>~ @AppState.FiatSymbol@FormatFiat(amountFiat) @AppState.FiatCurrency</span>
            }
            @if (amount > 0 && !isLoadingPrice)
            {
                <span class="italic ml-1">(estimate — actual rate may vary)</span>
            }
        </p>
        <p class="text-xs text-slate-400 dark:text-slate-500">Minimum send: 0.0001 DGB</p>
        @if (amountError != null) { <p class="text-xs text-red-500 font-medium">@amountError</p> }
        @if (amountWarning != null) { <p class="text-xs text-amber-500 font-medium">@amountWarning</p> }
    </div>
    } @* end single-recipient mode *@

    @* Advanced Mode: Fee Control *@
    @if (!AppState.IsSimpleMode)
    {
        <div class="flex flex-col gap-1.5 slide-up-delay-3">
            <div class="flex items-center gap-1.5">
                <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Fee Rate (sat/vB)</label>
                <button type="button" @onclick="() => showFeeInfo = true" class="text-slate-400 hover:text-dgb-500 transition-colors" title="What is this?">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
                    </svg>
                </button>
            </div>
            <div class="flex gap-2">
                <button class="flex-1 py-2 text-xs font-semibold rounded-lg transition-all @(feeLevel == "low" ? "bg-dgb-500 text-white" : "bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-400")"
                        @onclick="SetFeeLow" disabled="@isFormDisabled">Slow (100)</button>
                <button class="flex-1 py-2 text-xs font-semibold rounded-lg transition-all @(feeLevel == "med" ? "bg-dgb-500 text-white" : "bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-400")"
                        @onclick="SetFeeMed" disabled="@isFormDisabled">Normal (200)</button>
                <button class="flex-1 py-2 text-xs font-semibold rounded-lg transition-all @(feeLevel == "high" ? "bg-dgb-500 text-white" : "bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-400")"
                        @onclick="SetFeeHigh" disabled="@isFormDisabled">Fast (400)</button>
            </div>
            <input type="number" @bind="customFeeRate" min="1" placeholder="Custom sat/vB" disabled="@isFormDisabled"
                   class="w-full px-3 py-2 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-lg text-xs text-slate-900 dark:text-white outline-none focus:border-dgb-500 transition-all disabled:opacity-50 disabled:cursor-not-allowed" />
        </div>
    }

    @* Memo *@
    <div class="flex flex-col gap-1.5 slide-up-delay-3">
