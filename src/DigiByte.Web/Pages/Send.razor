@code {
    private string destinationAddress = "";
    private string recipientName = "";
    private decimal amount;
    private decimal availableBalance;
    private string memo = "";
    private string? addressError;
    private string? amountError;
    private string? sendError;
    private bool showConfirm;
    private bool isSending;
    private bool isReviewing;
    private bool showContactPicker;
    private bool showScanner;
    private bool showFeeInfo;
    private bool showBatchInfo;
    private bool isAmountInFiat = false;
    private List<Contact> contactList = [];

    // Batch mode
    private bool isBatchMode;
    private string? batchError;
    private int batchContactPickerIndex = -1;
    private int batchScannerIndex = -1;
    private List<BatchRecipient> batchRecipients = [new(), new()];
    private decimal BatchTotal => batchRecipients.Sum(r => r.Amount);

    private class BatchRecipient
    {
        public string Address { get; set; } = "";
        public string Name { get; set; } = "";
        public decimal Amount { get; set; }
        public string? Error { get; set; }
    }

    // Advanced fee control
    private string feeLevel = "med";
    private int customFeeRate = 200;
    private decimal estimatedFee = 0.0026m;

    // Fee estimation helpers — detect address types for accurate vbyte calculation
    // HD wallets default to SegWit (dgb1...), WIF wallets default to Legacy (D...)
    private bool walletUsesSegWit;
    private int inputVBytes => walletUsesSegWit ? 68 : 148;
    private int OutputVBytes(string addr) =>
        !string.IsNullOrEmpty(addr) && addr.StartsWith("dgb1") ? 31 : 34;
    private int EstimateVBytes()
    {
        int outputCount;
        int outputVB;
        if (isBatchMode)
        {
            // N recipient outputs + 1 change output
            outputCount = batchRecipients.Count + 1;
            outputVB = batchRecipients.Sum(r => OutputVBytes(r.Address)) + (walletUsesSegWit ? 31 : 34);
        }
        else
        {
            // 1 destination + 1 change
            var destVB = OutputVBytes(destinationAddress);
            var changeVB = walletUsesSegWit ? 31 : 34;
            outputVB = destVB + changeVB;
        }
        var memoVB = 0;
        if (!string.IsNullOrWhiteSpace(memo))
        {
            var dataLen = Math.Min(System.Text.Encoding.UTF8.GetByteCount(memo), 80);
            memoVB = 9 + 1 + 1 + dataLen;
        }
        return 10 + inputVBytes + outputVB + memoVB;
    }
    private void RecalcFee()
    {
        estimatedFee = (EstimateVBytes() * customFeeRate) / 100_000_000m;
    }

    // Batch mode helpers
    private void ToggleBatchMode()
    {
        isBatchMode = !isBatchMode;
        batchError = null;
        if (isBatchMode && batchRecipients.Count < 2)
            batchRecipients = [new(), new()];
        RecalcFee();
    }

    private void AddBatchRecipient()
    {
        if (batchRecipients.Count < 20)
        {
            batchRecipients.Add(new());
            RecalcFee();
        }
    }

    private void RemoveBatchRecipient(int index)
    {
        if (batchRecipients.Count > 2 && index >= 0 && index < batchRecipients.Count)
        {
            batchRecipients.RemoveAt(index);
            batchContactPickerIndex = -1;
            RecalcFee();
        }
    }

    private void OnBatchAddressChanged(int index, ChangeEventArgs e)
    {
        batchRecipients[index].Address = e.Value?.ToString() ?? "";
        batchRecipients[index].Name = "";
        batchRecipients[index].Error = null;
        RecalcFee();
    }

    private void OnBatchAmountChanged(int index, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var val))
            batchRecipients[index].Amount = val;
        else
            batchRecipients[index].Amount = 0;
        batchRecipients[index].Error = null;
        RecalcFee();
    }

    private void ShowBatchScanner(int index)
    {
        batchScannerIndex = index;
        showScanner = true;
    }

    private void ShowBatchContactPicker(int index)
    {
        batchContactPickerIndex = batchContactPickerIndex == index ? -1 : index;
    }

    private void SelectBatchContact(int index, Contact c)
    {
        batchRecipients[index].Address = c.Address;
        batchRecipients[index].Name = c.Name;
        batchContactPickerIndex = -1;
        RecalcFee();
    }

    // Loading & price state
    private bool isLoadingBalance = true;
    private bool isLoadingPrice = true;
    private bool isFormDisabled => isLoadingBalance || isLoadingPrice;
    private decimal dgbPrice;
    private decimal amountDgb => isAmountInFiat ? (dgbPrice > 0 ? amount / dgbPrice : 0) : amount;
    private decimal amountFiat => isAmountInFiat ? amount : amount * dgbPrice;

    private string? amountWarning;
    private bool hasUnconfirmedUtxos;

    private void UpdateAmountWarning()
    {
        var dgb = amountDgb;
        if (amount <= 0 || isFormDisabled)
            amountWarning = null;
        else if (dgb > 0 && dgb < 0.0001m)
            amountWarning = "Below minimum send amount (0.0001 DGB)";
        else if (!isLoadingBalance && dgb > availableBalance)
            amountWarning = $"Exceeds available balance ({availableBalance:N4} DGB)";
        else
            amountWarning = null;
    }

    private static string FormatFiat(decimal value)
    {
        if (value == 0) return "0.00";
        var abs = Math.Abs(value);
        if (abs >= 1m) return value.ToString("N2");
        if (abs >= 0.01m) return value.ToString("N4");
        if (abs >= 0.001m) return value.ToString("N5");
        if (abs >= 0.0001m) return value.ToString("N6");
        return value.ToString("N8");
    }

    private void ToggleAmountMode()
    {
        // Convert the current amount to the other unit
        if (isAmountInFiat && amount > 0)
        {
            // Switching from fiat to DGB — convert current fiat to DGB
            amount = Math.Round(amountDgb, 8);
        }
        else if (!isAmountInFiat && amount > 0)
        {
            // Switching from DGB to fiat — convert current DGB to fiat
            amount = Math.Round(amountFiat, 2);
        }
        isAmountInFiat = !isAmountInFiat;
    }

    protected override async Task OnInitializedAsync()
    {
        AppState.ResetLockTimer();

        // Parse query params immediately (no I/O) — with validation
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var qAddr = query["address"];
        if (qAddr != null && qAddr.Length <= 128 && DigiByte.Crypto.Addresses.AddressValidator.IsValid(qAddr))
            destinationAddress = qAddr;
        var qName = query["name"];
        if (qName != null && qName.Length <= 64)
            recipientName = qName;
        if (query["amount"] != null && decimal.TryParse(query["amount"], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var qtyAmount) && qtyAmount > 0 && qtyAmount < 21_000_000_000m)
            amount = qtyAmount;

        // Detect wallet address type for fee estimation
        if (WalletService.IsUnlocked)
        {
            try
            {
                var addr = await WalletService.GetReceivingAddressAsync();
                walletUsesSegWit = addr.StartsWith("dgb1");
            }
            catch { walletUsesSegWit = true; }
        }
        RecalcFee();

        // Run all async loads in parallel
        var contactsTask = ContactService.GetAllAsync();
        var balanceTask = Task.Run(async () =>
        {
            try { var b = await WalletService.GetBalanceAsync(); availableBalance = b.ConfirmedDgb; }
            catch { }
            finally { isLoadingBalance = false; await InvokeAsync(StateHasChanged); }
        });
        var priceTask = Task.Run(async () =>
        {
            try
            {
                dgbPrice = await Cache.GetOrFetchAsync(
                    $"price:{AppState.FiatCurrency}",
                    () => Blockchain.GetDgbPriceAsync(AppState.FiatCurrency),
                    TimeSpan.FromMinutes(5));
            }
            catch { }
            finally { isLoadingPrice = false; await InvokeAsync(StateHasChanged); }
        });

        contactList = await contactsTask;
        await Task.WhenAll(balanceTask, priceTask);
    }

    private void SelectContact(Contact c)
    {
        destinationAddress = c.Address;
        recipientName = c.Name;
        showContactPicker = false;
        RecalcFee();
    }

    private void ClearRecipient()
    {
        destinationAddress = "";
        recipientName = "";
    }

    private void SetMaxAmount()
    {
        if (isAmountInFiat)
            amount = Math.Round(availableBalance * dgbPrice, 2);
        else
            amount = availableBalance;
    }

    private void SetFeeLow() => SetFee("low", 100);
    private void SetFeeMed() => SetFee("med", 200);
    private void SetFeeHigh() => SetFee("high", 400);

    private void SetFee(string level, int rate)
    {
        feeLevel = level;
        customFeeRate = rate;
        RecalcFee();
    }

    private void OnQrScanned(string data)
    {
        showScanner = false;

        // Parse digibyte: URI or raw address
        var parsed = DigiByte.Wallet.Models.PaymentRequest.FromUri(data);
        var scannedAddress = parsed?.Address ?? data.Trim();
        var scannedAmount = parsed?.AmountDgb;
        var scannedMemo = parsed?.Message;

        if (isBatchMode && batchScannerIndex >= 0 && batchScannerIndex < batchRecipients.Count)
        {
            batchRecipients[batchScannerIndex].Address = scannedAddress;
            batchRecipients[batchScannerIndex].Name = "";
            batchRecipients[batchScannerIndex].Error = null;
            if (scannedAmount.HasValue)
                batchRecipients[batchScannerIndex].Amount = scannedAmount.Value;
            batchScannerIndex = -1;
        }
        else
        {
            destinationAddress = scannedAddress;
            if (scannedAmount.HasValue) amount = scannedAmount.Value;
            if (!string.IsNullOrEmpty(scannedMemo)) memo = scannedMemo ?? "";
        }

        RecalcFee();
        StateHasChanged();
    }

    private async Task PreviewSend()
    {
        addressError = null;
        amountError = null;
        batchError = null;
        hasUnconfirmedUtxos = false;

        if (isBatchMode)
        {
            // Batch validation
            var ownAddresses = WalletService.GetAllAddresses();
            var seenAddresses = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            bool hasErrors = false;

            foreach (var r in batchRecipients)
            {
                r.Error = null;
                if (string.IsNullOrWhiteSpace(r.Address))
                {
                    r.Error = "Address is required.";
                    hasErrors = true;
                }
                else if (!DigiByte.Crypto.Addresses.AddressValidator.IsValid(r.Address))
                {
                    r.Error = "Invalid DigiByte address.";
                    hasErrors = true;
                }
                else if (!seenAddresses.Add(r.Address))
                {
                    r.Error = "Duplicate address.";
                    hasErrors = true;
                }
                else if (ownAddresses.Contains(r.Address.Trim()))
                {
                    r.Error = "Cannot send to your own address.";
                    hasErrors = true;
                }

                if (r.Amount <= 0)
                {
                    r.Error = (r.Error ?? "") + " Amount must be greater than zero.";
                    hasErrors = true;
                }
                else if (r.Amount < 0.0001m)
                {
                    r.Error = (r.Error ?? "") + " Below minimum (0.0001 DGB).";
                    hasErrors = true;
                }
            }

            if (hasErrors) return;

            if (BatchTotal + estimatedFee > availableBalance)
            {
                batchError = $"Insufficient balance. Need ~{(BatchTotal + estimatedFee):N4} DGB but have {availableBalance:N4} DGB.";
                return;
            }
        }
        else
        {
        if (!DigiByte.Crypto.Addresses.AddressValidator.IsValid(destinationAddress))
        {
            addressError = "Invalid DigiByte address.";
            return;
        }
        if (WalletService.GetAllAddresses().Contains(destinationAddress.Trim()))
        {
            addressError = "You cannot send to your own address.";
            return;
        }
        if (amountDgb <= 0)
        {
            amountError = "Please enter an amount greater than zero.";
            return;
        }
        if (amountDgb < 0.0001m)
        {
            amountError = "Minimum send amount is 0.0001 DGB.";
            return;
        }
        if (amountDgb > availableBalance)
        {
            amountError = $"Insufficient balance. You have {availableBalance:N4} DGB available.";
            return;
        }
        }

        isReviewing = true;
        StateHasChanged();
        await Task.Yield();

        // Check for unconfirmed UTXOs
        try
        {
            var addresses = WalletService.GetAllAddresses();
            var utxos = await Blockchain.GetUtxosAsync(addresses);
            hasUnconfirmedUtxos = utxos.Any(u => u.Confirmations == 0);
        }
        catch { }
        finally { isReviewing = false; }

        showConfirm = true;
    }

    private string? sentTxId;

    private async Task ConfirmSend()
    {
        sendError = null; isSending = true;
        StateHasChanged();
        await Task.Yield();
        try
        {
            string txId;
            if (isBatchMode)
            {
                var recipients = batchRecipients
                    .Select(r => (r.Address, r.Amount))
                    .ToList();
                txId = await WalletService.SendBatchAsync(recipients, memo, customFeeRate);
            }
            else
            {
                txId = await WalletService.SendAsync(destinationAddress, amountDgb, memo, customFeeRate);
            }
            // Invalidate in-memory + IndexedDB caches after successful send
            Cache.RemoveByPrefix("balance");
            Cache.RemoveByPrefix("transactions");
            Cache.RemoveByPrefix("price");
            Cache.Remove("lastFetchTime");
            try
            {
                await Storage.RemoveAsync("cache:balance");
                await Storage.RemoveAsync("cache:transactions");
                await Storage.RemoveAsync("cache:lastFetch");
            }
            catch { }
            isSending = false;
            sentTxId = txId;
            showConfirm = false;
            StateHasChanged();
            // Show success for 2 seconds then go home with forceRefresh
            await Task.Delay(2500);
            Nav.NavigateTo("/?refresh=1", forceLoad: false);
        }
        catch (Exception ex)
        {
            sendError = MapSendError(ex.Message);
            isSending = false;
        }
    }

    private static string MapSendError(string message) => message switch
    {
        _ when message.Contains("too-long-mempool-chain", StringComparison.OrdinalIgnoreCase)
            => "Too many unconfirmed transactions. Please wait for some to confirm before sending again.",
        _ when message.Contains("insufficient fee", StringComparison.OrdinalIgnoreCase)
            => "Transaction fee is too low. Try increasing the fee rate.",
        _ when message.Contains("dust", StringComparison.OrdinalIgnoreCase)
            => "Amount is too small (dust). Please send a larger amount.",
        _ when message.Contains("txn-mempool-conflict", StringComparison.OrdinalIgnoreCase)
            => "A conflicting transaction is already in the mempool. Please wait and try again.",
        _ when message.Contains("bad-txns-inputs-missingorspent", StringComparison.OrdinalIgnoreCase)
            => "Some inputs have already been spent. Pull to refresh your balance and try again.",
        _ => message
    };

    private static string TruncateAddress(string addr) => addr.Length <= 16 ? addr : $"{addr[..8]}...{addr[^8..]}";
}
