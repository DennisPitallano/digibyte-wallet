@page "/send"
@inject WalletService WalletService
@inject ContactService ContactService
@inject IBlockchainService Blockchain
@inject AppState AppState
@inject NavigationManager Nav

<PageTitle>Send DGB</PageTitle>

<AuthGuard>
<div class="flex flex-col gap-4">
    <h2 class="text-xl font-bold text-slate-900 dark:text-white slide-up">Send DigiByte</h2>

    @* Recipient *@
    <div class="flex flex-col gap-1.5 slide-up-delay-1">
        <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Recipient</label>
        @if (!string.IsNullOrEmpty(recipientName))
        {
            <div class="flex items-center gap-2 bg-dgb-50 dark:bg-dgb-900 border border-dgb-200 dark:border-dgb-700 rounded-xl px-3 py-2.5">
                <div class="w-7 h-7 rounded-full bg-dgb-100 dark:bg-dgb-800 flex items-center justify-center">
                    <span class="text-xs font-bold text-dgb-600 dark:text-dgb-400">@recipientName[..1].ToUpper()</span>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-dgb-700 dark:text-dgb-300">@recipientName</p>
                    <p class="text-xs font-mono text-dgb-500/70 truncate">@destinationAddress</p>
                </div>
                <button class="text-dgb-400 hover:text-dgb-600 p-1" @onclick="ClearRecipient">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        }
        else
        {
            <div class="flex gap-1.5">
                <input type="text" @bind="destinationAddress" @bind:event="oninput"
                       placeholder="D... or dgb1... or search contact"
                       autocomplete="off" spellcheck="false"
                       class="flex-1 px-4 py-3 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl text-sm text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
                <button class="w-11 h-11 rounded-xl bg-dgb-500 text-white flex items-center justify-center hover:bg-dgb-600 transition-all flex-shrink-0 press-effect"
                        @onclick="() => showScanner = true" title="Scan QR">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 3.75 9.375v-4.5ZM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5ZM13.5 14.625v2.625m3.375-2.625v2.625" />
                    </svg>
                </button>
                <button class="w-11 h-11 rounded-xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center hover:border-dgb-300 dark:hover:border-dgb-600 transition-all flex-shrink-0"
                        @onclick="() => showContactPicker = !showContactPicker" title="Contacts">
                    <svg class="w-5 h-5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                    </svg>
                </button>
            </div>
            @* Contact Picker *@
            @if (showContactPicker && contactList.Count > 0)
            {
                <div class="scale-in bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl max-h-40 overflow-y-auto">
                    @foreach (var c in contactList)
                    {
                        var contact = c;
                        <button class="w-full flex items-center gap-2 px-3 py-2 hover:bg-slate-50 dark:hover:bg-dgb-800 transition-colors text-left"
                                @onclick="() => SelectContact(contact)">
                            <div class="w-7 h-7 rounded-full bg-dgb-100 dark:bg-dgb-800 flex items-center justify-center flex-shrink-0">
                                <span class="text-xs font-bold text-dgb-600 dark:text-dgb-400">@contact.Name[..1].ToUpper()</span>
                            </div>
                            <div class="min-w-0">
                                <p class="text-sm font-medium text-slate-900 dark:text-white truncate">@contact.Name</p>
                                <p class="text-xs font-mono text-slate-400 truncate">@contact.Address</p>
                            </div>
                        </button>
                    }
                </div>
            }
        }
        @if (addressError != null) { <p class="text-xs text-red-500 font-medium">@addressError</p> }
    </div>

    @* Amount *@
    <div class="flex flex-col gap-1.5 slide-up-delay-2">
        <div class="flex items-center justify-between">
            <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Amount</label>
            <button type="button" @onclick="SetMaxAmount"
                    class="text-xs font-semibold text-dgb-500 hover:text-dgb-400 transition-colors">
                Available: @availableBalance.ToString("N4") DGB
            </button>
        </div>
        <div class="flex items-center bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl focus-within:border-dgb-500 focus-within:ring-2 focus-within:ring-dgb-500/20 transition-all">
            <input type="number" @bind="amount" step="0.00000001" min="0" placeholder="0.00" inputmode="decimal"
                   class="flex-1 px-4 py-3 bg-transparent text-sm text-slate-900 dark:text-white outline-none" />
            <button type="button" @onclick="ToggleAmountMode"
                    class="flex items-center gap-1 mr-2 px-2.5 py-1.5 rounded-lg bg-slate-100 dark:bg-dgb-800 hover:bg-slate-200 dark:hover:bg-dgb-700 transition-colors press-effect">
                <span class="text-sm font-bold text-dgb-500">@(isAmountInFiat ? AppState.FiatCurrency : "DGB")</span>
                <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                </svg>
            </button>
        </div>
        <p class="text-xs text-slate-400 dark:text-slate-500">
            @if (isAmountInFiat)
            {
                <span>~ @amountDgb.ToString("N8") DGB</span>
            }
            else
            {
                <span>~ $@FormatFiat(amountFiat) @AppState.FiatCurrency</span>
            }
            @if (amount > 0)
            {
                <span class="italic ml-1">(estimate — actual rate may vary)</span>
            }
        </p>
        <p class="text-xs text-slate-400 dark:text-slate-500">Minimum send: 0.0001 DGB</p>
        @if (amountError != null) { <p class="text-xs text-red-500 font-medium">@amountError</p> }
    </div>

    @* Advanced Mode: Fee Control *@
    @if (!AppState.IsSimpleMode)
    {
        <div class="flex flex-col gap-1.5 slide-up-delay-3">
            <div class="flex items-center gap-1.5">
                <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Fee Rate (sat/vB)</label>
                <button type="button" @onclick="() => showFeeInfo = true" class="text-slate-400 hover:text-dgb-500 transition-colors" title="What is this?">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
                    </svg>
                </button>
            </div>
            <div class="flex gap-2">
                <button class="flex-1 py-2 text-xs font-semibold rounded-lg transition-all @(feeLevel == "low" ? "bg-dgb-500 text-white" : "bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-400")"
                        @onclick="SetFeeLow">Slow (1)</button>
                <button class="flex-1 py-2 text-xs font-semibold rounded-lg transition-all @(feeLevel == "med" ? "bg-dgb-500 text-white" : "bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-400")"
                        @onclick="SetFeeMed">Normal (5)</button>
                <button class="flex-1 py-2 text-xs font-semibold rounded-lg transition-all @(feeLevel == "high" ? "bg-dgb-500 text-white" : "bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-400")"
                        @onclick="SetFeeHigh">Fast (20)</button>
            </div>
            <input type="number" @bind="customFeeRate" min="1" placeholder="Custom sat/vB"
                   class="w-full px-3 py-2 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-lg text-xs text-slate-900 dark:text-white outline-none focus:border-dgb-500 transition-all" />
        </div>
    }

    @* Memo *@
    <div class="flex flex-col gap-1.5 slide-up-delay-3">
        <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Memo (optional)</label>
        <input type="text" @bind="memo" placeholder="What's this for?"
               class="w-full px-4 py-3 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl text-sm text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
    </div>

    @* Fee Display *@
    <div class="flex justify-between px-4 py-3 bg-slate-50 dark:bg-dgb-900/50 rounded-xl border border-slate-100 dark:border-dgb-800 slide-up-delay-4">
        <div class="flex items-center gap-1.5">
            <span class="text-xs text-slate-500 dark:text-slate-400 font-medium">Estimated Fee</span>
            @if (AppState.IsSimpleMode)
            {
                <button type="button" @onclick="() => showFeeInfo = true" class="text-slate-400 hover:text-dgb-500 transition-colors" title="What is this?">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
                    </svg>
                </button>
            }
        </div>
        <span class="text-xs text-slate-700 dark:text-slate-300 font-semibold">~@estimatedFee.ToString("N4") DGB</span>
    </div>

    <button class="slide-up-delay-5 w-full py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 hover:shadow-xl hover:shadow-dgb-500/30 transition-all press-effect disabled:opacity-50 mt-2"
            @onclick="PreviewSend"
            disabled="@(string.IsNullOrWhiteSpace(destinationAddress) || amount <= 0)">
        Review Transaction
    </button>

    @* Fee Info Modal *@
    @if (showFeeInfo)
    {
        <div class="modal-overlay" @onclick="() => showFeeInfo = false">
            <div class="modal-card flex flex-col gap-4 max-w-sm" @onclick:stopPropagation="true">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-dgb-50 dark:bg-dgb-800 flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                        </svg>
                    </div>
                    <h3 class="text-base font-bold text-slate-900 dark:text-white">What is a Transaction Fee?</h3>
                </div>

                <div class="flex flex-col gap-3 text-sm text-slate-600 dark:text-slate-300 leading-relaxed">
                    <p>Every crypto transaction pays a small fee to the network. Think of it like <strong>postage on a letter</strong> — you pay a little extra so the network delivers your payment.</p>

                    <div class="bg-slate-50 dark:bg-dgb-950 rounded-xl p-3 border border-slate-100 dark:border-dgb-800">
                        <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-2">Real-world comparison</p>
                        <div class="flex flex-col gap-1.5 text-xs">
                            <div class="flex justify-between"><span>Bank wire transfer</span><span class="font-semibold">$15 – $45</span></div>
                            <div class="flex justify-between"><span>PayPal / Venmo</span><span class="font-semibold">1.5% – 3%</span></div>
                            <div class="flex justify-between"><span>Western Union</span><span class="font-semibold">$5 – $50</span></div>
                            <div class="flex justify-between text-dgb-500 font-semibold"><span>DigiByte</span><span>~$0.001 or less</span></div>
                        </div>
                    </div>

                    <div class="bg-slate-50 dark:bg-dgb-950 rounded-xl p-3 border border-slate-100 dark:border-dgb-800">
                        <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-2">Speed options</p>
                        <div class="flex flex-col gap-1.5 text-xs">
                            <div class="flex justify-between"><span>🐢 Slow (1 sat/vB)</span><span>Cheapest — may take a few minutes</span></div>
                            <div class="flex justify-between"><span>⚡ Normal (5 sat/vB)</span><span>Recommended — ~15 seconds</span></div>
                            <div class="flex justify-between"><span>🚀 Fast (20 sat/vB)</span><span>Priority — next block</span></div>
                        </div>
                    </div>

                    <p class="text-xs text-slate-400 dark:text-slate-500">DigiByte blocks are mined every ~15 seconds, so even "Slow" is fast compared to traditional payments. For most transactions, <strong>Normal</strong> is perfect.</p>
                </div>

                <button class="w-full py-2.5 bg-dgb-500 hover:bg-dgb-600 text-white text-sm font-semibold rounded-xl press-effect"
                        @onclick="() => showFeeInfo = false">Got it!</button>
            </div>
        </div>
    }

    @* Confirm Modal — centered card *@
    @if (showConfirm)
    {
        <div class="modal-overlay" @onclick="() => { if (!isSending) showConfirm = false; }">
            <div class="modal-card flex flex-col gap-5" @onclick:stopPropagation="true">
                @* Header *@
                <div class="flex flex-col items-center gap-2">
                    <div class="w-12 h-12 rounded-full bg-dgb-50 dark:bg-dgb-800 flex items-center justify-center">
                        <svg class="w-6 h-6 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
                        </svg>
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Confirm Send</h3>
                </div>

                @* Details *@
                <div class="bg-slate-50 dark:bg-dgb-950 rounded-2xl p-4 flex flex-col gap-3">
                    <div class="flex justify-between items-start">
                        <span class="text-xs text-slate-400 dark:text-slate-500 font-medium uppercase">To</span>
                        <div class="text-right">
                            @if (!string.IsNullOrEmpty(recipientName))
                            {
                                <p class="text-sm font-semibold text-slate-900 dark:text-white">@recipientName</p>
                                <p class="text-[10px] font-mono text-slate-400">@TruncateAddress(destinationAddress)</p>
                            }
                            else
                            {
                                <p class="text-xs font-mono font-medium text-slate-900 dark:text-white">@TruncateAddress(destinationAddress)</p>
                            }
                        </div>
                    </div>
                    <div class="h-px bg-slate-200 dark:bg-dgb-800"></div>
                    <div class="flex justify-between">
                        <span class="text-xs text-slate-400 dark:text-slate-500 font-medium uppercase">Amount</span>
                        <span class="text-sm font-bold text-slate-900 dark:text-white">@amountDgb.ToString("N8") DGB</span>
                    </div>
                    <div class="h-px bg-slate-200 dark:bg-dgb-800"></div>
                    <div class="flex justify-between">
                        <span class="text-xs text-slate-400 dark:text-slate-500 font-medium uppercase">Network Fee</span>
                        <span class="text-xs text-slate-600 dark:text-slate-300">~@estimatedFee.ToString("N4") DGB</span>
                    </div>
                </div>

                @if (sendError != null)
                {
                    <p class="text-xs text-red-500 font-medium text-center bg-red-50 dark:bg-red-900/20 px-3 py-2 rounded-xl">@sendError</p>
                }

                @* Actions *@
                <div class="flex gap-3">
                    <button class="flex-1 py-3 bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-300 font-semibold rounded-2xl press-effect"
                            @onclick="() => showConfirm = false" disabled="@isSending">
                        Cancel
                    </button>
                    <button class="flex-1 py-3 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 transition-all press-effect disabled:opacity-50 flex items-center justify-center gap-2"
                            @onclick="ConfirmSend" disabled="@isSending">
                        @if (isSending)
                        {
                            <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                            </svg>
                            <span>Sending...</span>
                        }
                        else
                        {
                            <span>Send Now</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

    @* QR Scanner *@
    @* Success overlay *@
    @if (sentTxId != null)
    {
        <TxSuccessOverlay Amount="@amountDgb" TxId="@sentTxId" />
    }

    <QrScannerModal IsOpen="@showScanner" OnScanned="OnQrScanned" OnClosed="() => showScanner = false" />
</div>
</AuthGuard>

@code {
    private string destinationAddress = "";
    private string recipientName = "";
    private decimal amount;
    private decimal availableBalance;
    private string memo = "";
    private string? addressError;
    private string? amountError;
    private string? sendError;
    private bool showConfirm;
    private bool isSending;
    private bool showContactPicker;
    private bool showScanner;
    private bool showFeeInfo;
    private bool isAmountInFiat = false;
    private List<Contact> contactList = [];

    // Advanced fee control
    private string feeLevel = "med";
    private int customFeeRate = 5;
    private decimal estimatedFee = 0.0001m;

    // Live DGB price from CoinGecko
    private decimal dgbPrice;
    private decimal amountDgb => isAmountInFiat ? (dgbPrice > 0 ? amount / dgbPrice : 0) : amount;
    private decimal amountFiat => isAmountInFiat ? amount : amount * dgbPrice;

    private static string FormatFiat(decimal value)
    {
        if (value == 0) return "0.00";
        var abs = Math.Abs(value);
        if (abs >= 0.01m) return value.ToString("N2");
        if (abs >= 0.001m) return value.ToString("N3");
        if (abs >= 0.0001m) return value.ToString("N4");
        return value.ToString("N6");
    }

    private void ToggleAmountMode()
    {
        // Convert the current amount to the other unit
        if (isAmountInFiat && amount > 0)
        {
            // Switching from fiat to DGB — convert current fiat to DGB
            amount = Math.Round(amountDgb, 8);
        }
        else if (!isAmountInFiat && amount > 0)
        {
            // Switching from DGB to fiat — convert current DGB to fiat
            amount = Math.Round(amountFiat, 2);
        }
        isAmountInFiat = !isAmountInFiat;
    }

    protected override async Task OnInitializedAsync()
    {
        // Parse query params immediately (no I/O)
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (query["address"] != null) destinationAddress = query["address"]!;
        if (query["name"] != null) recipientName = query["name"]!;
        if (query["amount"] != null && decimal.TryParse(query["amount"], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var qtyAmount))
            amount = qtyAmount;

        // Run all async loads in parallel
        var contactsTask = ContactService.GetAllAsync();
        var balanceTask = Task.Run(async () => { try { var b = await WalletService.GetBalanceAsync(); availableBalance = b.ConfirmedDgb; } catch { } });
        var priceTask = Task.Run(async () => { try { dgbPrice = await Blockchain.GetDgbPriceAsync(AppState.FiatCurrency); } catch { } });

        contactList = await contactsTask;
        await Task.WhenAll(balanceTask, priceTask);
    }

    private void SelectContact(Contact c)
    {
        destinationAddress = c.Address;
        recipientName = c.Name;
        showContactPicker = false;
    }

    private void ClearRecipient()
    {
        destinationAddress = "";
        recipientName = "";
    }

    private void SetMaxAmount()
    {
        if (isAmountInFiat)
            amount = Math.Round(availableBalance * dgbPrice, 2);
        else
            amount = availableBalance;
    }

    private void SetFeeLow() => SetFee("low", 1);
    private void SetFeeMed() => SetFee("med", 5);
    private void SetFeeHigh() => SetFee("high", 20);

    private void SetFee(string level, int rate)
    {
        feeLevel = level;
        customFeeRate = rate;
        estimatedFee = rate * 0.000068m; // ~68 vbytes * rate
    }

    private void OnQrScanned(string data)
    {
        showScanner = false;
        // Parse digibyte: URI or raw address
        var parsed = DigiByte.Wallet.Models.PaymentRequest.FromUri(data);
        if (parsed != null)
        {
            destinationAddress = parsed.Address;
            if (parsed.AmountDgb.HasValue) amount = parsed.AmountDgb.Value;
            if (!string.IsNullOrEmpty(parsed.Message)) memo = parsed.Message ?? "";
        }
        else
        {
            destinationAddress = data.Trim();
        }
        StateHasChanged();
    }

    private void PreviewSend()
    {
        addressError = null;
        amountError = null;
        if (!DigiByte.Crypto.Addresses.AddressValidator.IsValid(destinationAddress))
        {
            addressError = "Invalid DigiByte address.";
            return;
        }
        if (amountDgb <= 0)
        {
            amountError = "Please enter an amount greater than zero.";
            return;
        }
        if (amountDgb < 0.0001m)
        {
            amountError = "Minimum send amount is 0.0001 DGB.";
            return;
        }
        if (amountDgb > availableBalance)
        {
            amountError = $"Insufficient balance. You have {availableBalance:N4} DGB available.";
            return;
        }
        showConfirm = true;
    }

    private string? sentTxId;

    private async Task ConfirmSend()
    {
        sendError = null; isSending = true;
        StateHasChanged();
        try
        {
            var txId = await WalletService.SendAsync(destinationAddress, amountDgb, memo);
            isSending = false;
            sentTxId = txId;
            showConfirm = false;
            StateHasChanged();
            // Show success for 2 seconds then go home
            await Task.Delay(2500);
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            sendError = ex.Message;
            isSending = false;
        }
    }

    private static string TruncateAddress(string addr) => addr.Length <= 16 ? addr : $"{addr[..8]}...{addr[^8..]}";
}
