@page "/multisig/{WalletId}/pending"
@inject MultisigWalletService MultisigService
@inject WalletService WalletService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Pending Transactions</PageTitle>

<AuthGuard>
<div class="flex flex-col gap-4">
    <div class="flex items-center gap-3 slide-up">
        <button class="p-2 rounded-xl bg-slate-100 dark:bg-dgb-800 hover:bg-slate-200 dark:hover:bg-dgb-700 transition-colors"
                @onclick="GoBack">
            <svg class="w-4 h-4 text-slate-600 dark:text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
        </button>
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Pending Transactions</h2>
    </div>

    @if (isLoading)
    {
        <div class="flex flex-col gap-3">
            @for (int i = 0; i < 2; i++)
            {
                <div class="p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800">
                    <div class="h-5 w-48 skeleton rounded"></div>
                    <div class="h-4 w-32 skeleton rounded mt-2"></div>
                </div>
            }
        </div>
    }
    else if (pendingTxs.Count == 0)
    {
        <div class="flex flex-col items-center justify-center gap-3 py-12 text-center slide-up-delay-1">
            <div class="w-14 h-14 rounded-full bg-slate-100 dark:bg-dgb-800 flex items-center justify-center">
                <svg class="w-7 h-7 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z" />
                </svg>
            </div>
            <p class="text-sm text-slate-500 dark:text-slate-400">No pending transactions.</p>
        </div>
    }
    else
    {
        <div class="flex flex-col gap-3">
            @foreach (var tx in pendingTxs)
            {
                <div class="slide-up-delay-1 p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800">
                    @* Header *@
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs font-bold uppercase tracking-wider @StatusColor(tx.Status)">@StatusText(tx.Status)</span>
                        <span class="text-[10px] text-slate-400">@tx.CreatedAt.ToString("MMM d, HH:mm")</span>
                    </div>

                    @* Description *@
                    <p class="text-sm font-semibold text-slate-900 dark:text-white">@tx.Description</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                        @tx.AmountDgb.ToString("N8") DGB &rarr; @tx.DestinationAddress[..16]...
                    </p>

                    @* Signature progress *@
                    <div class="mt-3 mb-1">
                        <div class="flex items-center justify-between mb-1">
                            <span class="text-[10px] text-slate-500 dark:text-slate-400">Signatures</span>
                            <span class="text-xs font-bold @(tx.HasEnoughSignatures ? "text-green-500" : "text-amber-500")">
                                @tx.SignatureCount / @tx.RequiredSignatures
                            </span>
                        </div>
                        <div class="h-1.5 bg-slate-100 dark:bg-dgb-800 rounded-full overflow-hidden">
                            <div class="h-full rounded-full transition-all duration-500 @(tx.HasEnoughSignatures ? "bg-green-500" : "bg-amber-500")"
                                 style="width: @(Math.Min(100, tx.SignatureCount * 100 / tx.RequiredSignatures))%"></div>
                        </div>
                    </div>

                    @* Actions *@
                    <div class="flex gap-2 mt-3">
                        @if (tx.Status == PendingTxStatus.AwaitingSignatures && config?.OwnKeyIndex >= 0 && !HasLocalSigned(tx))
                        {
                            <button class="flex-1 py-2 bg-dgb-500 hover:bg-dgb-600 text-white text-sm font-semibold rounded-xl transition-colors press-effect disabled:opacity-50"
                                    @onclick="() => SignTransaction(tx)" disabled="@isSigning">
                                Sign
                            </button>
                        }
                        @if (tx.Status == PendingTxStatus.AwaitingSignatures || tx.Status == PendingTxStatus.ReadyToFinalize)
                        {
                            <button class="flex-1 py-2 bg-slate-100 dark:bg-dgb-800 text-slate-700 dark:text-slate-300 text-sm font-semibold rounded-xl transition-colors press-effect"
                                    @onclick="() => ExportPSBT(tx)">
                                Export PSBT
                            </button>
                            <button class="py-2 px-3 bg-slate-100 dark:bg-dgb-800 text-slate-700 dark:text-slate-300 text-sm font-semibold rounded-xl transition-colors press-effect"
                                    @onclick="() => showImportFor = tx.Id">
                                Import
                            </button>
                        }
                        @if (tx.Status == PendingTxStatus.ReadyToFinalize)
                        {
                            <button class="flex-1 py-2 bg-green-500 hover:bg-green-600 text-white text-sm font-semibold rounded-xl transition-colors press-effect disabled:opacity-50"
                                    @onclick="() => BroadcastTransaction(tx)" disabled="@isBroadcasting">
                                Broadcast
                            </button>
                        }
                        @if (tx.Status == PendingTxStatus.Broadcast)
                        {
                            <span class="text-xs text-green-500 font-mono truncate flex-1">TxID: @tx.BroadcastTxId</span>
                        }
                    </div>

                    @* Import PSBT panel *@
                    @if (showImportFor == tx.Id)
                    {
                        <div class="mt-3 p-3 bg-slate-50 dark:bg-dgb-800/50 rounded-xl border border-slate-200 dark:border-dgb-700">
                            <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 mb-2">Paste signed PSBT from co-signer:</p>
                            <textarea @bind="importPsbtBase64" rows="3"
                                      placeholder="Base64-encoded PSBT..."
                                      class="w-full px-3 py-2 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-700 rounded-xl text-[11px] font-mono text-slate-900 dark:text-white outline-none focus:border-dgb-500 transition-all resize-none"></textarea>
                            <div class="flex gap-2 mt-2">
                                <button class="flex-1 py-2 bg-dgb-500 text-white text-sm font-semibold rounded-xl press-effect disabled:opacity-50"
                                        @onclick="() => ImportSignedPSBT(tx)" disabled="@(string.IsNullOrWhiteSpace(importPsbtBase64))">Merge</button>
                                <button class="py-2 px-3 text-sm text-slate-500 font-medium" @onclick="() => showImportFor = null">Cancel</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="p-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800/30 rounded-xl">
            <p class="text-sm text-green-700 dark:text-green-300">@message</p>
        </div>
    }
    @if (!string.IsNullOrEmpty(error))
    {
        <div class="p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800/30 rounded-xl">
            <p class="text-sm text-red-600 dark:text-red-400">@error</p>
        </div>
    }
</div>
</AuthGuard>

@code {
    [Parameter] public string WalletId { get; set; } = "";

    private MultisigWalletConfig? config;
    private List<PendingMultisigTransaction> pendingTxs = [];
    private bool isLoading = true;
    private bool isSigning;
    private bool isBroadcasting;
    private string? showImportFor;
    private string importPsbtBase64 = "";
    private string? message;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            config = await MultisigService.GetConfigAsync(WalletId);
            pendingTxs = await MultisigService.GetPendingTransactionsAsync(WalletId);
        }
        finally
        {
            isLoading = false;
        }
    }

    private bool HasLocalSigned(PendingMultisigTransaction tx)
    {
        if (config?.OwnKeyIndex < 0 || config?.OwnKeyIndex >= config?.CoSigners.Count)
            return true; // Can't sign
        var ownPubKeyHex = config!.CoSigners[config.OwnKeyIndex].PublicKeyHex;
        return tx.SignedBy.Contains(ownPubKeyHex);
    }

    private async Task SignTransaction(PendingMultisigTransaction tx)
    {
        isSigning = true;
        error = null;
        message = null;
        StateHasChanged();
        await Task.Yield();

        try
        {
            var privateKey = WalletService.GetPrivateKeyForMultisig();
            if (privateKey == null)
                throw new InvalidOperationException("Wallet is locked or private key unavailable.");

            var key = new NBitcoin.Key(Convert.FromHexString(privateKey));
            await MultisigService.SignPendingTransactionAsync(tx, key);
            pendingTxs = await MultisigService.GetPendingTransactionsAsync(WalletId);
            message = "Transaction signed successfully.";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isSigning = false;
        }
    }

    private async Task ExportPSBT(PendingMultisigTransaction tx)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", tx.PsbtBase64);
        message = "PSBT copied to clipboard. Share with co-signers.";
    }

    private async Task ImportSignedPSBT(PendingMultisigTransaction tx)
    {
        error = null;
        message = null;
        try
        {
            await MultisigService.ImportSignedPSBTAsync(tx, importPsbtBase64.Trim());
            pendingTxs = await MultisigService.GetPendingTransactionsAsync(WalletId);
            showImportFor = null;
            importPsbtBase64 = "";
            message = "Signatures merged successfully.";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task BroadcastTransaction(PendingMultisigTransaction tx)
    {
        isBroadcasting = true;
        error = null;
        message = null;
        StateHasChanged();
        await Task.Yield();

        try
        {
            var txId = await MultisigService.FinalizeAndBroadcastAsync(tx);
            pendingTxs = await MultisigService.GetPendingTransactionsAsync(WalletId);
            message = $"Transaction broadcast! TxID: {txId}";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBroadcasting = false;
        }
    }

    private void GoBack() => Nav.NavigateTo($"/multisig/{WalletId}");

    private static string StatusText(PendingTxStatus status) => status switch
    {
        PendingTxStatus.AwaitingSignatures => "Awaiting Signatures",
        PendingTxStatus.ReadyToFinalize => "Ready to Broadcast",
        PendingTxStatus.Broadcast => "Broadcast",
        PendingTxStatus.Failed => "Failed",
        PendingTxStatus.Cancelled => "Cancelled",
        _ => status.ToString(),
    };

    private static string StatusColor(PendingTxStatus status) => status switch
    {
        PendingTxStatus.AwaitingSignatures => "text-amber-500",
        PendingTxStatus.ReadyToFinalize => "text-green-500",
        PendingTxStatus.Broadcast => "text-dgb-500",
        PendingTxStatus.Failed => "text-red-500",
        PendingTxStatus.Cancelled => "text-slate-400",
        _ => "text-slate-500",
    };
}
