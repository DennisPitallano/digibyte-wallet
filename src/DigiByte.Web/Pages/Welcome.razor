@page "/welcome"
@inject NavigationManager Nav

<PageTitle>Welcome</PageTitle>

<div class="flex flex-col items-center justify-center min-h-[80vh] text-center gap-8">
    <div class="flex flex-col items-center gap-3 float-in">
        <div class="relative">
            <div class="absolute inset-0 bg-dgb-500/20 rounded-full blur-2xl scale-150 glow-pulse"></div>
            <div class="float">
                <DigiLogo Size="80" Class="relative drop-shadow-xl" />
            </div>
        </div>
        <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white mt-2">
            Digi<span class="text-dgb-500">Byte</span>
        </h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 font-medium tracking-wide">
            Your money. Your keys. Your freedom.
        </p>
    </div>

    <div class="flex flex-col gap-3 w-full max-w-[280px]">
        <button class="slide-up-delay-2 w-full py-3.5 px-6 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 hover:shadow-xl hover:shadow-dgb-500/30 transition-all duration-200 press-effect"
                @onclick="CreateWallet">
            Create New Wallet
        </button>
        <button class="slide-up-delay-3 w-full py-3.5 px-6 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 text-slate-700 dark:text-slate-300 font-semibold rounded-2xl hover:bg-slate-50 dark:hover:bg-dgb-800 hover:border-dgb-300 dark:hover:border-dgb-600 transition-all duration-200 press-effect"
                @onclick="RecoverWallet">
            Recover Existing Wallet
        </button>
        <button class="slide-up-delay-3 w-full py-3.5 px-6 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 text-slate-700 dark:text-slate-300 font-semibold rounded-2xl hover:bg-slate-50 dark:hover:bg-dgb-800 hover:border-dgb-300 dark:hover:border-dgb-600 transition-all duration-200 press-effect"
                @onclick="ImportXpub">
            Watch-Only (xpub)
        </button>
    </div>

    <div class="flex items-center gap-3 text-xs text-slate-400 dark:text-slate-500 slide-up-delay-3">
        <a href="/help" class="hover:text-dgb-500 transition-colors">Help</a>
        <span>·</span>
        <a href="/about" class="hover:text-dgb-500 transition-colors">About</a>
        <span>·</span>
        <a href="/roadmap" class="hover:text-dgb-500 transition-colors">Roadmap</a>
        <span>·</span>
        <a href="/analytics" class="hover:text-dgb-500 transition-colors">Analytics</a>
        <span>·</span>
        <a href="/deployment" class="hover:text-dgb-500 transition-colors">Deployment</a>
    </div>

    <div class="flex flex-col items-center gap-2 slide-up-delay-3">
        <button type="button" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-dgb-50 dark:bg-dgb-900/60 border border-dgb-200/60 dark:border-dgb-700/40 hover:border-dgb-400 dark:hover:border-dgb-500 transition-colors cursor-pointer"
                @onclick="() => showVersionInfo = true">
            <span class="text-xs font-bold text-dgb-600 dark:text-dgb-300 tracking-tight">v@(AppVersion.ShortVersion)</span>
            @if (AppVersion.IsPreRelease)
            {
                <span class="text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400">@AppVersion.Channel</span>
            }
            <svg class="w-3.5 h-3.5 text-dgb-400 dark:text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
            </svg>
        </button>
        <p class="text-[10px] text-slate-400 dark:text-slate-500 tracking-wide">Speed · Security · Scalability</p>
    </div>
</div>

@* Version Info Modal *@
@if (showVersionInfo)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm" @onclick="() => showVersionInfo = false">
        <div class="scale-in bg-white dark:bg-dgb-900 rounded-2xl shadow-2xl p-5 mx-4 max-w-xs w-full flex flex-col gap-4"
             @onclick:stopPropagation="true">
            <div class="flex items-center justify-between">
                <h3 class="text-sm font-bold text-slate-900 dark:text-white">Version Info</h3>
                <button type="button" class="p-1 rounded-lg hover:bg-slate-100 dark:hover:bg-dgb-800 transition-colors"
                        @onclick="() => showVersionInfo = false">
                    <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <div class="flex flex-col gap-3">
                @* Version badge *@
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-dgb-100 dark:bg-dgb-800 flex items-center justify-center">
                        <DigiLogo Size="24" />
                    </div>
                    <div>
                        <p class="text-sm font-bold text-slate-900 dark:text-white">DigiByte Wallet</p>
                        <p class="text-xs text-slate-500 dark:text-slate-400 font-mono">v@(AppVersion.Version)</p>
                    </div>
                </div>

                @* Details *@
                <div class="flex flex-col gap-2 text-xs">
                    <div class="flex justify-between py-1.5 border-b border-slate-100 dark:border-dgb-800">
                        <span class="text-slate-500 dark:text-slate-400">Version</span>
                        <span class="font-semibold text-slate-900 dark:text-white font-mono">@AppVersion.Version</span>
                    </div>
                    <div class="flex justify-between py-1.5 border-b border-slate-100 dark:border-dgb-800">
                        <span class="text-slate-500 dark:text-slate-400">Channel</span>
                        <span class="inline-flex items-center gap-1.5 font-semibold">
                            <span class="w-1.5 h-1.5 rounded-full @(AppVersion.Channel switch { "alpha" => "bg-amber-500", "beta" => "bg-blue-500", "rc" => "bg-purple-500", _ => "bg-green-500" })"></span>
                            <span class="text-slate-900 dark:text-white capitalize">@AppVersion.Channel</span>
                        </span>
                    </div>
                    <div class="flex justify-between py-1.5 border-b border-slate-100 dark:border-dgb-800">
                        <span class="text-slate-500 dark:text-slate-400">Platform</span>
                        <span class="font-semibold text-slate-900 dark:text-white">Blazor WASM (PWA)</span>
                    </div>
                    <div class="flex justify-between py-1.5 border-b border-slate-100 dark:border-dgb-800">
                        <span class="text-slate-500 dark:text-slate-400">Framework</span>
                        <span class="font-semibold text-slate-900 dark:text-white">.NET 10</span>
                    </div>
                </div>

                @* What's New *@
                <div>
                    <p class="text-[11px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-2">What's New</p>
                    <div class="flex flex-col gap-1.5 text-[11px] text-slate-600 dark:text-slate-300">
                        <div class="flex items-start gap-2">
                            <span class="text-dgb-500 mt-0.5">●</span>
                            <span>M-of-N multisig wallets with PSBT signing</span>
                        </div>
                        <div class="flex items-start gap-2">
                            <span class="text-dgb-500 mt-0.5">●</span>
                            <span>Help Center with 12 tutorial sections</span>
                        </div>
                        <div class="flex items-start gap-2">
                            <span class="text-dgb-500 mt-0.5">●</span>
                            <span>Multisig guide with visual flows</span>
                        </div>
                        <div class="flex items-start gap-2">
                            <span class="text-dgb-500 mt-0.5">●</span>
                            <span>Video tutorials for install, recover & send</span>
                        </div>
                        <div class="flex items-start gap-2">
                            <span class="text-dgb-500 mt-0.5">●</span>
                            <span>iOS PWA install support</span>
                        </div>
                    </div>
                </div>
            </div>

            <a href="/roadmap" class="w-full py-2 text-xs font-semibold text-center rounded-xl bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-dgb-700 transition-colors">
                View Full Roadmap
            </a>
        </div>
    </div>
}

@code {
    private bool showVersionInfo;
    private void CreateWallet() => Nav.NavigateTo("/create-wallet");
    private void RecoverWallet() => Nav.NavigateTo("/recover-wallet");
    private void ImportXpub() => Nav.NavigateTo("/import-xpub");
}
