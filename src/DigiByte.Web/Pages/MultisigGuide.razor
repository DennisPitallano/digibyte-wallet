                            <td class="py-1.5 px-3">Can send</td>
                            <td class="text-center py-1.5 px-2 text-green-500">✓</td>
                            <td class="text-center py-1.5 px-2 text-red-400">✗</td>
                            <td class="text-center py-1.5 px-2 text-green-500">✓*</td>
                        </tr>
                        <tr class="border-b border-slate-50 dark:border-dgb-800/50">
                            <td class="py-1.5 px-3">View balance</td>
                            <td class="text-center py-1.5 px-2 text-green-500">✓</td>
                            <td class="text-center py-1.5 px-2 text-green-500">✓</td>
                            <td class="text-center py-1.5 px-2 text-green-500">✓</td>
                        </tr>
                        <tr class="border-b border-slate-50 dark:border-dgb-800/50">
                            <td class="py-1.5 px-3">Single point of failure</td>
                            <td class="text-center py-1.5 px-2 text-red-400">Yes</td>
                            <td class="text-center py-1.5 px-2">N/A</td>
                            <td class="text-center py-1.5 px-2 text-green-500">No</td>
                        </tr>
                        <tr>
                            <td class="py-1.5 px-3">Best for</td>
                            <td class="text-center py-1.5 px-2">Daily use</td>
                            <td class="text-center py-1.5 px-2">Monitoring</td>
                            <td class="text-center py-1.5 px-2 font-semibold text-purple-500">Security</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <p class="text-[9px] text-slate-400 dark:text-slate-500 px-3 py-1.5 border-t border-slate-50 dark:border-dgb-800/50">* Requires M co-signers to approve via PSBT workflow</p>
        </div>
    </div>

    @* CTA *@
    <div class="flex flex-col gap-2 mt-2 pb-4">
        <button class="w-full py-3 bg-purple-500 hover:bg-purple-600 text-white font-semibold rounded-2xl shadow-lg shadow-purple-500/25 transition-all press-effect"
                @onclick='() => Nav.NavigateTo("/multisig")'>
            Create a Multisig Wallet
        </button>
        <button class="w-full py-3 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 text-slate-600 dark:text-slate-300 font-semibold rounded-2xl hover:bg-slate-50 dark:hover:bg-dgb-800 transition-all press-effect"
                @onclick='() => Nav.NavigateTo("/help")'>
            Back to Help Center
        </button>
    </div>
</div>

@code {
    private HashSet<string> openGuides = [];

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private void ToggleGuide(string id)
    {
        if (!openGuides.Remove(id))
            openGuides.Add(id);
    }

    private record FlowStep(int Number, string Title, string Description);

    private FlowStep[] createSteps = [
        new(1, "Choose your threshold", "Decide how many signatures are required (M) and total key holders (N). E.g., 2-of-3."),
        new(2, "Gather public keys", "Each co-signer shares their compressed public key (hex). Your key is auto-added."),
        new(3, "Create the wallet", "The app generates a redeem script (BIP67 sorted), derives the multisig address, and saves the config."),
        new(4, "Share the redeem script", "Send the redeem script to all co-signers so they can import the same wallet."),
        new(5, "Fund the address", "Send DGB to the multisig address. Anyone can deposit — only M-of-N can withdraw."),
    ];

    private FlowStep[] spendSteps = [
        new(1, "Initiator creates PSBT", "One co-signer enters the destination and amount. A Partially Signed Transaction (PSBT) is created."),
        new(2, "Initiator signs", "The initiator adds their signature to the PSBT."),
        new(3, "Share with co-signers", "The partially signed PSBT is shared via secure messaging (Signal, email, etc.)."),
        new(4, "Co-signers sign", "Each co-signer imports the PSBT and adds their signature. Signatures combine automatically."),
        new(5, "Threshold met → Broadcast", "When M signatures are collected, finalize the PSBT and broadcast to the DigiByte network."),
    ];
}
