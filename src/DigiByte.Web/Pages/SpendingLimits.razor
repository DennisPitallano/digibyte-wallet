@page "/settings/spending-limits"
@inject WalletService WalletService
@inject SpendingLimitService SpendingLimit
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Spending Limits — DigiByte Wallet</PageTitle>

<div class="flex flex-col gap-4">
    <button class="flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-dgb-500 transition-colors w-fit -mb-2" @onclick="GoBack">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
        Back
    </button>

    <div class="slide-up">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Spending Limits</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
            Set daily, weekly, and monthly limits for
            @if (WalletService.ActiveWallet is { } w)
            {
                <span class="inline-flex items-center gap-1 font-medium text-slate-700 dark:text-slate-300">
                    <span class="inline-block w-2.5 h-2.5 rounded-full" style="background-color: @w.Color"></span>
                    @w.Name
                </span>
            }
            else
            {
                <span>your wallet</span>
            }.
        </p>
    </div>

    @if (!pinVerified)
    {
        @* PIN verification gate *@
        <div class="slide-up-delay-1 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 p-5 flex flex-col gap-4 items-center">
            <div class="w-14 h-14 rounded-full bg-red-50 dark:bg-red-900/20 flex items-center justify-center">
                <svg class="w-7 h-7 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                </svg>
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400 text-center">Enter your PIN to view or change spending limits.</p>
            <PinInput @ref="pinInput" ValueChanged="(v) => pin = v" OnComplete="VerifyPin" Error="@pinError" />
            <button class="w-full max-w-[260px] py-3 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl press-effect disabled:opacity-50"
                    @onclick="VerifyPin" disabled="@(pin.Length < 6 || isVerifying)">
                @(isVerifying ? "Verifying..." : "Unlock")
            </button>
        </div>
    }
    else
    {
        @* Enable/Disable toggle *@
        <div class="slide-up-delay-1 flex items-center justify-between p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-red-50 dark:bg-red-900/20 flex items-center justify-center">
                    <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.286ZM12 15.75h.008v.008H12v-.008Z" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white">Spending Limits</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400">@(settings.Enabled ? "Active" : "Disabled")</p>
                </div>
            </div>
            <button class="relative w-12 h-7 rounded-full transition-colors duration-200 @(settings.Enabled ? "bg-dgb-500" : "bg-slate-300")"
                    @onclick="ToggleEnabled">
                <span class="absolute top-1 left-1 h-5 w-5 bg-white rounded-full shadow transition-transform duration-200 @(settings.Enabled ? "translate-x-5" : "translate-x-0")"></span>
            </button>
        </div>

        @if (settings.Enabled)
        {
            @* Limit inputs *@
            <div class="slide-up-delay-1 flex flex-col gap-3">
                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 px-1">Limits (DGB)</p>

                @* Daily *@
                <div class="flex items-center justify-between p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center">
                            <span class="text-xs font-bold text-blue-500">24h</span>
                        </div>
                        <p class="text-sm font-medium text-slate-800 dark:text-slate-200">Daily</p>
                    </div>
                    <input type="number" min="0" step="0.01" value="@settings.DailyLimitDgb"
                           @onchange="(e) => OnLimitChanged(e, nameof(settings.DailyLimitDgb))"
                           placeholder="0"
                           class="w-28 text-right px-3 py-2 bg-slate-50 dark:bg-dgb-800 border border-slate-200 dark:border-dgb-700 rounded-xl text-sm text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-1 focus:ring-dgb-500/20" />
                </div>

                @* Weekly *@
                <div class="flex items-center justify-between p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-900/20 flex items-center justify-center">
                            <span class="text-xs font-bold text-indigo-500">7d</span>
                        </div>
                        <p class="text-sm font-medium text-slate-800 dark:text-slate-200">Weekly</p>
                    </div>
                    <input type="number" min="0" step="0.1" value="@settings.WeeklyLimitDgb"
                           @onchange="(e) => OnLimitChanged(e, nameof(settings.WeeklyLimitDgb))"
                           placeholder="0"
                           class="w-28 text-right px-3 py-2 bg-slate-50 dark:bg-dgb-800 border border-slate-200 dark:border-dgb-700 rounded-xl text-sm text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-1 focus:ring-dgb-500/20" />
                </div>

                @* Monthly *@
                <div class="flex items-center justify-between p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-purple-50 dark:bg-purple-900/20 flex items-center justify-center">
                            <span class="text-xs font-bold text-purple-500">30d</span>
                        </div>
                        <p class="text-sm font-medium text-slate-800 dark:text-slate-200">Monthly</p>
                    </div>
                    <input type="number" min="0" step="1" value="@settings.MonthlyLimitDgb"
                           @onchange="(e) => OnLimitChanged(e, nameof(settings.MonthlyLimitDgb))"
                           placeholder="0"
                           class="w-28 text-right px-3 py-2 bg-slate-50 dark:bg-dgb-800 border border-slate-200 dark:border-dgb-700 rounded-xl text-sm text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-1 focus:ring-dgb-500/20" />
                </div>
                <p class="text-[10px] text-slate-400 dark:text-slate-500 px-1">Set to 0 to disable a specific period. All periods use rolling time windows.</p>
            </div>

            @* Alert threshold *@
            <div class="slide-up-delay-2 flex flex-col gap-2">
                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 px-1">Alert Threshold</p>
                <div class="flex items-center justify-between p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800">
                    <p class="text-sm text-slate-700 dark:text-slate-300">Warn at</p>
                    <div class="flex gap-1.5">
                        @foreach (var pct in new[] { 60, 70, 80, 90 })
                        {
                            var p = pct;
                            <button class="px-3 py-1.5 text-xs font-semibold rounded-lg transition-all @(settings.AlertThresholdPercent == p ? "bg-dgb-500 text-white" : "bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-dgb-700")"
                                    @onclick="() => SetThreshold(p)">@p%</button>
                        }
                    </div>
                </div>
            </div>

            @* Hard block toggle *@
            <div class="slide-up-delay-2 flex items-center justify-between p-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl bg-red-50 dark:bg-red-900/20 flex items-center justify-center">
                        <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-slate-900 dark:text-white">Block Sends</p>
                        <p class="text-xs text-slate-500 dark:text-slate-400">@(settings.HardBlock ? "Sends over limit are blocked" : "Warn only — sends still allowed")</p>
                    </div>
                </div>
                <button class="relative w-12 h-7 rounded-full transition-colors duration-200 @(settings.HardBlock ? "bg-red-500" : "bg-slate-300")"
                        @onclick="ToggleHardBlock">
                    <span class="absolute top-1 left-1 h-5 w-5 bg-white rounded-full shadow transition-transform duration-200 @(settings.HardBlock ? "translate-x-5" : "translate-x-0")"></span>
                </button>
            </div>

            @* Current spending summary *@
            <div class="slide-up-delay-3 flex flex-col gap-2">
                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 px-1">Current Spending</p>
                @if (isLoadingSpent)
                {
                    <div class="bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 p-4">
                        <div class="animate-pulse flex flex-col gap-3">
                            <div class="h-3 bg-slate-200 dark:bg-dgb-800 rounded w-2/3"></div>
                            <div class="h-2 bg-slate-100 dark:bg-dgb-800/60 rounded w-full"></div>
                            <div class="h-3 bg-slate-200 dark:bg-dgb-800 rounded w-2/3"></div>
                            <div class="h-2 bg-slate-100 dark:bg-dgb-800/60 rounded w-full"></div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 p-4 flex flex-col gap-3">
                        @if (settings.DailyLimitDgb > 0)
                        {
                            @SpendingBar("Today (24h)", spentDaily, settings.DailyLimitDgb, settings.AlertThresholdPercent)
                        }
                        @if (settings.WeeklyLimitDgb > 0)
                        {
                            @SpendingBar("This Week (7d)", spentWeekly, settings.WeeklyLimitDgb, settings.AlertThresholdPercent)
                        }
                        @if (settings.MonthlyLimitDgb > 0)
                        {
                            @SpendingBar("This Month (30d)", spentMonthly, settings.MonthlyLimitDgb, settings.AlertThresholdPercent)
                        }
                        @if (settings.DailyLimitDgb == 0 && settings.WeeklyLimitDgb == 0 && settings.MonthlyLimitDgb == 0)
                        {
                            <p class="text-xs text-slate-400 dark:text-slate-500 text-center py-2">No limits configured. Set at least one limit above.</p>
                        }
                    </div>
                }
            </div>
        }

        @* Save confirmation *@
        @if (saved)
        {
            <div class="slide-up flex items-center gap-2 bg-green-50 dark:bg-green-900/20 px-4 py-3 rounded-xl border border-green-200 dark:border-green-800/30">
                <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <p class="text-xs text-green-700 dark:text-green-400 font-medium">Settings saved.</p>
            </div>
        }
    }
</div>

@code {
    private string pin = "";
    private string? pinError;
    private bool pinVerified;
    private bool isVerifying;
    private PinInput? pinInput;

    private SpendingLimitSettings settings = new();
    private string? walletId;
    private bool saved;
    private bool isLoadingSpent;

    private decimal spentDaily;
    private decimal spentWeekly;
    private decimal spentMonthly;

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private async Task VerifyPin()
    {
        if (pin.Length < 6) return;
        isVerifying = true;
        pinError = null;
        StateHasChanged();

        try
        {
            walletId = await WalletService.GetActiveWalletIdAsync();
            if (walletId == null) { pinError = "No active wallet."; return; }

            var success = await WalletService.UnlockWalletAsync(walletId, pin);
            if (!success)
            {
                pinError = "Incorrect PIN.";
                pin = "";
                pinInput?.Clear();
                return;
            }

            pinVerified = true;
            settings = await SpendingLimit.GetSettingsAsync(walletId);
            await LoadSpentAmounts();
        }
        catch { pinError = "Verification failed."; }
        finally { isVerifying = false; StateHasChanged(); }
    }

    private async Task LoadSpentAmounts()
    {
        isLoadingSpent = true;
        StateHasChanged();
        try
        {
            spentDaily = await SpendingLimit.GetSpentInPeriodAsync(TimeSpan.FromHours(24));
            spentWeekly = await SpendingLimit.GetSpentInPeriodAsync(TimeSpan.FromDays(7));
            spentMonthly = await SpendingLimit.GetSpentInPeriodAsync(TimeSpan.FromDays(30));
        }
        catch { }
        finally { isLoadingSpent = false; StateHasChanged(); }
    }

    private async Task ToggleEnabled()
    {
        settings.Enabled = !settings.Enabled;
        await SaveSettings();
        if (settings.Enabled) await LoadSpentAmounts();
    }

    private void OnLimitChanged(ChangeEventArgs e, string field)
    {
        if (decimal.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var val) && val >= 0)
        {
            switch (field)
            {
                case nameof(settings.DailyLimitDgb): settings.DailyLimitDgb = val; break;
                case nameof(settings.WeeklyLimitDgb): settings.WeeklyLimitDgb = val; break;
                case nameof(settings.MonthlyLimitDgb): settings.MonthlyLimitDgb = val; break;
            }
        }
        _ = SaveSettings();
    }

    private async Task SetThreshold(int pct)
    {
        settings.AlertThresholdPercent = pct;
        await SaveSettings();
    }

    private async Task ToggleHardBlock()
    {
        settings.HardBlock = !settings.HardBlock;
        await SaveSettings();
    }

    private async Task SaveSettings()
    {
        if (walletId == null) return;
        await SpendingLimit.SaveSettingsAsync(walletId, settings);
        saved = true;
        StateHasChanged();
        await Task.Delay(2000);
        saved = false;
        StateHasChanged();
    }

    private RenderFragment SpendingBar(string Label, decimal Spent, decimal Limit, int ThresholdPercent) => __builder =>
    {
        var pct = Limit > 0 ? Math.Min(Spent / Limit * 100, 100) : 0;
        var thresholdPct = ThresholdPercent;
        var barColor = pct >= 100 ? "bg-red-500" : pct >= thresholdPct ? "bg-amber-500" : "bg-dgb-500";
        var textColor = pct >= 100 ? "text-red-500" : pct >= thresholdPct ? "text-amber-500" : "text-slate-600 dark:text-slate-400";

        <div class="flex flex-col gap-1">
            <div class="flex items-center justify-between">
                <span class="text-xs font-medium text-slate-700 dark:text-slate-300">@Label</span>
                <span class="text-xs font-mono @textColor">@Spent.ToString("N4") / @Limit.ToString("N4")</span>
            </div>
            <div class="h-2 bg-slate-100 dark:bg-dgb-800 rounded-full overflow-hidden">
                <div class="h-full rounded-full transition-all duration-500 @barColor" style="width: @($"{pct:N1}")%"></div>
            </div>
        </div>;
    };
}
