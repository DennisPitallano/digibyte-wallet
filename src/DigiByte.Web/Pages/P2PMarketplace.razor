@page "/p2p"

<PageTitle>P2P Exchange</PageTitle>

<div class="flex flex-col gap-4">
    <h2 class="text-xl font-bold text-slate-900 dark:text-white slide-up">P2P Exchange</h2>

    <div class="slide-up-delay-1 flex bg-slate-100 dark:bg-dgb-900 rounded-xl p-1 gap-0.5">
        <button class="flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all duration-200 @(activeTab == "buy" ? "bg-white dark:bg-dgb-800 text-dgb-500 shadow-sm" : "text-slate-500 dark:text-slate-400")"
                @onclick="@(() => activeTab = "buy")">Buy DGB</button>
        <button class="flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all duration-200 @(activeTab == "sell" ? "bg-white dark:bg-dgb-800 text-dgb-500 shadow-sm" : "text-slate-500 dark:text-slate-400")"
                @onclick="@(() => activeTab = "sell")">Sell DGB</button>
        <button class="flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all duration-200 @(activeTab == "orders" ? "bg-white dark:bg-dgb-800 text-dgb-500 shadow-sm" : "text-slate-500 dark:text-slate-400")"
                @onclick="@(() => activeTab = "orders")">My Orders</button>
    </div>

    <div class="scale-in-delay-1 bg-white dark:bg-dgb-900/50 rounded-2xl border border-slate-200/80 dark:border-dgb-800 p-8 text-center card-hover">
        <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-slate-100 dark:bg-dgb-800 flex items-center justify-center">
            <svg class="w-6 h-6 text-slate-400 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
            </svg>
        </div>
        <p class="text-sm font-medium text-slate-500 dark:text-slate-400">P2P marketplace coming soon</p>
        <p class="text-xs text-slate-400 dark:text-slate-500 mt-1">Buy and sell DGB directly with other users</p>
    </div>
</div>

@code {
    private string activeTab = "buy";
}
