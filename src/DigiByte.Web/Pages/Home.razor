                            </div>
                            <div class="text-right">
                                <p class="text-xs font-bold @(tx.Direction == TransactionDirection.Sent ? "text-red-500" : "text-green-500")">
                                    @(tx.Direction == TransactionDirection.Sent ? "-" : "+")@tx.AmountDgb.ToString("N4") DGB
                                </p>
                                <ConfirmationBadge Confirmations="tx.Confirmations" />
                            </div>
                        </div>
                    </Virtualize>
                </div>
            }


        </div>
    </div>

    <QrScannerModal IsOpen="@showScanner" OnScanned="OnQrScanned" OnClosed="() => showScanner = false" />
    <TransactionDetailModal IsOpen="@(selectedTx != null)" Tx="@selectedTx"
