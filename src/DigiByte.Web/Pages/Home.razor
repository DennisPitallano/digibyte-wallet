@page "/"
@inject NavigationManager Nav
@inject ContactService ContactService
@inject WalletService WalletService
@inject FallbackBlockchainService BlockchainApi

<PageTitle>DigiByte Wallet</PageTitle>

<AuthGuard>
    <div class="flex flex-col gap-5">
        @* Demo Mode Banner *@
        @if (BlockchainApi.IsDemoMode)
        {
            <div class="flex items-center gap-2 px-4 py-2.5 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700/40 rounded-2xl">
                <svg class="w-4 h-4 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                </svg>
                <p class="text-xs font-medium text-amber-700 dark:text-amber-300">DEMO MODE — Simulated data for testing. Not from testnet or mainnet.</p>
            </div>
        }

        @* Balance Card *@
        <div class="scale-in relative overflow-hidden rounded-3xl bg-gradient-to-br from-dgb-900 via-dgb-800 to-dgb-700 p-6 text-white shadow-xl shadow-dgb-900/30">
            <div class="absolute -top-10 -right-10 w-32 h-32 bg-dgb-500/20 rounded-full blur-2xl glow-pulse"></div>
            <div class="absolute -bottom-8 -left-8 w-24 h-24 bg-dgb-400/15 rounded-full blur-xl glow-pulse" style="animation-delay: 1.5s"></div>
            <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
            <div class="relative">
                <div class="flex items-center gap-2">
                    <p class="text-sm text-dgb-200 font-medium">Total Balance</p>
                    @if (AppState.IsTestnet)
                    {
                        <span class="text-[10px] font-bold text-amber-300 bg-amber-500/20 px-1.5 py-0.5 rounded-full">TESTNET</span>
                    }
                    @if (BlockchainApi.IsDemoMode)
                    {
                        <span class="text-[10px] font-bold text-orange-300 bg-orange-500/20 px-1.5 py-0.5 rounded-full">DEMO</span>
                    }
                    @if (isLoadingBalance)
                    {
                        <div class="w-3 h-3 border-2 border-dgb-300 border-t-transparent rounded-full animate-spin"></div>
                    }
                </div>
                @if (AppState.IsSimpleMode)
                {
                    <h1 class="text-4xl font-extrabold mt-1 tracking-tight">$@balance.FiatValue.ToString("N2")</h1>
                    <p class="text-sm text-dgb-300 mt-1">@balance.TotalDgb.ToString("N8") DGB</p>
                }
                else
                {
                    <h1 class="text-4xl font-extrabold mt-1 tracking-tight">@balance.TotalDgb.ToString("N8") DGB</h1>
                    <p class="text-sm text-dgb-300 mt-1">$@balance.FiatValue.ToString("N2") @balance.FiatCurrency</p>
                }
            </div>
        </div>

        @* Action Buttons *@
        <div class="flex justify-center gap-5">
            <button class="slide-up-delay-1 flex flex-col items-center gap-2 group" @onclick="OnSend">
                <div class="w-14 h-14 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center shadow-sm card-hover group-active:scale-90 transition-transform">
                    <svg class="w-6 h-6 text-dgb-500 transition-transform duration-200 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
                    </svg>
                </div>
                <span class="text-xs font-semibold text-slate-600 dark:text-slate-400">Send</span>
            </button>
            <button class="slide-up-delay-2 flex flex-col items-center gap-2 group" @onclick="OnReceive">
                <div class="w-14 h-14 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center shadow-sm card-hover group-active:scale-90 transition-transform">
                    <svg class="w-6 h-6 text-dgb-500 transition-transform duration-200 group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
                    </svg>
                </div>
                <span class="text-xs font-semibold text-slate-600 dark:text-slate-400">Receive</span>
            </button>
            <button class="slide-up-delay-3 flex flex-col items-center gap-2 group" @onclick="OnContacts">
                <div class="w-14 h-14 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center shadow-sm card-hover group-active:scale-90 transition-transform">
                    <svg class="w-6 h-6 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                    </svg>
                </div>
                <span class="text-xs font-semibold text-slate-600 dark:text-slate-400">Contacts</span>
            </button>
            <button class="slide-up-delay-3 flex flex-col items-center gap-2 group" @onclick="OnScan">
                <div class="w-14 h-14 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center shadow-sm card-hover group-active:scale-90 transition-transform">
                    <svg class="w-6 h-6 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 3.75 9.375v-4.5ZM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5ZM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 13.5 9.375v-4.5Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 14.625v2.625m3.375-2.625v2.625M16.875 20.25h-3.375v-2.625" />
                    </svg>
                </div>
                <span class="text-xs font-semibold text-slate-600 dark:text-slate-400">Scan</span>
            </button>
        </div>

        @* Advanced Mode: Address Info *@
        @if (!AppState.IsSimpleMode)
        {
            <div class="slide-up-delay-4 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200 dark:border-dgb-800 p-4 flex flex-col gap-3">
                <h3 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Wallet Info</h3>
                <div class="flex flex-col gap-2">
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-500 dark:text-slate-400">HD Path</span>
                        <span class="font-mono text-slate-700 dark:text-slate-300 text-xs">m/44'/20'/0'</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-500 dark:text-slate-400">Address Type</span>
                        <span class="text-slate-700 dark:text-slate-300">SegWit (Bech32)</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-500 dark:text-slate-400">Network</span>
                        <span class="text-green-500 font-medium">Mainnet</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-500 dark:text-slate-400">UTXOs</span>
                        <span class="text-slate-700 dark:text-slate-300">0</span>
                    </div>
                </div>
            </div>
        }

        @* Quick Contacts *@
        @if (quickContacts.Count > 0)
        {
            <div class="slide-up-delay-4">
                <div class="flex items-center justify-between mb-2">
                    <h3 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Quick Send</h3>
                    <button class="text-xs text-dgb-500 font-medium" @onclick="OnContacts">See all</button>
                </div>
                <div class="flex gap-3 overflow-x-auto pb-1">
                    @foreach (var c in quickContacts)
                    {
                        var contact = c;
                        <button class="flex flex-col items-center gap-1.5 min-w-[60px] press-effect"
                                @onclick="() => SendToContact(contact)">
                            <div class="w-11 h-11 rounded-full bg-dgb-100 dark:bg-dgb-800 flex items-center justify-center">
                                <span class="text-sm font-bold text-dgb-600 dark:text-dgb-400">@contact.Name[..1].ToUpper()</span>
                            </div>
                            <span class="text-[10px] font-medium text-slate-500 dark:text-slate-400 truncate max-w-[60px]">@contact.Name</span>
                        </button>
                    }
                </div>
            </div>
        }

        @* Transactions *@
        <div class="slide-up-delay-4">
            <div class="flex items-center justify-between mb-3">
                <h3 class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Recent Transactions</h3>
                @if (isLoadingTx)
                {
                    <div class="w-3 h-3 border-2 border-dgb-500 border-t-transparent rounded-full animate-spin"></div>
                }
            </div>
            @if (transactions.Count == 0)
            {
                <div class="bg-white dark:bg-dgb-900/50 rounded-2xl border border-slate-200/80 dark:border-dgb-800 p-8 text-center card-hover">
                    <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-slate-100 dark:bg-dgb-800 flex items-center justify-center">
                        <svg class="w-6 h-6 text-slate-400 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                    </div>
                    <p class="text-sm font-medium text-slate-500 dark:text-slate-400">No transactions yet</p>
                    <p class="text-xs text-slate-400 dark:text-slate-500 mt-1">Send or receive DGB to get started</p>
                </div>
            }
            else
            {
                <div class="flex flex-col gap-1.5">
                    @foreach (var tx in transactions.Take(10))
                    {
                        var isSent = tx.Direction == TransactionDirection.Sent;
                        <div class="flex items-center gap-3 p-3 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200/80 dark:border-dgb-800 card-hover">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 @(isSent ? "bg-red-50 dark:bg-red-900/20" : "bg-green-50 dark:bg-green-900/20")">
                                <svg class="w-5 h-5 @(isSent ? "text-red-500" : "text-green-500")" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    @if (isSent)
                                    {
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
                                    }
                                    else
                                    {
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
                                    }
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-semibold text-slate-900 dark:text-white">@(isSent ? "Sent" : "Received")</p>
                                <p class="text-xs text-slate-400 dark:text-slate-500 truncate">@tx.Timestamp.ToString("MMM d, h:mm tt")</p>
                            </div>
                            <div class="text-right">
                                <p class="text-sm font-bold @(isSent ? "text-red-500" : "text-green-500")">
                                    @(isSent ? "-" : "+")@tx.AmountDgb.ToString("N4") DGB
                                </p>
                                <p class="text-[10px] text-slate-400">@tx.Confirmations conf</p>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</AuthGuard>

@code {
    [Inject] private AppState AppState { get; set; } = default!;
    private List<Contact> quickContacts = [];
    private WalletBalance balance = new();
    private List<TransactionRecord> transactions = [];
    private bool isLoadingBalance;
    private bool isLoadingTx;

    protected override async Task OnInitializedAsync()
    {
        quickContacts = (await ContactService.GetAllAsync()).Take(6).ToList();

        // Sync network setting
        WalletService.SetNetwork(AppState.IsTestnet);

        // Load balance and transactions in background
        _ = LoadBalanceAsync();
        _ = LoadTransactionsAsync();
    }

    private async Task LoadBalanceAsync()
    {
        isLoadingBalance = true;
        StateHasChanged();
        try
        {
            balance = await WalletService.GetBalanceAsync();
        }
        catch { }
        finally
        {
            isLoadingBalance = false;
            StateHasChanged();
        }
    }

    private async Task LoadTransactionsAsync()
    {
        isLoadingTx = true;
        StateHasChanged();
        try
        {
            transactions = await WalletService.GetTransactionHistoryAsync();
        }
        catch { }
        finally
        {
            isLoadingTx = false;
            StateHasChanged();
        }
    }

    private void OnSend() => Nav.NavigateTo("/send");
    private void OnReceive() => Nav.NavigateTo("/receive");
    private void OnContacts() => Nav.NavigateTo("/contacts");
    private void OnScan() { }
    private void SendToContact(Contact c) =>
        Nav.NavigateTo($"/send?address={Uri.EscapeDataString(c.Address)}&name={Uri.EscapeDataString(c.Name)}");
}
