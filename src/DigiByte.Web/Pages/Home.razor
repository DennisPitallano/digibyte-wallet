@page "/"
@implements IAsyncDisposable
@inject NavigationManager Nav
@inject ContactService ContactService
@inject WalletService WalletService
@inject NetworkStatusService Network
@inject MemoryCacheService Cache
@inject IBlockchainService Blockchain
@inject ISecureStorage Storage

<PageTitle>DigiByte Wallet — Self-Custodial DGB Wallet</PageTitle>

<AuthGuard>
    <OnboardingWalkthrough />
    <div class="flex flex-col gap-4" @ontouchstart="OnTouchStart" @ontouchmove="OnTouchMove" @ontouchend="OnTouchEnd">
        @* Pull-to-refresh indicator *@
        @if (pullDistance > 0)
        {
            <div class="flex justify-center -mb-2 transition-all duration-150" style="height: @(Math.Min(pullDistance / 2, 40))px; opacity: @(Math.Min(pullDistance / 80.0, 1))">
                <div class="w-6 h-6 border-2 border-dgb-500 border-t-transparent rounded-full @(isRefreshing ? "animate-spin" : "")"
                     style="transform: rotate(@(pullDistance * 2)deg)"></div>
            </div>
        }

        @* ===== Balance + Actions (normal flow) ===== *@
        <div>
            @* Balance Card *@
            <div class="scale-in relative overflow-hidden rounded-2xl bg-white dark:bg-gradient-to-br dark:from-dgb-900 dark:via-dgb-800 dark:to-dgb-700 border border-dgb-200 dark:border-dgb-700/50 px-5 py-4 text-dgb-900 dark:text-white shadow-lg shadow-gray-200/50 dark:shadow-dgb-900/25">
                <div class="absolute -top-8 -right-8 w-24 h-24 bg-dgb-100/40 dark:bg-dgb-500/20 rounded-full blur-2xl"></div>
                <div class="absolute -bottom-6 -left-6 w-20 h-20 bg-dgb-50/50 dark:bg-dgb-400/10 rounded-full blur-xl"></div>
                <div class="absolute -bottom-4 -right-4 opacity-[0.08] dark:opacity-[0.10] pointer-events-none">
                    <SpinningCoin Size="120" />
                </div>
                <div class="relative">
                    <div class="flex items-center gap-2">
                        <p class="text-xs text-dgb-600 dark:text-dgb-200 font-medium">Total Balance</p>
                        @if (AppState.NetworkMode != "mainnet")
                        {
                            <span class="text-[9px] font-bold text-amber-700 dark:text-amber-300 bg-amber-500/20 px-1.5 py-0.5 rounded-full uppercase">@AppState.NetworkMode</span>
                        }
                        @if (WalletService.ActiveWallet?.WalletType == "xpub")
                        {
                            <span class="text-[9px] font-bold text-sky-700 dark:text-sky-300 bg-sky-500/20 px-1.5 py-0.5 rounded-full uppercase">Watch-Only</span>
                        }
                        @if (isLoadingBalance)
                        {
                            <div class="w-2.5 h-2.5 border-2 border-dgb-500 dark:border-dgb-300 border-t-transparent rounded-full animate-spin"></div>
                        }
                        <div class="flex-1"></div>
                        <button type="button" class="p-1 rounded-lg hover:bg-dgb-200/50 dark:hover:bg-white/10 transition-colors" title="Wallet Info"
                                @onclick="() => showWalletInfo = true">
                            <svg class="w-4 h-4 text-dgb-500 dark:text-dgb-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                            </svg>
                        </button>
                    </div>
                    @if (isLoadingBalance && balance.ConfirmedSatoshis == 0)
                    {
                        <div class="h-9 w-40 skeleton mt-1 rounded-lg" style="background:rgba(0,102,204,0.1)"></div>
                        <div class="h-4 w-24 skeleton mt-1.5 rounded" style="background:rgba(0,102,204,0.08)"></div>
                    }
                    else if (AppState.IsSimpleMode)
                    {
                        <h1 class="text-3xl font-extrabold mt-0.5 tracking-tight">@AppState.FiatSymbol@FormatFiat(fiatValue)</h1>
                        @if (isLoadingPrice)
                        {
                            <div class="h-4 w-28 skeleton mt-1 rounded" style="background:rgba(0,102,204,0.08)"></div>
                        }
                        else
                        {
                            <p class="text-xs text-dgb-500 dark:text-dgb-300 mt-0.5">@balance.TotalDgb.ToString("N8") DGB</p>
                        }
                    }
                    else
                    {
                        <h1 class="text-3xl font-extrabold mt-0.5 tracking-tight">@balance.TotalDgb.ToString("N8") DGB</h1>
                        @if (isLoadingPrice)
                        {
                            <div class="h-4 w-28 skeleton mt-1 rounded" style="background:rgba(0,102,204,0.08)"></div>
                        }
                        else
                        {
                            <p class="text-xs text-dgb-500 dark:text-dgb-300 mt-0.5">@AppState.FiatSymbol@FormatFiat(fiatValue) @AppState.FiatCurrency</p>
                        }
                    }

                    @* Wallet address with copy & QR *@
                    @if (!string.IsNullOrEmpty(receivingAddress))
                    {
                        <div class="flex items-center gap-1.5 mt-2 pt-2 border-t border-dgb-300/30 dark:border-white/10">
                            <span class="text-[11px] font-mono text-dgb-500/70 dark:text-dgb-300/80 truncate flex-1">@TruncateAddress(receivingAddress)</span>
                            <button type="button" class="p-1 rounded hover:bg-dgb-200/50 dark:hover:bg-white/10 transition-colors" title="Copy address"
                                    @onclick="CopyAddress">
                                <svg class="w-3.5 h-3.5 text-dgb-500 dark:text-dgb-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9.75a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" />
                                </svg>
                            </button>
                            <button type="button" class="p-1 rounded hover:bg-dgb-200/50 dark:hover:bg-white/10 transition-colors" title="Show QR code"
                                    @onclick="ShowAddressQr">
                                <svg class="w-3.5 h-3.5 text-dgb-500 dark:text-dgb-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 3.75 9.375v-4.5ZM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5ZM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5Z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 14.625v2.625m3.375-2.625v2.625m-6.75 0h8.25" />
                                </svg>
                            </button>
                        </div>
                    }
                </div>
            </div>

            @* Action Buttons *@
            <div class="flex justify-center gap-5 mt-3">
                <button class="flex flex-col items-center gap-1 group @(isWatchOnly ? "opacity-40 pointer-events-none" : "")" @onclick="OnSend">
                    <div class="w-12 h-12 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center shadow-sm group-active:scale-90 transition-transform">
                        <svg class="w-5 h-5 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
                        </svg>
                    </div>
                    <span class="text-[10px] font-semibold text-slate-500 dark:text-slate-400">Send</span>
                </button>
                <button class="flex flex-col items-center gap-1 group" @onclick="OnReceive">
                    <div class="w-12 h-12 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center shadow-sm group-active:scale-90 transition-transform">
                        <svg class="w-5 h-5 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
                        </svg>
                    </div>
                    <span class="text-[10px] font-semibold text-slate-500 dark:text-slate-400">Receive</span>
                </button>
                <button class="flex flex-col items-center gap-1 group" @onclick="OnContacts">
                    <div class="w-12 h-12 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center shadow-sm group-active:scale-90 transition-transform">
                        <svg class="w-5 h-5 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                        </svg>
                    </div>
                    <span class="text-[10px] font-semibold text-slate-500 dark:text-slate-400">Contacts</span>
                </button>
                <button class="flex flex-col items-center gap-1 group" @onclick="OnScan">
                    <div class="w-12 h-12 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center shadow-sm group-active:scale-90 transition-transform">
                        <svg class="w-5 h-5 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 3.75 9.375v-4.5ZM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5ZM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 13.5 9.375v-4.5Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 14.625v2.625m3.375-2.625v2.625M16.875 20.25h-3.375v-2.625" />
                        </svg>
                    </div>
                    <span class="text-[10px] font-semibold text-slate-500 dark:text-slate-400">Scan</span>
                </button>
                <button class="flex flex-col items-center gap-1 group" @onclick="OnMultisig">
                    <div class="w-12 h-12 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center shadow-sm group-active:scale-90 transition-transform">
                        <svg class="w-5 h-5 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" />
                        </svg>
                    </div>
                    <span class="text-[10px] font-semibold text-slate-500 dark:text-slate-400">Multisig</span>
                </button>
            </div>
        </div>

        @* ===== TX AREA ===== *@
        <div>
            @* Quick Contacts *@
            @if (quickContacts.Count > 0 && !isWatchOnly)
            {
                <div class="mt-3 mb-3">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="text-[11px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Quick Send</h3>
                        <button class="text-[11px] text-dgb-500 font-medium" @onclick="OnContacts">See all</button>
                    </div>
                    <div class="flex gap-3 overflow-x-auto pb-1 thin-scrollbar">
                        @foreach (var c in quickContacts)
                        {
                            var contact = c;
                            <button @key="contact.Address" class="flex flex-col items-center gap-1 min-w-[52px] press-effect"
                                    @onclick="() => SendToContact(contact)">
                                <div class="w-10 h-10 rounded-full bg-dgb-100 dark:bg-dgb-800 flex items-center justify-center">
                                    <span class="text-xs font-bold text-dgb-600 dark:text-dgb-400">@contact.Name[..1].ToUpper()</span>
                                </div>
                                <span class="text-[9px] font-medium text-slate-400 dark:text-slate-500 truncate max-w-[52px]">@contact.Name</span>
                            </button>
                        }
                    </div>
                </div>
            }

            @* BIP44→BIP84 Migration Banner *@
            @if (checkingLegacyBalance)
            {
                <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-2xl p-4 fade-in">
                    <div class="flex items-center gap-3">
                        <div class="w-5 h-5 border-2 border-dgb-500 border-t-transparent rounded-full animate-spin"></div>
                        <p class="text-[11px] text-slate-500 dark:text-slate-400">Checking for funds on previous addresses…</p>
                    </div>
                </div>
            }
            else if (legacyBip44Balance > 0)
            {
                <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-2xl p-4 fade-in">
                    <div class="flex items-start gap-3">
                        <div class="w-8 h-8 rounded-full bg-amber-100 dark:bg-amber-900/40 flex items-center justify-center flex-shrink-0 mt-0.5">
                            <svg class="w-4 h-4 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                            </svg>
                        </div>
                        <div class="flex-1">
                            <p class="text-xs font-semibold text-amber-800 dark:text-amber-300">Funds found on old addresses</p>
                            <p class="text-[10px] text-amber-600 dark:text-amber-400 mt-0.5">
                                @((legacyBip44Balance / 100_000_000m).ToString("N8")) DGB was found on legacy BIP44 addresses from a previous wallet version.
                                Move it to your current wallet?
                            </p>
                            <div class="flex gap-2 mt-2">
                                <button class="px-3 py-1.5 bg-amber-500 hover:bg-amber-600 text-white text-[10px] font-semibold rounded-lg transition-all press-effect disabled:opacity-50 flex items-center gap-1.5"
                                        @onclick="SweepLegacyFunds" disabled="@isSweeping">
                                    @if (isSweeping)
                                    {
                                        <div class="w-3 h-3 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                                        <span>Moving funds…</span>
                                    }
                                    else
                                    {
                                        <span>Move to wallet</span>
                                    }
                                </button>
                                @if (!isSweeping)
                                {
                                    <button class="px-3 py-1.5 text-amber-600 dark:text-amber-400 text-[10px] font-medium hover:underline"
                                            @onclick="DismissLegacyBanner">
                                        Dismiss
                                    </button>
                                }
                            </div>
                            @if (isSweeping)
                            {
                                <p class="text-[10px] text-amber-600 dark:text-amber-400 mt-1.5">Building and broadcasting transaction…</p>
                            }
                            @if (sweepError != null)
                            {
                                <p class="text-[10px] text-red-500 mt-1">@sweepError</p>
                            }
                        </div>
                    </div>
                </div>
            }

            @* Transaction Header *@
            <div class="flex items-center justify-between mt-2 mb-2">
                <h3 class="text-[11px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Transactions</h3>
                @if (isLoadingTx)
                {
                    <div class="w-2.5 h-2.5 border-2 border-dgb-500 border-t-transparent rounded-full animate-spin"></div>
                }
            </div>

            @* Transaction List — scrollable *@
            @if (isLoadingTx && transactions.Count == 0)
            {
                @* Skeleton rows while loading *@
                <div class="flex flex-col gap-1">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="flex items-center gap-3 px-3 py-3 rounded-xl">
                            <div class="w-8 h-8 rounded-full skeleton"></div>
                            <div class="flex-1 flex flex-col gap-1.5">
                                <div class="h-3 w-16 skeleton rounded"></div>
                                <div class="h-2.5 w-24 skeleton rounded"></div>
                            </div>
                            <div class="flex flex-col items-end gap-1.5">
                                <div class="h-3 w-20 skeleton rounded"></div>
                                <div class="h-2 w-10 skeleton rounded"></div>
                            </div>
                        </div>
                    }
                </div>
            }
            else if (transactions.Count == 0)
            {
                <div class="bg-white dark:bg-dgb-900/50 rounded-2xl border border-slate-200/80 dark:border-dgb-800 p-6 text-center">
                    <div class="w-10 h-10 mx-auto mb-2 rounded-full @(fetchFailed ? "bg-amber-100 dark:bg-amber-900/20" : "bg-slate-100 dark:bg-dgb-800") flex items-center justify-center">
                        @if (fetchFailed)
                        {
                            <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                            </svg>
                        }
                        else
                        {
                            <svg class="w-5 h-5 text-slate-400 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                            </svg>
                        }
                    </div>
                    @if (fetchFailed)
                    {
                        <p class="text-xs font-medium text-amber-600 dark:text-amber-400">Unable to load data</p>
                        <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-0.5">Pull down to refresh or check your connection</p>
                    }
                    else
                    {
                        <p class="text-xs font-medium text-slate-500 dark:text-slate-400">No transactions yet</p>
                        <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-0.5">Send or receive DGB to get started</p>
                    }
                </div>
            }
            else
            {
                <div id="tx-list" class="overflow-y-auto thin-scrollbar flex flex-col gap-0.5 rounded-xl">
                    <Virtualize Items="@transactions" Context="tx" OverscanCount="5">
                        <div @key="tx.TxId" class="flex items-center gap-3 px-3 py-2.5 bg-white dark:bg-dgb-900/60 rounded-xl border border-slate-100 dark:border-dgb-800/40 cursor-pointer hover:bg-slate-50 dark:hover:bg-dgb-800/40 transition-colors"
                             @onclick="() => OpenTxDetail(tx)">
                            <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 @(tx.Direction == TransactionDirection.Sent ? "bg-red-50 dark:bg-red-900/20" : "bg-green-50 dark:bg-green-900/20")">
                                <svg class="w-4 h-4 @(tx.Direction == TransactionDirection.Sent ? "text-red-500" : "text-green-500")" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                    @if (tx.Direction == TransactionDirection.Sent)
                                    {
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
                                    }
                                    else
                                    {
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
                                    }
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-xs font-semibold text-slate-900 dark:text-white">@(tx.Direction == TransactionDirection.Sent ? "Sent" : "Received")</p>
                                <p class="text-[10px] text-slate-400 dark:text-slate-500">@tx.Timestamp.ToString("MMM d, h:mm tt")</p>
                            </div>
                            <div class="text-right">
                                <p class="text-xs font-bold @(tx.Direction == TransactionDirection.Sent ? "text-red-500" : "text-green-500")">
                                    @(tx.Direction == TransactionDirection.Sent ? "-" : "+")@tx.AmountDgb.ToString("N4") DGB
                                </p>
                                <p class="text-[9px] text-slate-400">@tx.Confirmations conf</p>
                            </div>
                        </div>
                    </Virtualize>
                </div>
            }


        </div>
    </div>

    <QrScannerModal IsOpen="@showScanner" OnScanned="OnQrScanned" OnClosed="() => showScanner = false" />
    <TransactionDetailModal IsOpen="@(selectedTx != null)" Tx="@selectedTx"
        OnClosed="() => selectedTx = null"
        OnAddContact="AddCounterpartyToContacts" />

    @* Wallet Info Modal *@
    @if (showWalletInfo)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm" @onclick="() => showWalletInfo = false">
            <div class="scale-in bg-white dark:bg-dgb-900 rounded-2xl shadow-2xl p-5 mx-4 max-w-xs w-full flex flex-col gap-3"
                 @onclick:stopPropagation="true">
                <div class="flex items-center justify-between">
                    <h3 class="text-sm font-bold text-slate-900 dark:text-white">Wallet Info</h3>
                    <button type="button" class="p-1 rounded-lg hover:bg-slate-100 dark:hover:bg-dgb-800 transition-colors"
                            @onclick="() => showWalletInfo = false">
                        <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>

                @{ var wallet = WalletService.ActiveWallet; }
                @if (wallet != null)
                {
                    <div class="flex flex-col gap-2">
                        <WalletInfoRow Label="Wallet Type"
                            Value="@(wallet.WalletType == "privatekey" ? "Private Key (WIF)" : "HD Wallet (BIP84)")"
                            Hint="@(wallet.WalletType == "privatekey"
                                ? "Imported from a single private key. Has one fixed address — like having one bank account number."
                                : "Hierarchical Deterministic wallet created from a seed phrase. Can generate many addresses from one backup — like having unlimited account numbers from one master key.")" />

                        @if (wallet.WalletType != "privatekey")
                        {
                            <WalletInfoRow Label="HD Path"
                                Value="m/84'/20'/0'"
                                Hint="The derivation path used to generate your addresses. 84 = BIP84 standard (native SegWit), 20 = DigiByte coin type, 0 = first account. This ensures any BIP84-compatible wallet can restore your addresses from the same seed phrase."
                                Mono="true" />
                        }

                        <WalletInfoRow Label="Address Format"
                            Value="@(wallet.WalletType == "privatekey" ? "Legacy + SegWit" : "SegWit (Bech32)")"
                            Hint="@(wallet.WalletType == "privatekey"
                                ? "Your wallet uses both Legacy (D...) and SegWit (dgb1...) addresses. SegWit addresses have lower transaction fees."
                                : "Uses modern SegWit addresses starting with dgb1. These are more efficient and have lower fees than older Legacy addresses starting with D.")" />

                        <WalletInfoRow Label="Network"
                            Value="@AppState.NetworkMode"
                            Hint="Mainnet is the real DigiByte network where DGB has actual value. Testnet is for developers to test without real money."
                            Highlight="true" />

                        <WalletInfoRow Label="Security"
                            Value="Self-Custodial"
                            Hint="Your keys never leave this device. No company or server holds your funds — only you control your wallet. If you lose your seed phrase or private key, nobody can recover it for you." />
                    </div>
                }
            </div>
        </div>
    }

    @* Address QR Code Modal *@
    @if (showAddressQr)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm" @onclick="() => showAddressQr = false">
            <div class="scale-in bg-white dark:bg-dgb-900 rounded-2xl shadow-2xl p-5 mx-4 max-w-xs w-full flex flex-col items-center gap-3"
                 @onclick:stopPropagation="true">
                <h3 class="text-sm font-bold text-slate-900 dark:text-white">Your Receiving Address</h3>
                @if (!string.IsNullOrEmpty(addressQrDataUri))
                {
                    <div class="bg-white rounded-2xl p-3 shadow-inner relative">
                        <img src="@addressQrDataUri" alt="QR Code" class="w-48 h-48 rounded-lg" />
                        <div class="absolute inset-0 flex items-center justify-center">
                            <div class="bg-white rounded-full p-1.5 shadow-md">
                                <DigiLogo Size="32" />
                            </div>
                        </div>
                    </div>
                }
                <p class="text-[11px] font-mono text-slate-500 dark:text-slate-400 text-center break-all leading-relaxed select-all">@receivingAddress</p>
                <div class="flex gap-2 w-full">
                    <button class="flex-1 py-2 text-xs font-semibold rounded-lg bg-dgb-500 text-white hover:bg-dgb-600 transition-colors"
                            @onclick="CopyAddress">Copy</button>
                    <button class="flex-1 py-2 text-xs font-semibold rounded-lg bg-slate-100 dark:bg-dgb-800 text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-dgb-700 transition-colors"
                            @onclick="() => showAddressQr = false">Close</button>
                </div>
            </div>
        </div>
    }
</AuthGuard>

@code {
    [Inject] private AppState AppState { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    private List<Contact> quickContacts = [];
    private WalletBalance balance = new();
    private decimal dgbPrice;
    private decimal fiatValue => balance.TotalDgb * dgbPrice;
    private List<TransactionRecord> transactions = [];
    private bool isLoadingBalance;
    private bool isLoadingTx;
    private bool isLoadingPrice;
    private bool hasCachedData; // true = loaded real data from IndexedDB
    private bool fetchFailed; // true = network fetch errored (not just empty)
    private bool balanceFetchFailed;
    private bool txFetchFailed;
    private string receivingAddress = "";
    private bool showAddressQr;
    private string? addressQrDataUri;
    private bool showWalletInfo;
    private bool isWatchOnly => WalletService.ActiveWallet?.WalletType == "xpub";

    // BIP44→BIP84 migration state
    private long legacyBip44Balance;
    private bool checkingLegacyBalance;
    private bool isSweeping;
    private string? sweepError;
    private bool legacyBannerDismissed;

    // Pull-to-refresh state
    private double pullDistance;
    private double touchStartY;
    private bool isRefreshing;
    private const double RefreshThreshold = 80;

    // IndexedDB cache keys
    private const string CacheKeyBalance = "cache:balance";
    private const string CacheKeyTx = "cache:transactions";
    private const string CacheKeyPrice = "cache:dgbPrice";
    private const string CacheKeyTimestamp = "cache:lastFetch";

    protected override async Task OnInitializedAsync()
    {
        // Reset auto-lock timer on page load
        AppState.ResetLockTimer();

        WalletService.SetNetworkMode(AppState.NetworkMode);

        // Fire all I/O in parallel — UI renders immediately with skeleton states
        var contactsTask = ContactService.GetAllAsync();
        var addressTask = WalletService.IsUnlocked
            ? WalletService.GetReceivingAddressAsync()
            : Task.FromResult("");

        // Try IndexedDB cache first — instant display
        await LoadFromCacheAsync();

        // Check if redirected from a send — force fresh fetch after a short delay
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var forceRefresh = uri.Query.Contains("refresh=1");

        if (forceRefresh)
        {
            // Explorer may take a moment to index the new tx — wait briefly then fetch
            await Task.Delay(2000);
            await FetchAndCacheAsync();
        }
        else if (hasCachedData && !IsCacheStale())
        {
            // Cache is fresh — no network needed, render cached data
        }
        else if (hasCachedData)
        {
            // Cache exists but stale — show cached data now, refresh in background
            _ = FetchAndCacheAsync();
        }
        else
        {
            // No cache at all (first load) — must await network so UI gets data
            await FetchAndCacheAsync();
        }

        // Contacts & address are fast (IndexedDB) — await them
        try { quickContacts = (await contactsTask).Take(6).ToList(); } catch { }
        try { receivingAddress = await addressTask; } catch { }

        // Check for stranded funds on old BIP44 addresses (background, non-blocking).
        // Cutoff: skip after May 10 2026 — by then all users should have migrated.
        if (WalletService.IsUnlocked && WalletService.ActiveWallet?.WalletType == "hd"
            && DateTime.UtcNow < new DateTime(2026, 5, 10, 0, 0, 0, DateTimeKind.Utc))
            _ = CheckLegacyBip44BalanceAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Auto-size tx list + disable page scroll (this page handles its own)
        await JS.InvokeVoidAsync("domHelpers.autoSizeTxList");
    }

    public async ValueTask DisposeAsync()
    {
        // Restore page scroll when leaving this page
        try { await JS.InvokeVoidAsync("domHelpers.restoreScroll"); }
        catch { }
    }

    /// <summary>Load balance, txs, and price from IndexedDB cache for instant display.</summary>
    private async Task LoadFromCacheAsync()
    {
        try
        {
            var balJson = await Storage.GetAsync(CacheKeyBalance);
            if (balJson != null)
            {
                var cached = System.Text.Json.JsonSerializer.Deserialize<WalletBalance>(balJson);
                if (cached != null && (cached.ConfirmedSatoshis > 0 || cached.UnconfirmedSatoshis > 0))
                {
                    balance = cached;
                    hasCachedData = true;
                }
            }

            var priceJson = await Storage.GetAsync(CacheKeyPrice);
            if (priceJson != null && decimal.TryParse(priceJson, System.Globalization.NumberStyles.Any,
                    System.Globalization.CultureInfo.InvariantCulture, out var p) && p > 0)
                dgbPrice = p;

            var txJson = await Storage.GetAsync(CacheKeyTx);
            if (txJson != null)
            {
                var cached = System.Text.Json.JsonSerializer.Deserialize<List<TransactionRecord>>(txJson);
                if (cached != null && cached.Count > 0)
                    transactions = cached;
            }

            if (hasCachedData) StateHasChanged();

            // Load timestamp so IsCacheStale() works on fresh app start
            var tsJson = await Storage.GetAsync(CacheKeyTimestamp);
            if (tsJson != null && long.TryParse(tsJson, out var ticks))
                Cache.Set("lastFetchTime", new DateTime(ticks, DateTimeKind.Utc), TimeSpan.FromMinutes(5));
        }
        catch { }
    }

    private bool IsCacheStale()
    {
        // We don't await the timestamp here — check in-memory cache instead
        if (Cache.TryGet<DateTime>("lastFetchTime", out var ts))
            return (DateTime.UtcNow - ts).TotalMinutes > 2;
        return true; // no timestamp = treat as stale
    }

    /// <summary>Fetch fresh data from network, then persist to IndexedDB.</summary>
    private async Task FetchAndCacheAsync()
    {
        fetchFailed = false;
        balanceFetchFailed = false;
        txFetchFailed = false;
        await Task.WhenAll(LoadBalanceAsync(), LoadTransactionsAsync(), LoadPriceAsync());

        // Mark as failed only if both balance AND tx fetches errored
        fetchFailed = balanceFetchFailed && txFetchFailed;

        // Cache whatever we got (even zeros — a 0 balance is valid data)
        if (!fetchFailed)
            await SaveToCacheAsync();

        StateHasChanged();
    }

    /// <summary>Persist balance, txs, and price to IndexedDB + update timestamp.</summary>
    private async Task SaveToCacheAsync()
    {
        try
        {
            var now = DateTime.UtcNow;
            await Storage.SetAsync(CacheKeyBalance, System.Text.Json.JsonSerializer.Serialize(balance));
            await Storage.SetAsync(CacheKeyTx, System.Text.Json.JsonSerializer.Serialize(transactions));
            if (dgbPrice > 0)
                await Storage.SetAsync(CacheKeyPrice, dgbPrice.ToString(System.Globalization.CultureInfo.InvariantCulture));
            await Storage.SetAsync(CacheKeyTimestamp, now.Ticks.ToString());
            Cache.Set("lastFetchTime", now, TimeSpan.FromMinutes(5));
        }
        catch { }
    }

    private async Task LoadBalanceAsync()
    {
        isLoadingBalance = true;
        try
        {
            balance = await WalletService.GetBalanceAsync();
        }
        catch { balanceFetchFailed = true; }
        finally { isLoadingBalance = false; StateHasChanged(); }
    }

    private async Task LoadPriceAsync()
    {
        isLoadingPrice = true;
        try
        {
            var p = await Cache.GetOrFetchAsync(
                $"price:{AppState.FiatCurrency}",
                () => Blockchain.GetDgbPriceAsync(AppState.FiatCurrency),
                TimeSpan.FromMinutes(5));
            if (p > 0) dgbPrice = p;
        }
        catch { }
        finally { isLoadingPrice = false; StateHasChanged(); }
    }

    private async Task LoadTransactionsAsync()
    {
        isLoadingTx = true;
        try
        {
            transactions = await WalletService.GetTransactionHistoryAsync();
        }
        catch { txFetchFailed = true; }
        finally { isLoadingTx = false; StateHasChanged(); }
    }

    // Transaction detail
    private TransactionRecord? selectedTx;

    private void OpenTxDetail(TransactionRecord tx) => selectedTx = tx;

    private void AddCounterpartyToContacts(string address)
    {
        selectedTx = null;
        Nav.NavigateTo($"/contacts?add={Uri.EscapeDataString(address)}");
    }

    private void OnSend() => Nav.NavigateTo("/send");
    private void OnReceive() => Nav.NavigateTo("/receive");
    private void OnContacts() => Nav.NavigateTo("/contacts");
    private void OnMultisig() => Nav.NavigateTo("/multisig");
    private void OnScan() { showScanner = true; }
    private bool showScanner;

    private void OnQrScanned(string data)
    {
        showScanner = false;
        // Parse digibyte: URI and navigate to send with pre-filled data
        var parsed = DigiByte.Wallet.Models.PaymentRequest.FromUri(data);
        if (parsed != null)
        {
            var url = $"/send?address={Uri.EscapeDataString(parsed.Address)}";
            if (parsed.AmountDgb.HasValue) url += $"&amount={parsed.AmountDgb.Value}";
            Nav.NavigateTo(url);
        }
        else
        {
            Nav.NavigateTo($"/send?address={Uri.EscapeDataString(data.Trim())}");
        }
    }
    private void SendToContact(Contact c) =>
        Nav.NavigateTo($"/send?address={Uri.EscapeDataString(c.Address)}&name={Uri.EscapeDataString(c.Name)}");

    private static string TruncateAddress(string addr) =>
        addr.Length > 16 ? $"{addr[..10]}...{addr[^6..]}" : addr;

    private static string FormatFiat(decimal value)
    {
        if (value == 0) return "0.00";
        var abs = Math.Abs(value);
        if (abs >= 1m) return value.ToString("N2");
        if (abs >= 0.01m) return value.ToString("N4");
        if (abs >= 0.001m) return value.ToString("N5");
        if (abs >= 0.0001m) return value.ToString("N6");
        return value.ToString("N8");
    }

    private async Task CopyAddress()
    {
        if (!string.IsNullOrEmpty(receivingAddress))
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", receivingAddress);
    }

    private void ShowAddressQr()
    {
        if (string.IsNullOrEmpty(receivingAddress)) return;
        if (addressQrDataUri == null)
        {
            using var qrGenerator = new QRCoder.QRCodeGenerator();
            using var qrCodeData = qrGenerator.CreateQrCode(receivingAddress, QRCoder.QRCodeGenerator.ECCLevel.H);
            using var qrCode = new QRCoder.PngByteQRCode(qrCodeData);
            var png = qrCode.GetGraphic(10, [0, 35, 82], [255, 255, 255]);
            addressQrDataUri = $"data:image/png;base64,{Convert.ToBase64String(png)}";
        }
        showAddressQr = true;
    }

    // Pull-to-refresh handlers
    private void OnTouchStart(TouchEventArgs e)
    {
        if (!isRefreshing && e.Touches.Length > 0)
            touchStartY = e.Touches[0].ClientY;
    }

    private void OnTouchMove(TouchEventArgs e)
    {
        if (isRefreshing || e.Touches.Length == 0) return;
        var delta = e.Touches[0].ClientY - touchStartY;
        var newPull = Math.Max(0, delta * 0.5);
        // Only re-render when distance changes by at least 4px
        if (Math.Abs(newPull - pullDistance) < 4) return;
        pullDistance = newPull;
        StateHasChanged();
    }

    private async Task OnTouchEnd(TouchEventArgs e)
    {
        if (pullDistance >= RefreshThreshold && !isRefreshing)
        {
            isRefreshing = true;
            pullDistance = RefreshThreshold;
            StateHasChanged();

            try
            {
                // Force fresh data from network (invalidate in-memory cache)
                Cache.RemoveByPrefix("price");
                await Task.WhenAll(LoadBalanceAsync(), LoadTransactionsAsync(), LoadPriceAsync());
                // Persist fresh data to IndexedDB
                await SaveToCacheAsync();
                quickContacts = (await ContactService.GetAllAsync()).Take(6).ToList();
            }
            catch { /* swallow — balance/tx methods handle their own errors */ }
            finally
            {
                isRefreshing = false;
                pullDistance = 0;
                StateHasChanged();
            }
            return;
        }
        pullDistance = 0;
        StateHasChanged();
    }

    // BIP44→BIP84 migration methods
    private async Task CheckLegacyBip44BalanceAsync()
    {
        if (legacyBannerDismissed) return;
        checkingLegacyBalance = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var (total, _) = await WalletService.ScanLegacyBip44BalanceAsync();
            if (total > 0)
            {
                legacyBip44Balance = total;
            }
        }
        catch { }
        finally
        {
            checkingLegacyBalance = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SweepLegacyFunds()
    {
        isSweeping = true;
        sweepError = null;
        StateHasChanged();

        try
        {
            await WalletService.SweepLegacyBip44FundsAsync();
            legacyBip44Balance = 0;

            // Refresh balance and transactions to show the swept funds
            await FetchAndCacheAsync();
        }
        catch (Exception ex)
        {
            sweepError = ex.Message;
        }
        finally
        {
            isSweeping = false;
            StateHasChanged();
        }
    }

    private void DismissLegacyBanner()
    {
        legacyBip44Balance = 0;
        legacyBannerDismissed = true;
    }
}
