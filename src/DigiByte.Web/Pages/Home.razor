@page "/"
@implements IAsyncDisposable
@inject NavigationManager Nav
@inject ContactService ContactService
@inject WalletService WalletService
@inject FallbackBlockchainService BlockchainApi

<PageTitle>DigiByte Wallet</PageTitle>

<AuthGuard>
    <div class="flex flex-col gap-4">
        @* ===== Balance + Actions (normal flow) ===== *@
        <div>
            @* Demo Banner *@
            @if (BlockchainApi.IsDemoMode)
            {
                <div class="flex items-center gap-2 px-3 py-2 mb-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700/40 rounded-xl">
                    <svg class="w-3.5 h-3.5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126Z" />
                    </svg>
                    <p class="text-[11px] font-medium text-amber-700 dark:text-amber-300">DEMO MODE — Simulated data</p>
                </div>
            }

            @* Balance Card *@
            <div class="scale-in relative overflow-hidden rounded-2xl bg-gradient-to-br from-dgb-900 via-dgb-800 to-dgb-700 px-5 py-4 text-white shadow-lg shadow-dgb-900/25">
                <div class="absolute -top-8 -right-8 w-24 h-24 bg-dgb-500/20 rounded-full blur-2xl"></div>
                <div class="absolute -bottom-6 -left-6 w-20 h-20 bg-dgb-400/10 rounded-full blur-xl"></div>
                <div class="relative">
                    <div class="flex items-center gap-2">
                        <p class="text-xs text-dgb-200 font-medium">Total Balance</p>
                        @if (AppState.NetworkMode != "mainnet")
                        {
                            <span class="text-[9px] font-bold text-amber-300 bg-amber-500/20 px-1.5 py-0.5 rounded-full uppercase">@AppState.NetworkMode</span>
                        }
                        @if (isLoadingBalance)
                        {
                            <div class="w-2.5 h-2.5 border-2 border-dgb-300 border-t-transparent rounded-full animate-spin"></div>
                        }
                    </div>
                    @if (isLoadingBalance && balance.ConfirmedSatoshis == 0)
                    {
                        <div class="h-9 w-40 skeleton mt-1 rounded-lg" style="background:rgba(255,255,255,0.1)"></div>
                        <div class="h-4 w-24 skeleton mt-1.5 rounded" style="background:rgba(255,255,255,0.08)"></div>
                    }
                    else if (AppState.IsSimpleMode)
                    {
                        <h1 class="text-3xl font-extrabold mt-0.5 tracking-tight">$@balance.FiatValue.ToString("N2")</h1>
                        <p class="text-xs text-dgb-300 mt-0.5">@balance.TotalDgb.ToString("N8") DGB</p>
                    }
                    else
                    {
                        <h1 class="text-3xl font-extrabold mt-0.5 tracking-tight">@balance.TotalDgb.ToString("N8") DGB</h1>
                        <p class="text-xs text-dgb-300 mt-0.5">$@balance.FiatValue.ToString("N2") @balance.FiatCurrency</p>
                    }
                </div>
            </div>

            @* Action Buttons *@
            <div class="flex justify-center gap-5 mt-3">
                <button class="flex flex-col items-center gap-1 group" @onclick="OnSend">
                    <div class="w-12 h-12 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center shadow-sm group-active:scale-90 transition-transform">
                        <svg class="w-5 h-5 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
                        </svg>
                    </div>
                    <span class="text-[10px] font-semibold text-slate-500 dark:text-slate-400">Send</span>
                </button>
                <button class="flex flex-col items-center gap-1 group" @onclick="OnReceive">
                    <div class="w-12 h-12 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center shadow-sm group-active:scale-90 transition-transform">
                        <svg class="w-5 h-5 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
                        </svg>
                    </div>
                    <span class="text-[10px] font-semibold text-slate-500 dark:text-slate-400">Receive</span>
                </button>
                <button class="flex flex-col items-center gap-1 group" @onclick="OnContacts">
                    <div class="w-12 h-12 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center shadow-sm group-active:scale-90 transition-transform">
                        <svg class="w-5 h-5 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                        </svg>
                    </div>
                    <span class="text-[10px] font-semibold text-slate-500 dark:text-slate-400">Contacts</span>
                </button>
                <button class="flex flex-col items-center gap-1 group" @onclick="OnScan">
                    <div class="w-12 h-12 rounded-2xl bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 flex items-center justify-center shadow-sm group-active:scale-90 transition-transform">
                        <svg class="w-5 h-5 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 3.75 9.375v-4.5ZM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5ZM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 13.5 9.375v-4.5Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 14.625v2.625m3.375-2.625v2.625M16.875 20.25h-3.375v-2.625" />
                        </svg>
                    </div>
                    <span class="text-[10px] font-semibold text-slate-500 dark:text-slate-400">Scan</span>
                </button>
            </div>
        </div>

        @* ===== TX AREA ===== *@
        <div>
            @* Quick Contacts *@
            @if (quickContacts.Count > 0)
            {
                <div class="mt-3 mb-3">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="text-[11px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Quick Send</h3>
                        <button class="text-[11px] text-dgb-500 font-medium" @onclick="OnContacts">See all</button>
                    </div>
                    <div class="flex gap-3 overflow-x-auto pb-1 thin-scrollbar">
                        @foreach (var c in quickContacts)
                        {
                            var contact = c;
                            <button class="flex flex-col items-center gap-1 min-w-[52px] press-effect"
                                    @onclick="() => SendToContact(contact)">
                                <div class="w-10 h-10 rounded-full bg-dgb-100 dark:bg-dgb-800 flex items-center justify-center">
                                    <span class="text-xs font-bold text-dgb-600 dark:text-dgb-400">@contact.Name[..1].ToUpper()</span>
                                </div>
                                <span class="text-[9px] font-medium text-slate-400 dark:text-slate-500 truncate max-w-[52px]">@contact.Name</span>
                            </button>
                        }
                    </div>
                </div>
            }

            @* Transaction Header *@
            <div class="flex items-center justify-between mt-2 mb-2">
                <h3 class="text-[11px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Transactions</h3>
                @if (isLoadingTx)
                {
                    <div class="w-2.5 h-2.5 border-2 border-dgb-500 border-t-transparent rounded-full animate-spin"></div>
                }
            </div>

            @* Transaction List — scrollable *@
            @if (isLoadingTx && transactions.Count == 0)
            {
                @* Skeleton rows while loading *@
                <div class="flex flex-col gap-1">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="flex items-center gap-3 px-3 py-3 rounded-xl">
                            <div class="w-8 h-8 rounded-full skeleton"></div>
                            <div class="flex-1 flex flex-col gap-1.5">
                                <div class="h-3 w-16 skeleton rounded"></div>
                                <div class="h-2.5 w-24 skeleton rounded"></div>
                            </div>
                            <div class="flex flex-col items-end gap-1.5">
                                <div class="h-3 w-20 skeleton rounded"></div>
                                <div class="h-2 w-10 skeleton rounded"></div>
                            </div>
                        </div>
                    }
                </div>
            }
            else if (transactions.Count == 0)
            {
                <div class="bg-white dark:bg-dgb-900/50 rounded-2xl border border-slate-200/80 dark:border-dgb-800 p-6 text-center">
                    <div class="w-10 h-10 mx-auto mb-2 rounded-full bg-slate-100 dark:bg-dgb-800 flex items-center justify-center">
                        <svg class="w-5 h-5 text-slate-400 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                    </div>
                    <p class="text-xs font-medium text-slate-500 dark:text-slate-400">No transactions yet</p>
                    <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-0.5">Send or receive DGB to get started</p>
                </div>
            }
            else
            {
                <div id="tx-list" class="overflow-y-auto thin-scrollbar flex flex-col gap-0.5 rounded-xl">
                    @foreach (var tx in transactions.Take(50))
                    {
                        var currentTx = tx;
                        var isSent = tx.Direction == TransactionDirection.Sent;
                        <div class="flex items-center gap-3 px-3 py-2.5 bg-white dark:bg-dgb-900/60 rounded-xl border border-slate-100 dark:border-dgb-800/40 cursor-pointer hover:bg-slate-50 dark:hover:bg-dgb-800/40 transition-colors"
                             @onclick="() => OpenTxDetail(currentTx)">
                            <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 @(isSent ? "bg-red-50 dark:bg-red-900/20" : "bg-green-50 dark:bg-green-900/20")">
                                <svg class="w-4 h-4 @(isSent ? "text-red-500" : "text-green-500")" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                    @if (isSent)
                                    {
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
                                    }
                                    else
                                    {
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
                                    }
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-xs font-semibold text-slate-900 dark:text-white">@(isSent ? "Sent" : "Received")</p>
                                <p class="text-[10px] text-slate-400 dark:text-slate-500">@tx.Timestamp.ToString("MMM d, h:mm tt")</p>
                            </div>
                            <div class="text-right">
                                <p class="text-xs font-bold @(isSent ? "text-red-500" : "text-green-500")">
                                    @(isSent ? "-" : "+")@tx.AmountDgb.ToString("N4") DGB
                                </p>
                                <p class="text-[9px] text-slate-400">@tx.Confirmations conf</p>
                            </div>
                        </div>
                    }
                </div>
            }

            @* Advanced Mode: Wallet Info *@
            @if (!AppState.IsSimpleMode)
            {
                <div class="mt-3 bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800 p-3 flex flex-col gap-1.5">
                    <h3 class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Wallet Info</h3>
                    <div class="flex justify-between text-xs">
                        <span class="text-slate-400">HD Path</span>
                        <span class="font-mono text-slate-600 dark:text-slate-300 text-[11px]">m/44'/20'/0'</span>
                    </div>
                    <div class="flex justify-between text-xs">
                        <span class="text-slate-400">Address Type</span>
                        <span class="text-slate-600 dark:text-slate-300">SegWit (Bech32)</span>
                    </div>
                    <div class="flex justify-between text-xs">
                        <span class="text-slate-400">Network</span>
                        <span class="text-dgb-500 font-medium capitalize">@AppState.NetworkMode</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <QrScannerModal IsOpen="@showScanner" OnScanned="OnQrScanned" OnClosed="() => showScanner = false" />
    <TransactionDetailModal IsOpen="@(selectedTx != null)" Tx="@selectedTx"
        OnClosed="() => selectedTx = null"
        OnAddContact="AddCounterpartyToContacts" />
</AuthGuard>

@code {
    [Inject] private AppState AppState { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    private List<Contact> quickContacts = [];
    private WalletBalance balance = new();
    private List<TransactionRecord> transactions = [];
    private bool isLoadingBalance;
    private bool isLoadingTx;

    protected override async Task OnInitializedAsync()
    {
        quickContacts = (await ContactService.GetAllAsync()).Take(6).ToList();
        WalletService.SetNetworkMode(AppState.NetworkMode);
        _ = LoadBalanceAsync();
        _ = LoadTransactionsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Auto-size tx list + disable page scroll (this page handles its own)
        await JS.InvokeVoidAsync("eval", @"
            (function() {
                var main = document.querySelector('main');
                if (main) main.style.overflow = 'hidden';

                var el = document.getElementById('tx-list');
                if (!el) return;
                var rect = el.getBoundingClientRect();
                var navHeight = 64;
                var padding = 16;
                var available = window.innerHeight - rect.top - navHeight - padding;
                if (available > 100) el.style.maxHeight = available + 'px';
            })();
        ");
    }

    public async ValueTask DisposeAsync()
    {
        // Restore page scroll when leaving this page
        try { await JS.InvokeVoidAsync("eval", "var m=document.querySelector('main');if(m)m.style.overflow='';"); }
        catch { }
    }

    private async Task LoadBalanceAsync()
    {
        isLoadingBalance = true; StateHasChanged();
        try { balance = await WalletService.GetBalanceAsync(); } catch { }
        finally { isLoadingBalance = false; StateHasChanged(); }
    }

    private async Task LoadTransactionsAsync()
    {
        isLoadingTx = true; StateHasChanged();
        try { transactions = await WalletService.GetTransactionHistoryAsync(); } catch { }
        finally { isLoadingTx = false; StateHasChanged(); }
    }

    // Transaction detail
    private TransactionRecord? selectedTx;

    private void OpenTxDetail(TransactionRecord tx) => selectedTx = tx;

    private void AddCounterpartyToContacts(string address)
    {
        selectedTx = null;
        Nav.NavigateTo($"/contacts?add={Uri.EscapeDataString(address)}");
    }

    private void OnSend() => Nav.NavigateTo("/send");
    private void OnReceive() => Nav.NavigateTo("/receive");
    private void OnContacts() => Nav.NavigateTo("/contacts");
    private void OnScan() { showScanner = true; }
    private bool showScanner;

    private void OnQrScanned(string data)
    {
        showScanner = false;
        // Parse digibyte: URI and navigate to send with pre-filled data
        var parsed = DigiByte.Wallet.Models.PaymentRequest.FromUri(data);
        if (parsed != null)
        {
            var url = $"/send?address={Uri.EscapeDataString(parsed.Address)}";
            if (parsed.AmountDgb.HasValue) url += $"&amount={parsed.AmountDgb.Value}";
            Nav.NavigateTo(url);
        }
        else
        {
            Nav.NavigateTo($"/send?address={Uri.EscapeDataString(data.Trim())}");
        }
    }
    private void SendToContact(Contact c) =>
        Nav.NavigateTo($"/send?address={Uri.EscapeDataString(c.Address)}&name={Uri.EscapeDataString(c.Name)}");
}
