    @* Wallet Picker Bottom Sheet *@
    <WalletPickerSheet IsOpen="@showWalletPicker"
                       OnClose="() => showWalletPicker = false"
                       OnWalletSelected="OnWalletSwitched"
                       Wallets="@allWallets"
                       ActiveWalletId="@(WalletService.ActiveWallet?.Id)" />
</AuthGuard>

@code {
    [Inject] private AppState AppState { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    private List<Contact> quickContacts = [];
    private WalletBalance balance = new();
    private decimal dgbPrice;
    private decimal fiatValue => balance.TotalDgb * dgbPrice;
    private List<TransactionRecord> transactions = [];
    private bool isLoadingBalance;
    private bool isLoadingTx;
    private bool isLoadingPrice;
    private bool hasCachedData; // true = loaded real data from IndexedDB
    private bool fetchFailed; // true = network fetch errored (not just empty)
    private bool balanceFetchFailed;
    private bool txFetchFailed;
    private string receivingAddress = "";
    private bool showAddressQr;
    private string? addressQrDataUri;
    private bool showWalletInfo;
    private bool isWatchOnly => WalletService.ActiveWallet?.WalletType == "xpub";
    private bool showWalletPicker;
    private List<WalletInfo> allWallets = [];

    // Pull-to-refresh state
    private double pullDistance;
    private double touchStartY;
    private bool isRefreshing;
    private const double RefreshThreshold = 80;

    // Card carousel state
    private int activeCardIndex;
    private double touchStartX;
    private double cardSwipeOffset;
    private string swipeDirection = "";
    private bool isCardAnimating;
    private const double SwipeThreshold = 60;

    // IndexedDB cache keys
    private const string CacheKeyPrice = "cache:dgbPrice";

    private string ActiveWalletId => WalletService.ActiveWallet?.Id ?? "";
    private string CacheKeyBalance => $"cache:balance:{ActiveWalletId}";
    private string CacheKeyTx => $"cache:transactions:{ActiveWalletId}";
    private string CacheKeyTimestamp => $"cache:lastFetch:{ActiveWalletId}";

    protected override async Task OnInitializedAsync()
    {
        // Reset auto-lock timer on page load
        AppState.ResetLockTimer();

        WalletService.SetNetworkMode(AppState.NetworkMode);

        // Load wallet list for switcher
        try { allWallets = await WalletService.GetAllWalletsAsync(); } catch { }
        activeCardIndex = allWallets.FindIndex(w => w.Id == WalletService.ActiveWallet?.Id);
        if (activeCardIndex < 0) activeCardIndex = 0;

        // Fire all I/O in parallel — UI renders immediately with skeleton states
        var contactsTask = ContactService.GetAllWithWalletsAsync(WalletService);
        var addressTask = WalletService.IsUnlocked
            ? WalletService.GetReceivingAddressAsync()
            : Task.FromResult("");

        // Try IndexedDB cache first — instant display
        await LoadFromCacheAsync();

        // Check if redirected from a send — force fresh fetch after a short delay
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var forceRefresh = uri.Query.Contains("refresh=1");

        if (forceRefresh)
        {
            // Explorer may take a moment to index the new tx — wait briefly then fetch
            await Task.Delay(2000);
            await FetchAndCacheAsync();
        }
        else if (hasCachedData && !IsCacheStale())
        {
            // Cache is fresh — no network needed, render cached data
        }
        else if (hasCachedData)
        {
            // Cache exists but stale — show cached data now, refresh in background
            _ = FetchAndCacheAsync();
        }
        else
        {
            // No cache at all (first load) — must await network so UI gets data
            await FetchAndCacheAsync();
        }

        // Contacts & address are fast (IndexedDB) — await them
        try { quickContacts = (await contactsTask).Take(6).ToList(); } catch { }
        try { receivingAddress = await addressTask; } catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Auto-size tx list + disable page scroll (this page handles its own)
        await JS.InvokeVoidAsync("domHelpers.autoSizeTxList");
    }

    public async ValueTask DisposeAsync()
    {
        // Stop pending-tx confirmation poller
        if (_confirmationPollTimer != null)
        {
            await _confirmationPollTimer.DisposeAsync();
            _confirmationPollTimer = null;
        }
        // Restore page scroll when leaving this page
        try { await JS.InvokeVoidAsync("domHelpers.restoreScroll"); }
        catch { }
    }

    // ── Pending-transaction confirmation polling ────────────────────────────

    private System.Threading.Timer? _confirmationPollTimer;

    /// <summary>
    /// Starts a 15-second repeating timer that re-fetches confirmations for any
    /// unconfirmed transactions, mirroring DGB's ~15-second block time so the UI
    /// updates automatically without a manual pull-to-refresh.
    /// </summary>
    private void StartConfirmationPoller()
    {
        if (_confirmationPollTimer != null) return; // already running
        _confirmationPollTimer = new System.Threading.Timer(
            async _ => await PollPendingConfirmationsAsync(),
            null,
            dueTime: TimeSpan.FromSeconds(15),
            period: TimeSpan.FromSeconds(15));
    }

    private void StopConfirmationPoller()
    {
        _confirmationPollTimer?.Dispose();
        _confirmationPollTimer = null;
    }

    private async Task PollPendingConfirmationsAsync()
    {
        try
        {
            var hasPending = transactions.Any(t => t.Confirmations < 6);
            if (!hasPending)
            {
                StopConfirmationPoller();
                return;
            }

            TxTracker.SetActiveWallet(ActiveWalletId);
            await TxTracker.UpdateConfirmationsAsync(Blockchain);
            var updated = await TxTracker.GetAllAsync();

            // Merge updated confirmations into the current list
            foreach (var tx in transactions)
            {
                var fresh = updated.FirstOrDefault(u => u.TxId == tx.TxId);
                if (fresh != null && fresh.Confirmations != tx.Confirmations)
                    tx.Confirmations = fresh.Confirmations;
            }

            await InvokeAsync(StateHasChanged);

            if (!transactions.Any(t => t.Confirmations < 6))
                StopConfirmationPoller();
        }
        catch { /* ignore transient errors — will retry next interval */ }
    }

    /// <summary>Load balance, txs, and price from IndexedDB cache for instant display.</summary>
    private async Task LoadFromCacheAsync()
    {
        try
        {
            var balJson = await Storage.GetAsync(CacheKeyBalance);
            if (balJson != null)
            {
                var cached = System.Text.Json.JsonSerializer.Deserialize<WalletBalance>(balJson);
                if (cached != null)
                {
                    balance = cached;
                    hasCachedData = true;
                }
            }

            var priceJson = await Storage.GetAsync(CacheKeyPrice);
            if (priceJson != null && decimal.TryParse(priceJson, System.Globalization.NumberStyles.Any,
                    System.Globalization.CultureInfo.InvariantCulture, out var p) && p > 0)
                dgbPrice = p;

            var txJson = await Storage.GetAsync(CacheKeyTx);
            if (txJson != null)
            {
                var cached = System.Text.Json.JsonSerializer.Deserialize<List<TransactionRecord>>(txJson);
                if (cached != null && cached.Count > 0)
                    transactions = cached;
            }

            if (hasCachedData) StateHasChanged();

            // Load timestamp so IsCacheStale() works on fresh app start
            var tsJson = await Storage.GetAsync(CacheKeyTimestamp);
            if (tsJson != null && long.TryParse(tsJson, out var ticks))
                Cache.Set($"lastFetchTime:{ActiveWalletId}", new DateTime(ticks, DateTimeKind.Utc), TimeSpan.FromMinutes(10));
        }
        catch { }
    }

    private bool IsCacheStale()
    {
        // We don't await the timestamp here — check in-memory cache instead
        if (Cache.TryGet<DateTime>($"lastFetchTime:{ActiveWalletId}", out var ts))
            return (DateTime.UtcNow - ts).TotalMinutes > 5;
        return true; // no timestamp = treat as stale
    }

    /// <summary>Fetch fresh data from network, then persist to IndexedDB.</summary>
    private async Task FetchAndCacheAsync()
    {
        // Guard against stale results when user switches wallets during a background fetch
        var walletIdAtStart = ActiveWalletId;

        fetchFailed = false;
        balanceFetchFailed = false;
        txFetchFailed = false;
        await Task.WhenAll(LoadBalanceAsync(), LoadTransactionsAsync());

        // Abort if user switched wallets while we were fetching
        if (ActiveWalletId != walletIdAtStart) return;

        // Only fetch price if we have a balance to convert
        if (!balanceFetchFailed && balance.TotalDgb > 0)
            await LoadPriceAsync();

        // Abort if user switched wallets while we were fetching
        if (ActiveWalletId != walletIdAtStart) return;

        // Mark as failed only if both balance AND tx fetches errored
        fetchFailed = balanceFetchFailed && txFetchFailed;

        // Cache whatever we got (even zeros — a 0 balance is valid data)
        if (!fetchFailed)
            await SaveToCacheAsync();

        StateHasChanged();
    }

    /// <summary>Persist balance, txs, and price to IndexedDB + update timestamp.</summary>
    private async Task SaveToCacheAsync()
    {
        try
        {
            var now = DateTime.UtcNow;
            await Storage.SetAsync(CacheKeyBalance, System.Text.Json.JsonSerializer.Serialize(balance));
            await Storage.SetAsync(CacheKeyTx, System.Text.Json.JsonSerializer.Serialize(transactions));
            if (dgbPrice > 0)
                await Storage.SetAsync(CacheKeyPrice, dgbPrice.ToString(System.Globalization.CultureInfo.InvariantCulture));
            await Storage.SetAsync(CacheKeyTimestamp, now.Ticks.ToString());
            Cache.Set($"lastFetchTime:{ActiveWalletId}", now, TimeSpan.FromMinutes(10));
        }
        catch { }
    }

    private async Task LoadBalanceAsync()
    {
        isLoadingBalance = true;
        try
        {
            balance = await WalletService.GetBalanceAsync();
        }
        catch { balanceFetchFailed = true; }
        finally { isLoadingBalance = false; StateHasChanged(); }
    }

    private async Task LoadPriceAsync()
    {
        isLoadingPrice = true;
        try
        {
            var p = await Cache.GetOrFetchAsync(
                $"price:{AppState.FiatCurrency}",
                () => Blockchain.GetDgbPriceAsync(AppState.FiatCurrency),
                TimeSpan.FromMinutes(5));
            if (p > 0) dgbPrice = p;
        }
        catch { }
        finally { isLoadingPrice = false; StateHasChanged(); }
    }

    private async Task LoadTransactionsAsync()
    {
        isLoadingTx = true;
        try
        {
            transactions = await WalletService.GetTransactionHistoryAsync();

            // Start poller if any txs are still under 6 confirmations
            if (transactions.Any(t => t.Confirmations < 6))
                StartConfirmationPoller();
            else
                StopConfirmationPoller();
        }
        catch { txFetchFailed = true; }
        finally { isLoadingTx = false; StateHasChanged(); }
    }

    // Transaction detail
    private TransactionRecord? selectedTx;

    private void OpenTxDetail(TransactionRecord tx) => selectedTx = tx;

    private void AddCounterpartyToContacts(string address)
    {
        selectedTx = null;
        Nav.NavigateTo($"/contacts?add={Uri.EscapeDataString(address)}");
    }

    private void OnSend() => Nav.NavigateTo("/send");
    private void OnReceive() => Nav.NavigateTo("/receive");
    private void OnContacts() => Nav.NavigateTo("/contacts");
    private void OnMultisig() => Nav.NavigateTo("/multisig");
    private void OnConsolidate() => Nav.NavigateTo("/consolidate");
    private void OnScan() { showScanner = true; }
    private static void OnActionTouchStart(TouchEventArgs e) { /* stop propagation only */ }

    private ElementReference actionScrollRef;
    private int actionPage;

    private async Task OnActionTouchEnd(TouchEventArgs e)
    {
        // Small delay for snap-scroll to settle
        await Task.Delay(150);
        try
        {
            var page = await JS.InvokeAsync<int>("domHelpers.getScrollPage", actionScrollRef);
            if (page != actionPage)
            {
                actionPage = page;
                StateHasChanged();
            }
        }
        catch { }
    }
    private bool showScanner;

    private void OnQrScanned(string data)
    {
        showScanner = false;
        // Parse digibyte: URI and navigate to send with pre-filled data
        var parsed = DigiByte.Wallet.Models.PaymentRequest.FromUri(data);
        if (parsed != null)
        {
            var url = $"/send?address={Uri.EscapeDataString(parsed.Address)}";
            if (parsed.AmountDgb.HasValue) url += $"&amount={parsed.AmountDgb.Value}";
            Nav.NavigateTo(url);
        }
        else
        {
            Nav.NavigateTo($"/send?address={Uri.EscapeDataString(data.Trim())}");
        }
    }
    private void SendToContact(Contact c) =>
        Nav.NavigateTo($"/send?address={Uri.EscapeDataString(c.Address)}&name={Uri.EscapeDataString(c.Name)}");

    private static string TruncateAddress(string addr) =>
        addr.Length > 16 ? $"{addr[..10]}...{addr[^6..]}" : addr;

    private static string FormatFiat(decimal value)
    {
        if (value == 0) return "0.00";
        var abs = Math.Abs(value);
        if (abs >= 1m) return value.ToString("N2");
        if (abs >= 0.01m) return value.ToString("N4");
        if (abs >= 0.001m) return value.ToString("N5");
        if (abs >= 0.0001m) return value.ToString("N6");
        return value.ToString("N8");
    }

    private async Task CopyAddress()
    {
        if (!string.IsNullOrEmpty(receivingAddress))
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", receivingAddress);
    }

    private void ShowAddressQr()
    {
        if (string.IsNullOrEmpty(receivingAddress)) return;
        if (addressQrDataUri == null)
        {
            using var qrGenerator = new QRCoder.QRCodeGenerator();
            using var qrCodeData = qrGenerator.CreateQrCode(receivingAddress, QRCoder.QRCodeGenerator.ECCLevel.H);
            using var qrCode = new QRCoder.PngByteQRCode(qrCodeData);
            var png = qrCode.GetGraphic(10, [0, 35, 82], [255, 255, 255]);
            addressQrDataUri = $"data:image/png;base64,{Convert.ToBase64String(png)}";
        }
        showAddressQr = true;
    }

    // Touch handlers (pull-to-refresh + card swipe)
    private void OnTouchStart(TouchEventArgs e)
    {
        if (e.Touches.Length > 0)
        {
            touchStartY = e.Touches[0].ClientY;
            touchStartX = e.Touches[0].ClientX;
            swipeDirection = "";
        }
    }

    private async Task ManualRefreshAsync()
    {
        if (isRefreshing) return;
        isRefreshing = true;
        StateHasChanged();

        try
        {
            Cache.RemoveByPrefix("price");
            await Task.WhenAll(LoadBalanceAsync(), LoadTransactionsAsync());
            if (balance.TotalDgb > 0) await LoadPriceAsync();
            await SaveToCacheAsync();
            quickContacts = (await ContactService.GetAllWithWalletsAsync(WalletService)).Take(6).ToList();
        }
        catch { }
        finally
        {
            isRefreshing = false;
            StateHasChanged();
        }
    }

    private void OnTouchMove(TouchEventArgs e)
    {
        if (isRefreshing || isCardAnimating || e.Touches.Length == 0) return;
        var deltaY = e.Touches[0].ClientY - touchStartY;
        var deltaX = e.Touches[0].ClientX - touchStartX;

        if (swipeDirection == "")
        {
            if (Math.Abs(deltaX) > 10 || Math.Abs(deltaY) > 10)
                swipeDirection = Math.Abs(deltaX) > Math.Abs(deltaY) ? "horizontal" : "vertical";
            else return;
        }

        if (swipeDirection == "horizontal" && allWallets.Count > 1)
        {
            cardSwipeOffset = deltaX * 0.5;
            StateHasChanged();
        }
        else if (swipeDirection == "vertical")
        {
            var newPull = Math.Max(0, deltaY * 0.5);
            if (Math.Abs(newPull - pullDistance) < 4) return;
            pullDistance = newPull;
            StateHasChanged();
        }
    }

    private async Task OnTouchEnd(TouchEventArgs e)
    {
        if (swipeDirection == "horizontal" && allWallets.Count > 1)
        {
            if (Math.Abs(cardSwipeOffset) >= SwipeThreshold)
            {
                var direction = cardSwipeOffset < 0 ? 1 : -1;
                await SwipeToWallet(direction);
            }
            else
            {
                isCardAnimating = true;
                cardSwipeOffset = 0;
                StateHasChanged();
                await Task.Delay(300);
                isCardAnimating = false;
            }
            swipeDirection = "";
            return;
        }

        if (pullDistance >= RefreshThreshold && !isRefreshing)
        {
            isRefreshing = true;
            pullDistance = RefreshThreshold;
            StateHasChanged();

            try
            {
                Cache.RemoveByPrefix("price");
                await Task.WhenAll(LoadBalanceAsync(), LoadTransactionsAsync());
                if (balance.TotalDgb > 0) await LoadPriceAsync();
                await SaveToCacheAsync();
                quickContacts = (await ContactService.GetAllWithWalletsAsync(WalletService)).Take(6).ToList();
            }
            catch { }
            finally
            {
                isRefreshing = false;
                pullDistance = 0;
                StateHasChanged();
            }
            return;
        }
        pullDistance = 0;
        StateHasChanged();
    }

    private async Task SwipeToWallet(int direction)
    {
        var newIndex = (activeCardIndex + direction + allWallets.Count) % allWallets.Count;
        var targetWallet = allWallets[newIndex];

        if (!WalletService.IsWalletUnlockedInSession(targetWallet.Id))
        {
            isCardAnimating = true;
            cardSwipeOffset = 0;
            StateHasChanged();
            await Task.Delay(200);
            isCardAnimating = false;
            Nav.NavigateTo($"/unlock?walletId={targetWallet.Id}");
            return;
        }

        // Animate card out
        isCardAnimating = true;
        cardSwipeOffset = direction > 0 ? -350 : 350;
        StateHasChanged();
        await Task.Delay(200);

        // Switch wallet + update index
        activeCardIndex = newIndex;
        await WalletService.SwitchWalletAsync(targetWallet.Id);
        AppState.ActiveWalletName = targetWallet.Name;
        AppState.NotifyStateChanged();

        balance = new WalletBalance();
        transactions = [];
        receivingAddress = "";
        addressQrDataUri = null;
        hasCachedData = false;
        quickContacts = (await ContactService.GetAllWithWalletsAsync(WalletService)).Take(6).ToList();

        // Position on opposite side (no animation)
        isCardAnimating = false;
        cardSwipeOffset = direction > 0 ? 350 : -350;
        StateHasChanged();
        await Task.Delay(20);

        // Animate in
        isCardAnimating = true;
        cardSwipeOffset = 0;
        StateHasChanged();
        await Task.Delay(300);
        isCardAnimating = false;
        StateHasChanged();

        // Load data for new wallet
        await LoadFromCacheAsync();
        WalletService.SetNetworkMode(AppState.NetworkMode);
        try { receivingAddress = await WalletService.GetReceivingAddressAsync(); } catch { }

        if (hasCachedData && !IsCacheStale())
        {
            StateHasChanged();
        }
        else if (hasCachedData)
        {
            StateHasChanged();
            _ = FetchAndCacheAsync();
        }
        else
        {
            await FetchAndCacheAsync();
        }
    }

    private async Task OnWalletSwitched(WalletInfo wallet)
    {
        if (wallet.Id == WalletService.ActiveWallet?.Id) return;

        if (WalletService.IsWalletUnlockedInSession(wallet.Id))
        {
            // Already unlocked — switch instantly
            await WalletService.SwitchWalletAsync(wallet.Id);
            AppState.ActiveWalletName = wallet.Name;
            AppState.NotifyStateChanged();

            activeCardIndex = allWallets.FindIndex(w => w.Id == wallet.Id);
            if (activeCardIndex < 0) activeCardIndex = 0;

            // Reset UI state for the new wallet
            balance = new WalletBalance();
            transactions = [];
            receivingAddress = "";
            addressQrDataUri = null;
            hasCachedData = false;
            quickContacts = (await ContactService.GetAllWithWalletsAsync(WalletService)).Take(6).ToList();

            // Load cache for the new wallet (keys are now wallet-scoped)
            await LoadFromCacheAsync();

            // Refresh data for the new wallet
            WalletService.SetNetworkMode(AppState.NetworkMode);
            try { receivingAddress = await WalletService.GetReceivingAddressAsync(); } catch { }

            if (hasCachedData && !IsCacheStale())
            {
                // Cache is fresh — no network fetch needed
                StateHasChanged();
            }
            else if (hasCachedData)
            {
                // Cache exists but stale — show cached, refresh in background
                StateHasChanged();
                _ = FetchAndCacheAsync();
            }
            else
            {
                // No cache — must fetch
                await FetchAndCacheAsync();
            }
        }
        else
        {
            // Needs PIN — redirect to unlock page
            Nav.NavigateTo($"/unlock?walletId={wallet.Id}");
        }
    }
}
