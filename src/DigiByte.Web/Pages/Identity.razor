@page "/identity"
@inject WalletService WalletService
@inject HttpClient Http
@inject NavigationManager Nav
@inject IConfiguration Config
@inject ISecureStorage Storage

<PageTitle>Digi-ID</PageTitle>

<div class="flex flex-col gap-4">
    <div class="flex items-center justify-between slide-up">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Digi-ID</h2>
        @{ var idWalletColor = WalletService.ActiveWallet?.Color ?? "#0066FF"; }
        <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-white/5 border border-white/10">
            <div class="w-2 h-2 rounded-full" style="background-color: @idWalletColor;"></div>
            <span class="text-[10px] font-medium text-slate-400 dark:text-slate-500 truncate max-w-[100px]">@(WalletService.ActiveWallet?.Name ?? "Wallet")</span>
        </div>
    </div>

    @* How it works *@
    <div class="slide-up-delay-1 bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200 dark:border-dgb-800 p-4 flex flex-col gap-3">
        <h3 class="text-sm font-semibold text-slate-900 dark:text-white">Passwordless Login</h3>
        <div class="flex flex-col gap-2">
            <div class="flex items-start gap-3">
                <div class="w-7 h-7 rounded-lg bg-dgb-50 dark:bg-dgb-800 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <span class="text-xs font-bold text-dgb-500">1</span>
                </div>
                <p class="text-sm text-slate-600 dark:text-slate-400">Website shows a Digi-ID QR code</p>
            </div>
            <div class="flex items-start gap-3">
                <div class="w-7 h-7 rounded-lg bg-dgb-50 dark:bg-dgb-800 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <span class="text-xs font-bold text-dgb-500">2</span>
                </div>
                <p class="text-sm text-slate-600 dark:text-slate-400">You scan it with your wallet</p>
            </div>
            <div class="flex items-start gap-3">
                <div class="w-7 h-7 rounded-lg bg-dgb-50 dark:bg-dgb-800 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <span class="text-xs font-bold text-dgb-500">3</span>
                </div>
                <p class="text-sm text-slate-600 dark:text-slate-400">Your wallet signs the challenge &mdash; you're logged in!</p>
            </div>
        </div>
    </div>

    @* Scan / Paste URI *@
    <div class="slide-up-delay-2 flex flex-col gap-3">
        <button class="w-full py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 transition-all press-effect flex items-center justify-center gap-2"
                @onclick="ScanDigiId">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 3.75 9.375v-4.5Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 13.5 9.375v-4.5Z" />
            </svg>
            Scan Digi-ID QR Code
        </button>

        <div class="flex items-center gap-3">
            <div class="flex-1 h-px bg-slate-200 dark:bg-dgb-800"></div>
            <span class="text-xs text-slate-400 dark:text-slate-500 font-medium">or paste URI</span>
            <div class="flex-1 h-px bg-slate-200 dark:bg-dgb-800"></div>
        </div>

        <div class="flex gap-2">
            <input type="text" @bind="digiIdUri" placeholder="digiid://..."
                   class="flex-1 px-4 py-2.5 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl text-sm font-mono text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
            <button class="px-4 py-2.5 bg-dgb-500 hover:bg-dgb-600 text-white text-sm font-semibold rounded-xl press-effect disabled:opacity-50"
                    @onclick="AuthenticateAsync" disabled="@(string.IsNullOrWhiteSpace(digiIdUri) || isAuthenticating)">
                @(isAuthenticating ? "..." : "Sign")
            </button>
        </div>

        @if (parseError != null)
        {
            <p class="text-sm text-red-500 font-medium">@parseError</p>
        }
    </div>

    @* Auth confirmation *@
    @if (pendingRequest != null && !isAuthenticating && authResult == AuthResult.None)
    {
        <div class="scale-in bg-white dark:bg-dgb-900 rounded-2xl border-2 border-dgb-300 dark:border-dgb-700 p-5 flex flex-col gap-4 shadow-lg shadow-dgb-500/10">
            <div class="flex flex-col items-center gap-2">
                <div class="w-12 h-12 rounded-full bg-dgb-50 dark:bg-dgb-800 flex items-center justify-center">
                    <svg class="w-6 h-6 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                    </svg>
                </div>
                <h3 class="text-base font-bold text-slate-900 dark:text-white">Authenticate with</h3>
            </div>

            <div class="bg-slate-50 dark:bg-dgb-950 rounded-xl px-4 py-3 border border-slate-200/60 dark:border-dgb-800">
                <p class="text-base font-bold text-slate-900 dark:text-white text-center">@pendingRequest.Domain</p>
                <p class="text-[10px] font-mono text-slate-400 dark:text-slate-500 mt-1 text-center truncate">@pendingRequest.CallbackUrl</p>
            </div>

            @if (pendingRequest.IsUnsecure)
            {
                <div class="flex items-start gap-2 bg-amber-50 dark:bg-amber-900/10 rounded-xl px-3 py-2.5 border border-amber-200/60 dark:border-amber-900/30">
                    <svg class="w-4 h-4 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                    </svg>
                    <p class="text-xs text-amber-700 dark:text-amber-400 leading-relaxed">
                        <b>Insecure connection</b> — This site uses HTTP. Your authentication could be intercepted.
                    </p>
                </div>
            }

            <div class="bg-dgb-50/50 dark:bg-dgb-800/30 rounded-xl p-3">
                <p class="text-[10px] text-slate-500 dark:text-slate-400 leading-relaxed text-center">
                    This will sign a cryptographic challenge proving you own a DigiByte address.
                    No funds will be sent. A site-specific key is used — your main wallet keys are never exposed.
                </p>
            </div>

            <div class="flex gap-3">
                <button class="flex-1 py-3 bg-slate-100 dark:bg-dgb-800 text-slate-700 dark:text-slate-300 text-sm font-semibold rounded-xl press-effect hover:bg-slate-200 dark:hover:bg-dgb-700 transition-colors"
                        @onclick="CancelAuth">Cancel</button>
                <button class="flex-1 py-3 bg-dgb-500 hover:bg-dgb-600 text-white text-sm font-bold rounded-xl press-effect shadow-md shadow-dgb-500/25 transition-all"
                        @onclick="ConfirmAuthAsync">
                    Approve
                </button>
            </div>
        </div>
    }

    @* Signing in progress — step animation *@
    @if (isAuthenticating)
    {
        <div class="scale-in bg-white dark:bg-dgb-900 rounded-2xl border border-slate-200 dark:border-dgb-800 p-5 flex flex-col items-center gap-4 shadow-lg">
            <div class="w-14 h-14 rounded-full bg-dgb-50 dark:bg-dgb-800 flex items-center justify-center">
                <div class="w-7 h-7 border-[3px] border-dgb-500 border-t-transparent rounded-full animate-spin"></div>
            </div>
            <div class="flex flex-col items-center gap-1">
                <p class="text-sm font-bold text-slate-900 dark:text-white">Authenticating…</p>
                <p class="text-xs text-slate-500 dark:text-slate-400">@pendingRequest?.Domain</p>
            </div>

            <div class="w-full flex flex-col gap-2">
                @* Step 1: Signing *@
                <div class="flex items-center gap-3 p-2.5 rounded-lg @(authStep >= 1 ? "bg-dgb-50/50 dark:bg-dgb-800/30" : "opacity-40")">
                    @if (authStep > 1)
                    {
                        <div class="w-6 h-6 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center flex-shrink-0">
                            <svg class="w-3.5 h-3.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                        </div>
                    }
                    else if (authStep == 1)
                    {
                        <div class="w-6 h-6 flex items-center justify-center flex-shrink-0">
                            <div class="w-4 h-4 border-2 border-dgb-500 border-t-transparent rounded-full animate-spin"></div>
                        </div>
                    }
                    else
                    {
                        <div class="w-6 h-6 rounded-full border-2 border-slate-300 dark:border-dgb-700 flex-shrink-0"></div>
                    }
                    <span class="text-xs font-medium @(authStep >= 1 ? "text-slate-700 dark:text-slate-300" : "text-slate-400 dark:text-slate-600")">Signing challenge with your key…</span>
                </div>

                @* Step 2: Sending *@
                <div class="flex items-center gap-3 p-2.5 rounded-lg @(authStep >= 2 ? "bg-dgb-50/50 dark:bg-dgb-800/30" : "opacity-40")">
                    @if (authStep > 2)
                    {
                        <div class="w-6 h-6 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center flex-shrink-0">
                            <svg class="w-3.5 h-3.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                        </div>
                    }
                    else if (authStep == 2)
                    {
                        <div class="w-6 h-6 flex items-center justify-center flex-shrink-0">
                            <div class="w-4 h-4 border-2 border-dgb-500 border-t-transparent rounded-full animate-spin"></div>
                        </div>
                    }
                    else
                    {
                        <div class="w-6 h-6 rounded-full border-2 border-slate-300 dark:border-dgb-700 flex-shrink-0"></div>
                    }
                    <span class="text-xs font-medium @(authStep >= 2 ? "text-slate-700 dark:text-slate-300" : "text-slate-400 dark:text-slate-600")">Sending to @(pendingRequest?.Domain ?? "server")…</span>
                </div>

                @* Step 3: Verifying *@
                <div class="flex items-center gap-3 p-2.5 rounded-lg @(authStep >= 3 ? "bg-dgb-50/50 dark:bg-dgb-800/30" : "opacity-40")">
                    @if (authStep > 3)
                    {
                        <div class="w-6 h-6 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center flex-shrink-0">
                            <svg class="w-3.5 h-3.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                        </div>
                    }
                    else if (authStep == 3)
                    {
                        <div class="w-6 h-6 flex items-center justify-center flex-shrink-0">
                            <div class="w-4 h-4 border-2 border-dgb-500 border-t-transparent rounded-full animate-spin"></div>
                        </div>
                    }
                    else
                    {
                        <div class="w-6 h-6 rounded-full border-2 border-slate-300 dark:border-dgb-700 flex-shrink-0"></div>
                    }
                    <span class="text-xs font-medium @(authStep >= 3 ? "text-slate-700 dark:text-slate-300" : "text-slate-400 dark:text-slate-600")">Verifying server response…</span>
                </div>
            </div>
        </div>
    }

    @* Success *@
    @if (authResult == AuthResult.Success)
    {
        <div class="scale-in bg-green-50 dark:bg-green-900/10 rounded-2xl border border-green-200 dark:border-green-800/30 p-5 flex flex-col items-center gap-3">
            <div class="w-14 h-14 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center check-pop">
                <svg class="w-7 h-7 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
            </div>
            <div class="text-center">
                <p class="text-base font-bold text-green-700 dark:text-green-400">Authenticated!</p>
                <p class="text-sm text-green-600 dark:text-green-500 mt-0.5">You're now logged in to <b>@lastAuthDomain</b></p>
            </div>
            <div class="w-full bg-green-100/50 dark:bg-green-900/20 rounded-xl px-3 py-2 flex flex-col gap-1">
                <div class="flex items-center justify-between">
                    <span class="text-[10px] text-green-600/70 dark:text-green-500/70">Address used</span>
                    <span class="text-[10px] font-mono text-green-700 dark:text-green-400 truncate ml-2 max-w-[200px]">@lastAuthAddress</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-[10px] text-green-600/70 dark:text-green-500/70">Time</span>
                    <span class="text-[10px] text-green-700 dark:text-green-400">@DateTime.Now.ToString("h:mm:ss tt")</span>
                </div>
            </div>
            <button class="text-xs text-green-600 dark:text-green-400 font-medium hover:underline mt-1" @onclick="ResetState">Authenticate another site</button>
        </div>
    }

    @* Failure *@
    @if (authResult == AuthResult.Failed)
    {
        <div class="scale-in bg-red-50 dark:bg-red-900/10 rounded-2xl border border-red-200 dark:border-red-800/30 p-5 flex flex-col items-center gap-3">
            <div class="w-14 h-14 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
                <svg class="w-7 h-7 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
            </div>
            <div class="text-center">
                <p class="text-base font-bold text-red-700 dark:text-red-400">Authentication Failed</p>
                <p class="text-sm text-red-600 dark:text-red-500 mt-0.5">@authErrorTitle</p>
            </div>
            @if (authErrorDetail != null)
            {
                <div class="w-full bg-red-100/50 dark:bg-red-900/20 rounded-xl px-3 py-2.5">
                    <p class="text-[11px] text-red-600/80 dark:text-red-400/80 leading-relaxed">@authErrorDetail</p>
                </div>
            }
            <div class="flex gap-2 w-full">
                <button class="flex-1 py-2.5 bg-slate-100 dark:bg-dgb-800 text-slate-700 dark:text-slate-300 text-sm font-semibold rounded-xl press-effect"
                        @onclick="ResetState">Dismiss</button>
                <button class="flex-1 py-2.5 bg-dgb-500 hover:bg-dgb-600 text-white text-sm font-semibold rounded-xl press-effect"
                        @onclick="RetryAuth">Try Again</button>
            </div>
        </div>
    }

    @* Recent Authentications *@
    @if (authHistory.Count > 0)
    {
        <div class="slide-up-delay-3">
            <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Login History</h3>
                <button class="text-[11px] text-red-400 hover:text-red-500 font-medium transition-colors press-effect"
                        @onclick="ClearHistoryAsync">Clear all</button>
            </div>
            <div class="flex flex-col gap-1.5">
                @foreach (var entry in authHistory)
                {
                    var e = entry;
                    <div class="flex items-center gap-3 p-3 bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800">
                        <div class="w-8 h-8 rounded-full bg-dgb-50 dark:bg-dgb-800 flex items-center justify-center flex-shrink-0">
                            <svg class="w-4 h-4 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3" />
                            </svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-semibold text-slate-900 dark:text-white truncate">@e.Domain</p>
                            <p class="text-[10px] font-mono text-slate-400 dark:text-slate-500 truncate">@TruncateAddress(e.Address)</p>
                        </div>
                        <div class="text-right flex-shrink-0">
                            <p class="text-[10px] text-slate-500 dark:text-slate-400">@FormatRelativeTime(e.Timestamp)</p>
                            <p class="text-[9px] text-slate-300 dark:text-slate-600">@e.Timestamp.ToLocalTime().ToString("MMM d, h:mm tt")</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<QrScannerModal IsOpen="@showScanner" OnScanned="OnQrScanned" OnClosed="() => showScanner = false" />

@code {
    private enum AuthResult { None, Success, Failed }

    private const string HistoryStorageKey = "digiid_login_history";
    private const int MaxHistoryEntries = 50;

    private string digiIdUri = "";
    private string? parseError;
    private bool isAuthenticating;
    private int authStep; // 0=idle, 1=signing, 2=sending, 3=verifying
    private AuthResult authResult = AuthResult.None;
    private string? lastAuthDomain;
    private string? lastAuthAddress;
    private string? authErrorTitle;
    private string? authErrorDetail;
    private bool showScanner;
    private DigiByte.Crypto.DigiId.DigiIdRequest? pendingRequest;
    private List<AuthHistoryEntry> authHistory = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadHistoryAsync();
        
        // Auto-populate from query parameter if present
        // Sources: PWA protocol handler (?uri=web+digiid:...) or API redirect (?uri=digiid://...)
        var navUri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(navUri.Query);
        var incomingUri = query["uri"];
        
        if (!string.IsNullOrEmpty(incomingUri))
        {
            // PWA protocol_handlers use "web+digiid" scheme — normalize to "digiid"
            if (incomingUri.StartsWith("web+digiid://", StringComparison.OrdinalIgnoreCase))
                incomingUri = "digiid://" + incomingUri.Substring("web+digiid://".Length);

            if (incomingUri.StartsWith("digiid://", StringComparison.OrdinalIgnoreCase))
            {
                digiIdUri = incomingUri;
                StateHasChanged();
                await Task.Delay(100); // brief delay for UI to render
                await AuthenticateAsync();
            }
        }
    }

    private async Task LoadHistoryAsync()
    {
        try
        {
            var json = await Storage.GetAsync(HistoryStorageKey);
            if (json != null)
                authHistory = System.Text.Json.JsonSerializer.Deserialize<List<AuthHistoryEntry>>(json) ?? [];
        }
        catch { /* non-critical — start fresh if storage fails */ }
    }

    private async Task SaveHistoryAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(authHistory);
            await Storage.SetAsync(HistoryStorageKey, json);
        }
        catch { }
    }

    private async Task ClearHistoryAsync()
    {
        authHistory.Clear();
        await Storage.RemoveAsync(HistoryStorageKey);
    }

    private void ScanDigiId()
    {
        showScanner = true;
    }

    private void OnQrScanned(string value)
    {
        showScanner = false;
        digiIdUri = value;
        StateHasChanged();

        // Auto-parse if it looks like a Digi-ID URI
        if (value.StartsWith("digiid://", StringComparison.OrdinalIgnoreCase))
        {
            _ = AuthenticateAsync();
        }
    }

    private async Task AuthenticateAsync()
    {
        parseError = null;
        authResult = AuthResult.None;

        var request = DigiByte.Crypto.DigiId.DigiIdService.ParseUri(digiIdUri.Trim());
        if (request == null)
        {
            parseError = "Invalid Digi-ID URI. Expected format: digiid://...";
            return;
        }

        pendingRequest = request;
    }

    private void CancelAuth()
    {
        pendingRequest = null;
    }

    private void ResetState()
    {
        authResult = AuthResult.None;
        parseError = null;
        authErrorTitle = null;
        authErrorDetail = null;
        pendingRequest = null;
        digiIdUri = "";
    }

    private async Task RetryAuth()
    {
        authResult = AuthResult.None;
        authErrorTitle = null;
        authErrorDetail = null;

        if (pendingRequest != null)
        {
            await ConfirmAuthAsync();
        }
    }

    private async Task ConfirmAuthAsync()
    {
        if (pendingRequest == null) return;
        isAuthenticating = true;
        authStep = 1;
        parseError = null;
        authResult = AuthResult.None;
        StateHasChanged();

        try
        {
            // Step 1: Sign the URI with site-specific HD key (m/13'/siteIndex'/0'/0)
            var response = await WalletService.SignDigiIdAsync(pendingRequest);

            // Step 2: POST the signed response via API proxy (avoids CORS)
            authStep = 2;
            StateHasChanged();
            await Task.Delay(200); // brief visual pause for step transition

            var apiBase = Config["PriceApiUrl"]?.Replace("/api/price", "") ?? "http://localhost:5007";
            var proxyPayload = new
            {
                callbackUrl = pendingRequest.CallbackUrl,
                address = response.Address,
                uri = response.Uri,
                signature = response.Signature,
            };
            var httpResponse = await Http.PostAsJsonAsync($"{apiBase}/api/digiid/callback", proxyPayload);

            // Step 3: Verify server response
            authStep = 3;
            StateHasChanged();
            await Task.Delay(200);

            if (!httpResponse.IsSuccessStatusCode)
            {
                var body = await httpResponse.Content.ReadAsStringAsync();
                var statusCode = (int)httpResponse.StatusCode;

                authErrorTitle = statusCode switch
                {
                    401 or 403 => $"{pendingRequest.Domain} rejected the signature",
                    404 => $"Authentication endpoint not found on {pendingRequest.Domain}",
                    >= 500 => $"{pendingRequest.Domain} is experiencing server issues",
                    _ => $"{pendingRequest.Domain} returned an error ({statusCode})"
                };
                authErrorDetail = statusCode switch
                {
                    401 or 403 => "The server did not accept the cryptographic signature. This may mean the site doesn't recognize your Digi-ID address or the challenge has expired. Try scanning a fresh QR code.",
                    404 => "The callback URL returned 404. The site may have changed its Digi-ID integration or the QR code may be outdated.",
                    >= 500 => $"The server returned a {statusCode} error. This is a problem on their end — try again in a few minutes.",
                    _ => !string.IsNullOrWhiteSpace(body) ? body : null
                };

                authResult = AuthResult.Failed;
                return;
            }

            // Success
            lastAuthDomain = pendingRequest.Domain;
            lastAuthAddress = response.Address;

            authHistory.Insert(0, new AuthHistoryEntry
            {
                Domain = pendingRequest.Domain,
                Address = response.Address,
                Timestamp = DateTime.UtcNow,
            });

            // Keep last MaxHistoryEntries, then persist
            if (authHistory.Count > MaxHistoryEntries)
                authHistory = authHistory.Take(MaxHistoryEntries).ToList();
            await SaveHistoryAsync();

            pendingRequest = null;
            authResult = AuthResult.Success;
            digiIdUri = "";
        }
        catch (HttpRequestException)
        {
            authErrorTitle = $"Could not reach {pendingRequest?.Domain ?? "server"}";
            authErrorDetail = "The authentication server is unreachable. This could be a network issue on your end, or the server may be down. Check your internet connection and try again.";
            authResult = AuthResult.Failed;
        }
        catch (InvalidOperationException ex)
        {
            authErrorTitle = "Wallet error";
            authErrorDetail = ex.Message;
            authResult = AuthResult.Failed;
        }
        catch (Exception ex)
        {
            authErrorTitle = "Unexpected error";
            authErrorDetail = ex.Message;
            authResult = AuthResult.Failed;
        }
        finally
        {
            isAuthenticating = false;
            authStep = 0;
        }
    }

    private record AuthHistoryEntry
    {
        public required string Domain { get; init; }
        public required string Address { get; init; }
        public required DateTime Timestamp { get; init; }
    }

    private static string TruncateAddress(string address)
    {
        if (address.Length <= 16) return address;
        return $"{address[..8]}…{address[^6..]}";
    }

    private static string FormatRelativeTime(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return utcTime.ToLocalTime().ToString("MMM d");
    }
}
