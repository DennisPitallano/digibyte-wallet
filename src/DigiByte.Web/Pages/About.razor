@page "/about"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>About</PageTitle>

<div class="flex flex-col gap-5">
    <button class="flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-dgb-500 transition-colors w-fit -mb-2" @onclick="GoBack">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
        Back
    </button>
    <div class="slide-up flex flex-col items-center gap-3 text-center pt-4">
        <DigiLogo Size="56" />
        <h1 class="text-2xl font-extrabold text-slate-900 dark:text-white">
            Digi<span class="text-dgb-500">Byte</span> Wallet
        </h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 max-w-[300px]">
            A self-custodial, open-source DigiByte wallet for everyone. Your money, your keys, your freedom.
        </p>
        <div class="flex gap-2 mt-1">
            <span class="text-[10px] font-bold text-dgb-500 bg-dgb-50 dark:bg-dgb-900 px-2 py-1 rounded-full">v@(AppVersion.ShortVersion)</span>
            @if (AppVersion.IsPreRelease)
            {
                <span class="text-[10px] font-bold text-amber-600 dark:text-amber-400 bg-amber-50 dark:bg-amber-500/10 px-2 py-1 rounded-full uppercase">@AppVersion.Channel</span>
            }
            <span class="text-[10px] font-bold text-green-500 bg-green-50 dark:bg-green-900/20 px-2 py-1 rounded-full">MIT License</span>
            <span class="text-[10px] font-bold text-slate-500 bg-slate-100 dark:bg-dgb-800 px-2 py-1 rounded-full">.NET 10 + Blazor WASM</span>
        </div>
    </div>

    @* Links *@
    <div class="slide-up-delay-1 flex flex-col gap-1.5">
        <a href="https://github.com/DennisPitallano/digibyte-wallet" target="_blank" rel="noopener"
           class="flex items-center gap-3 p-3 bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800 hover:bg-slate-50 dark:hover:bg-dgb-800 transition-colors">
            <div class="w-8 h-8 rounded-lg bg-slate-900 dark:bg-white flex items-center justify-center">
                <svg class="w-5 h-5 text-white dark:text-slate-900" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
            </div>
            <div class="flex-1">
                <p class="text-sm font-semibold text-slate-900 dark:text-white">GitHub Repository</p>
                <p class="text-xs text-slate-400">DennisPitallano/digibyte-wallet</p>
            </div>
            <svg class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
        </a>
        <a href="https://www.digibyte.org" target="_blank" rel="noopener"
           class="flex items-center gap-3 p-3 bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800 hover:bg-slate-50 dark:hover:bg-dgb-800 transition-colors">
            <div class="w-8 h-8 rounded-lg bg-dgb-500 flex items-center justify-center">
                <DigiLogo Size="20" />
            </div>
            <div class="flex-1">
                <p class="text-sm font-semibold text-slate-900 dark:text-white">DigiByte.org</p>
                <p class="text-xs text-slate-400">Official DigiByte website</p>
            </div>
            <svg class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
        </a>
    </div>

    @* Contributors *@
    <div class="slide-up-delay-2">
        <h3 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Contributors</h3>
        @if (isLoadingContributors)
        {
            <div class="flex gap-2">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="w-10 h-10 rounded-full skeleton"></div>
                }
            </div>
        }
        else if (contributors.Count > 0)
        {
            <div class="flex flex-wrap gap-2">
                @foreach (var c in contributors)
                {
                    <a href="@c.HtmlUrl" target="_blank" rel="noopener" title="@c.Login (@c.Contributions commits)"
                       class="flex flex-col items-center gap-1 p-2 rounded-xl hover:bg-slate-50 dark:hover:bg-dgb-800 transition-colors">
                        <img src="@c.AvatarUrl" alt="@c.Login" class="w-10 h-10 rounded-full border-2 border-white dark:border-dgb-800 shadow-sm" />
                        <span class="text-[10px] font-medium text-slate-600 dark:text-slate-400">@c.Login</span>
                        <span class="text-[9px] text-slate-400 dark:text-slate-500">@c.Contributions commits</span>
                    </a>
                }
            </div>
        }
        else
        {
            <p class="text-xs text-slate-400">Could not load contributors.</p>
        }

        @* AI Contributor *@
        <div class="mt-3 flex items-center gap-3 p-3 bg-dgb-50 dark:bg-dgb-900/30 rounded-xl border border-dgb-100 dark:border-dgb-800">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-dgb-500 to-dgb-700 flex items-center justify-center text-white text-xs font-bold">AI</div>
            <div>
                <p class="text-sm font-semibold text-slate-900 dark:text-white">Claude (Anthropic)</p>
                <p class="text-[10px] text-slate-400 dark:text-slate-500">AI pair programmer — architecture, code, and docs</p>
            </div>
        </div>
    </div>

    @* Tech Stack *@
    <div class="slide-up-delay-3">
        <h3 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Built With</h3>
        <div class="flex flex-wrap gap-1.5">
            @foreach (var tech in techStack)
            {
                <span class="text-[10px] font-semibold text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-dgb-800 px-2.5 py-1 rounded-full">@tech</span>
            }
        </div>
    </div>
</div>

@code {
    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private List<GitHubContributor> contributors = [];
    private bool isLoadingContributors = true;

    private string[] techStack = [
        ".NET 10", "Blazor WASM", "NBitcoin", "Tailwind CSS",
        "IndexedDB", "QRCoder", "SignalR", "Docker",
        "DigiByte Core v8.26.2", "Scalar API Docs"
    ];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<List<GitHubContributor>>(
                "https://api.github.com/repos/DennisPitallano/digibyte-wallet/contributors");
            contributors = response ?? [];
        }
        catch { }
        finally { isLoadingContributors = false; }
    }

    private class GitHubContributor
    {
        public string Login { get; set; } = "";
        public string AvatarUrl { get; set; } = "";
        public string HtmlUrl { get; set; } = "";
        public int Contributions { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("login")]
        public string LoginProp { set => Login = value; }
        [System.Text.Json.Serialization.JsonPropertyName("avatar_url")]
        public string AvatarProp { set => AvatarUrl = value; }
        [System.Text.Json.Serialization.JsonPropertyName("html_url")]
        public string HtmlProp { set => HtmlUrl = value; }
        [System.Text.Json.Serialization.JsonPropertyName("contributions")]
        public int ContribProp { set => Contributions = value; }
    }
}
