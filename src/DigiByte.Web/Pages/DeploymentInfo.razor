@page "/deployment"
@inject IJSRuntime JS

<PageTitle>Deployment</PageTitle>

<div class="flex flex-col gap-5">
    <button class="flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-dgb-500 transition-colors w-fit -mb-2" @onclick="GoBack">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
        Back
    </button>
    <h2 class="text-xl font-bold text-slate-900 dark:text-white slide-up">Deployment & Support</h2>

    @* Deployment Status *@
    <div class="slide-up-delay-1">
        <h3 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Infrastructure</h3>
        <div class="flex flex-col gap-1.5">
            <div class="flex items-center gap-3 p-3 bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800">
                <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                <div class="flex-1">
                    <p class="text-sm font-semibold text-slate-900 dark:text-white">PWA (Wallet App)</p>
                    <p class="text-[10px] text-slate-400">Blazor WASM — runs in your browser</p>
                </div>
                <span class="text-[10px] font-bold text-green-500 bg-green-50 dark:bg-green-900/20 px-2 py-0.5 rounded-full">Online</span>
            </div>
            <div class="flex items-center gap-3 p-3 bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800">
                <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                <div class="flex-1">
                    <p class="text-sm font-semibold text-slate-900 dark:text-white">Block Explorer API</p>
                    <p class="text-[10px] text-slate-400">digiexplorer.info — balance, txs, broadcast</p>
                </div>
                <span class="text-[10px] font-bold text-green-500 bg-green-50 dark:bg-green-900/20 px-2 py-0.5 rounded-full">Online</span>
            </div>
            <div class="flex items-center gap-3 p-3 bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800">
                <div class="w-2 h-2 rounded-full bg-slate-300"></div>
                <div class="flex-1">
                    <p class="text-sm font-semibold text-slate-900 dark:text-white">Node API + DigiByte Node</p>
                    <p class="text-[10px] text-slate-400">Docker — 87 RPC endpoints + Scalar docs</p>
                </div>
                <span class="text-[10px] font-bold text-slate-400 bg-slate-100 dark:bg-dgb-800 px-2 py-0.5 rounded-full">Local Only</span>
            </div>
        </div>
    </div>

    @* Cost Breakdown *@
    <div class="slide-up-delay-2">
        <h3 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Estimated Monthly Cost</h3>
        <div class="bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800 p-4">
            <div class="flex flex-col gap-2">
                <div class="flex justify-between text-xs">
                    <span class="text-slate-500 dark:text-slate-400">PWA Hosting (static files)</span>
                    <span class="font-semibold text-slate-900 dark:text-white">Free</span>
                </div>
                <div class="flex justify-between text-xs">
                    <span class="text-slate-500 dark:text-slate-400">Node API (Railway/VPS)</span>
                    <span class="font-semibold text-slate-900 dark:text-white">~$5-10/mo</span>
                </div>
                <div class="flex justify-between text-xs">
                    <span class="text-slate-500 dark:text-slate-400">DigiByte Full Node</span>
                    <span class="font-semibold text-slate-900 dark:text-white">~$10-20/mo</span>
                </div>
                <div class="flex justify-between text-xs">
                    <span class="text-slate-500 dark:text-slate-400">Domain + SSL</span>
                    <span class="font-semibold text-slate-900 dark:text-white">~$1/mo</span>
                </div>
                <div class="h-px bg-slate-200 dark:bg-dgb-800 my-1"></div>
                <div class="flex justify-between text-sm">
                    <span class="font-bold text-slate-900 dark:text-white">Total</span>
                    <span class="font-bold text-dgb-500">~$16-31/mo</span>
                </div>
            </div>
        </div>
    </div>

    @* Donation *@
    <div class="slide-up-delay-3 bg-gradient-to-br from-dgb-500 to-dgb-700 rounded-2xl p-5 text-white text-center">
        <h3 class="text-lg font-bold">Support This Project</h3>
        <p class="text-sm text-dgb-200 mt-1">Help keep the servers running and fund new features</p>

        <div class="mt-4 bg-white/10 backdrop-blur rounded-xl p-3">
            <p class="text-[10px] text-dgb-200 uppercase font-semibold mb-1">DigiByte (DGB) Donation Address</p>
            <p class="font-mono text-xs break-all text-white">dgb1q7g8arn8d4agadaqzvvx4utnwdwaahtyc0p5fnz</p>
        </div>

        <p class="text-[10px] text-dgb-300 mt-3">100% of donations go to infrastructure and development</p>
    </div>

    @* Open Source *@
    <div class="slide-up-delay-4 bg-white dark:bg-dgb-900 rounded-xl border border-slate-200 dark:border-dgb-800 p-4 text-center">
        <p class="text-sm font-semibold text-slate-900 dark:text-white">This project is open source</p>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">
            MIT Licensed — free to use, modify, and distribute.
            Contributions welcome!
        </p>
        <a href="https://github.com/DennisPitallano/digibyte-wallet" target="_blank" rel="noopener"
           class="inline-block mt-3 px-4 py-2 bg-dgb-500 text-white text-sm font-semibold rounded-xl press-effect">
            View on GitHub
        </a>
    </div>
</div>

@code {
    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");
}
