@page "/multisig/{WalletId}/send"
@inject MultisigWalletService MultisigService
@inject NavigationManager Nav

<PageTitle>Multisig Send</PageTitle>

<AuthGuard>
@if (config == null)
{
    <div class="flex items-center justify-center py-12">
        <div class="w-6 h-6 border-2 border-dgb-500 border-t-transparent rounded-full animate-spin"></div>
    </div>
}
else
{
    <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3 slide-up">
            <button class="p-2 rounded-xl bg-slate-100 dark:bg-dgb-800 hover:bg-slate-200 dark:hover:bg-dgb-700 transition-colors"
                    @onclick="GoBack">
                <svg class="w-4 h-4 text-slate-600 dark:text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
                </svg>
            </button>
            <div>
                <h2 class="text-xl font-bold text-slate-900 dark:text-white">Send from Multisig</h2>
                <p class="text-xs text-slate-500 dark:text-slate-400">@config.Label</p>
            </div>
        </div>

        @* Destination *@
        <div class="flex flex-col gap-1.5 slide-up-delay-1">
            <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Destination Address</label>
            <input type="text" @bind="destinationAddress" placeholder="D... or dgb1..."
                   autocomplete="off" spellcheck="false"
                   class="w-full px-4 py-3 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl text-sm font-mono text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
        </div>

        @* Amount *@
        <div class="flex flex-col gap-1.5 slide-up-delay-1">
            <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Amount (DGB)</label>
            <input type="number" @bind="amountDgb" step="0.00000001" min="0" placeholder="0.00000000"
                   class="w-full px-4 py-3 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
        </div>

        @* Memo (optional) *@
        <div class="flex flex-col gap-1.5 slide-up-delay-1">
            <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Memo (optional)</label>
            <input type="text" @bind="memo" placeholder="What's this for?"
                   class="w-full px-4 py-3 bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl text-slate-900 dark:text-white outline-none focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20 transition-all" />
        </div>

        <div class="slide-up-delay-1 p-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800/30 rounded-xl">
            <p class="text-xs text-amber-700 dark:text-amber-300 leading-relaxed">
                This will create a PSBT (Partially Signed Bitcoin Transaction) that needs
                <strong>@config.RequiredSignatures</strong> signatures before it can be broadcast.
            </p>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <p class="text-sm text-red-500 font-medium">@error</p>
        }

        <button class="w-full py-3.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 transition-all press-effect slide-up-delay-2 disabled:opacity-50"
                @onclick="CreatePSBT" disabled="@(isCreating || string.IsNullOrWhiteSpace(destinationAddress) || amountDgb <= 0)">
            @if (isCreating)
            {
                <div class="flex items-center justify-center gap-2">
                    <div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                    <span>Creating PSBT...</span>
                </div>
            }
            else
            {
                <span>Create Transaction</span>
            }
        </button>
    </div>
}
</AuthGuard>

@code {
    [Parameter] public string WalletId { get; set; } = "";

    private MultisigWalletConfig? config;
    private string destinationAddress = "";
    private decimal amountDgb;
    private string? memo;
    private string? error;
    private bool isCreating;

    protected override async Task OnInitializedAsync()
    {
        config = await MultisigService.GetConfigAsync(WalletId);
    }

    private async Task CreatePSBT()
    {
        isCreating = true;
        error = null;
        StateHasChanged();
        await Task.Yield();

        try
        {
            await MultisigService.CreateSpendingPSBTAsync(config!, destinationAddress.Trim(), amountDgb, memo: memo);
            Nav.NavigateTo($"/multisig/{WalletId}/pending");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isCreating = false;
        }
    }

    private void GoBack() => Nav.NavigateTo($"/multisig/{WalletId}");
}
