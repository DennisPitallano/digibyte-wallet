@inject AppState AppState

<nav class="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-[480px] z-50 safe-area-bottom">
    @* Frosted glass background with top fade *@
    <div class="absolute inset-0 bg-white/70 dark:bg-dgb-950/80 backdrop-blur-2xl border-t border-slate-200/60 dark:border-white/[0.06]"></div>

    <div class="relative flex justify-around items-end px-2 pt-2.5 pb-1.5">
        <NavLink class="nav-item group flex flex-col items-center gap-1 relative px-4 py-1 select-none" href="" Match="NavLinkMatch.All" @onclick="() => OnNavTap(0)">
            @* Active pill indicator *@
            <div class="absolute -top-1 left-1/2 -translate-x-1/2 h-[3px] rounded-full bg-gradient-to-r from-dgb-400 to-dgb-600 transition-all duration-300 ease-out group-[.active]:w-6 group-[.active]:opacity-100 w-0 opacity-0"></div>
            <div class="transition-transform duration-200 ease-out group-[.active]:scale-110 group-active:scale-90 @(tappedIndex == 0 ? "nav-tap" : "")">
                <svg class="w-[22px] h-[22px] text-slate-400 dark:text-slate-500 group-[.active]:text-dgb-500 transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9m18 0V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v3" />
                </svg>
            </div>
            <span class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 group-[.active]:text-dgb-600 dark:group-[.active]:text-dgb-400 transition-colors duration-200">Wallet</span>
        </NavLink>

        <NavLink class="nav-item group flex flex-col items-center gap-1 relative px-4 py-1 select-none" href="payments" @onclick="() => OnNavTap(1)">
            <div class="absolute -top-1 left-1/2 -translate-x-1/2 h-[3px] rounded-full bg-gradient-to-r from-dgb-400 to-dgb-600 transition-all duration-300 ease-out group-[.active]:w-6 group-[.active]:opacity-100 w-0 opacity-0"></div>
            <div class="transition-transform duration-200 ease-out group-[.active]:scale-110 group-active:scale-90 @(tappedIndex == 1 ? "nav-tap" : "")">
                <svg class="w-[22px] h-[22px] text-slate-400 dark:text-slate-500 group-[.active]:text-dgb-500 transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />
                </svg>
            </div>
            <span class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 group-[.active]:text-dgb-600 dark:group-[.active]:text-dgb-400 transition-colors duration-200">Pay</span>
        </NavLink>

        <NavLink class="nav-item group flex flex-col items-center gap-1 relative px-4 py-1 select-none" href="p2p" @onclick="() => OnNavTap(2)">
            <div class="absolute -top-1 left-1/2 -translate-x-1/2 h-[3px] rounded-full bg-gradient-to-r from-dgb-400 to-dgb-600 transition-all duration-300 ease-out group-[.active]:w-6 group-[.active]:opacity-100 w-0 opacity-0"></div>
            <div class="transition-transform duration-200 ease-out group-[.active]:scale-110 group-active:scale-90 @(tappedIndex == 2 ? "nav-tap" : "")">
                <svg class="w-[22px] h-[22px] text-slate-400 dark:text-slate-500 group-[.active]:text-dgb-500 transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                </svg>
            </div>
            <span class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 group-[.active]:text-dgb-600 dark:group-[.active]:text-dgb-400 transition-colors duration-200">P2P</span>
        </NavLink>

        <NavLink class="nav-item group flex flex-col items-center gap-1 relative px-4 py-1 select-none" href="identity" @onclick="() => OnNavTap(3)">
            <div class="absolute -top-1 left-1/2 -translate-x-1/2 h-[3px] rounded-full bg-gradient-to-r from-dgb-400 to-dgb-600 transition-all duration-300 ease-out group-[.active]:w-6 group-[.active]:opacity-100 w-0 opacity-0"></div>
            <div class="transition-transform duration-200 ease-out group-[.active]:scale-110 group-active:scale-90 @(tappedIndex == 3 ? "nav-tap" : "")">
                <svg class="w-[22px] h-[22px] text-slate-400 dark:text-slate-500 group-[.active]:text-dgb-500 transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a48.667 48.667 0 0 0 7.5 0" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 10.5V12m-3 4.5h6" />
                </svg>
            </div>
            <span class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 group-[.active]:text-dgb-600 dark:group-[.active]:text-dgb-400 transition-colors duration-200">ID</span>
        </NavLink>

        <NavLink class="nav-item group flex flex-col items-center gap-1 relative px-4 py-1 select-none" href="settings" @onclick="() => OnNavTap(4)">
            <div class="absolute -top-1 left-1/2 -translate-x-1/2 h-[3px] rounded-full bg-gradient-to-r from-dgb-400 to-dgb-600 transition-all duration-300 ease-out group-[.active]:w-6 group-[.active]:opacity-100 w-0 opacity-0"></div>
            <div class="transition-transform duration-200 ease-out group-[.active]:scale-110 group-active:scale-90 @(tappedIndex == 4 ? "nav-tap" : "")">
                <svg class="w-[22px] h-[22px] text-slate-400 dark:text-slate-500 group-[.active]:text-dgb-500 transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                </svg>
            </div>
            <span class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 group-[.active]:text-dgb-600 dark:group-[.active]:text-dgb-400 transition-colors duration-200">Settings</span>
        </NavLink>
    </div>
</nav>

@code {
    private int tappedIndex = -1;

    private async Task OnNavTap(int index)
    {
        tappedIndex = index;
        StateHasChanged();
        await Task.Delay(350);
        tappedIndex = -1;
        StateHasChanged();
    }
}
