@inherits LayoutComponentBase
@implements IDisposable
@inject ThemeService Theme
@inject NavigationManager Nav
@inject AppState AppState

<ToastContainer />
<PwaInstallBanner />
<PwaUpdateBanner />

<div class="flex flex-col h-dvh max-w-[480px] mx-auto relative bg-slate-50 dark:bg-dgb-950">
    <main class="flex-1 overflow-y-auto px-4 pt-4 @(ShowNav ? "pb-24" : "pb-4") scroll-smooth thin-scrollbar"
          @onclick="AppState.ResetLockTimer" @ontouchstart="AppState.ResetLockTimer">
        <OfflineBanner />
        <div class="page-enter">
            @Body
        </div>
    </main>
    @if (ShowNav)
    {
        <NavMenu />
    }
</div>

<div id="modal-root"></div>

@code {
    private static readonly string[] HiddenNavPaths = ["/welcome", "/create-wallet", "/recover-wallet", "/unlock", "/about", "/roadmap", "/analytics", "/deployment", "/help", "/help/multisig", "/multisig/room"];

    private bool ShowNav
    {
        get
        {
            var path = new Uri(Nav.Uri).AbsolutePath.TrimEnd('/').ToLower();
            if (string.IsNullOrEmpty(path)) path = "/";
            return !HiddenNavPaths.Contains(path);
        }
    }

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        AppState.OnAutoLocked += OnAutoLocked;
    }

    private void OnAutoLocked()
    {
        InvokeAsync(() =>
        {
            Nav.NavigateTo("/unlock", forceLoad: false);
            StateHasChanged();
        });
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        AppState.OnAutoLocked -= OnAutoLocked;
    }
}
