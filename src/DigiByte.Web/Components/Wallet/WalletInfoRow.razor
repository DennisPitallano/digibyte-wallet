@* A single row in the Wallet Info section with an expandable explanation. *@

<div class="flex flex-col">
    <button type="button" class="flex items-center justify-between text-xs w-full text-left group"
            @onclick="() => expanded = !expanded">
        <span class="flex items-center gap-1 text-slate-400">
            @Label
            <svg class="w-3 h-3 text-slate-400/60 group-hover:text-dgb-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
            </svg>
        </span>
        <span class="@ValueClasses">@Value</span>
    </button>
    @if (expanded)
    {
        <p class="mt-1 text-[11px] leading-relaxed text-slate-400 dark:text-slate-500 bg-slate-50 dark:bg-dgb-950 rounded-lg px-2.5 py-2 scale-in">
            @Hint
        </p>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter, EditorRequired] public string Hint { get; set; } = "";
    [Parameter] public bool Mono { get; set; }
    [Parameter] public bool Highlight { get; set; }

    private bool expanded;

    private string ValueClasses
    {
        get
        {
            var classes = "text-[11px] ";
            if (Mono) classes += "font-mono ";
            if (Highlight) classes += "text-dgb-500 font-medium capitalize";
            else classes += "text-slate-600 dark:text-slate-300";
            return classes;
        }
    }
}
