@implements IDisposable
@inject NetworkStatusService Network

@if (!Network.IsOnline)
{
    <div class="flex items-center gap-2 px-3 py-2 bg-amber-500/10 border border-amber-500/20 rounded-xl mb-3 fade-in">
        <svg class="w-4 h-4 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 0 1 7.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12 18.75h.008v.008H12v-.008Z" />
        </svg>
        <span class="text-xs font-medium text-amber-600 dark:text-amber-400">You're offline — showing cached data</span>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        Network.OnStatusChanged += OnChanged;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Network.OnStatusChanged -= OnChanged;
    }
}
