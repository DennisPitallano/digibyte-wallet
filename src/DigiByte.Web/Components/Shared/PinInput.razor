@inject IJSRuntime JS

<div class="flex justify-center gap-2 @(showError ? "animate-shake" : "")">
    @for (int i = 0; i < Length; i++)
    {
        var idx = i;
        <input type="@(Masked ? "password" : "text")"
               maxlength="1"
               inputmode="numeric"
               pattern="[0-9]"
               autocomplete="off"
               id="@InputId(idx)"
               value="@GetDigit(idx)"
               class="w-11 h-14 text-center text-xl font-bold rounded-xl border-2 outline-none transition-all duration-200
                      bg-white dark:bg-dgb-900
                      @(showError ? "border-red-400 dark:border-red-500" : GetDigit(idx) != "" ? "border-dgb-500 dark:border-dgb-400" : "border-slate-200 dark:border-dgb-800")
                      focus:border-dgb-500 focus:ring-2 focus:ring-dgb-500/20
                      text-slate-900 dark:text-white"
               @oninput="(e) => OnDigitInput(idx, e)"
               @onkeydown="(e) => OnKeyDown(idx, e)"
               @onfocus="() => OnFocus(idx)" />
    }
</div>

@if (!string.IsNullOrEmpty(Error))
{
    <p class="text-sm text-red-500 font-medium text-center mt-2 fade-in">@Error</p>
}

@code {
    [Parameter] public int Length { get; set; } = 6;
    [Parameter] public bool Masked { get; set; } = true;
    [Parameter] public bool AutoFocus { get; set; } = true;
    [Parameter] public string? Error { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public EventCallback OnComplete { get; set; }

    private string _instanceId = Guid.NewGuid().ToString("N")[..6];
    private string[] digits = [];
    private bool showError;
    private string? _lastError;

    private string InputId(int idx) => $"pin-{_instanceId}-{idx}";

    protected override void OnInitialized()
    {
        digits = new string[Length];
        Array.Fill(digits, "");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AutoFocus)
        {
            await Task.Delay(100); // Let DOM settle
            await FocusInput(0);
        }

        // Detect error change → trigger shake + refocus
        if (Error != _lastError && Error != null)
        {
            _lastError = Error;
            showError = true;
            StateHasChanged();
            await Task.Delay(600); // Shake duration
            showError = false;
            StateHasChanged();
        }
        else if (Error == null)
        {
            _lastError = null;
        }
    }

    private string GetDigit(int idx) => idx < digits.Length ? digits[idx] : "";

    private string GetFullPin() => string.Join("", digits);

    private async Task OnDigitInput(int idx, ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";

        if (val.Length > 1)
        {
            // Handle paste — distribute digits across inputs
            for (int i = 0; i < val.Length && (idx + i) < Length; i++)
            {
                if (char.IsDigit(val[i]))
                    digits[idx + i] = val[i].ToString();
            }
            var nextIdx = Math.Min(idx + val.Length, Length - 1);
            await FocusInput(nextIdx);
        }
        else if (val.Length == 1 && char.IsDigit(val[0]))
        {
            digits[idx] = val;
            if (idx < Length - 1)
                await FocusInput(idx + 1);
        }
        else
        {
            digits[idx] = "";
        }

        await ValueChanged.InvokeAsync(GetFullPin());

        if (digits.All(d => d.Length == 1))
            await OnComplete.InvokeAsync();
    }

    private async Task OnKeyDown(int idx, KeyboardEventArgs e)
    {
        if (e.Key == "Backspace")
        {
            if (digits[idx] == "" && idx > 0)
            {
                digits[idx - 1] = "";
                await FocusInput(idx - 1);
                await ValueChanged.InvokeAsync(GetFullPin());
            }
            else
            {
                digits[idx] = "";
                await ValueChanged.InvokeAsync(GetFullPin());
            }
        }
        else if (e.Key == "ArrowLeft" && idx > 0)
        {
            await FocusInput(idx - 1);
        }
        else if (e.Key == "ArrowRight" && idx < Length - 1)
        {
            await FocusInput(idx + 1);
        }
    }

    private async Task OnFocus(int idx)
    {
        await JS.InvokeVoidAsync("domHelpers.selectElement", InputId(idx));
    }

    private async Task FocusInput(int idx)
    {
        await JS.InvokeVoidAsync("domHelpers.focusElement", InputId(idx));
    }

    /// <summary>
    /// Reset all digits and refocus first input.
    /// </summary>
    public async Task ClearAsync()
    {
        Array.Fill(digits, "");
        StateHasChanged();
        await Task.Delay(50);
        await FocusInput(0);
    }

    /// <summary>
    /// Sync reset (for use where async isn't available).
    /// </summary>
    public void Clear()
    {
        Array.Fill(digits, "");
        StateHasChanged();
        _ = Task.Run(async () =>
        {
            await Task.Delay(50);
            await FocusInput(0);
        });
    }
}
