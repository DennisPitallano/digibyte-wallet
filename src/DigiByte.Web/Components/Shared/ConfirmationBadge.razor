@if (Expanded)
{
    @* Extended view for the detail modal *@
    <div class="flex flex-col gap-3">

        @* Status label row *@
        <div class="flex items-center justify-between text-xs">
            <span class="text-slate-400 dark:text-slate-500">Status</span>
            @if (Confirmations == 0)
            {
                <span class="flex items-center gap-1.5 font-medium text-amber-500">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
                    Pending
                </span>
            }
            else if (Confirmations >= 6)
            {
                <span class="flex items-center gap-1.5 font-medium text-green-500">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                    Confirmed
                </span>
            }
            else
            {
                <span class="font-medium text-dgb-500">@Confirmations / 6 confirmations</span>
            }
        </div>

        @* 6-block chain with animated icons *@
        <div class="flex items-center">
            @for (int i = 1; i <= 6; i++)
            {
                var idx = i;
                var confirmed = idx <= Confirmations;
                var mining = idx == Confirmations + 1 && Confirmations < 6;

                @* Chain connector before each block except the first *@
                @if (idx > 1)
                {
                    <div class="flex-1 h-0.5 rounded-full transition-colors duration-700 @(idx - 1 < Confirmations ? "bg-green-500" : "bg-slate-200 dark:bg-slate-700")"></div>
                }

                @* Block node *@
                <div class="relative flex-shrink-0">
                    @* Ping ring for the block currently being mined *@
                    @if (mining)
                    {
                        <span class="absolute rounded-full animate-ping bg-dgb-400 opacity-25" style="inset: -5px;"></span>
                    }
                    <div class="relative z-10 w-7 h-7 rounded-full flex items-center justify-center transition-all duration-500
                                @(confirmed ? "bg-green-500 shadow-sm" : mining ? "bg-dgb-500 shadow-md animate-pulse" : "bg-slate-100 dark:bg-slate-800")">
                        @if (confirmed)
                        {
                            @* Confirmed block: white checkmark *@
                            <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                            </svg>
                        }
                        else
                        {
                            @* Pending or mining block: cube icon *@
                            <svg class="w-3 h-3 @(mining ? "text-white" : "text-slate-300 dark:text-slate-600")"
                                 fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
                            </svg>
                        }
                    </div>
                </div>
            }
        </div>

        @* Context callout — pending/mining vs settled *@
        @if (Confirmations >= 6)
        {
            <div class="flex items-center justify-center gap-1.5 bg-green-50/60 dark:bg-green-900/20 rounded-lg px-3 py-1.5">
                <svg class="w-3 h-3 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                <span class="text-[10px] text-green-600 dark:text-green-400 font-medium">Settled on the DigiByte blockchain</span>
            </div>
        }
        else
        {
            <div class="flex items-center justify-center gap-1.5 bg-dgb-50/60 dark:bg-dgb-900/40 rounded-lg px-3 py-1.5">
                <svg class="w-3 h-3 text-dgb-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                </svg>
                @if (Confirmations == 0)
                {
                    <span class="text-[10px] text-dgb-500 dark:text-dgb-400 font-medium">DigiByte blocks every ~15 seconds</span>
                }
                else
                {
                    <span class="text-[10px] text-dgb-500 dark:text-dgb-400 font-medium">
                        @(6 - Confirmations) more · ~@((6 - Confirmations) * 15)s at DGB's 15s block time
                    </span>
                }
            </div>
        }
    </div>
}
else
{
    @* Compact inline display for transaction list rows *@
    @if (Confirmations == 0)
    {
        <span class="text-[9px] font-semibold text-amber-500 flex items-center gap-0.5">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse flex-shrink-0"></span>
            Pending
        </span>
    }
    else if (Confirmations >= 6)
    {
        <span class="text-[9px] font-semibold text-green-500 flex items-center gap-0.5">
            <svg class="w-2.5 h-2.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            Confirmed
        </span>
    }
    else
    {
        <div class="flex flex-col items-end gap-0.5">
            <span class="text-[9px] text-dgb-500 dark:text-dgb-400 font-semibold">@Confirmations / 6 conf</span>
            @* Small block squares instead of pill dots *@
            <div class="flex gap-0.5 items-center">
                @for (int i = 1; i <= 6; i++)
                {
                    var idx = i;
                    <div class="w-2 h-2 rounded-sm transition-colors duration-500
                                @(idx <= Confirmations ? "bg-dgb-500" : idx == Confirmations + 1 ? "bg-dgb-400 animate-pulse" : "bg-slate-200 dark:bg-dgb-700")"></div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter] public int Confirmations { get; set; }

    /// <summary>
    /// When true renders the expanded 6-step progress bar with DGB speed context.
    /// When false renders the compact inline badge for use in list rows.
    /// </summary>
    [Parameter] public bool Expanded { get; set; }
}
