@inject NotificationService Notifications
@implements IDisposable

<div class="fixed top-4 left-1/2 -translate-x-1/2 z-[300] flex flex-col gap-2 max-w-[460px] w-full px-4 pointer-events-none" role="region" aria-label="Notifications" aria-live="polite">
    @foreach (var toast in Notifications.Active)
    {
        var t = toast;
        var bgClass = t.Type switch
        {
            ToastType.Success => "bg-green-500",
            ToastType.Error => "bg-red-500",
            ToastType.Warning => "bg-amber-500",
            _ => "bg-dgb-500"
        };
        var iconPath = t.Type switch
        {
            ToastType.Success => "m4.5 12.75 6 6 9-13.5",
            ToastType.Error => "M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z",
            ToastType.Warning => "M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126Z",
            _ => "m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z"
        };

        <div role="@(t.Type == ToastType.Error ? "alert" : "status")" class="slide-up @bgClass text-white rounded-2xl px-4 py-3 shadow-lg flex items-center gap-3 pointer-events-auto">
            <svg class="w-5 h-5 flex-shrink-0" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="@iconPath" />
            </svg>
            <p class="text-sm font-medium flex-1">@t.Message</p>
            <button class="text-white/70 hover:text-white" aria-label="Dismiss notification" @onclick="() => Notifications.Dismiss(t.Id)">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
    }
</div>

@code {
    protected override void OnInitialized() => Notifications.OnChange += StateHasChanged;
    public void Dispose() => Notifications.OnChange -= StateHasChanged;
}
