@inject IJSRuntime JS

@if (IsOpen)
{
    <div class="modal-overlay" style="flex-direction:column; gap:1rem;">
        <div class="relative w-[300px] h-[300px] rounded-2xl overflow-hidden bg-black shadow-2xl scale-in">
            <video id="qr-video" class="w-full h-full object-cover" playsinline muted></video>
            @* Scan frame overlay *@
            <div class="absolute inset-0 pointer-events-none">
                <div class="absolute inset-8 border-2 border-white/40 rounded-xl"></div>
                <div class="absolute top-8 left-8 w-6 h-6 border-t-2 border-l-2 border-dgb-400 rounded-tl-lg"></div>
                <div class="absolute top-8 right-8 w-6 h-6 border-t-2 border-r-2 border-dgb-400 rounded-tr-lg"></div>
                <div class="absolute bottom-8 left-8 w-6 h-6 border-b-2 border-l-2 border-dgb-400 rounded-bl-lg"></div>
                <div class="absolute bottom-8 right-8 w-6 h-6 border-b-2 border-r-2 border-dgb-400 rounded-br-lg"></div>
                @* Scanning line animation *@
                <div class="absolute left-8 right-8 h-0.5 bg-gradient-to-r from-transparent via-dgb-400 to-transparent animate-scan"></div>
            </div>
            @if (isLoading)
            {
                <div class="absolute inset-0 flex items-center justify-center bg-black/60">
                    <div class="w-8 h-8 border-3 border-dgb-400 border-t-transparent rounded-full animate-spin"></div>
                </div>
            }
        </div>

        <p class="text-white/80 text-sm font-medium">Point camera at QR code</p>

        @if (errorMessage != null)
        {
            <p class="text-red-400 text-xs font-medium bg-red-900/30 px-3 py-1.5 rounded-lg">@errorMessage</p>
        }

        <div class="flex items-center gap-3">
            <label class="px-5 py-2.5 bg-white/10 hover:bg-white/20 text-white text-sm font-semibold rounded-xl backdrop-blur transition-colors press-effect cursor-pointer flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                </svg>
                Upload Image
                <InputFile OnChange="OnFileSelected" accept="image/*" class="hidden" />
            </label>
            <button class="px-5 py-2.5 bg-white/10 hover:bg-white/20 text-white text-sm font-semibold rounded-xl backdrop-blur transition-colors press-effect"
                    @onclick="Close">
                Cancel
            </button>
        </div>

        @if (isDecoding)
        {
            <p class="text-dgb-400 text-xs font-medium">Decoding image...</p>
        }
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<string> OnScanned { get; set; }
    [Parameter] public EventCallback OnClosed { get; set; }

    private DotNetObjectReference<QrScannerModal>? objRef;
    private bool isLoading = true;
    private bool isDecoding;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && objRef == null)
        {
            objRef = DotNetObjectReference.Create(this);
            isLoading = true;
            errorMessage = null;
            StateHasChanged();

            await Task.Delay(100); // Let DOM render the video element
            var success = await JS.InvokeAsync<bool>("qrScanner.start", objRef);
            isLoading = !success;
        }
    }

    [JSInvokable]
    public async Task OnScanResult(string data)
    {
        await OnScanned.InvokeAsync(data);
        await Close();
    }

    [JSInvokable]
    public void OnScanError(string error)
    {
        errorMessage = error;
        isLoading = false;
        StateHasChanged();
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        isDecoding = true;
        StateHasChanged();

        try
        {
            var file = e.File;
            if (file.Size > 10 * 1024 * 1024)
            {
                errorMessage = "Image too large (max 10 MB)";
                return;
            }

            // Read file as data URL for JS processing
            var buffer = new byte[file.Size];
            await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).ReadExactlyAsync(buffer);
            var dataUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";

            var result = await JS.InvokeAsync<string?>("qrScanner.decodeImage", dataUrl);

            if (!string.IsNullOrEmpty(result))
            {
                await OnScanned.InvokeAsync(result);
                await Close();
            }
            else
            {
                errorMessage = "No QR code found in image";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to read image: {ex.Message}";
        }
        finally
        {
            isDecoding = false;
            StateHasChanged();
        }
    }

    private async Task Close()
    {
        await JS.InvokeVoidAsync("qrScanner.stop");
        objRef?.Dispose();
        objRef = null;
        await OnClosed.InvokeAsync();
    }
}
