@* Reusable "Coming Soon" banner for unfinished features *@

<div class="scale-in bg-white dark:bg-dgb-900/50 rounded-2xl border border-dashed border-dgb-300 dark:border-dgb-700 p-8 text-center">
    <div class="relative w-14 h-14 mx-auto mb-4">
        <div class="absolute inset-0 rounded-full bg-dgb-100 dark:bg-dgb-800 glow-pulse"></div>
        <div class="relative w-14 h-14 rounded-full bg-dgb-50 dark:bg-dgb-800 flex items-center justify-center">
            @if (ChildContent is not null)
            {
                @ChildContent
            }
            else
            {
                <svg class="w-7 h-7 text-dgb-400 dark:text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.049.58.025 1.193-.14 1.743" />
                </svg>
            }
        </div>
    </div>
    <h4 class="text-sm font-bold text-slate-700 dark:text-slate-300">@Title</h4>
    <p class="text-xs text-slate-400 dark:text-slate-500 mt-1 max-w-[240px] mx-auto">@Description</p>
    <div class="mt-3 inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 dark:bg-amber-500/10 border border-amber-200 dark:border-amber-500/20">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
        <span class="text-[10px] font-semibold text-amber-600 dark:text-amber-400 uppercase tracking-wider">Coming Soon</span>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Under Construction";
    [Parameter] public string Description { get; set; } = "This feature is being built and will be available in a future update.";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
