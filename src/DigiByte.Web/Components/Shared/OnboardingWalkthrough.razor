@inject IJSRuntime JS

@if (isVisible)
{
    <div class="modal-overlay" style="flex-direction: column;">
        <div class="w-full max-w-[380px] mx-auto flex flex-col items-center gap-6 px-4 scale-in">
            @* Step content *@
            <div class="flex flex-col items-center text-center gap-4 min-h-[280px] justify-center">
                <div class="w-16 h-16 rounded-2xl @steps[currentStep].IconBg flex items-center justify-center">
                    @((MarkupString)steps[currentStep].Icon)
                </div>
                <h2 class="text-xl font-bold text-white">@steps[currentStep].Title</h2>
                <p class="text-sm text-slate-300 leading-relaxed max-w-[300px]">@steps[currentStep].Description</p>
            </div>

            @* Dots *@
            <div class="flex items-center gap-2">
                @for (int i = 0; i < steps.Length; i++)
                {
                    var idx = i;
                    <button class="rounded-full transition-all duration-300 @(idx == currentStep ? "w-6 h-2 bg-dgb-500" : "w-2 h-2 bg-white/30 hover:bg-white/50")"
                            @onclick="() => currentStep = idx"></button>
                }
            </div>

            @* Actions *@
            <div class="flex gap-3 w-full max-w-[300px]">
                @if (currentStep < steps.Length - 1)
                {
                    <button class="flex-1 py-3 text-sm font-semibold text-white/60 hover:text-white transition-colors"
                            @onclick="Skip">Skip</button>
                    <button class="flex-1 py-3 bg-dgb-500 hover:bg-dgb-600 text-white text-sm font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 press-effect"
                            @onclick="Next">Next</button>
                }
                else
                {
                    <button class="flex-1 py-3 bg-dgb-500 hover:bg-dgb-600 text-white text-sm font-semibold rounded-2xl shadow-lg shadow-dgb-500/25 press-effect"
                            @onclick="Finish">Get Started</button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback OnCompleted { get; set; }

    private bool isVisible;
    private int currentStep;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var seen = await JS.InvokeAsync<string?>("localStorage.getItem", "dgb-onboarding-done");
            if (seen == null)
            {
                isVisible = true;
                StateHasChanged();
            }
        }
    }

    private void Next()
    {
        if (currentStep < steps.Length - 1) currentStep++;
    }

    private async Task Skip() => await Finish();

    private async Task Finish()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "dgb-onboarding-done", "1");
        isVisible = false;
        await OnCompleted.InvokeAsync();
    }

    private record Step(string Title, string Description, string IconBg, string Icon);

    private Step[] steps =
    [
        new("Welcome to DigiByte", "A self-custodial wallet where you control your keys. No accounts, no tracking, no middlemen.",
            "bg-dgb-500/20",
            """<svg class="w-8 h-8 text-dgb-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9m18 0V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v3" /></svg>"""),

        new("Send & Receive", "Send DGB anywhere in seconds. Scan QR codes, upload images, or paste addresses. Payments made simple.",
            "bg-green-500/20",
            """<svg class="w-8 h-8 text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>"""),

        new("Stay Secure", "Your seed phrase is your backup. Never share it. PIN-protected with AES-256 encryption at rest.",
            "bg-amber-500/20",
            """<svg class="w-8 h-8 text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>"""),

        new("Digi-ID Login", "Sign in to websites without passwords. Scan a QR code and your wallet proves your identity cryptographically.",
            "bg-purple-500/20",
            """<svg class="w-8 h-8 text-purple-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a48.667 48.667 0 0 0 7.5 0" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 10.5V12m-3 4.5h6" /></svg>"""),

        new("You're All Set!", "Pull down on the home screen to refresh. Explore Settings for themes, languages, and network options.",
            "bg-dgb-500/20",
            """<svg class="w-8 h-8 text-dgb-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>"""),
    ];
}
