@* CSS 3D spinning DigiByte coin — zero dependencies *@

<div class="coin-scene" style="width:@(Size)px;height:@(Size)px;">
    <div class="coin @(Paused ? "" : "coin-spin")">
        <div class="coin-face coin-front">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 479.8 479.8" width="100%" height="100%">
                <defs>
                    <radialGradient id="coinGrad" cx="40%" cy="35%" r="60%">
                        <stop offset="0%" stop-color="#1a8fff"/>
                        <stop offset="60%" stop-color="#0066CC"/>
                        <stop offset="100%" stop-color="#002352"/>
                    </radialGradient>
                </defs>
                <circle cx="239.9" cy="239.9" r="230" fill="url(#coinGrad)"/>
                <circle cx="239.9" cy="239.9" r="219.5" fill="none" stroke="#4d94ff" stroke-opacity="0.4" stroke-width="3"/>
                <circle cx="239.9" cy="239.9" r="210" fill="none" stroke="#80b3ff" stroke-opacity="0.15" stroke-width="1.5"/>
                <path fill="#fff" d="M116.9 182.9h155s53.5-.5 16.5 68.5c0 0-27 54-94 53l36.1-92.2a7.3 7.3 0 0 0-6.6-10l-47.5-.8-60 146s20 2 31 1l-6 15h28.3a3.8 3.8 0 0 0 3.6-2.5l5.1-13.5 12-1-7 17H211a5 5 0 0 0 4.7-3.2l7.7-19.8s84-14 122-82c0 0 51-79-9-107a116 116 0 0 0-37-10l7-17.3a3.4 3.4 0 0 0-3.1-4.7h-25.9l-8 21h-11l6.2-16.3a3.5 3.5 0 0 0-3.2-4.7h-26l-8 21h-80.8a12 12 0 0 0-10.6 6.3z"/>
            </svg>
        </div>
        <div class="coin-face coin-back">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 479.8 479.8" width="100%" height="100%">
                <defs>
                    <radialGradient id="coinGradBack" cx="60%" cy="35%" r="60%">
                        <stop offset="0%" stop-color="#1a8fff"/>
                        <stop offset="60%" stop-color="#0066CC"/>
                        <stop offset="100%" stop-color="#002352"/>
                    </radialGradient>
                </defs>
                <circle cx="239.9" cy="239.9" r="230" fill="url(#coinGradBack)"/>
                <circle cx="239.9" cy="239.9" r="219.5" fill="none" stroke="#4d94ff" stroke-opacity="0.4" stroke-width="3"/>
                <circle cx="239.9" cy="239.9" r="210" fill="none" stroke="#80b3ff" stroke-opacity="0.15" stroke-width="1.5"/>
                <text x="239.9" y="260" text-anchor="middle" fill="white" font-size="120" font-weight="700" font-family="Inter, sans-serif">DGB</text>
            </svg>
        </div>
    </div>
</div>

@code {
    [Parameter] public int Size { get; set; } = 64;
    [Parameter] public bool Paused { get; set; }
}
