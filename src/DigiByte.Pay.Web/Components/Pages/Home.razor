@page "/"

<PageTitle>DigiPay</PageTitle>

<link rel="stylesheet" href="css/checkout.css" />

<main class="dp-checkout">
    <div class="dp-card">
        <div class="dp-row dp-row--center">
            <div>
                <div class="dp-eyebrow">DIGIPAY</div>
                <div class="dp-merchant">Accept DigiByte on your site</div>
            </div>
        </div>

        <p class="dp-muted dp-center">Pluggable, non-custodial payment gateway. Register once with Digi-ID, add an address or xpub, and start accepting DGB.</p>

        <a href="/merchant/signin" class="dp-button">Sign in with Digi-ID</a>

        <p class="dp-muted dp-center" style="font-size: 0.6875rem;">No account? Signing in creates one automatically.</p>
    </div>
</main>
