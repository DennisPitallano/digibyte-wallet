                   @bind="pinEntered" @bind:event="oninput"
                   @onkeydown="@(e => { if (e.Key == "Enter") _ = VerifyPinChallengeAsync(); })" />
            @if (!string.IsNullOrEmpty(pinChallengeError))
            {
                <p class="text-sm text-red-400 m-0 mb-3">@pinChallengeError</p>
            }
            <div class="flex gap-2">
                <button class="flex-1 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-200 font-semibold rounded-lg text-sm" @onclick="CancelPinChallenge">Cancel</button>
                <button class="flex-1 py-2.5 bg-dgb-500 hover:bg-dgb-400 text-white font-semibold rounded-lg text-sm" @onclick="VerifyPinChallengeAsync">Continue</button>
            </div>
        </div>
    </div>
}

@code {
    private enum Screen { Pair, Keypad, Waiting, Result }

    // Keypad layout — "." at bottom-left accepts a single decimal point, and
    // "back" is a soft backspace (keeps the keypad 3x4 without a clear button,
    // which staff kept mis-tapping on the prototype).
    private static readonly string[] KeypadKeys = new[]
    {
        "1","2","3",
        "4","5","6",
        "7","8","9",
        ".","0","back",
    };

    private Screen screen = Screen.Pair;
    private string pairMode = "code";
    private string pairCode = "";
    private string manualApiKey = "";
    private string manualStoreId = "";
    private string? pairError;

    private PairedDevice? device;
    private bool busy;

    // Keypad state — amount is stored as a string so we can display
    // the user's literal input (e.g. "10." → they're about to type decimals).
    private string amount = "";
    private string labelInput = "";
    private string? chargeError;

    // Currency mode. "DGB" means the cashier is typing a raw DGB amount
    // (8 decimals allowed). Anything else is a fiat code like "EUR" / "USD"
    // — the cashier types a fiat amount (2 decimals), we convert live using
    // the cached /v1/pay/public/price quote. Persisted in localStorage via
    // digipayPos.setCurrency so each tablet remembers its till currency.
    //
    // SupportedCurrencies is intentionally narrow and mirrors the server's
    // allow-list in PublicEndpoints so an operator can't pick a currency
    // the price endpoint will reject.
    private static readonly string[] SupportedCurrencies =
        new[] { "DGB", "USD", "EUR", "GBP", "CAD", "AUD", "JPY", "CHF", "PHP", "NGN", "ZAR" };
    private string currency = "DGB";
    private decimal? dgbPrice;          // null while loading or on error
    private DateTime? dgbPriceFetchedAt;
    private string? priceError;
    private System.Threading.Timer? priceTimer;

    private CreatedSession? session;
    private string? qrDataUrl;
    private HubConnection? hub;

    private string? resultStatus;
    private string? resultTxid;
    private long? resultAmount;
    private int autoReturnSeconds = 5;
    private CancellationTokenSource? autoReturnCts;

    private bool showUnpair;

    // Shift-report (end-of-day summary) state. shiftReport stays null until
    // the modal fetches — we use that as the "loading" signal in the UI.
    // shiftStartedAt is kept in localStorage (see pos-store.js) so "Start
    // new shift" resets the clock per-tablet without touching the API.
    private bool showShiftReport;
    private ShiftReport? shiftReport;
    private string? shiftReportError;

    // Manager PIN state. hasPin is mirrored from localStorage so the gear
    // icon can show "shield" when set and "settings" when not.
    private bool hasPin;
    private bool showPinSettings;
    private bool showPinChallenge;
    private string pinNew = "";
    private string pinConfirm = "";
    private string pinEntered = "";
    private string? pinSettingsError;
    private string? pinChallengeError;
    private string pinChallengePrompt = "";
    private Func<Task>? pinChallengePending;

    private bool CanSavePin =>
        !string.IsNullOrEmpty(pinNew)
        && pinNew.Length >= 4 && pinNew.Length <= 8
        && pinNew.All(char.IsDigit)
        && pinNew == pinConfirm;

    private bool IsFiat => currency != "DGB";

    // Decimal precision allowed in the current currency. DGB supports 8
    // (satoshi); fiat only needs 2; JPY has no sub-unit.
    private int MaxDecimals => currency switch
    {
        "DGB" => 8,
        "JPY" => 0,
        _ => 2,
    };

    private bool HasAmount => decimal.TryParse(amount, NumberStyles.Number, CultureInfo.InvariantCulture, out var a) && a > 0;
    private string FormattedAmount => string.IsNullOrEmpty(amount) ? "0" : amount;

    // Gratuity. Stored as an integer percentage of the subtotal so the rate is
    // obvious in receipts/reports. 0 = no tip. We only support presets for now
    // (10/15/20) — custom-amount / custom-% can be added later without schema
    // changes because the tip is folded into the total before it ever hits the
    // API.
    private static readonly int[] TipPresets = new[] { 0, 10, 15, 20 };
    private int tipPercent;

    private decimal? SubtotalDecimal =>
        decimal.TryParse(amount, NumberStyles.Number, CultureInfo.InvariantCulture, out var v) && v > 0 ? v : null;

    // Tip is computed off the subtotal in whatever currency the cashier is in,
    // then rounded to the currency's display precision so "10% of 12.50 EUR"
    // is a clean 1.25 instead of banker-rounded nonsense.
    private decimal TipDecimal
    {
        get
        {
            if (tipPercent <= 0 || SubtotalDecimal is not decimal sub) return 0m;
            var raw = sub * tipPercent / 100m;
            return Math.Round(raw, MaxDecimals, MidpointRounding.AwayFromZero);
        }
    }

    private decimal? TotalDecimal => SubtotalDecimal is decimal sub ? sub + TipDecimal : null;

    // String form the "Charge" button actually commits. Uses the subtotal's
    // literal string when tipPercent=0 so we don't round-trip "12.5" → "12.50"
    // and surprise the cashier; otherwise formats the computed total.
    private string AmountForCharge
    {
        get
        {
            if (tipPercent == 0) return amount;
            if (TotalDecimal is decimal t)
            {
                return MaxDecimals == 0
                    ? t.ToString("0", CultureInfo.InvariantCulture)
                    : t.ToString("0." + new string('#', MaxDecimals), CultureInfo.InvariantCulture);
            }
            return amount;
        }
    }

    // Live DGB equivalent of the fiat amount the cashier has typed. Used for
    // the secondary readout on the keypad + for the charge payload. Returns
    // null if we don't have a price yet or the amount is empty / invalid.
    // When a tip is applied, converts the total (subtotal + tip) so what the
    // customer sees on the QR matches what their wallet will ask them to sign.
    private decimal? DgbEquivalent
    {
        get
        {
            if (!IsFiat || dgbPrice is not decimal p || p <= 0) return null;
            if (TotalDecimal is not decimal fiat || fiat <= 0) return null;
            // Round to 8dp (satoshi grid). Banker's rounding would bias us, so
            // use AwayFromZero — customers paying fiat-quoted invoices expect
            // "no less than" the quote, and InvoiceMonitor has a 1% slack
            // either way, so a half-sat rounding up can't trip underpayment.
            return Math.Round(fiat / p, 8, MidpointRounding.AwayFromZero);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        // Load a previously paired device from localStorage so returning
        // cashiers don't see the pair screen every session.
        var stored = await JS.InvokeAsync<PairedDevice?>("digipayPos.load");
        if (stored is { ApiKey.Length: > 0, StoreId.Length: > 0 })
        {
            device = stored;
            screen = Screen.Keypad;
        }
        hasPin = await JS.InvokeAsync<bool>("digipayPos.hasPin");
        // Remember the last-selected currency so a JPY till stays on JPY
        // across reloads.
        var storedCurrency = await JS.InvokeAsync<string?>("digipayPos.loadCurrency");
        if (!string.IsNullOrWhiteSpace(storedCurrency)
            && SupportedCurrencies.Contains(storedCurrency))
        {
            currency = storedCurrency;
        }
        if (IsFiat) _ = RefreshPriceAsync();
        StateHasChanged();
    }

    private string KeyClass(string key) => key switch
    {
        "back" => "bg-slate-800 hover:bg-slate-700 text-slate-300",
        "." => "bg-slate-800 hover:bg-slate-700 text-slate-300",
        _ => "bg-dgb-900 hover:bg-dgb-800 border border-dgb-800 text-white",
    };

    private void PressKey(string key)
    {
        chargeError = null;
        if (key == "back")
        {
            if (amount.Length > 0) amount = amount[..^1];
            return;
        }
        if (key == ".")
        {
            // Currencies with no sub-unit (JPY) don't get a decimal point at all.
            if (MaxDecimals == 0) return;
            if (amount.Contains('.')) return;
            amount = amount.Length == 0 ? "0." : amount + ".";
            return;
        }
        // Numeric
        // Prevent leading-zero weirdness ("007" stays "7") but keep "0.x"
        if (amount == "0") { amount = key == "0" ? "0" : key; return; }
        // Cap decimal precision per currency (8 for DGB, 2 for fiat, 0 for JPY).
        var dot = amount.IndexOf('.');
        if (dot >= 0 && amount.Length - dot - 1 >= MaxDecimals) return;
        // Cap total length to avoid absurd inputs
        if (amount.Length >= 16) return;
        amount += key;
    }

    private async Task CycleCurrencyAsync()
    {
        var i = Array.IndexOf(SupportedCurrencies, currency);
        currency = SupportedCurrencies[(i + 1) % SupportedCurrencies.Length];
        // Reset the typed amount — switching precision mid-entry ("12.345" in
        // USD) is more confusing than starting fresh. Tip clears with it so the
        // cashier isn't silently carrying "20%" over to a different till mode.
        amount = "";
        tipPercent = 0;
        chargeError = null;
        await JS.InvokeVoidAsync("digipayPos.saveCurrency", currency);
        if (IsFiat) _ = RefreshPriceAsync();
        else { dgbPrice = null; priceError = null; StopPriceTimer(); }
    }

    private void SetTip(int percent)
    {
        // Tapping the already-active preset clears it (acts as a toggle). Lets
        // the cashier "unselect" 15% without a dedicated clear button.
        tipPercent = tipPercent == percent ? 0 : percent;
        chargeError = null;
    }

    // Formats a number using the current currency's display precision, without
    // trailing zeros except for JPY where we always show integers.
    private string FormatAmount(decimal value) => MaxDecimals switch
    {
        0 => value.ToString("0", CultureInfo.InvariantCulture),
        _ => value.ToString("0." + new string('#', MaxDecimals), CultureInfo.InvariantCulture),
    };

    private async Task RefreshPriceAsync()
    {
        if (!IsFiat) return;
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var resp = await http.GetAsync($"/v1/pay/public/price?currency={currency.ToLowerInvariant()}");
            if (!resp.IsSuccessStatusCode)
            {
                priceError = "Price feed unavailable — switch to DGB or try again.";
                dgbPrice = null;
                return;
            }
            var body = await resp.Content.ReadFromJsonAsync<PriceQuote>();
            if (body is null || body.DgbPrice <= 0)
            {
                priceError = "Price feed returned nothing.";
                dgbPrice = null;
                return;
            }
            dgbPrice = body.DgbPrice;
            dgbPriceFetchedAt = body.FetchedAt;
            priceError = null;
            StartPriceTimer();
        }
        catch (Exception ex)
        {
            priceError = $"Price feed error: {ex.Message}";
            dgbPrice = null;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void StartPriceTimer()
    {
        // Refresh every 60s, matching the server's fresh cache window. The
        // server single-flights concurrent requests, so even a busy fleet of
        // tablets costs CoinGecko at most 1 call/currency/minute.
        priceTimer ??= new System.Threading.Timer(async _ =>
        {
            if (IsFiat && screen == Screen.Keypad) await RefreshPriceAsync();
        }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
    }

    private void StopPriceTimer()
    {
        priceTimer?.Dispose();
        priceTimer = null;
    }

    private async Task ClaimPairingAsync()
    {
        pairError = null;
        busy = true;
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.PostAsJsonAsync("/v1/pay/pos/claim", new { code = pairCode.Trim() });
            if (!response.IsSuccessStatusCode)
            {
                pairError = response.StatusCode == System.Net.HttpStatusCode.NotFound
                    ? "That pairing code is invalid or has expired."
                    : $"Pairing failed ({(int)response.StatusCode}).";
                return;
            }
            var dto = await response.Content.ReadFromJsonAsync<ClaimResponse>();
            if (dto is null) { pairError = "Pairing failed — empty response."; return; }
            await SaveDeviceAsync(new PairedDevice(
                dto.ApiKey, dto.StoreId, dto.StoreName,
                dto.MerchantName, dto.DeviceLabel));
            screen = Screen.Keypad;
        }
        catch (Exception ex) { pairError = $"Pairing failed: {ex.Message}"; }
        finally { busy = false; }
    }

    private async Task ApplyManualKeyAsync()
    {
        pairError = null;
        busy = true;
        try
        {
            var key = manualApiKey.Trim();
            if (!key.StartsWith("dgp_")) { pairError = "API key should start with \"dgp_\"."; return; }
            var http = HttpFactory.CreateClient("PayApi");
            // Resolve the merchant + stores for this key so we can prefill
            // name/store info without asking the user to type them.
            var req = new HttpRequestMessage(HttpMethod.Get, "/v1/pay/me");
            req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", key);
            var resp = await http.SendAsync(req);
            if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            { pairError = "That API key was rejected."; return; }
            if (!resp.IsSuccessStatusCode)
            { pairError = $"Could not verify key ({(int)resp.StatusCode})."; return; }

            var me = await resp.Content.ReadFromJsonAsync<MeResponse>();
            var stores = me?.Stores ?? new();
            if (stores.Count == 0) { pairError = "This account has no stores yet."; return; }

            var targetId = string.IsNullOrWhiteSpace(manualStoreId) ? stores[0].Id : manualStoreId.Trim();
            var target = stores.FirstOrDefault(s => s.Id == targetId);
            if (target is null) { pairError = "Store ID not found for this account."; return; }

            await SaveDeviceAsync(new PairedDevice(
                key, target.Id, target.Name, me?.DisplayName ?? "", "Manual pairing"));
            screen = Screen.Keypad;
        }
        catch (Exception ex) { pairError = $"Could not verify key: {ex.Message}"; }
        finally { busy = false; }
    }

    private async Task SaveDeviceAsync(PairedDevice d)
    {
        device = d;
        await JS.InvokeVoidAsync("digipayPos.save", d);
    }

    private async Task ChargeAsync()
    {
        chargeError = null;
        if (!HasAmount || device is null) return;

        // In fiat mode the cashier typed a fiat amount — convert to DGB for
        // the on-chain invoice and stash the fiat context on the session so
        // the dashboard / receipt / CSV can show both. When a tip is applied
        // it's already folded into TotalDecimal / DgbEquivalent, so the
        // conversion below uses the combined number.
        decimal dgbAmount;
        decimal? fiatAmount = null;
        string? fiatCurrency = null;
        decimal? priceSnapshot = null;
        if (IsFiat)
        {
            if (DgbEquivalent is not decimal d || TotalDecimal is not decimal totalFiat)
            {
                chargeError = priceError ?? "Price feed unavailable — cannot charge in fiat.";
                return;
            }
            dgbAmount = d;
            fiatAmount = totalFiat;
            fiatCurrency = currency;
            priceSnapshot = dgbPrice;
        }
        else
        {
            dgbAmount = decimal.Parse(AmountForCharge, CultureInfo.InvariantCulture);
        }

        // When tipped, annotate the session label so the breakdown survives in
        // the dashboard, webhooks, exports, and receipts without needing an
        // extra column on PaySession. Keeps the tip visible to the merchant
        // even though the on-chain amount is "total only".
        string? label = string.IsNullOrWhiteSpace(labelInput) ? null : labelInput.Trim();
        if (tipPercent > 0 && SubtotalDecimal is decimal subtotalForLabel)
        {
            var tipNote = $"Tip {tipPercent}% ({FormatAmount(TipDecimal)} {currency})";
            label = string.IsNullOrEmpty(label) ? tipNote : $"{label} · {tipNote}";
        }

        busy = true;
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var req = new HttpRequestMessage(HttpMethod.Post, "/v1/pay/sessions")
            {
                Content = JsonContent.Create(new
                {
                    amount = dgbAmount,
                    storeId = device.StoreId,
                    label,
                    fiatCurrency,
                    fiatAmount,
                    dgbPriceAtCreation = priceSnapshot,
                }),
            };
            req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", device.ApiKey);
            var resp = await http.SendAsync(req);
            if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                chargeError = "Pairing was revoked — unpair and re-pair this device.";
                return;
            }
            if (!resp.IsSuccessStatusCode)
            {
                chargeError = $"Could not create session ({(int)resp.StatusCode}).";
                return;
            }
            session = await resp.Content.ReadFromJsonAsync<CreatedSession>();
            if (session is null) { chargeError = "Empty response from server."; return; }
            qrDataUrl = GenerateQr(session.Uri);
            screen = Screen.Waiting;
            await ConnectHubAsync();
        }
        catch (Exception ex) { chargeError = $"Failed: {ex.Message}"; }
        finally { busy = false; }
    }

    private async Task ConnectHubAsync()
    {
        if (hub is not null) await hub.DisposeAsync();
        hub = new HubConnectionBuilder()
            .WithUrl($"{PayApi.Value}/hubs/checkout")
            .WithAutomaticReconnect()
            .Build();
        hub.On<StatusUpdate>("StatusChanged", OnStatusChangedAsync);
        await hub.StartAsync();
        if (session != null)
            await hub.InvokeAsync("SubscribeToSession", session.Id);
    }

    private async Task OnStatusChangedAsync(StatusUpdate u)
    {
        if (session is null) return;
        await InvokeAsync(() =>
        {
            session = session with
            {
                Status = u.Status,
                ReceivedSatoshis = u.ReceivedSatoshis,
                Confirmations = u.Confirmations,
                PaidTxid = u.Txid ?? session.PaidTxid,
            };
            if (IsTerminal(u.Status)) _ = ShowResultAsync(u.Status, u.Txid, u.ReceivedSatoshis);
            else StateHasChanged();
        });
    }

    private async Task ShowResultAsync(string status, string? txid, long received)
    {
        resultStatus = status;
        resultTxid = txid;
        resultAmount = received;
        screen = Screen.Result;
        StateHasChanged();
        // Tear down the hub — we're done with this session.
        if (hub is not null) { try { await hub.DisposeAsync(); } catch { } hub = null; }

        if (status == "confirmed")
        {
            await JS.InvokeVoidAsync("digipayPos.beep").ConfigureAwait(false);
            autoReturnCts?.Cancel();
            autoReturnCts = new CancellationTokenSource();
            var ct = autoReturnCts.Token;
            autoReturnSeconds = 5;
            _ = Task.Run(async () =>
            {
                try
                {
                    for (var i = 5; i > 0; i--)
                    {
                        autoReturnSeconds = i;
                        await InvokeAsync(StateHasChanged);
                        await Task.Delay(1000, ct);
                    }
                    await InvokeAsync(NewSale);
                }
                catch (TaskCanceledException) { /* cancelled — operator hit New sale */ }
            }, ct);
        }
    }

    private async Task CancelChargeAsync()
    {
        if (hub is not null) { try { await hub.DisposeAsync(); } catch { } hub = null; }
        session = null;
        qrDataUrl = null;
        tipPercent = 0;
        screen = Screen.Keypad;
    }

    private void NewSale()
    {
        autoReturnCts?.Cancel();
        amount = "";
        labelInput = "";
        tipPercent = 0;
        session = null;
        qrDataUrl = null;
        resultStatus = null;
        resultTxid = null;
        resultAmount = null;
        screen = Screen.Keypad;
        StateHasChanged();
    }

    private Task ShowUnpairAsync()
    {
        // If a manager PIN is set, require it before even showing the confirm
        // dialog. Keeps staff from accidentally (or deliberately) disarming
        // the tablet while the owner is away.
        if (hasPin)
        {
            return PromptPinAsync("Enter the manager PIN to unpair this device.", () =>
            {
                showUnpair = true;
                StateHasChanged();
                return Task.CompletedTask;
            });
        }
        showUnpair = true;
        return Task.CompletedTask;
    }

    private async Task OpenShiftReportAsync()
    {
        if (device is null) return;
        // Reset state every time so a stale report from a previous open never
        // flashes. Show the modal immediately and let the fetch populate.
        shiftReport = null;
        shiftReportError = null;
        showShiftReport = true;
        StateHasChanged();

        try
        {
            var since = await JS.InvokeAsync<string?>("digipayPos.loadShiftStart");
            var http = HttpFactory.CreateClient("PayApi");
            var url = $"/v1/pay/pos/shift-report?storeId={Uri.EscapeDataString(device.StoreId)}";
            if (!string.IsNullOrWhiteSpace(since))
                url += $"&since={Uri.EscapeDataString(since)}";
            var req = new HttpRequestMessage(HttpMethod.Get, url);
            req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", device.ApiKey);
            var resp = await http.SendAsync(req);
            if (!resp.IsSuccessStatusCode)
            {
                shiftReportError = $"Could not load report ({(int)resp.StatusCode}).";
                return;
            }
            shiftReport = await resp.Content.ReadFromJsonAsync<ShiftReport>();
            if (shiftReport is null) shiftReportError = "Empty response from server.";
        }
        catch (Exception ex) { shiftReportError = $"Failed: {ex.Message}"; }
    }

    private async Task StartNewShiftAsync()
    {
        // Stamp "now" so the next report only shows sales from this moment
        // onward. Per-tablet by design — the dashboard keeps the merchant-
        // wide picture, this is purely a cashier convenience.
        var nowIso = DateTime.UtcNow.ToString("o", CultureInfo.InvariantCulture);
        await JS.InvokeVoidAsync("digipayPos.saveShiftStart", nowIso);
        showShiftReport = false;
        shiftReport = null;
    }

    private void OpenPinSettings()
    {
        pinNew = "";
        pinConfirm = "";
        pinSettingsError = null;

        // If a PIN already exists, the "Change" flow must first verify the
        // old PIN so a walk-up attacker can't silently rotate it.
        if (hasPin)
        {
            _ = PromptPinAsync("Enter the current manager PIN to change it.", () =>
            {
                showPinSettings = true;
                StateHasChanged();
                return Task.CompletedTask;
            });
            return;
        }
        showPinSettings = true;
    }

    private void ClosePinSettings()
    {
        showPinSettings = false;
        pinNew = "";
        pinConfirm = "";
        pinSettingsError = null;
    }

    private async Task SavePinAsync()
    {
        pinSettingsError = null;
        if (!CanSavePin)
        {
            pinSettingsError = "PIN must be 4–8 digits and match in both fields.";
            return;
        }
        var ok = await JS.InvokeAsync<bool>("digipayPos.setPin", pinNew);
        if (!ok) { pinSettingsError = "Could not save PIN — try again."; return; }
        hasPin = true;
        ClosePinSettings();
    }

    private async Task RemovePinAsync()
    {
        // Removing a PIN is itself a guarded action — require the current PIN
        // before we wipe it. Same reasoning as change-PIN.
        await JS.InvokeVoidAsync("digipayPos.clearPin");
        hasPin = false;
        ClosePinSettings();
    }

    private Task PromptPinAsync(string prompt, Func<Task> onSuccess)
    {
        pinChallengePrompt = prompt;
        pinChallengeError = null;
        pinEntered = "";
        pinChallengePending = onSuccess;
        showPinChallenge = true;
        return Task.CompletedTask;
    }

    private void CancelPinChallenge()
    {
        showPinChallenge = false;
        pinChallengePending = null;
        pinEntered = "";
        pinChallengeError = null;
    }

    private async Task VerifyPinChallengeAsync()
    {
        pinChallengeError = null;
        var ok = await JS.InvokeAsync<bool>("digipayPos.verifyPin", pinEntered);
        if (!ok) { pinChallengeError = "Incorrect PIN."; return; }
        var pending = pinChallengePending;
        CancelPinChallenge();
        if (pending != null) await pending();
    }

    private async Task UnpairAsync()
    {
        showUnpair = false;
        await JS.InvokeVoidAsync("digipayPos.clear");
        device = null;
        pairCode = "";
        manualApiKey = "";
        manualStoreId = "";
        screen = Screen.Pair;
    }

    private static string GenerateQr(string content)
    {
        using var gen = new QRCoder.QRCodeGenerator();
        using var data = gen.CreateQrCode(content, QRCoder.QRCodeGenerator.ECCLevel.H);
        using var qr = new QRCoder.PngByteQRCode(data);
        return $"data:image/png;base64,{Convert.ToBase64String(qr.GetGraphic(8))}";
    }

    private static string FormatDgb(long sats) =>
        (sats / 100_000_000m).ToString("0.########", CultureInfo.InvariantCulture);

    private static string FormatDgb8(decimal dgb) =>
        dgb.ToString("0.########", CultureInfo.InvariantCulture);

    private static bool IsTerminal(string status) =>
        status is "confirmed" or "expired" or "underpaid";

    public async ValueTask DisposeAsync()
    {
        autoReturnCts?.Cancel();
        StopPriceTimer();
        if (hub != null) { try { await hub.DisposeAsync(); } catch { } }
    }

