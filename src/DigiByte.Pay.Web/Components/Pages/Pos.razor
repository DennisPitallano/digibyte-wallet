@page "/pos"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IHttpClientFactory HttpFactory
@inject PayApiUrl PayApi
@inject IJSRuntime JS
@using Microsoft.AspNetCore.SignalR.Client
@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json.Serialization

<PageTitle>@(device?.StoreName is { Length: > 0 } s ? $"{s} — POS" : "DigiPay POS")</PageTitle>

@* Full-bleed kiosk shell. Fixed dark theme so the tablet looks consistent
   regardless of the merchant's OS light/dark setting, and so the success
   flash-green actually reads as success on a countertop. No nav, no chrome. *@
<div class="fixed inset-0 bg-slate-950 text-white font-sans flex flex-col select-none touch-manipulation overflow-hidden">

    @if (screen == Screen.Pair)
    {
        <div class="flex-1 flex items-center justify-center p-6">
            <div class="w-full max-w-md bg-dgb-900 border border-dgb-800 rounded-3xl p-6 sm:p-8 flex flex-col gap-4 shadow-2xl">
                <header class="flex items-center gap-3 pb-2">
                    <img src="/digipay-logo.svg" alt="" class="w-10 h-10" />
                    <div>
                        <div class="text-lg font-extrabold tracking-tight">Digi<span class="text-dgb-500">Pay</span> POS</div>
                        <div class="text-xs text-slate-400">Pair this device to start taking payments</div>
                    </div>
                </header>

                <div class="flex rounded-xl bg-slate-900 p-1 text-sm font-semibold">
                    <button class="flex-1 py-2 rounded-lg transition-colors @(pairMode == "code" ? "bg-dgb-500 text-white" : "text-slate-400")"
                            @onclick="@(() => pairMode = "code")">Pairing code</button>
                    <button class="flex-1 py-2 rounded-lg transition-colors @(pairMode == "key" ? "bg-dgb-500 text-white" : "text-slate-400")"
                            @onclick="@(() => pairMode = "key")">API key</button>
                </div>

                @if (pairMode == "code")
                {
                    <label class="text-[0.6875rem] font-bold uppercase tracking-widest text-slate-400 block">
                        Enter the 6-character code from your dashboard
                    </label>
                    <input @bind="pairCode" @bind:event="oninput" autocomplete="off" autocorrect="off" autocapitalize="characters" spellcheck="false"
                           maxlength="8" placeholder="AB2C9D"
                           class="w-full text-center font-mono text-3xl tracking-[0.5em] uppercase bg-slate-900 border border-dgb-800 rounded-xl py-4 focus:outline-none focus:ring-2 focus:ring-dgb-500/50" />
                    <button class="w-full py-3 bg-dgb-500 hover:bg-dgb-600 disabled:bg-dgb-500/40 text-white font-bold rounded-xl text-base transition-colors"
                            @onclick="ClaimPairingAsync" disabled="@(busy || string.IsNullOrWhiteSpace(pairCode))">
                        @(busy ? "Pairing…" : "Pair this device")
                    </button>
                }
                else
                {
                    <label class="text-[0.6875rem] font-bold uppercase tracking-widest text-slate-400 block">
                        Paste an API key (dgp_…)
                    </label>
                    <input @bind="manualApiKey" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
                           placeholder="dgp_xxxx_xxxxxxxx…"
                           class="w-full font-mono text-sm bg-slate-900 border border-dgb-800 rounded-xl px-3 py-3 focus:outline-none focus:ring-2 focus:ring-dgb-500/50" />
                    <label class="text-[0.6875rem] font-bold uppercase tracking-widest text-slate-400 block">
                        Store ID (optional — leaves blank to use default store)
                    </label>
                    <input @bind="manualStoreId" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
                           placeholder="sto_…"
                           class="w-full font-mono text-sm bg-slate-900 border border-dgb-800 rounded-xl px-3 py-3 focus:outline-none focus:ring-2 focus:ring-dgb-500/50" />
                    <button class="w-full py-3 bg-dgb-500 hover:bg-dgb-600 disabled:bg-dgb-500/40 text-white font-bold rounded-xl text-base transition-colors"
                            @onclick="ApplyManualKeyAsync" disabled="@(busy || string.IsNullOrWhiteSpace(manualApiKey))">
                        @(busy ? "Checking…" : "Use this key")
                    </button>
                }

                @if (pairError != null)
                {
                    <p class="text-sm text-red-400 text-center m-0">@pairError</p>
                }

                <p class="text-[0.6875rem] text-slate-500 text-center m-0 mt-2">
                    Tip: add this page to your home screen for a full-screen experience.
                </p>
            </div>
        </div>
    }
    else
    {
        @* Top bar — merchant + store + "lock / unpair" access. Minimal so the
           keypad and QR dominate the viewport. *@
        <header class="flex items-center justify-between px-4 sm:px-6 py-3 border-b border-dgb-800/60 shrink-0">
            <div class="flex items-center gap-2.5 min-w-0">
                <img src="/digipay-logo.svg" alt="" class="w-7 h-7 shrink-0" />
                <div class="min-w-0">
                    <div class="text-sm font-bold truncate">@(device?.StoreName ?? "Store")</div>
                    <div class="text-[0.6875rem] text-slate-500 truncate">@(device?.MerchantName ?? "")</div>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <button class="w-9 h-9 flex items-center justify-center text-slate-300 border border-dgb-800 rounded-lg hover:bg-dgb-900 transition-colors"
                        @onclick="OpenPinSettings" title="@(hasPin ? "Change / remove PIN" : "Set a manager PIN")" aria-label="PIN settings">
                    <Icon Name="@(hasPin ? "shield" : "settings")" Class="w-4 h-4" />
                </button>
                @* "Close shift" surfaces the today-so-far summary. Disabled on
                   anything but the keypad screen so we don't yank the cashier
                   out of a sale mid-flow. *@
                <button class="px-3 py-1.5 text-xs font-semibold text-slate-300 border border-dgb-800 rounded-lg hover:bg-dgb-900 transition-colors disabled:opacity-40"
                        @onclick="OpenShiftReportAsync" disabled="@(screen != Screen.Keypad)" title="Today's totals">Close shift</button>
                <button class="px-3 py-1.5 text-xs font-semibold text-slate-300 border border-dgb-800 rounded-lg hover:bg-dgb-900 transition-colors"
                        @onclick="ShowUnpairAsync" title="Unpair this device">Unpair</button>
            </div>
        </header>

        @if (screen == Screen.Keypad)
        {
            <main class="flex-1 grid grid-rows-[auto_1fr_auto] md:grid-cols-2 md:grid-rows-1 gap-4 p-4 sm:p-6 min-h-0">

                @* Amount readout *@
                <section class="md:order-2 flex flex-col items-center justify-center bg-dgb-900/60 border border-dgb-800 rounded-3xl p-6 min-h-[8rem] relative">

                    @* Currency cycler — small pill in the corner so the primary
                       readout is uncluttered. Tap to rotate DGB → USD → EUR → … *@
                    <button class="absolute top-3 right-3 px-2.5 py-1 rounded-full text-[0.625rem] font-bold tracking-wider bg-dgb-800 hover:bg-dgb-700 border border-dgb-700 text-dgb-100 transition-colors"
                            @onclick="CycleCurrencyAsync" title="Cycle currency">
                        @currency
                    </button>

                    <div class="text-[0.6875rem] uppercase tracking-widest text-slate-400 mb-2">Total</div>
                    <div class="text-5xl sm:text-6xl md:text-7xl font-bold tabular-nums">
                        @(tipPercent > 0 && TotalDecimal is decimal tot ? FormatAmount(tot) : FormattedAmount) <span class="text-dgb-500">@currency</span>
                    </div>

                    @if (tipPercent > 0 && SubtotalDecimal is decimal subTotal)
                    {
                        @* Tip breakdown: shown only when a tip is applied so the
                           cashier / customer can see exactly how the total was
                           built. Doesn't exist as separate fields on the invoice
                           — the charge amount is just subtotal + tip folded in. *@
                        <div class="text-xs text-slate-400 mt-2">
                            @FormatAmount(subTotal) + @FormatAmount(TipDecimal) tip (@tipPercent%)
                        </div>
                    }

                    @if (IsFiat)
                    {
                        @* Secondary line: live DGB conversion. Keeps the cashier
                           honest about what's actually being invoiced and gives
                           a fallback to sanity-check the rate. *@
                        <div class="text-xs text-slate-400 mt-2 h-4">
                            @if (priceError != null)
                            {
                                <span class="text-amber-400">@priceError</span>
                            }
                            else if (DgbEquivalent is decimal d)
                            {
                                <span>≈ @d.ToString("0.########") DGB</span>
                                @if (dgbPrice is decimal p)
                                {
                                    <span class="text-slate-600 ml-2">· 1 DGB = @p.ToString("0.########") @currency</span>
                                }
                            }
                            else if (dgbPrice is null && !string.IsNullOrEmpty(amount))
                            {
                                <span>Fetching price…</span>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(labelInput))
                    {
                        <div class="text-xs text-slate-400 mt-3 truncate max-w-full">@labelInput</div>
                    }
                </section>

                @* Keypad *@
                <section class="md:order-1 flex flex-col gap-3 min-h-0">
                    <input @bind="labelInput" @bind:event="oninput" maxlength="60" placeholder="Label (optional — e.g. Order #42)"
                           class="w-full bg-slate-900 border border-dgb-800 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-dgb-500/50" />
                    <div class="grid grid-cols-3 gap-2 sm:gap-3 flex-1">
                        @foreach (var k in KeypadKeys)
                        {
                            var key = k;
                            <button class="@KeyClass(key) text-2xl sm:text-3xl font-bold rounded-2xl transition-all active:scale-95"
                                    @onclick="() => PressKey(key)">
                                @(key == "back" ? "⌫" : key)
                            </button>
                        }
                    </div>
                    @* Gratuity pill row — only makes sense once the cashier has
                       entered a base amount, so hide the whole strip until then
                       to keep the quick-sale (no-tip) flow uncluttered. *@
                    @if (HasAmount)
                    {
                        <div class="flex gap-2" role="group" aria-label="Tip">
                            @foreach (var pct in TipPresets)
                            {
                                var p = pct;
                                var selected = tipPercent == p;
                                var cls = selected
                                    ? "bg-dgb-500 text-white border-dgb-500"
                                    : "bg-slate-900 hover:bg-slate-800 text-slate-300 border-dgb-800";
                                <button type="button"
                                        class="flex-1 py-2 text-sm font-bold rounded-xl border transition-colors @cls"
                                        @onclick="() => SetTip(p)">
                                    @(p == 0 ? "No tip" : $"{p}%")
                                </button>
                            }
                        </div>
                    }
                    <button class="w-full py-5 bg-dgb-500 hover:bg-dgb-600 disabled:bg-dgb-500/30 disabled:text-white/50 text-white font-extrabold rounded-2xl text-xl transition-colors active:scale-[0.99]"
                            @onclick="ChargeAsync" disabled="@(busy || !HasAmount)">
                        @(busy ? "Creating…" : "Charge")
                    </button>
                    @if (chargeError != null)
                    {
                        <p class="text-sm text-red-400 text-center m-0">@chargeError</p>
                    }
                </section>
            </main>
        }
        else if (screen == Screen.Waiting && session != null)
        {
            <main class="flex-1 grid grid-rows-[auto_1fr] md:grid-cols-2 md:grid-rows-1 gap-6 p-4 sm:p-6 min-h-0 items-center">

                <section class="flex flex-col items-center gap-3 order-2 md:order-1">
                    <div class="bg-white p-3 rounded-3xl shadow-2xl">
                        <img src="@qrDataUrl" alt="Scan to pay" class="block w-64 h-64 sm:w-80 sm:h-80 rounded-xl" />
                    </div>
                    <div class="font-mono text-[0.6875rem] text-slate-400 break-all max-w-xs text-center">@session.Address</div>
                </section>

                <section class="flex flex-col items-center md:items-start gap-4 order-1 md:order-2 text-center md:text-left">
                    <div>
                        <div class="text-[0.6875rem] uppercase tracking-widest text-slate-400">Asking</div>
                        @if (session.FiatAmount is decimal fa && !string.IsNullOrEmpty(session.FiatCurrency))
                        {
                            @* Fiat-quoted sale: lead with the fiat number (what the
                               cashier rang up) and put the DGB equivalent underneath
                               so the customer can reconcile with what their wallet shows. *@
                            <div class="text-5xl sm:text-6xl md:text-7xl font-bold tabular-nums mt-1">
                                @fa.ToString("0.##") <span class="text-dgb-500">@session.FiatCurrency</span>
                            </div>
                            <div class="text-sm text-slate-400 mt-1">≈ @FormatDgb(session.AmountSatoshis) DGB</div>
                        }
                        else
                        {
                            <div class="text-5xl sm:text-6xl md:text-7xl font-bold tabular-nums mt-1">
                                @FormatDgb(session.AmountSatoshis) <span class="text-dgb-500">DGB</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(session.Label))
                        {
                            <div class="text-sm text-slate-300 mt-2">@session.Label</div>
                        }
                    </div>

                    @{
                        var statusColour = session.Status switch
                        {
                            "seen" => "bg-amber-500/20 text-amber-300 border-amber-500/30",
                            "paid" => "bg-emerald-500/20 text-emerald-300 border-emerald-500/30",
                            _ => "bg-slate-500/20 text-slate-300 border-slate-500/30",
                        };
                        var statusText = session.Status switch
                        {
                            "pending" => "Waiting for scan…",
                            "seen" => "Transaction detected — confirming",
                            "paid" => $"Paid · {session.Confirmations} conf",
                            _ => session.Status,
                        };
                    }
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border text-sm font-semibold @statusColour">
                        <span class="w-2 h-2 rounded-full bg-current animate-pulse"></span>
                        @statusText
                    </div>

                    <div class="text-xs text-slate-500">
                        Expires in <span data-digipay-expires="@session.ExpiresAt.ToString("o", CultureInfo.InvariantCulture)">—</span>
                    </div>

                    <button class="mt-2 px-5 py-3 bg-slate-800 hover:bg-slate-700 text-slate-200 font-semibold rounded-xl text-sm transition-colors"
                            @onclick="CancelChargeAsync">Cancel sale</button>
                </section>
            </main>
        }
        else if (screen == Screen.Result)
        {
            <main class="flex-1 flex items-center justify-center p-6">
                @{
                    var success = resultStatus == "confirmed";
                    var ring = success ? "bg-emerald-500" : (resultStatus == "underpaid" ? "bg-red-500" : "bg-slate-600");
                    var icon = success ? "✓" : (resultStatus == "underpaid" ? "!" : "⏱");
                    var heading = success ? "Payment received" : resultStatus == "underpaid" ? "Underpaid" : "Expired";
                    var body = success
                        ? "Thank the customer — all done."
                        : resultStatus == "underpaid"
                            ? "Amount received was less than requested."
                            : "No payment received in time.";
                }
                <div class="w-full max-w-lg bg-dgb-900 border border-dgb-800 rounded-3xl p-8 flex flex-col items-center gap-5 shadow-2xl text-center">
                    <div class="w-24 h-24 rounded-full flex items-center justify-center text-white text-5xl font-bold shadow-lg @ring">@icon</div>
                    <div>
                        <h2 class="text-3xl font-extrabold m-0">@heading</h2>
                        <p class="text-sm text-slate-400 mt-2 m-0">@body</p>
                    </div>
                    @if (success && resultAmount != null)
                    {
                        <div class="text-4xl font-bold tabular-nums">@FormatDgb(resultAmount.Value) <span class="text-dgb-500">DGB</span></div>
                    }
                    @if (!string.IsNullOrEmpty(resultTxid))
                    {
                        <div class="font-mono text-[0.625rem] text-slate-500 break-all max-w-full">@resultTxid</div>
                    }
                    <button class="w-full py-4 bg-dgb-500 hover:bg-dgb-600 text-white font-extrabold rounded-2xl text-lg transition-colors mt-2"
                            @onclick="NewSale">New sale</button>
                    @if (success)
                    {
                        <p class="text-[0.6875rem] text-slate-500 m-0">Auto-returning in @autoReturnSeconds…</p>
                    }
                </div>
            </main>
        }
    }
</div>

@* Unpair confirmation *@
@if (showUnpair)
{
    <div class="fixed inset-0 bg-black/70 z-50 flex items-center justify-center p-6" @onclick="() => showUnpair = false">
        <div class="bg-dgb-900 border border-dgb-800 rounded-2xl p-6 max-w-sm w-full text-white" @onclick:stopPropagation>
            <h3 class="text-lg font-bold m-0 mb-2">Unpair this device?</h3>
            <p class="text-sm text-slate-400 m-0 mb-4">The stored API key will be forgotten on this tablet. Revoke it from the dashboard too if it's lost or stolen.</p>
            <div class="flex gap-2">
                <button class="flex-1 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-200 font-semibold rounded-lg text-sm" @onclick="() => showUnpair = false">Cancel</button>
                <button class="flex-1 py-2.5 bg-red-500 hover:bg-red-600 text-white font-semibold rounded-lg text-sm" @onclick="UnpairAsync">Unpair</button>
            </div>
        </div>
    </div>
}

@* Shift close / end-of-day summary.
   Pulls from /v1/pay/pos/shift-report?since=<shiftStartedAt>. The "since"
   timestamp is kept in localStorage per-tablet so resetting the shift only
   affects this till, not the merchant's aggregate dashboard numbers. *@
@if (showShiftReport)
{
    <div class="fixed inset-0 bg-black/70 z-50 flex items-center justify-center p-6" @onclick="() => showShiftReport = false">
        <div class="bg-dgb-900 border border-dgb-800 rounded-2xl p-6 max-w-md w-full text-white" @onclick:stopPropagation>
            <div class="flex items-start justify-between gap-2 mb-4">
                <div>
                    <h3 class="text-lg font-bold m-0">Shift summary</h3>
                    @if (shiftReport is not null)
                    {
                        <p class="text-xs text-slate-400 m-0 mt-0.5">@shiftReport.From.ToLocalTime().ToString("dd MMM, HH:mm") → @shiftReport.To.ToLocalTime().ToString("HH:mm")</p>
                    }
                </div>
                <button class="text-slate-400 hover:text-white text-lg leading-none p-1" @onclick="() => showShiftReport = false" aria-label="Close">×</button>
            </div>

            @if (shiftReportError is not null)
            {
                <p class="text-sm text-red-400 m-0">@shiftReportError</p>
            }
            else if (shiftReport is null)
            {
                <p class="text-sm text-slate-400 m-0">Loading…</p>
            }
            else
            {
                var totals = shiftReport.Totals;
                var outcomes = shiftReport.Outcomes;
                <div class="space-y-4">
                    @* Collected / totals block. DGB total is always shown (it's
                       the one number that survives across currencies); fiat
                       buckets are listed only when present so a DGB-only till
                       doesn't render an empty section. *@
                    <div>
                        <div class="text-[0.6875rem] uppercase tracking-widest text-slate-400 mb-1">Collected</div>
                        <div class="text-3xl font-bold tabular-nums">@FormatDgb8(totals.CollectedDgb) <span class="text-dgb-500 text-xl">DGB</span></div>
                        <div class="text-xs text-slate-400 mt-0.5">across @outcomes.Collected @(outcomes.Collected == 1 ? "sale" : "sales")</div>
                        @if (totals.Fiat is { Count: > 0 })
                        {
                            <div class="mt-2 flex flex-wrap gap-1.5">
                                @foreach (var kv in totals.Fiat.OrderBy(k => k.Key))
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-slate-800 text-slate-200 text-xs font-semibold tabular-nums">
                                        @kv.Value.ToString("0.##") @kv.Key
                                    </span>
                                }
                            </div>
                        }
                    </div>

                    @if (totals.Tips is { Count: > 0 })
                    {
                        <div>
                            <div class="text-[0.6875rem] uppercase tracking-widest text-slate-400 mb-1">Tips</div>
                            <div class="flex flex-wrap gap-1.5">
                                @foreach (var kv in totals.Tips.OrderBy(k => k.Key))
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-300 text-xs font-semibold tabular-nums border border-emerald-500/20">
                                        @kv.Value.ToString("0.##") @kv.Key
                                    </span>
                                }
                            </div>
                        </div>
                    }

                    <div>
                        <div class="text-[0.6875rem] uppercase tracking-widest text-slate-400 mb-1">Outcomes</div>
                        <div class="grid grid-cols-4 gap-2 text-center">
                            <div class="bg-emerald-500/10 border border-emerald-500/20 rounded-lg py-1.5">
                                <div class="text-lg font-bold tabular-nums text-emerald-300">@outcomes.Collected</div>
                                <div class="text-[0.625rem] uppercase tracking-wider text-emerald-300/80">Paid</div>
                            </div>
                            <div class="bg-slate-800/60 border border-slate-700 rounded-lg py-1.5">
                                <div class="text-lg font-bold tabular-nums">@outcomes.Pending</div>
                                <div class="text-[0.625rem] uppercase tracking-wider text-slate-400">Pending</div>
                            </div>
                            <div class="bg-amber-500/10 border border-amber-500/20 rounded-lg py-1.5">
                                <div class="text-lg font-bold tabular-nums text-amber-300">@outcomes.Underpaid</div>
                                <div class="text-[0.625rem] uppercase tracking-wider text-amber-300/80">Underpaid</div>
                            </div>
                            <div class="bg-slate-800/60 border border-slate-700 rounded-lg py-1.5">
                                <div class="text-lg font-bold tabular-nums">@outcomes.Expired</div>
                                <div class="text-[0.625rem] uppercase tracking-wider text-slate-400">Expired</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex gap-2 mt-5">
                    <button class="flex-1 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-200 font-semibold rounded-lg text-sm" @onclick="() => showShiftReport = false">Close</button>
                    <button class="flex-1 py-2.5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-lg text-sm" @onclick="StartNewShiftAsync">Start new shift</button>
                </div>
            }
        </div>
    </div>
}

@* PIN settings (set / change / remove).
   Kept as a dedicated modal so a busy cashier can't toggle security in passing —
   the "Save" button is only enabled when both fields match and length is valid. *@
@if (showPinSettings)
{
    <div class="fixed inset-0 bg-black/70 z-50 flex items-center justify-center p-6" @onclick="ClosePinSettings">
        <div class="bg-dgb-900 border border-dgb-800 rounded-2xl p-6 max-w-sm w-full text-white" @onclick:stopPropagation>
            <h3 class="text-lg font-bold m-0 mb-1">@(hasPin ? "Change manager PIN" : "Set a manager PIN")</h3>
            <p class="text-sm text-slate-400 m-0 mb-4">
                A 4–8 digit PIN gates destructive actions on this tablet (right now: unpairing).
                The PIN never leaves the browser.
            </p>
            <label class="block text-xs font-semibold text-slate-300 mb-1">New PIN</label>
            <input type="password" inputmode="numeric" pattern="[0-9]*" autocomplete="new-password"
                   maxlength="8"
                   class="w-full px-3 py-2.5 bg-slate-950 border border-dgb-800 rounded-lg text-white tracking-[0.4em] text-center mb-3"
                   @bind="pinNew" @bind:event="oninput" />
            <label class="block text-xs font-semibold text-slate-300 mb-1">Confirm PIN</label>
            <input type="password" inputmode="numeric" pattern="[0-9]*" autocomplete="new-password"
                   maxlength="8"
                   class="w-full px-3 py-2.5 bg-slate-950 border border-dgb-800 rounded-lg text-white tracking-[0.4em] text-center mb-3"
                   @bind="pinConfirm" @bind:event="oninput" />
            @if (!string.IsNullOrEmpty(pinSettingsError))
            {
                <p class="text-sm text-red-400 m-0 mb-3">@pinSettingsError</p>
            }
            <div class="flex gap-2 mb-2">
                <button class="flex-1 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-200 font-semibold rounded-lg text-sm" @onclick="ClosePinSettings">Cancel</button>
                <button class="flex-1 py-2.5 bg-dgb-500 hover:bg-dgb-400 disabled:bg-slate-700 disabled:text-slate-400 text-white font-semibold rounded-lg text-sm"
                        @onclick="SavePinAsync" disabled="@(!CanSavePin)">Save PIN</button>
