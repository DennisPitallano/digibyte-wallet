@page "/merchant/signin"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@using System.Net.Http.Json

<PageTitle>Sign in — DigiPay</PageTitle>

<main class="min-h-dvh flex items-center justify-center p-4 bg-slate-50 dark:bg-dgb-950 text-slate-900 dark:text-white font-sans">
    <div class="w-full max-w-md">
        <div class="bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-3xl p-5 sm:p-6 flex flex-col items-center gap-4 shadow-sm">
            <div class="text-center">
                <div class="text-[0.6875rem] font-bold tracking-widest text-slate-500 dark:text-slate-400 uppercase">DIGIPAY</div>
                <div class="text-sm font-bold">Sign in with Digi-ID</div>
            </div>

            @if (loadError != null)
            {
                <p class="text-xs text-center text-slate-500 dark:text-slate-400 m-0">@loadError</p>
            }
            else if (challenge == null)
            {
                <Loader Text="Generating sign-in challenge…" Class="py-4 gap-3" />
            }
            else if (signed != null)
            {
                <div class="flex flex-col items-center gap-3 py-6 text-center">
                    <div class="w-14 h-14 rounded-full bg-emerald-500 text-white text-2xl font-bold flex items-center justify-center">✓</div>
                    <h3 class="text-base font-bold m-0 text-slate-900 dark:text-white">Signed in</h3>
                    <p class="text-xs text-slate-500 dark:text-slate-400 max-w-xs m-0">Welcome back, <strong>@signed.DisplayName</strong>.</p>
                    <p class="text-[0.625rem] font-mono text-slate-400 dark:text-slate-500 break-all m-0">@signed.MerchantId</p>
                </div>
            }
            else
            {
                <p class="text-xs text-center text-slate-500 dark:text-slate-400 m-0">Scan the QR with your DigiByte wallet to sign in. The page will advance automatically.</p>

                <div class="bg-white p-3 rounded-2xl shadow-inner">
                    <img src="@qrDataUrl" alt="Scan to sign in" class="block w-56 h-56 rounded-lg" />
                </div>

                <a href="@challenge.Uri" class="w-full text-center py-3 px-4 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-xl no-underline transition-colors">Open in wallet</a>

                <div class="text-[0.6875rem] text-slate-500 dark:text-slate-400">Polling for signature… @pollCount</div>
            }
        </div>
    </div>
</main>

@code {
    private ChallengeResponse? challenge;
    private SignedResponse? signed;
    private string? qrDataUrl;
    private string? loadError;
    private int pollCount;
    private System.Threading.Timer? poller;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            challenge = await http.GetFromJsonAsync<ChallengeResponse>("/v1/pay/auth/challenge");
            if (challenge != null) qrDataUrl = GenerateQr(challenge.Uri);
        }
        catch (Exception ex) { loadError = $"Could not start sign-in: {ex.Message}"; }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender || challenge is null || poller is not null) return;
        poller = new System.Threading.Timer(async _ => await PollAsync(), null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private async Task PollAsync()
    {
        if (challenge is null || signed is not null) return;
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.GetAsync($"/v1/pay/auth/poll/{challenge.Nonce}");
            if (response.StatusCode == System.Net.HttpStatusCode.Accepted)
            {
                await InvokeAsync(() => { pollCount++; StateHasChanged(); });
                return;
            }
            if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                await InvokeAsync(() =>
                {
                    loadError = "Sign-in expired. Refresh to try again.";
                    StateHasChanged();
                });
                poller?.Dispose();
                return;
            }
            if (response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadFromJsonAsync<SignedResponse>();
                if (body is null) return;
                poller?.Dispose();
                await InvokeAsync(async () =>
                {
                    signed = body;
                    await JS.InvokeVoidAsync("localStorage.setItem", "digipay-token", body.Token);
                    await JS.InvokeVoidAsync("localStorage.setItem", "digipay-merchant-id", body.MerchantId);
                    StateHasChanged();
                });
                // Brief "Signed in" confirmation, then hand off to the dashboard.
                // Use a full reload so localStorage reads on the next page happen cleanly
                // in the new InteractiveServer circuit.
                await Task.Delay(1200);
                await InvokeAsync(async () =>
                    await JS.InvokeVoidAsync("eval", "window.location.href = '/merchant'"));
            }
        }
        catch { /* transient — keep polling */ }
    }

    private static string GenerateQr(string content)
    {
        using var gen = new QRCoder.QRCodeGenerator();
        using var data = gen.CreateQrCode(content, QRCoder.QRCodeGenerator.ECCLevel.M);
        using var qr = new QRCoder.PngByteQRCode(data);
        return $"data:image/png;base64,{Convert.ToBase64String(qr.GetGraphic(6))}";
    }

    public ValueTask DisposeAsync()
    {
        poller?.Dispose();
        return ValueTask.CompletedTask;
    }

    private record ChallengeResponse(string Nonce, string Uri, DateTime ExpiresAt);
    private record SignedResponse(string Status, string MerchantId, string DisplayName, string Token);
}
