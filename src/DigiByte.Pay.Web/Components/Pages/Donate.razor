@page "/pay/button"
@using DigiByte.Crypto.Addresses

<PageTitle>@(string.IsNullOrEmpty(Name) ? "Pay with DigiByte" : $"Tip {Name}")</PageTitle>

<main class="min-h-dvh flex items-center justify-center p-4 bg-slate-50 dark:bg-dgb-950 text-slate-900 dark:text-white font-sans">
    <div class="w-full max-w-md">
        @if (!isValid)
        {
            <div class="bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-3xl p-6 text-center shadow-sm">
                <h2 class="text-lg font-bold m-0 mb-2">Invalid donation link</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Missing or invalid <code class="px-1 bg-slate-100 dark:bg-dgb-800 rounded">to</code> parameter.</p>
            </div>
        }
        else
        {
            <div class="bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-3xl p-5 sm:p-6 flex flex-col items-center gap-4 shadow-sm">
                <div class="text-center">
                    <div class="text-[0.6875rem] font-bold tracking-widest text-slate-500 dark:text-slate-400 uppercase">TIP</div>
                    <div class="text-sm font-bold">@(string.IsNullOrEmpty(Name) ? "DigiByte" : Name)</div>
                </div>

                @if (amount > 0)
                {
                    <div class="text-3xl sm:text-4xl font-bold tabular-nums">@amount.ToString("0.########") DGB</div>
                }

                <div class="bg-white p-3 rounded-2xl shadow-inner">
                    <img src="@qrDataUrl" alt="Scan to pay" class="block w-56 h-56 rounded-lg" />
                </div>

                <a href="@BipUri" class="w-full text-center py-3 px-4 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-xl no-underline transition-colors">Open in wallet</a>

                <div class="w-full font-mono text-[0.6875rem] text-center break-all bg-slate-50 dark:bg-dgb-950 text-slate-500 dark:text-slate-400 p-3 rounded-xl border border-slate-100 dark:border-dgb-800">@To</div>

                @if (!string.IsNullOrEmpty(Label))
                {
                    <p class="text-xs text-center text-slate-500 dark:text-slate-400 m-0">@Label</p>
                }
            </div>
        }
    </div>
</main>

@code {
    [Parameter, SupplyParameterFromQuery] public string? To { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "amount")] public string? AmountParam { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? Label { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? Name { get; set; }

    private bool isValid;
    private decimal amount;
    private string? qrDataUrl;
    private string BipUri = "";

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(To) || !AddressValidator.IsValid(To)) { isValid = false; return; }
        isValid = true;

        if (!string.IsNullOrWhiteSpace(AmountParam)
            && decimal.TryParse(AmountParam, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var parsed)
            && parsed > 0)
        {
            amount = parsed;
        }

        BipUri = BuildBip21();
        qrDataUrl = GenerateQr(BipUri);
    }

    private string BuildBip21()
    {
        var sb = new System.Text.StringBuilder("digibyte:").Append(To);
        var first = true;
        void Add(string key, string? value)
        {
            if (string.IsNullOrWhiteSpace(value)) return;
            sb.Append(first ? '?' : '&').Append(key).Append('=').Append(Uri.EscapeDataString(value));
            first = false;
        }
        if (amount > 0)
            Add("amount", amount.ToString("0.########", System.Globalization.CultureInfo.InvariantCulture));
        Add("label", Name);
        Add("message", Label);
        return sb.ToString();
    }

    private static string GenerateQr(string content)
    {
        using var gen = new QRCoder.QRCodeGenerator();
        using var data = gen.CreateQrCode(content, QRCoder.QRCodeGenerator.ECCLevel.M);
        using var qr = new QRCoder.PngByteQRCode(data);
        return $"data:image/png;base64,{Convert.ToBase64String(qr.GetGraphic(6))}";
    }
}
