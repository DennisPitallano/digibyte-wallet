@page "/merchant"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory
@inject IJSRuntime JS
@inject NavigationManager Nav
@using System.Net.Http.Json

<PageTitle>@(me?.DisplayName ?? "Dashboard") — DigiPay</PageTitle>

@* Shared class strings for consistency *@
@{
    const string Card = "bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl p-5 sm:p-6 flex flex-col gap-3 shadow-sm";
    const string Btn = "px-4 py-2.5 bg-dgb-500 hover:bg-dgb-600 disabled:bg-dgb-500/50 text-white font-semibold rounded-lg text-sm disabled:cursor-not-allowed transition-colors";
    const string BtnGhost = "px-4 py-2.5 bg-transparent hover:bg-slate-50 dark:hover:bg-dgb-800 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-dgb-800 font-semibold rounded-lg text-sm disabled:opacity-50 transition-colors";
    const string Input = "w-full rounded-lg px-3 py-2 text-sm bg-slate-50 dark:bg-dgb-950 border border-slate-200 dark:border-dgb-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-dgb-500/40";
    const string Eyebrow = "text-[0.6875rem] uppercase tracking-widest font-bold text-slate-500 dark:text-slate-400";
    const string Muted = "text-xs text-slate-500 dark:text-slate-400";
    const string Pre = "bg-slate-900 text-slate-100 rounded-lg p-3 text-[0.6875rem] font-mono overflow-x-auto whitespace-pre-wrap break-all m-0 leading-relaxed";
    const string H2 = "text-base font-bold text-slate-900 dark:text-white m-0";
    const string H1 = "text-xl sm:text-2xl font-bold tracking-tight m-0";
}

@if (bootstrapError != null)
{
    <main class="min-h-dvh flex items-center justify-center p-4 bg-slate-50 dark:bg-dgb-950 text-slate-900 dark:text-white font-sans">
        <div class="@Card text-center"><p class="text-sm text-red-500 m-0">@bootstrapError</p></div>
    </main>
}
else if (me == null)
{
    <main class="min-h-dvh flex items-center justify-center p-4 bg-slate-50 dark:bg-dgb-950 text-slate-900 dark:text-white font-sans">
        <p class="@Muted m-0">Loading…</p>
    </main>
}
else
{
    <div class="min-h-dvh bg-slate-50 dark:bg-dgb-950 text-slate-900 dark:text-white font-sans md:grid md:grid-cols-[240px_1fr]">
        @* Mobile top bar *@
        <header class="md:hidden sticky top-0 z-[15] bg-white dark:bg-dgb-900 border-b border-slate-200 dark:border-dgb-800 px-3 py-2.5 flex items-center gap-2.5">
            <button class="w-9 h-9 flex items-center justify-center border border-slate-200 dark:border-dgb-800 rounded-lg text-lg leading-none"
                    @onclick="() => sidebarOpen = !sidebarOpen" aria-label="Toggle navigation">
                @(sidebarOpen ? "×" : "☰")
            </button>
            <div class="flex items-center gap-1.5 font-bold text-[0.9375rem]">
                <span class="w-2 h-2 rounded-full bg-dgb-500"></span> DigiPay
            </div>
            <div class="flex-1"></div>
            <ThemeToggle />
            <div class="text-right">
                <div class="text-[0.8125rem] font-semibold truncate max-w-[8rem]">@me.DisplayName</div>
                <button class="px-2 py-0.5 text-[0.6875rem] font-semibold text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-dgb-800 rounded transition-colors hover:bg-slate-50 dark:hover:bg-dgb-800"
                        @onclick="SignOutAsync">Sign out</button>
            </div>
        </header>

        @* Mobile backdrop *@
        <div class="md:hidden fixed inset-0 bg-black/50 z-10 @(sidebarOpen ? "block" : "hidden")" @onclick="() => sidebarOpen = false"></div>

        @* Sidebar *@
        <aside class="bg-white dark:bg-dgb-900 border-r border-slate-200 dark:border-dgb-800 md:sticky md:top-0 md:self-start md:h-dvh md:z-20 fixed left-0 top-0 bottom-0 w-64 z-20 transition-transform flex flex-col gap-1 p-5 md:p-3 @(sidebarOpen ? "translate-x-0 shadow-2xl" : "-translate-x-full") md:translate-x-0 md:shadow-none">
            <div class="flex items-center gap-2 pb-4 mb-3 border-b border-slate-200 dark:border-dgb-800 font-bold text-base">
                <span class="w-2.5 h-2.5 rounded-full bg-dgb-500"></span> DigiPay
            </div>
            <nav class="flex flex-col gap-0.5 flex-1">
                @foreach (var tab in tabs)
                {
                    var t = tab;
                    var active = activeTab == t.Key;
                    <button class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-left transition-colors @(active ? "bg-dgb-500/10 text-dgb-500 font-semibold" : "text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-dgb-800 hover:text-slate-900 dark:hover:text-white")"
                            @onclick="() => SwitchTab(t.Key)">
                        <span class="w-4 h-4 shrink-0 text-center">@t.Icon</span>
                        @t.Label
                    </button>
                }
            </nav>
            <div class="border-t border-slate-200 dark:border-dgb-800 pt-3 flex flex-col gap-1.5 text-xs text-slate-500 dark:text-slate-400">
                <div>@me.DisplayName</div>
                @if (!string.IsNullOrEmpty(me.DigiIdAddress))
                {
                    <div class="font-mono text-[0.625rem]">@(me.DigiIdAddress.Length > 14 ? me.DigiIdAddress[..8] + "…" + me.DigiIdAddress[^4..] : me.DigiIdAddress)</div>
                }
                <div class="flex gap-1.5 items-stretch mt-1">
                    <button class="@BtnGhost flex-1 text-xs py-2" @onclick="SignOutAsync">Sign out</button>
                    <ThemeToggle />
                </div>
            </div>
        </aside>

        <main class="p-4 sm:p-8 max-w-5xl box-border">
            @if (activeTab == "overview")
            {
                <div class="flex items-baseline justify-between gap-2 flex-wrap mb-1"><h1 class="@H1">Overview</h1></div>
                <p class="@Muted mb-6">Summary of your DigiPay activity.</p>

                @if (!me.HasReceive)
                {
                    <section class="@Card">
                        <h2 class="@H2">Configure where to receive payments</h2>
                        <p class="@Muted m-0">Before you can create sessions, set a DigiByte address or BIP84 xpub in Settings.</p>
                        <button class="@Btn self-start" @onclick='() => SwitchTab("settings")'>Go to Settings</button>
                    </section>
                }
                else
                {
                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
                        <Stat Label="Total sessions" Value="@((sessions?.Count ?? 0).ToString())" />
                        <Stat Label="Paid / Confirmed" Value="@CountBy("paid", "confirmed").ToString()" />
                        <Stat Label="Pending" Value="@CountBy("pending", "seen").ToString()" />
                        <Stat Label="Expired" Value="@CountBy("expired", "underpaid").ToString()" />
                    </div>

                    <section class="@Card">
                        <h2 class="@H2">New session</h2>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                            <input @bind="newAmount" type="number" step="0.00000001" min="0" placeholder="Amount (DGB)" class="@Input" />
                            <input @bind="newLabel" placeholder="Label" class="@Input" />
                            <input @bind="newMemo" placeholder="Memo / invoice #" class="@Input" />
                        </div>
                        <button class="@Btn" @onclick="CreateSessionAsync" disabled="@(busy || newAmount <= 0)">
                            @(busy ? "Creating…" : "Create session")
                        </button>
                        @if (createError != null) { <p class="text-xs text-red-500 m-0">@createError</p> }
                        @if (createdSession != null)
                        {
                            <div class="bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800/30 rounded-lg p-3 flex flex-col gap-1">
                                <div class="@Eyebrow">Checkout URL</div>
                                <a href="@createdSession.CheckoutUrl" target="_blank" class="font-mono text-[0.6875rem] text-emerald-700 dark:text-emerald-300 break-all underline">@createdSession.CheckoutUrl</a>
                            </div>
                        }
                    </section>
                }
            }
            else if (activeTab == "sessions")
            {
                <div class="flex items-baseline justify-between gap-2 flex-wrap mb-1">
                    <h1 class="@H1">Sessions</h1>
                    <button class="@BtnGhost text-xs py-1.5 px-3" @onclick="LoadSessionsAsync" disabled="@loadingSessions">
                        @(loadingSessions ? "…" : "Refresh")
                    </button>
                </div>
                <p class="@Muted mb-6">Every checkout session you've created, newest first.</p>

                <section class="@Card">
                    @if (sessions == null) { <p class="@Muted m-0">Loading…</p> }
                    else if (sessions.Count == 0) { <p class="@Muted m-0">No sessions yet.</p> }
                    else
                    {
                        <ul class="list-none p-0 m-0 flex flex-col gap-2">
                            @foreach (var s in sessions)
                            {
                                <li>
                                    <a href="@s.CheckoutUrl" target="_blank"
                                       class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 sm:gap-3 p-3 border border-slate-200 dark:border-dgb-800 rounded-lg no-underline text-inherit hover:bg-slate-50 dark:hover:bg-dgb-800 transition-colors">
                                        <div class="min-w-0">
                                            <div class="font-bold text-[0.9375rem] tabular-nums">@s.Amount.ToString("0.########") DGB</div>
                                            <div class="font-mono text-[0.625rem] text-slate-500 dark:text-slate-400 break-all">@s.Address</div>
                                            @if (!string.IsNullOrEmpty(s.Label)) { <div class="@Muted">@s.Label</div> }
                                        </div>
                                        <div class="flex sm:flex-col items-center sm:items-end justify-between sm:justify-start gap-1.5 shrink-0">
                                            <CheckoutStatusPill Status="@s.Status" />
                                            <div class="@Muted">@s.CreatedAt.ToLocalTime().ToString("MMM d, HH:mm")</div>
                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                </section>
            }
            else if (activeTab == "donation")
            {
                <div class="flex items-baseline justify-between mb-1"><h1 class="@H1">Donation button</h1></div>
                <p class="@Muted mb-6">Static BIP21 link — no session created, no tracking. Any DigiByte wallet can pay. Tips reuse your donation address.</p>

                <section class="@Card">
                    @if (donationAddress is null) { <p class="@Muted m-0">Loading address…</p> }
                    else
                    {
                        <div class="font-mono text-[0.6875rem] px-3 py-2 bg-slate-50 dark:bg-dgb-950 border border-slate-200 dark:border-dgb-800 rounded-lg break-all">@donationAddress</div>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                            <input @bind="donAmount" @bind:event="oninput" type="number" step="0.00000001" min="0" placeholder="Amount (opt)" class="@Input" />
                            <input @bind="donName" @bind:event="oninput" placeholder="Name (opt)" class="@Input" />
                            <input @bind="donButtonText" @bind:event="oninput" placeholder="Button text" class="@Input" />
                        </div>
                        <div class="@Eyebrow mt-1">Preview</div>
                        <div class="p-4 bg-slate-50 dark:bg-dgb-950 border border-slate-200 dark:border-dgb-800 rounded-lg text-center">
                            <a href="@DonationUrl" target="_blank" class="inline-block px-4 py-2 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-lg no-underline text-sm">
                                @(string.IsNullOrWhiteSpace(donButtonText) ? "Tip DGB" : donButtonText)
                            </a>
                        </div>
                        <div class="@Eyebrow">HTML snippet</div>
                        <pre class="@Pre">@DonationSnippet</pre>
                        <button class="@BtnGhost" @onclick="CopyDonationSnippetAsync">@(donCopied ? "Copied ✓" : "Copy snippet")</button>
                    }
                </section>

                <section class="@Card mt-4">
                    <h2 class="@H2">JS embed widget</h2>
                    <p class="@Muted m-0">Drop this on your site for an in-page checkout modal (keeps the buyer on your domain).</p>
                    <pre class="@Pre">@EmbedSnippet</pre>
                    <button class="@BtnGhost" @onclick="CopyEmbedSnippetAsync">@(embedCopied ? "Copied ✓" : "Copy snippet")</button>
                </section>
            }
            else if (activeTab == "webhook")
            {
                <div class="flex items-baseline justify-between mb-1"><h1 class="@H1">Webhook</h1></div>
                <p class="@Muted mb-6">POST with HMAC-SHA256 signature on session state changes (seen → paid → confirmed → expired / underpaid). Header: <span class="font-mono">X-DigiPay-Signature: sha256=…</span></p>

                <section class="@Card">
                    <input @bind="webhookInput" placeholder="https://your-server.example/digipay-webhook" class="@Input" />
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                        <button class="@Btn" @onclick="SaveWebhookAsync" disabled="@(webhookBusy || webhookInput == (me.WebhookUrl ?? ""))">
                            @(webhookBusy ? "Saving…" : "Save")
                        </button>
                        <button class="@BtnGhost" @onclick="TestWebhookAsync" disabled="@(webhookBusy || string.IsNullOrWhiteSpace(me.WebhookUrl))">
                            Send test event
                        </button>
                    </div>
                    @if (webhookMessage != null) { <p class="@Muted m-0">@webhookMessage</p> }
                    @if (webhookError != null) { <p class="text-xs text-red-500 m-0">@webhookError</p> }
                </section>
            }
            else if (activeTab == "settings")
            {
                <div class="flex items-baseline justify-between mb-1"><h1 class="@H1">Settings</h1></div>
                <p class="@Muted mb-6">Receive address, session defaults, and merchant profile.</p>

                <section class="@Card">
                    <h2 class="@H2">Receive</h2>
                    @if (me.HasReceive)
                    {
                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                            <div class="min-w-0">
                                <div class="@Eyebrow">Current</div>
                                <div class="font-mono text-sm font-semibold my-0.5 break-all">@me.ReceivePreview</div>
                                <div class="@Muted">@(me.ReceiveMode == "xpub" ? "Fresh address per session" : "Single reused address")</div>
                            </div>
                            <button class="@BtnGhost shrink-0" @onclick="() => showEditReceive = !showEditReceive">
                                @(showEditReceive ? "Cancel" : "Change")
                            </button>
                        </div>
                    }
                    @if (!me.HasReceive || showEditReceive)
                    {
                        <input @bind="receiveInput" placeholder="dgb1… or xpub…" class="@Input font-mono text-xs" />
                        <button class="@Btn" @onclick="SaveReceiveAsync" disabled="@(busy || string.IsNullOrWhiteSpace(receiveInput))">
                            @(busy ? "Saving…" : "Save")
                        </button>
                        @if (patchError != null) { <p class="text-xs text-red-500 m-0">@patchError</p> }
                    }
                </section>

                <section class="@Card mt-4">
                    <h2 class="@H2">Default session expiry</h2>
                    <p class="@Muted m-0">How long a pending session stays open before it expires. Defaults to 30 minutes. Late payments (up to 3 days past expiry) still reconcile automatically.</p>
                    <div class="flex flex-col sm:flex-row sm:items-end gap-2">
                        <div class="flex-1">
                            <input @bind="expiryInput" type="number" min="1" max="1440" placeholder="30" class="@Input" />
                            <div class="@Muted text-[0.6875rem] mt-1">Minutes (1–1440). Blank = global default (30).</div>
                        </div>
                        <button class="@Btn sm:shrink-0" @onclick="SaveExpiryAsync" disabled="@expiryBusy">
                            @(expiryBusy ? "Saving…" : "Save")
                        </button>
                    </div>
                    @if (expiryMessage != null) { <p class="@Muted m-0">@expiryMessage</p> }
                    @if (expiryError != null) { <p class="text-xs text-red-500 m-0">@expiryError</p> }
                </section>
            }
        </main>
    </div>
}

@code {
    private record TabDef(string Key, string Label, string Icon);
    private readonly TabDef[] tabs = new[]
    {
        new TabDef("overview",  "Overview",        "▣"),
        new TabDef("sessions",  "Sessions",        "📋"),
        new TabDef("donation",  "Donation button", "🔘"),
        new TabDef("webhook",   "Webhook",         "🔔"),
        new TabDef("settings",  "Settings",        "⚙"),
    };
    private string activeTab = "overview";
    private bool sidebarOpen;

    private void SwitchTab(string key)
    {
        activeTab = key;
        sidebarOpen = false; // auto-dismiss the mobile drawer after a tab click
    }

    private string? token;
    private MeDto? me;
    private List<SessionRow>? sessions;
    private string? bootstrapError;

    private string receiveInput = "";
    private bool showEditReceive;
    private string? patchError;

    private decimal newAmount;
    private string newLabel = "";
    private string newMemo = "";
    private CreatedSession? createdSession;
    private string? createError;

    private string? donationAddress;
    private decimal donAmount;
    private string donName = "";
    private string donButtonText = "Tip DGB";
    private bool donCopied;
    private bool embedCopied;

    private string webhookInput = "";
    private bool webhookBusy;
    private string? webhookMessage;
    private string? webhookError;

    private int? expiryInput;
    private bool expiryBusy;
    private string? expiryMessage;
    private string? expiryError;

    private bool busy;
    private bool loadingSessions;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || me != null || bootstrapError != null) return;
        try
        {
            token = await JS.InvokeAsync<string?>("localStorage.getItem", "digipay-token");
            if (string.IsNullOrEmpty(token))
            {
                Nav.NavigateTo("/merchant/signin");
                return;
            }
            await LoadMeAsync();
            if (me is not null && me.HasReceive)
            {
                webhookInput = me.WebhookUrl ?? "";
                expiryInput = me.DefaultSessionExpiryMinutes;
                await LoadSessionsAsync();
                await LoadDonationAddressAsync();
            }
            StateHasChanged();
        }
        catch (Exception ex) { bootstrapError = ex.Message; StateHasChanged(); }
    }

    private int CountBy(params string[] statuses) =>
        sessions?.Count(s => statuses.Contains(s.Status)) ?? 0;

    private HttpRequestMessage AuthedRequest(HttpMethod method, string path, HttpContent? content = null)
    {
        var req = new HttpRequestMessage(method, path) { Content = content };
        req.Headers.TryAddWithoutValidation("Authorization", $"Bearer {token}");
        return req;
    }

    private async Task LoadMeAsync()
    {
        var http = HttpFactory.CreateClient("PayApi");
        var response = await http.SendAsync(AuthedRequest(HttpMethod.Get, "/v1/pay/me/"));
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", "digipay-token");
            Nav.NavigateTo("/merchant/signin");
            return;
        }
        response.EnsureSuccessStatusCode();
        me = await response.Content.ReadFromJsonAsync<MeDto>();
    }

    private async Task LoadSessionsAsync()
    {
        loadingSessions = true; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Get, "/v1/pay/sessions?take=25"));
            if (response.IsSuccessStatusCode)
            {
                var payload = await response.Content.ReadFromJsonAsync<SessionList>();
                if (payload != null) sessions = payload.Sessions;
            }
        }
        finally { loadingSessions = false; StateHasChanged(); }
    }

    private async Task LoadDonationAddressAsync()
    {
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Get, "/v1/pay/me/donation-address"));
            if (response.IsSuccessStatusCode)
            {
                var dto = await response.Content.ReadFromJsonAsync<DonationAddressDto>();
                donationAddress = dto?.Address;
            }
        }
        catch { }
    }

    private string WebBase => Nav.BaseUri.TrimEnd('/');

    private string DonationUrl
    {
        get
        {
            if (string.IsNullOrEmpty(donationAddress)) return "#";
            var sb = new System.Text.StringBuilder($"{WebBase}/pay/button?to=")
                .Append(Uri.EscapeDataString(donationAddress));
            if (donAmount > 0)
                sb.Append("&amount=").Append(donAmount.ToString("0.########", System.Globalization.CultureInfo.InvariantCulture));
            if (!string.IsNullOrWhiteSpace(donName))
                sb.Append("&name=").Append(Uri.EscapeDataString(donName));
            return sb.ToString();
        }
    }

    private string DonationSnippet =>
        $"<a href=\"{DonationUrl}\" target=\"_blank\" rel=\"noopener\">{System.Net.WebUtility.HtmlEncode(string.IsNullOrWhiteSpace(donButtonText) ? "Tip DGB" : donButtonText)}</a>";

    private string EmbedSnippet =>
        $"<script src=\"{WebBase}/embed/digipay.js?v=0.1\"></script>\n<button data-digipay-checkout data-session-id=\"SESSION_ID\">Pay with DigiByte</button>";

    private async Task CopyDonationSnippetAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", DonationSnippet);
            donCopied = true; StateHasChanged();
            await Task.Delay(1500);
            donCopied = false; StateHasChanged();
        }
        catch { }
    }

    private async Task CopyEmbedSnippetAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", EmbedSnippet);
            embedCopied = true; StateHasChanged();
            await Task.Delay(1500);
            embedCopied = false; StateHasChanged();
        }
        catch { }
    }

    private async Task SaveReceiveAsync()
    {
        busy = true; patchError = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var content = JsonContent.Create(new { addressOrXpub = receiveInput.Trim() });
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Patch, "/v1/pay/me/", content));
            if (!response.IsSuccessStatusCode)
            {
                patchError = await response.Content.ReadAsStringAsync();
                return;
            }
            me = await response.Content.ReadFromJsonAsync<MeDto>();
            receiveInput = "";
            showEditReceive = false;
            if (me?.HasReceive == true)
            {
                await LoadSessionsAsync();
                await LoadDonationAddressAsync();
            }
        }
        catch (Exception ex) { patchError = ex.Message; }
        finally { busy = false; StateHasChanged(); }
    }

    private async Task CreateSessionAsync()
    {
        busy = true; createError = null; createdSession = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var content = JsonContent.Create(new
            {
                amount = newAmount,
                label = string.IsNullOrWhiteSpace(newLabel) ? null : newLabel,
                memo = string.IsNullOrWhiteSpace(newMemo) ? null : newMemo,
            });
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Post, "/v1/pay/sessions", content));
            if (!response.IsSuccessStatusCode)
            {
                createError = await response.Content.ReadAsStringAsync();
                return;
            }
            createdSession = await response.Content.ReadFromJsonAsync<CreatedSession>();
            newAmount = 0; newLabel = ""; newMemo = "";
            await LoadSessionsAsync();
        }
        catch (Exception ex) { createError = ex.Message; }
        finally { busy = false; StateHasChanged(); }
    }

    private async Task SaveWebhookAsync()
    {
        webhookBusy = true; webhookError = null; webhookMessage = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var content = JsonContent.Create(new { webhookUrl = webhookInput.Trim() });
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Patch, "/v1/pay/me/", content));
            if (!response.IsSuccessStatusCode)
            {
                webhookError = await response.Content.ReadAsStringAsync();
                return;
            }
            me = await response.Content.ReadFromJsonAsync<MeDto>();
            webhookMessage = string.IsNullOrWhiteSpace(me?.WebhookUrl) ? "Webhook cleared." : "Webhook saved.";
        }
        catch (Exception ex) { webhookError = ex.Message; }
        finally { webhookBusy = false; StateHasChanged(); }
    }

    private async Task TestWebhookAsync()
    {
        webhookBusy = true; webhookError = null; webhookMessage = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Post, "/v1/pay/me/webhook/test"));
            if (!response.IsSuccessStatusCode)
            {
                webhookError = await response.Content.ReadAsStringAsync();
                return;
            }
            webhookMessage = "Test event dispatched — check your server logs for a 'webhook.test' POST.";
        }
        catch (Exception ex) { webhookError = ex.Message; }
        finally { webhookBusy = false; StateHasChanged(); }
    }

    private async Task SaveExpiryAsync()
    {
        expiryBusy = true; expiryError = null; expiryMessage = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var content = JsonContent.Create(new { defaultSessionExpiryMinutes = expiryInput });
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Patch, "/v1/pay/me/", content));
            if (!response.IsSuccessStatusCode)
            {
                expiryError = await response.Content.ReadAsStringAsync();
                return;
            }
            me = await response.Content.ReadFromJsonAsync<MeDto>();
            expiryMessage = me?.DefaultSessionExpiryMinutes is int m ? $"Default is now {m} minutes." : "Using global default (30 minutes).";
        }
        catch (Exception ex) { expiryError = ex.Message; }
        finally { expiryBusy = false; StateHasChanged(); }
    }

    private async Task SignOutAsync()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "digipay-token");
        await JS.InvokeVoidAsync("localStorage.removeItem", "digipay-merchant-id");
        Nav.NavigateTo("/");
    }

    private record MeDto(string Id, string DisplayName, string? DigiIdAddress, string Network,
        string ReceiveMode, bool HasReceive, string? ReceivePreview,
        string? WebhookUrl, bool HasWebhookSecret,
        int? DefaultSessionExpiryMinutes, DateTime CreatedAt);

    private record SessionList(int Total, int Take, int Skip, List<SessionRow> Sessions);

    private record SessionRow(string Id, string Address, long AmountSatoshis, decimal Amount,
        string? FiatCurrency, decimal? FiatAmount, string? Label, string? Memo,
        string Status, DateTime CreatedAt, DateTime ExpiresAt,
        long ReceivedSatoshis, int Confirmations, string? PaidTxid,
        string Uri, string CheckoutUrl);

    private record CreatedSession(string Id, string Address, decimal Amount, string Status,
        string Uri, string CheckoutUrl);

    private record DonationAddressDto(string Address, string Mode);
