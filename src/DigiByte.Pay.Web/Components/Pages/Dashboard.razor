@page "/merchant"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory
@inject IJSRuntime JS
@inject NavigationManager Nav
@using System.Net.Http.Json

<PageTitle>@(account?.DisplayName ?? "Dashboard") — DigiPay</PageTitle>

@* Shared class strings for consistency *@
@{
    const string Card = "bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl p-5 sm:p-6 flex flex-col gap-3 shadow-sm";
    const string Btn = "px-4 py-2.5 bg-dgb-500 hover:bg-dgb-600 disabled:bg-dgb-500/50 text-white font-semibold rounded-lg text-sm disabled:cursor-not-allowed transition-colors";
    const string BtnGhost = "px-4 py-2.5 bg-transparent hover:bg-slate-50 dark:hover:bg-dgb-800 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-dgb-800 font-semibold rounded-lg text-sm disabled:opacity-50 transition-colors";
    const string Input = "w-full rounded-lg px-3 py-2 text-sm bg-slate-50 dark:bg-dgb-950 border border-slate-200 dark:border-dgb-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-dgb-500/40";
    const string Eyebrow = "text-[0.6875rem] uppercase tracking-widest font-bold text-slate-500 dark:text-slate-400";
    const string Muted = "text-xs text-slate-500 dark:text-slate-400";
    const string Pre = "bg-slate-900 text-slate-100 rounded-lg p-3 text-[0.6875rem] font-mono overflow-x-auto whitespace-pre-wrap break-all m-0 leading-relaxed";
    const string H2 = "text-base font-bold text-slate-900 dark:text-white m-0";
    const string H1 = "text-xl sm:text-2xl font-bold tracking-tight m-0";
}

@if (bootstrapError != null)
{
    <main class="min-h-dvh flex items-center justify-center p-4 bg-slate-50 dark:bg-dgb-950 text-slate-900 dark:text-white font-sans">
        <div class="@Card text-center"><p class="text-sm text-red-500 m-0">@bootstrapError</p></div>
    </main>
}
else if (account == null)
{
    <main class="min-h-dvh flex items-center justify-center p-4 bg-slate-50 dark:bg-dgb-950 text-slate-900 dark:text-white font-sans">
        <p class="@Muted m-0">Loading…</p>
    </main>
}
else
{
    <div class="min-h-dvh bg-slate-50 dark:bg-dgb-950 text-slate-900 dark:text-white font-sans md:grid md:grid-cols-[240px_1fr]">
        @* Mobile top bar *@
        <header class="md:hidden sticky top-0 z-[15] bg-white dark:bg-dgb-900 border-b border-slate-200 dark:border-dgb-800 px-3 py-2.5 flex items-center gap-2.5">
            <button class="w-9 h-9 flex items-center justify-center border border-slate-200 dark:border-dgb-800 rounded-lg text-lg leading-none"
                    @onclick="() => sidebarOpen = !sidebarOpen" aria-label="Toggle navigation">
                @(sidebarOpen ? "×" : "☰")
            </button>
            <div class="flex items-center gap-1.5 font-bold text-[0.9375rem]">
                <span class="w-2 h-2 rounded-full bg-dgb-500"></span> DigiPay
            </div>
            <div class="flex-1"></div>
            <ThemeToggle />
            <div class="text-right">
                <div class="text-[0.8125rem] font-semibold truncate max-w-[8rem]">@account.DisplayName</div>
                <button class="px-2 py-0.5 text-[0.6875rem] font-semibold text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-dgb-800 rounded transition-colors hover:bg-slate-50 dark:hover:bg-dgb-800"
                        @onclick="SignOutAsync">Sign out</button>
            </div>
        </header>

        @* Mobile backdrop *@
        <div class="md:hidden fixed inset-0 bg-black/50 z-10 @(sidebarOpen ? "block" : "hidden")" @onclick="() => sidebarOpen = false"></div>

        @* Sidebar *@
        <aside class="bg-white dark:bg-dgb-900 border-r border-slate-200 dark:border-dgb-800 md:sticky md:top-0 md:self-start md:h-dvh md:z-20 fixed left-0 top-0 bottom-0 w-64 z-20 transition-transform flex flex-col gap-1 p-5 md:p-3 @(sidebarOpen ? "translate-x-0 shadow-2xl" : "-translate-x-full") md:translate-x-0 md:shadow-none">
            <div class="flex items-center gap-2 pb-3 mb-2 border-b border-slate-200 dark:border-dgb-800 font-bold text-base">
                <span class="w-2.5 h-2.5 rounded-full bg-dgb-500"></span> DigiPay
            </div>

            @* Store switcher — visible only when the account has at least one store *@
            @if (stores.Count > 0)
            {
                <div class="mb-2">
                    <label class="@Eyebrow block mb-1 px-1">Active store</label>
                    <select class="@Input text-[0.8125rem] py-1.5" @bind="activeStoreId" @bind:after="OnActiveStoreChangedAsync">
                        @foreach (var s in stores)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
            }

            <nav class="flex flex-col gap-0.5 flex-1">
                @foreach (var tab in tabs)
                {
                    var t = tab;
                    var active = activeTab == t.Key;
                    <button class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-left transition-colors @(active ? "bg-dgb-500/10 text-dgb-500 font-semibold" : "text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-dgb-800 hover:text-slate-900 dark:hover:text-white")"
                            @onclick="() => SwitchTab(t.Key)">
                        <span class="w-4 h-4 shrink-0 text-center">@t.Icon</span>
                        @t.Label
                    </button>
                }
            </nav>
            <div class="border-t border-slate-200 dark:border-dgb-800 pt-3 flex flex-col gap-1.5 text-xs text-slate-500 dark:text-slate-400">
                <div>@account.DisplayName</div>
                @if (!string.IsNullOrEmpty(account.DigiIdAddress))
                {
                    <div class="font-mono text-[0.625rem]">@(account.DigiIdAddress.Length > 14 ? account.DigiIdAddress[..8] + "…" + account.DigiIdAddress[^4..] : account.DigiIdAddress)</div>
                }
                <div class="flex gap-1.5 items-stretch mt-1">
                    <button class="@BtnGhost flex-1 text-xs py-2" @onclick="SignOutAsync">Sign out</button>
                    <ThemeToggle />
                </div>
            </div>
        </aside>

        <main class="p-4 sm:p-8 max-w-5xl box-border">
            @if (activeStore is null)
            {
                <div class="flex items-baseline justify-between mb-1"><h1 class="@H1">No stores</h1></div>
                <p class="@Muted mb-6">You don't have any stores yet. One should have been created automatically at sign-in.</p>
                <section class="@Card">
                    <button class="@Btn self-start" @onclick='() => SwitchTab("stores")'>Create your first store</button>
                </section>
            }
            else if (activeTab == "overview")
            {
                <div class="flex items-baseline justify-between gap-2 flex-wrap mb-1">
                    <h1 class="@H1">Overview</h1>
                    <span class="@Muted">Store: <strong class="text-slate-900 dark:text-white">@activeStore.Name</strong></span>
                </div>
                <p class="@Muted mb-6">Summary of this store's activity.</p>

                @if (!activeStore.HasReceive)
                {
                    <section class="@Card">
                        <h2 class="@H2">Configure where to receive payments</h2>
                        <p class="@Muted m-0">Before you can create sessions for this store, set a DigiByte address or BIP84 xpub in Settings.</p>
                        <button class="@Btn self-start" @onclick='() => SwitchTab("settings")'>Go to Settings</button>
                    </section>
                }
                else
                {
                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
                        <Stat Label="Total sessions" Value="@((sessions?.Count ?? 0).ToString())" />
                        <Stat Label="Paid / Confirmed" Value="@CountBy("paid", "confirmed").ToString()" />
                        <Stat Label="Pending" Value="@CountBy("pending", "seen").ToString()" />
                        <Stat Label="Expired" Value="@CountBy("expired", "underpaid").ToString()" />
                    </div>

                    <section class="@Card">
                        <h2 class="@H2">New session</h2>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                            <input @bind="newAmount" type="number" step="0.00000001" min="0" placeholder="Amount (DGB)" class="@Input" />
                            <input @bind="newLabel" placeholder="Label" class="@Input" />
                            <input @bind="newMemo" placeholder="Memo / invoice #" class="@Input" />
                        </div>
                        <button class="@Btn" @onclick="CreateSessionAsync" disabled="@(busy || newAmount <= 0)">
                            @(busy ? "Creating…" : "Create session")
                        </button>
                        @if (createError != null) { <p class="text-xs text-red-500 m-0">@createError</p> }
                        @if (createdSession != null)
                        {
                            <div class="bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800/30 rounded-lg p-3 flex flex-col gap-1">
                                <div class="@Eyebrow">Checkout URL</div>
                                <a href="@createdSession.CheckoutUrl" target="_blank" class="font-mono text-[0.6875rem] text-emerald-700 dark:text-emerald-300 break-all underline">@createdSession.CheckoutUrl</a>
                            </div>
                        }
                    </section>
                }
            }
            else if (activeTab == "sessions")
            {
                <div class="flex items-baseline justify-between gap-2 flex-wrap mb-1">
                    <h1 class="@H1">Sessions</h1>
                    <button class="@BtnGhost text-xs py-1.5 px-3" @onclick="LoadSessionsAsync" disabled="@loadingSessions">
                        @(loadingSessions ? "…" : "Refresh")
                    </button>
                </div>
                <p class="@Muted mb-6">Sessions for <strong class="text-slate-900 dark:text-white">@activeStore.Name</strong>, newest first.</p>

                <section class="@Card">
                    @if (sessions == null) { <p class="@Muted m-0">Loading…</p> }
                    else if (sessions.Count == 0) { <p class="@Muted m-0">No sessions yet.</p> }
                    else
                    {
                        <ul class="list-none p-0 m-0 flex flex-col gap-2">
                            @foreach (var s in sessions)
                            {
                                <li>
                                    <a href="@s.CheckoutUrl" target="_blank"
                                       class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 sm:gap-3 p-3 border border-slate-200 dark:border-dgb-800 rounded-lg no-underline text-inherit hover:bg-slate-50 dark:hover:bg-dgb-800 transition-colors">
                                        <div class="min-w-0">
                                            <div class="font-bold text-[0.9375rem] tabular-nums">@s.Amount.ToString("0.########") DGB</div>
                                            <div class="font-mono text-[0.625rem] text-slate-500 dark:text-slate-400 break-all">@s.Address</div>
                                            @if (!string.IsNullOrEmpty(s.Label)) { <div class="@Muted">@s.Label</div> }
                                        </div>
                                        <div class="flex sm:flex-col items-center sm:items-end justify-between sm:justify-start gap-1.5 shrink-0">
                                            <CheckoutStatusPill Status="@s.Status" />
                                            <div class="@Muted">@s.CreatedAt.ToLocalTime().ToString("MMM d, HH:mm")</div>
                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                </section>
            }
            else if (activeTab == "donation")
            {
                <div class="flex items-baseline justify-between mb-1">
                    <h1 class="@H1">Donation button</h1>
                    <span class="@Muted">Store: <strong class="text-slate-900 dark:text-white">@activeStore.Name</strong></span>
                </div>
                <p class="@Muted mb-6">Static BIP21 link — no session created, no tracking. Any DigiByte wallet can pay. Tips reuse this store's donation address.</p>

                <section class="@Card">
                    @if (donationAddress is null) { <p class="@Muted m-0">Loading address…</p> }
                    else
                    {
                        <div class="font-mono text-[0.6875rem] px-3 py-2 bg-slate-50 dark:bg-dgb-950 border border-slate-200 dark:border-dgb-800 rounded-lg break-all">@donationAddress</div>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                            <input @bind="donAmount" @bind:event="oninput" type="number" step="0.00000001" min="0" placeholder="Amount (opt)" class="@Input" />
                            <input @bind="donName" @bind:event="oninput" placeholder="Name (opt)" class="@Input" />
                            <input @bind="donButtonText" @bind:event="oninput" placeholder="Button text" class="@Input" />
                        </div>
                        <div class="@Eyebrow mt-1">Preview</div>
                        <div class="p-4 bg-slate-50 dark:bg-dgb-950 border border-slate-200 dark:border-dgb-800 rounded-lg text-center">
                            <a href="@DonationUrl" target="_blank" class="inline-block px-4 py-2 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-lg no-underline text-sm">
                                @(string.IsNullOrWhiteSpace(donButtonText) ? "Tip DGB" : donButtonText)
                            </a>
                        </div>
                        <div class="@Eyebrow">HTML snippet</div>
                        <pre class="@Pre">@DonationSnippet</pre>
                        <button class="@BtnGhost" @onclick="CopyDonationSnippetAsync">@(donCopied ? "Copied ✓" : "Copy snippet")</button>
                    }
                </section>

                <section class="@Card mt-4">
                    <h2 class="@H2">JS embed widget</h2>
                    <p class="@Muted m-0">Drop this on your site for an in-page checkout modal (keeps the buyer on your domain).</p>
                    <pre class="@Pre">@EmbedSnippet</pre>
                    <button class="@BtnGhost" @onclick="CopyEmbedSnippetAsync">@(embedCopied ? "Copied ✓" : "Copy snippet")</button>
                </section>
            }
            else if (activeTab == "webhook")
            {
                <div class="flex items-baseline justify-between mb-1">
                    <h1 class="@H1">Webhook</h1>
                    <span class="@Muted">Store: <strong class="text-slate-900 dark:text-white">@activeStore.Name</strong></span>
                </div>
                <p class="@Muted mb-6">POST with HMAC-SHA256 signature on session state changes. Each store has its own webhook URL and secret. Header: <span class="font-mono">X-DigiPay-Signature: sha256=…</span></p>

                <section class="@Card">
                    <input @bind="webhookInput" placeholder="https://your-server.example/digipay-webhook" class="@Input" />
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                        <button class="@Btn" @onclick="SaveWebhookAsync" disabled="@(webhookBusy || webhookInput == (activeStore.WebhookUrl ?? ""))">
                            @(webhookBusy ? "Saving…" : "Save")
                        </button>
                        <button class="@BtnGhost" @onclick="TestWebhookAsync" disabled="@(webhookBusy || string.IsNullOrWhiteSpace(activeStore.WebhookUrl))">
                            Send test event
                        </button>
                    </div>
                    @if (webhookMessage != null) { <p class="@Muted m-0">@webhookMessage</p> }
                    @if (webhookError != null) { <p class="text-xs text-red-500 m-0">@webhookError</p> }
                </section>

                <section class="@Card mt-4">
                    <div class="flex items-baseline justify-between">
                        <h2 class="@H2">Delivery log</h2>
                        <button class="@BtnGhost text-xs py-1.5 px-3" @onclick="LoadDeliveriesAsync" disabled="@loadingDeliveries">
                            @(loadingDeliveries ? "…" : "Refresh")
                        </button>
                    </div>
                    <p class="@Muted m-0">Last 25 delivery attempts for this store. Replays re-fire the event with the same payload and add a new row to the log.</p>
                    @if (deliveries is null)
                    {
                        <p class="@Muted m-0">Loading…</p>
                    }
                    else if (deliveries.Count == 0)
                    {
                        <p class="@Muted m-0">No deliveries yet. Save a webhook URL and send a test event to see it here.</p>
                    }
                    else
                    {
                        <ul class="list-none p-0 m-0 flex flex-col gap-2">
                            @foreach (var d in deliveries)
                            {
                                var pillBg = d.Success
                                    ? "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300"
                                    : (d.StatusCode is null
                                        ? "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300"
                                        : "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300");
                                var pillLabel = d.StatusCode?.ToString() ?? "network err";
                                <li class="p-3 border border-slate-200 dark:border-dgb-800 rounded-lg">
                                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                                        <div class="min-w-0 flex-1">
                                            <div class="flex items-center gap-2 flex-wrap">
                                                <span class="text-xs font-semibold px-2 py-0.5 rounded-full @pillBg">@pillLabel</span>
                                                <span class="font-semibold text-sm text-slate-900 dark:text-white">@d.EventName</span>
                                                @if (d.Attempt > 1) { <span class="@Muted">· attempt @d.Attempt</span> }
                                            </div>
                                            <div class="@Muted mt-1">
                                                @d.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                                                @(d.DurationMs is null ? "" : $" · {d.DurationMs}ms")
                                                @(string.IsNullOrEmpty(d.SessionId) ? "" : $" · {d.SessionId}")
                                            </div>
                                            @if (!string.IsNullOrEmpty(d.ErrorMessage))
                                            {
                                                <div class="font-mono text-xs text-red-500 dark:text-red-400 mt-1 break-all">@d.ErrorMessage</div>
                                            }
                                            else if (!string.IsNullOrEmpty(d.ResponseSnippet))
                                            {
                                                <div class="font-mono text-xs text-slate-500 dark:text-slate-400 mt-1 break-all max-w-xl">@(d.ResponseSnippet.Length > 160 ? d.ResponseSnippet[..160] + "…" : d.ResponseSnippet)</div>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(d.SessionId) && !d.SessionId.StartsWith("ses_test_"))
                                        {
                                            <button class="@BtnGhost text-xs py-1.5 px-3 shrink-0" @onclick="() => ReplayDeliveryAsync(d.Id)" disabled="@replayingId.Equals(d.Id)">
                                                @(replayingId == d.Id ? "Replaying…" : "Replay")
                                            </button>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </section>
            }
            else if (activeTab == "stores")
            {
                <div class="flex items-baseline justify-between mb-1"><h1 class="@H1">Stores</h1></div>
                <p class="@Muted mb-6">Each store has its own receive address, webhook config, and sessions. You can run multiple shops from one account.</p>

                <section class="@Card">
                    <h2 class="@H2">Add a new store</h2>
                    <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto_auto] gap-2">
                        <input @bind="newStoreName" placeholder="Store name" class="@Input" />
                        <select @bind="newStoreNetwork" class="@Input sm:w-32">
                            <option value="mainnet">mainnet</option>
                            <option value="testnet">testnet</option>
                            <option value="regtest">regtest</option>
                        </select>
                        <button class="@Btn" @onclick="AddStoreAsync" disabled="@(storeBusy || string.IsNullOrWhiteSpace(newStoreName))">
                            @(storeBusy ? "Adding…" : "Add store")
                        </button>
                    </div>
                    @if (storeError != null) { <p class="text-xs text-red-500 m-0">@storeError</p> }
                </section>

                <section class="@Card mt-4">
                    <h2 class="@H2">Your stores</h2>
                    <ul class="list-none p-0 m-0 flex flex-col gap-2">
                        @foreach (var s in stores)
                        {
                            var isActive = s.Id == activeStoreId;
                            <li class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 p-3 border rounded-lg @(isActive ? "border-dgb-500 bg-dgb-500/5" : "border-slate-200 dark:border-dgb-800")">
                                <div class="min-w-0">
                                    <div class="font-semibold text-sm text-slate-900 dark:text-white">@s.Name @(isActive ? "· active" : "")</div>
                                    <div class="@Muted">
                                        @s.Network ·
                                        @(s.HasReceive ? $"receiving to {s.ReceivePreview}" : "no receive configured")
                                        @(string.IsNullOrEmpty(s.WebhookUrl) ? "" : " · webhook set")
                                    </div>
                                </div>
                                <div class="flex gap-2 shrink-0">
                                    @if (!isActive)
                                    {
                                        <button class="@BtnGhost text-xs py-1.5 px-3" @onclick="() => SetActiveAsync(s.Id)">Switch to</button>
                                    }
                                    <button class="@BtnGhost text-xs py-1.5 px-3 text-red-500 dark:text-red-400 border-red-200 dark:border-red-800/40"
                                            @onclick="() => DeleteStoreAsync(s.Id)"
                                            disabled="@(stores.Count <= 1)">
                                        Delete
                                    </button>
                                </div>
                            </li>
                        }
                    </ul>
                </section>
            }
            else if (activeTab == "apikeys")
            {
                <div class="flex items-baseline justify-between mb-1"><h1 class="@H1">API keys</h1></div>
                <p class="@Muted mb-6">Long-lived tokens for SDK / server-to-server use. Secrets are shown <strong>once</strong> at creation — store them in your secrets manager.</p>

                @if (createdKey is not null)
                {
                    <section class="@Card mb-4 border-emerald-200 dark:border-emerald-800/30 bg-emerald-50 dark:bg-emerald-900/20">
                        <h2 class="@H2 text-emerald-700 dark:text-emerald-300">New key created — copy it now</h2>
                        <p class="@Muted m-0">This is the only time the secret will be shown. After you dismiss this card, only the prefix remains visible.</p>
                        <pre class="@Pre break-all">@createdKey.ApiKey</pre>
                        <div class="flex gap-2 flex-wrap">
                            <button class="@Btn" @onclick="CopyCreatedKeyAsync">@(createdKeyCopied ? "Copied ✓" : "Copy")</button>
                            <button class="@BtnGhost" @onclick="() => { createdKey = null; createdKeyCopied = false; }">Dismiss</button>
                        </div>
                    </section>
                }

                <section class="@Card">
                    <h2 class="@H2">Generate new key</h2>
                    <div class="flex flex-col sm:flex-row sm:items-end gap-2">
                        <div class="flex-1">
                            <input @bind="newKeyLabel" placeholder="Label (e.g. production, ci)" class="@Input" maxlength="80" />
                            <div class="@Muted text-[0.6875rem] mt-1">Optional — just to help you tell keys apart.</div>
                        </div>
                        <button class="@Btn sm:shrink-0" @onclick="CreateApiKeyAsync" disabled="@creatingKey">
                            @(creatingKey ? "Creating…" : "Generate key")
                        </button>
                    </div>
                    @if (apiKeyError != null) { <p class="text-xs text-red-500 m-0">@apiKeyError</p> }
                </section>

                <section class="@Card mt-4">
                    <h2 class="@H2">Your keys</h2>
                    @if (loadingKeys && apiKeys is null)
                    {
                        <p class="@Muted m-0">Loading…</p>
                    }
                    else if (apiKeys is null || apiKeys.Count == 0)
                    {
                        <p class="@Muted m-0">No keys yet. Generate one above to start using the SDK or REST API.</p>
                    }
                    else
                    {
                        <ul class="list-none p-0 m-0 flex flex-col gap-2">
                            @foreach (var k in apiKeys)
                            {
                                <li class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 p-3 border rounded-lg @(k.IsRevoked ? "border-slate-200 dark:border-dgb-800 opacity-50" : "border-slate-200 dark:border-dgb-800")">
                                    <div class="min-w-0">
                                        <div class="font-semibold text-sm text-slate-900 dark:text-white">
                                            @(string.IsNullOrEmpty(k.Label) ? "(no label)" : k.Label)
                                            @if (k.IsRevoked) { <span class="text-xs text-red-500 dark:text-red-400 font-medium"> · revoked</span> }
                                        </div>
                                        <div class="font-mono text-xs text-slate-500 dark:text-slate-400 my-0.5 break-all">@k.Prefix…</div>
                                        <div class="@Muted">
                                            Created @k.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")
                                            @(k.LastUsedAt is null ? " · never used" : $" · last used {k.LastUsedAt.Value.ToLocalTime():yyyy-MM-dd HH:mm}")
                                            @(k.RevokedAt is null ? "" : $" · revoked {k.RevokedAt.Value.ToLocalTime():yyyy-MM-dd}")
                                        </div>
                                    </div>
                                    @if (!k.IsRevoked)
                                    {
                                        <button class="@BtnGhost text-xs py-1.5 px-3 text-red-500 dark:text-red-400 border-red-200 dark:border-red-800/40 shrink-0"
                                                @onclick="() => RevokeApiKeyAsync(k.Id)">
                                            Revoke
                                        </button>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </section>
            }
            else if (activeTab == "settings")
            {
                <div class="flex items-baseline justify-between mb-1">
                    <h1 class="@H1">Settings</h1>
                    <span class="@Muted">Store: <strong class="text-slate-900 dark:text-white">@activeStore.Name</strong></span>
                </div>
                <p class="@Muted mb-6">Account profile + settings for the active store.</p>

                <section class="@Card">
                    <h2 class="@H2">Profile (account)</h2>
                    <p class="@Muted m-0">Display name for you as a DigiPay account owner. Store-facing names are set per store below.</p>
                    <input @bind="nameInput" placeholder="@account.DisplayName" class="@Input" maxlength="120" />
                    <button class="@Btn self-start" @onclick="SaveNameAsync" disabled="@(nameBusy || string.IsNullOrWhiteSpace(nameInput) || nameInput.Trim() == account.DisplayName)">
                        @(nameBusy ? "Saving…" : "Save")
                    </button>
                    @if (nameMessage != null) { <p class="@Muted m-0">@nameMessage</p> }
                    @if (nameError != null) { <p class="text-xs text-red-500 m-0">@nameError</p> }
                </section>

                <section class="@Card mt-4">
                    <h2 class="@H2">Store name</h2>
                    <p class="@Muted m-0">Shown to buyers on the hosted checkout and in webhook payloads.</p>
                    <input @bind="storeNameInput" placeholder="@activeStore.Name" class="@Input" maxlength="120" />
                    <button class="@Btn self-start" @onclick="SaveStoreNameAsync" disabled="@(storeNameBusy || string.IsNullOrWhiteSpace(storeNameInput) || storeNameInput.Trim() == activeStore.Name)">
                        @(storeNameBusy ? "Saving…" : "Save")
                    </button>
                    @if (storeNameError != null) { <p class="text-xs text-red-500 m-0">@storeNameError</p> }
                </section>

                <section class="@Card mt-4">
                    <h2 class="@H2">Receive</h2>
                    @if (activeStore.HasReceive)
                    {
                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                            <div class="min-w-0">
                                <div class="@Eyebrow">Current</div>
                                <div class="font-mono text-sm font-semibold my-0.5 break-all">@activeStore.ReceivePreview</div>
                                <div class="@Muted">@(activeStore.ReceiveMode == "xpub" ? "Fresh address per session" : "Single reused address")</div>
                            </div>
                            <button class="@BtnGhost shrink-0" @onclick="() => showEditReceive = !showEditReceive">
                                @(showEditReceive ? "Cancel" : "Change")
                            </button>
                        </div>
                    }
                    @if (!activeStore.HasReceive || showEditReceive)
                    {
                        <input @bind="receiveInput" placeholder="dgb1… or xpub…" class="@Input font-mono text-xs" />
                        <button class="@Btn" @onclick="SaveReceiveAsync" disabled="@(busy || string.IsNullOrWhiteSpace(receiveInput))">
                            @(busy ? "Saving…" : "Save")
                        </button>
                        @if (patchError != null) { <p class="text-xs text-red-500 m-0">@patchError</p> }
                    }
                </section>

                <section class="@Card mt-4">
                    <h2 class="@H2">Default session expiry</h2>
                    <p class="@Muted m-0">How long a pending session stays open before it expires. Defaults to 30 minutes. Late payments (up to 3 days past expiry) still reconcile automatically.</p>
                    <div class="flex flex-col sm:flex-row sm:items-end gap-2">
                        <div class="flex-1">
                            <input @bind="expiryInput" type="number" min="1" max="1440" placeholder="30" class="@Input" />
                            <div class="@Muted text-[0.6875rem] mt-1">Minutes (1–1440). Blank = global default (30).</div>
                        </div>
                        <button class="@Btn sm:shrink-0" @onclick="SaveExpiryAsync" disabled="@expiryBusy">
                            @(expiryBusy ? "Saving…" : "Save")
                        </button>
                    </div>
                    @if (expiryMessage != null) { <p class="@Muted m-0">@expiryMessage</p> }
                    @if (expiryError != null) { <p class="text-xs text-red-500 m-0">@expiryError</p> }
                </section>
            }
        </main>
    </div>
}

@code {
    private record TabDef(string Key, string Label, string Icon);
    private readonly TabDef[] tabs = new[]
    {
        new TabDef("overview",  "Overview",        "▣"),
        new TabDef("sessions",  "Sessions",        "📋"),
        new TabDef("donation",  "Donation button", "🔘"),
        new TabDef("webhook",   "Webhook",         "🔔"),
        new TabDef("stores",    "Stores",          "🏪"),
        new TabDef("apikeys",   "API keys",        "🔑"),
        new TabDef("settings",  "Settings",        "⚙"),
    };
    private string activeTab = "overview";
    private bool sidebarOpen;

    private void SwitchTab(string key)
    {
        activeTab = key;
        sidebarOpen = false;
    }

    private string? token;
    private AccountDto? account;
    private List<StoreDto> stores = new();
    private string activeStoreId = "";
    private StoreDto? activeStore => stores.FirstOrDefault(s => s.Id == activeStoreId);

    private List<SessionRow>? sessions;
    private string? bootstrapError;

    private string receiveInput = "";
    private bool showEditReceive;
    private string? patchError;

    private decimal newAmount;
    private string newLabel = "";
    private string newMemo = "";
    private CreatedSession? createdSession;
    private string? createError;

    private string? donationAddress;
    private decimal donAmount;
    private string donName = "";
    private string donButtonText = "Tip DGB";
    private bool donCopied;
    private bool embedCopied;

    private string webhookInput = "";
    private bool webhookBusy;
    private string? webhookMessage;
    private string? webhookError;

    private List<WebhookDeliveryDto>? deliveries;
    private bool loadingDeliveries;
    private string replayingId = "";

    private int? expiryInput;
    private bool expiryBusy;
    private string? expiryMessage;
    private string? expiryError;

    private string nameInput = "";
    private bool nameBusy;
    private string? nameMessage;
    private string? nameError;

    private string storeNameInput = "";
    private bool storeNameBusy;
    private string? storeNameError;

    // Stores tab — create new
    private string newStoreName = "";
    private string newStoreNetwork = "mainnet";
    private bool storeBusy;
    private string? storeError;

    // API keys tab
    private List<ApiKeyListDto>? apiKeys;
    private string newKeyLabel = "";
    private bool creatingKey;
    private bool loadingKeys;
    private string? apiKeyError;
    private CreatedApiKeyDto? createdKey;
    private bool createdKeyCopied;

    private bool busy;
    private bool loadingSessions;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || account != null || bootstrapError != null) return;
        try
        {
            token = await JS.InvokeAsync<string?>("localStorage.getItem", "digipay-token");
            if (string.IsNullOrEmpty(token))
            {
                Nav.NavigateTo("/merchant/signin");
                return;
            }
            await LoadAccountAsync();
            if (account is not null && stores.Count > 0)
            {
                activeStoreId = stores[0].Id;
                await LoadActiveStoreContextAsync();
            }
            // Account-scoped (not store-scoped), load once at bootstrap.
            await LoadApiKeysAsync();
            StateHasChanged();
        }
        catch (Exception ex) { bootstrapError = ex.Message; StateHasChanged(); }
    }

    private int CountBy(params string[] statuses) =>
        sessions?.Count(s => statuses.Contains(s.Status)) ?? 0;

    private HttpRequestMessage AuthedRequest(HttpMethod method, string path, HttpContent? content = null)
    {
        var req = new HttpRequestMessage(method, path) { Content = content };
        req.Headers.TryAddWithoutValidation("Authorization", $"Bearer {token}");
        return req;
    }

    private async Task LoadAccountAsync()
    {
        var http = HttpFactory.CreateClient("PayApi");
        var response = await http.SendAsync(AuthedRequest(HttpMethod.Get, "/v1/pay/me/"));
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", "digipay-token");
            Nav.NavigateTo("/merchant/signin");
            return;
        }
        response.EnsureSuccessStatusCode();
        var dto = await response.Content.ReadFromJsonAsync<AccountDto>();
        account = dto;
        stores = dto?.Stores?.ToList() ?? new();
    }

    private async Task LoadActiveStoreContextAsync()
    {
        if (activeStore is null) return;
        webhookInput = activeStore.WebhookUrl ?? "";
        expiryInput = activeStore.DefaultSessionExpiryMinutes;
        await LoadSessionsAsync();
        await LoadDeliveriesAsync();
        if (activeStore.HasReceive) await LoadDonationAddressAsync();
        else donationAddress = null;
    }

    private async Task OnActiveStoreChangedAsync()
    {
        // Reset store-scoped state, reload everything for the new active store.
        donationAddress = null;
        sessions = null;
        deliveries = null;
        createdSession = null;
        showEditReceive = false;
        receiveInput = "";
        storeNameInput = "";
        webhookMessage = webhookError = null;
        expiryMessage = expiryError = null;
        await LoadActiveStoreContextAsync();
        StateHasChanged();
    }

    private async Task SetActiveAsync(string storeId)
    {
        activeStoreId = storeId;
        await OnActiveStoreChangedAsync();
    }

    private async Task LoadSessionsAsync()
    {
        if (activeStore is null) return;
        loadingSessions = true; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Get,
                $"/v1/pay/sessions?take=25&storeId={Uri.EscapeDataString(activeStoreId)}"));
            if (response.IsSuccessStatusCode)
            {
                var payload = await response.Content.ReadFromJsonAsync<SessionList>();
                if (payload != null) sessions = payload.Sessions;
            }
        }
        finally { loadingSessions = false; StateHasChanged(); }
    }

    private async Task LoadDonationAddressAsync()
    {
        if (activeStore is null) return;
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Get,
                $"/v1/pay/stores/{activeStoreId}/donation-address"));
            if (response.IsSuccessStatusCode)
            {
                var dto = await response.Content.ReadFromJsonAsync<DonationAddressDto>();
                donationAddress = dto?.Address;
            }
        }
        catch { }
    }

    private async Task RefreshStoreAsync()
    {
        // Re-fetch account so the stores list (and active store's fields) stay fresh.
        await LoadAccountAsync();
        if (!stores.Any(s => s.Id == activeStoreId) && stores.Count > 0)
            activeStoreId = stores[0].Id;
    }

    private string WebBase => Nav.BaseUri.TrimEnd('/');

    private string DonationUrl
    {
        get
        {
            if (string.IsNullOrEmpty(donationAddress)) return "#";
            var sb = new System.Text.StringBuilder($"{WebBase}/pay/button?to=")
                .Append(Uri.EscapeDataString(donationAddress));
            if (donAmount > 0)
                sb.Append("&amount=").Append(donAmount.ToString("0.########", System.Globalization.CultureInfo.InvariantCulture));
            if (!string.IsNullOrWhiteSpace(donName))
                sb.Append("&name=").Append(Uri.EscapeDataString(donName));
            return sb.ToString();
        }
    }

    private string DonationSnippet =>
        $"<a href=\"{DonationUrl}\" target=\"_blank\" rel=\"noopener\">{System.Net.WebUtility.HtmlEncode(string.IsNullOrWhiteSpace(donButtonText) ? "Tip DGB" : donButtonText)}</a>";

    private string EmbedSnippet =>
        $"<script src=\"{WebBase}/embed/digipay.js?v=0.1\"></script>\n<button data-digipay-checkout data-session-id=\"SESSION_ID\">Pay with DigiByte</button>";

    private async Task CopyDonationSnippetAsync()
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", DonationSnippet); donCopied = true; StateHasChanged(); await Task.Delay(1500); donCopied = false; StateHasChanged(); } catch { }
    }

    private async Task CopyEmbedSnippetAsync()
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", EmbedSnippet); embedCopied = true; StateHasChanged(); await Task.Delay(1500); embedCopied = false; StateHasChanged(); } catch { }
    }

    private async Task SaveReceiveAsync()
    {
        if (activeStore is null) return;
        busy = true; patchError = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var content = JsonContent.Create(new { addressOrXpub = receiveInput.Trim() });
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Patch, $"/v1/pay/stores/{activeStoreId}", content));
            if (!response.IsSuccessStatusCode) { patchError = await response.Content.ReadAsStringAsync(); return; }
            await RefreshStoreAsync();
            receiveInput = "";
            showEditReceive = false;
            if (activeStore?.HasReceive == true) { await LoadSessionsAsync(); await LoadDonationAddressAsync(); }
        }
        catch (Exception ex) { patchError = ex.Message; }
        finally { busy = false; StateHasChanged(); }
    }

    private async Task CreateSessionAsync()
    {
        if (activeStore is null) return;
        busy = true; createError = null; createdSession = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var content = JsonContent.Create(new
            {
                amount = newAmount,
                storeId = activeStoreId,
                label = string.IsNullOrWhiteSpace(newLabel) ? null : newLabel,
                memo = string.IsNullOrWhiteSpace(newMemo) ? null : newMemo,
            });
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Post, "/v1/pay/sessions", content));
            if (!response.IsSuccessStatusCode) { createError = await response.Content.ReadAsStringAsync(); return; }
            createdSession = await response.Content.ReadFromJsonAsync<CreatedSession>();
            newAmount = 0; newLabel = ""; newMemo = "";
            await LoadSessionsAsync();
        }
        catch (Exception ex) { createError = ex.Message; }
        finally { busy = false; StateHasChanged(); }
    }

    private async Task SaveWebhookAsync()
    {
        if (activeStore is null) return;
        webhookBusy = true; webhookError = null; webhookMessage = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var content = JsonContent.Create(new { webhookUrl = webhookInput.Trim() });
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Patch, $"/v1/pay/stores/{activeStoreId}", content));
            if (!response.IsSuccessStatusCode) { webhookError = await response.Content.ReadAsStringAsync(); return; }
            await RefreshStoreAsync();
            webhookMessage = string.IsNullOrWhiteSpace(activeStore?.WebhookUrl) ? "Webhook cleared." : "Webhook saved.";
        }
        catch (Exception ex) { webhookError = ex.Message; }
        finally { webhookBusy = false; StateHasChanged(); }
    }

    private async Task TestWebhookAsync()
    {
        if (activeStore is null) return;
        webhookBusy = true; webhookError = null; webhookMessage = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Post, $"/v1/pay/stores/{activeStoreId}/webhook/test"));
            if (!response.IsSuccessStatusCode) { webhookError = await response.Content.ReadAsStringAsync(); return; }
            webhookMessage = "Test event dispatched — see the delivery log below for the result.";
            await LoadDeliveriesAsync();
        }
        catch (Exception ex) { webhookError = ex.Message; }
        finally { webhookBusy = false; StateHasChanged(); }
    }

    private async Task LoadDeliveriesAsync()
    {
        if (activeStore is null) return;
        loadingDeliveries = true; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Get,
                $"/v1/pay/stores/{activeStoreId}/webhook-deliveries"));
            if (response.IsSuccessStatusCode)
            {
                deliveries = await response.Content.ReadFromJsonAsync<List<WebhookDeliveryDto>>() ?? new();
            }
        }
        catch { /* non-fatal; the ref stays null and the tab shows "loading…" */ }
        finally { loadingDeliveries = false; StateHasChanged(); }
    }

    private async Task ReplayDeliveryAsync(string deliveryId)
    {
        if (activeStore is null) return;
        replayingId = deliveryId; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Post,
                $"/v1/pay/stores/{activeStoreId}/webhook-deliveries/{deliveryId}/replay"));
            if (!response.IsSuccessStatusCode)
            {
                webhookError = await response.Content.ReadAsStringAsync();
                return;
            }
            await LoadDeliveriesAsync();
        }
        catch (Exception ex) { webhookError = ex.Message; }
        finally { replayingId = ""; StateHasChanged(); }
    }

    private async Task SaveExpiryAsync()
    {
        if (activeStore is null) return;
        expiryBusy = true; expiryError = null; expiryMessage = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var content = JsonContent.Create(new { defaultSessionExpiryMinutes = expiryInput });
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Patch, $"/v1/pay/stores/{activeStoreId}", content));
            if (!response.IsSuccessStatusCode) { expiryError = await response.Content.ReadAsStringAsync(); return; }
            await RefreshStoreAsync();
            expiryMessage = activeStore?.DefaultSessionExpiryMinutes is int m ? $"Default is now {m} minutes." : "Using global default (30 minutes).";
        }
        catch (Exception ex) { expiryError = ex.Message; }
        finally { expiryBusy = false; StateHasChanged(); }
    }

    private async Task SaveNameAsync()
    {
        nameBusy = true; nameError = null; nameMessage = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var content = JsonContent.Create(new { displayName = nameInput.Trim() });
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Patch, "/v1/pay/me/", content));
            if (!response.IsSuccessStatusCode) { nameError = await response.Content.ReadAsStringAsync(); return; }
            await LoadAccountAsync();
            nameMessage = "Saved.";
            nameInput = "";
        }
        catch (Exception ex) { nameError = ex.Message; }
        finally { nameBusy = false; StateHasChanged(); }
    }

    private async Task SaveStoreNameAsync()
    {
        if (activeStore is null) return;
        storeNameBusy = true; storeNameError = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var content = JsonContent.Create(new { name = storeNameInput.Trim() });
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Patch, $"/v1/pay/stores/{activeStoreId}", content));
            if (!response.IsSuccessStatusCode) { storeNameError = await response.Content.ReadAsStringAsync(); return; }
            await RefreshStoreAsync();
            storeNameInput = "";
        }
        catch (Exception ex) { storeNameError = ex.Message; }
        finally { storeNameBusy = false; StateHasChanged(); }
    }

    private async Task AddStoreAsync()
    {
        storeBusy = true; storeError = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var content = JsonContent.Create(new { name = newStoreName.Trim(), network = newStoreNetwork });
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Post, "/v1/pay/stores", content));
            if (!response.IsSuccessStatusCode) { storeError = await response.Content.ReadAsStringAsync(); return; }
            var created = await response.Content.ReadFromJsonAsync<StoreDto>();
            await LoadAccountAsync();
            if (created is not null)
            {
                activeStoreId = created.Id;
                await LoadActiveStoreContextAsync();
            }
            newStoreName = "";
        }
        catch (Exception ex) { storeError = ex.Message; }
        finally { storeBusy = false; StateHasChanged(); }
    }

    private async Task DeleteStoreAsync(string storeId)
    {
        if (stores.Count <= 1) return;
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Delete, $"/v1/pay/stores/{storeId}"));
            if (!response.IsSuccessStatusCode)
            {
                storeError = await response.Content.ReadAsStringAsync();
                StateHasChanged();
                return;
            }
            await LoadAccountAsync();
            if (activeStoreId == storeId && stores.Count > 0)
            {
                activeStoreId = stores[0].Id;
                await LoadActiveStoreContextAsync();
            }
            StateHasChanged();
        }
        catch (Exception ex) { storeError = ex.Message; StateHasChanged(); }
    }

    private async Task LoadApiKeysAsync()
    {
        loadingKeys = true; apiKeyError = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Get, "/v1/pay/api-keys"));
            if (response.IsSuccessStatusCode)
            {
                apiKeys = await response.Content.ReadFromJsonAsync<List<ApiKeyListDto>>() ?? new();
            }
        }
        catch (Exception ex) { apiKeyError = ex.Message; }
        finally { loadingKeys = false; StateHasChanged(); }
    }

    private async Task CreateApiKeyAsync()
    {
        creatingKey = true; apiKeyError = null; StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var label = string.IsNullOrWhiteSpace(newKeyLabel) ? null : newKeyLabel.Trim();
            var content = JsonContent.Create(new { label });
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Post, "/v1/pay/api-keys", content));
            if (!response.IsSuccessStatusCode)
            {
                apiKeyError = await response.Content.ReadAsStringAsync();
                return;
            }
            createdKey = await response.Content.ReadFromJsonAsync<CreatedApiKeyDto>();
            createdKeyCopied = false;
            newKeyLabel = "";
            await LoadApiKeysAsync();
        }
        catch (Exception ex) { apiKeyError = ex.Message; }
        finally { creatingKey = false; StateHasChanged(); }
    }

    private async Task RevokeApiKeyAsync(string id)
    {
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.SendAsync(AuthedRequest(HttpMethod.Delete, $"/v1/pay/api-keys/{id}"));
            if (!response.IsSuccessStatusCode) { apiKeyError = await response.Content.ReadAsStringAsync(); StateHasChanged(); return; }
            await LoadApiKeysAsync();
        }
        catch (Exception ex) { apiKeyError = ex.Message; StateHasChanged(); }
    }

    private async Task CopyCreatedKeyAsync()
    {
        if (createdKey is null) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", createdKey.ApiKey);
            createdKeyCopied = true;
            StateHasChanged();
        }
        catch { }
    }

    private async Task SignOutAsync()
    {
        if (!string.IsNullOrEmpty(token))
        {
            try
            {
                var http = HttpFactory.CreateClient("PayApi");
                await http.SendAsync(AuthedRequest(HttpMethod.Delete, "/v1/pay/auth/session"));
            }
            catch { }
        }
        await JS.InvokeVoidAsync("localStorage.removeItem", "digipay-token");
        await JS.InvokeVoidAsync("localStorage.removeItem", "digipay-merchant-id");
        Nav.NavigateTo("/");
    }

    private record AccountDto(string Id, string DisplayName, string? DigiIdAddress, DateTime CreatedAt, List<StoreDto>? Stores);

    private record StoreDto(string Id, string MerchantId, string Name, string Network,
        string ReceiveMode, bool HasReceive, string? ReceivePreview,
        string? WebhookUrl, bool HasWebhookSecret,
        int? DefaultSessionExpiryMinutes, DateTime CreatedAt);

    private record SessionList(int Total, int Take, int Skip, List<SessionRow> Sessions);

    private record SessionRow(string Id, string? StoreId, string Address, long AmountSatoshis, decimal Amount,
        string? FiatCurrency, decimal? FiatAmount, string? Label, string? Memo,
        string Status, DateTime CreatedAt, DateTime ExpiresAt,
        long ReceivedSatoshis, int Confirmations, string? PaidTxid,
        string Uri, string CheckoutUrl);

    private record CreatedSession(string Id, string? StoreId, string Address, decimal Amount, string Status,
        string Uri, string CheckoutUrl);

    private record DonationAddressDto(string Address, string Mode);

    private record ApiKeyListDto(string Id, string? Label, string Prefix,
        DateTime CreatedAt, DateTime? LastUsedAt, DateTime? RevokedAt, bool IsRevoked);

    private record CreatedApiKeyDto(string Id, string? Label, string Prefix,
        DateTime CreatedAt, string ApiKey);

    private record WebhookDeliveryDto(string Id, string StoreId, string? SessionId,
        string EventName, string Url, int Attempt, int? StatusCode, string? ErrorMessage,
        int? DurationMs, string? ResponseSnippet,
        DateTime CreatedAt, DateTime? DeliveredAt, bool Success);
}
