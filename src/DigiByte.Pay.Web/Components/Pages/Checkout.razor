@page "/pay/{SessionId}"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IHttpClientFactory HttpFactory
@inject PayApiUrl PayApi
@using Microsoft.AspNetCore.SignalR.Client
@using System.Net.Http.Json

<PageTitle>@PageTitleText</PageTitle>

<main class="min-h-dvh flex items-center justify-center p-4 bg-slate-50 dark:bg-dgb-950 text-slate-900 dark:text-white font-sans page-enter">
    <div class="w-full max-w-md">
        @if (loadError != null)
        {
            <div data-digipay-measure class="bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-3xl p-6 text-center shadow-sm">
                <h2 class="text-lg font-bold m-0 mb-2">Payment link unavailable</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">@loadError</p>
            </div>
        }
        else if (session == null)
        {
            <div data-digipay-measure class="bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-3xl p-8 text-center shadow-sm">
                <Loader Text="Loading payment…" />
            </div>
        }
        else
        {
            <div data-digipay-measure class="bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-3xl p-5 sm:p-6 flex flex-col items-center gap-4 shadow-sm">
                @* Header: session label (if provided) is the primary identity,
                   store/merchant name sits smaller underneath. Falls back to just
                   "PAY / Store" when no label is set on the session. *@
                <header class="w-full flex items-start justify-between gap-4">
                    <div class="min-w-0">
                        @if (!string.IsNullOrWhiteSpace(session.Label))
                        {
                            <div class="text-base sm:text-lg font-bold leading-tight break-words">@session.Label</div>
                            <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                                @(merchantName ?? "Merchant")
                            </div>
                        }
                        else
                        {
                            <div class="text-[0.6875rem] font-bold tracking-widest text-slate-500 dark:text-slate-400 uppercase">PAY</div>
                            <div class="text-sm font-bold">@(merchantName ?? "Merchant")</div>
                        }
                    </div>
                    <CheckoutStatusPill Status="@session.Status" />
                </header>

                @if (session.FiatAmount is { } fiatAmt && !string.IsNullOrWhiteSpace(session.FiatCurrency))
                {
                    @* Fiat-priced session: merchant keyed in a fiat amount (e.g. 12.50 EUR)
                       and we quoted a DGB equivalent at creation time. Lead with the fiat
                       number the customer recognises; DGB sub-line is what actually gets paid. *@
                    <div class="flex flex-col items-center gap-1">
                        <div class="text-3xl sm:text-4xl font-bold tabular-nums">@FormatFiat(fiatAmt) <span class="text-slate-500 dark:text-slate-400 text-2xl sm:text-3xl font-semibold">@session.FiatCurrency!.ToUpperInvariant()</span></div>
                        <div class="text-sm text-slate-500 dark:text-slate-400 tabular-nums">≈ @FormatDgb(session.AmountSatoshis) DGB</div>
                    </div>
                }
                else
                {
                    <div class="text-3xl sm:text-4xl font-bold tabular-nums">@FormatDgb(session.AmountSatoshis) DGB</div>
                }

                @* Price-volatility notice. The DGB amount is locked at session
                   creation, so if the live price has moved meaningfully the
                   customer's fiat outlay differs from the sticker price — we
                   surface the direction + magnitude so they can decide whether
                   to pay now or ask the merchant to re-quote. Only meaningful
                   for fiat-priced sessions with a recorded quote. *@
                @if (priceDriftPct is { } drift && Math.Abs(drift) >= DriftThreshold && !IsTerminal(session.Status))
                {
                    var pricierNow = drift > 0;
                    <div class="w-full text-xs rounded-xl px-3 py-2 border flex items-start gap-2 @(pricierNow ? "bg-amber-50 dark:bg-amber-900/20 border-amber-200 dark:border-amber-900/40 text-amber-800 dark:text-amber-200" : "bg-emerald-50 dark:bg-emerald-900/20 border-emerald-200 dark:border-emerald-900/40 text-emerald-800 dark:text-emerald-200")">
                        <span aria-hidden="true">@(pricierNow ? "⚠" : "↓")</span>
                        <span>
                            DGB has moved <strong>@drift.ToString("+0.0;-0.0;0.0")%</strong> since this invoice was issued.
                            @if (pricierNow)
                            {
                                <text> Paying now costs a bit more in @session.FiatCurrency!.ToUpperInvariant() than the sticker price.</text>
                            }
                            else
                            {
                                <text> Paying now is slightly cheaper in @session.FiatCurrency!.ToUpperInvariant() than the sticker price.</text>
                            }
                        </span>
                    </div>
                }

                @if (IsTerminal(session.Status))
                {
                    <TerminalState Status="@session.Status" Txid="@session.PaidTxid" SessionId="@session.Id" ReturnUrl="@session.ReturnUrl" />
                }
                else
                {
                    @* QR with DigiByte logo centered on top. The QR is generated with
                       ECC level H (30% error correction) so the covered modules stay
                       recoverable — the logo only occupies the middle ~18% of area. *@
                    <div class="relative bg-white p-3 rounded-2xl shadow-inner">
                        <img src="@qrDataUrl" alt="Scan to pay" class="block w-56 h-56 rounded-lg" />
                        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                            <div class="bg-white rounded-xl p-1.5 shadow-sm">
                                <img src="/digibyte-logo.svg" alt="" class="block w-9 h-9" />
                            </div>
                        </div>
                    </div>
                    <a href="@session.Uri" class="w-full text-center py-3 px-4 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-xl no-underline transition-colors">Open in wallet</a>
                    <div class="w-full font-mono text-[0.6875rem] text-center break-all bg-slate-50 dark:bg-dgb-950 text-slate-500 dark:text-slate-400 p-3 rounded-xl border border-slate-100 dark:border-dgb-800">@session.Address</div>
                    @* ISO-8601 UTC goes to the attribute; checkout-countdown.js rewrites
                       the inner span's text every second. Avoids a server timer + circuit
                       round-trip, which was broken inside the embed iframe. *@
                    <div class="text-[0.6875rem] text-slate-500 dark:text-slate-400">
                        Expires in <span data-digipay-expires="@session.ExpiresAt.ToString("o", System.Globalization.CultureInfo.InvariantCulture)">—</span>
                    </div>
                }
            </div>
        }
    </div>
</main>

@code {
    [Parameter] public string SessionId { get; set; } = "";

    private SessionDto? session;
    private string? merchantName;
    private string? loadError;
    private string? qrDataUrl;
    // Drift between quote-time and current DGB price. Null until the live
    // price is fetched; |value| > DriftThreshold pops the volatility banner.
    // Recomputed on SignalR StatusChanged so a slow confirm also refreshes it.
    private decimal? priceDriftPct;
    private const decimal DriftThreshold = 3m; // percent; ±3% feels right for 30-min windows
    // Expiry countdown lives purely client-side (see wwwroot/checkout-countdown.js)
    // because Blazor's InteractiveServer circuit doesn't reliably hydrate inside
    // the embed iframe — a server-timer pattern leaves the user stuck on "—".
    private Microsoft.AspNetCore.SignalR.Client.HubConnection? hub;

    private string PageTitleText => merchantName is null ? "Pay" : $"Pay {merchantName}";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var response = await http.GetFromJsonAsync<GetSessionResponse>($"/v1/pay/sessions/{SessionId}");
            session = response?.Session;
            merchantName = response?.MerchantName;
            if (session == null) { loadError = "Session not found."; return; }
            qrDataUrl = GenerateQr(session.Uri);
            await RefreshPriceDriftAsync();
        }
        catch (Exception ex) { loadError = $"Could not load session: {ex.Message}"; }
    }

    // Fetch the live DGB price for the session's fiat and compare it to the
    // quote recorded at session creation. Silent-fail — if the price service
    // is down we just don't show the banner. No-op for pure-DGB sessions.
    private async Task RefreshPriceDriftAsync()
    {
        if (session is null) return;
        if (session.DgbPriceAtCreation is not { } quote || quote <= 0m) return;
        if (string.IsNullOrWhiteSpace(session.FiatCurrency)) return;
        if (IsTerminal(session.Status)) return;
        try
        {
            var http = HttpFactory.CreateClient("PayApi");
            var quoteDto = await http.GetFromJsonAsync<PriceQuoteDto>(
                $"/v1/pay/public/price?currency={Uri.EscapeDataString(session.FiatCurrency)}");
            if (quoteDto is null || quoteDto.DgbPrice <= 0m) return;
            priceDriftPct = (quoteDto.DgbPrice - quote) / quote * 100m;
        }
        catch { /* swallow — banner just stays hidden */ }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || session is null || IsTerminal(session.Status)) return;
        await ConnectHubAsync();
    }

    private async Task ConnectHubAsync()
    {
        if (hub is not null) return;
        hub = new Microsoft.AspNetCore.SignalR.Client.HubConnectionBuilder()
            .WithUrl($"{PayApi.Value}/hubs/checkout")
            .WithAutomaticReconnect()
            .Build();
        hub.On<StatusUpdate>("StatusChanged", OnStatusChanged);
        await hub.StartAsync();
        await hub.InvokeAsync("SubscribeToSession", SessionId);
    }

    private async Task OnStatusChanged(StatusUpdate update)
    {
        if (session == null) return;
        await InvokeAsync(() =>
        {
            session = session with
            {
                Status = update.Status,
                ReceivedSatoshis = update.ReceivedSatoshis,
                Confirmations = update.Confirmations,
                PaidTxid = update.Txid ?? session.PaidTxid,
            };
            StateHasChanged();
        });
        // A pending → pending update (e.g. a periodic nudge) is a good moment
        // to re-check drift; terminal transitions short-circuit inside.
        await RefreshPriceDriftAsync();
    }

    private static string GenerateQr(string content)
    {
        // ECC level H (30% error correction) so the DigiByte logo overlay in the
        // UI covers the centre without making the code unscannable.
        using var gen = new QRCoder.QRCodeGenerator();
        using var data = gen.CreateQrCode(content, QRCoder.QRCodeGenerator.ECCLevel.H);
        using var qr = new QRCoder.PngByteQRCode(data);
        return $"data:image/png;base64,{Convert.ToBase64String(qr.GetGraphic(6))}";
    }

    private static string FormatDgb(long sats) =>
        (sats / 100_000_000m).ToString("0.########", System.Globalization.CultureInfo.InvariantCulture);

    private static string FormatFiat(decimal amount) =>
        amount.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);

    private static bool IsTerminal(string status) =>
        status is "confirmed" or "expired" or "underpaid" or "refunded" or "voided";

    public async ValueTask DisposeAsync()
    {
        if (hub != null) await hub.DisposeAsync();
    }

    public record GetSessionResponse(SessionDto Session, string? MerchantName);

    public record SessionDto(
        string Id, string Address, long AmountSatoshis, decimal Amount,
        string? FiatCurrency, decimal? FiatAmount, decimal? DgbPriceAtCreation,
        string? Label, string? Memo,
        string Status, DateTime CreatedAt, DateTime ExpiresAt,
        long ReceivedSatoshis, int Confirmations, string? PaidTxid,
        string Uri, string CheckoutUrl,
        // Optional merchant URL the buyer is sent back to once paid.
        // Null for SDK / direct-API merchants who own the after-payment page.
        string? ReturnUrl = null);

    public record StatusUpdate(string SessionId, string Status, long ReceivedSatoshis, int Confirmations, string? Txid);

    // Minimal shape for /v1/pay/public/price — only the number we need, casing
    // matches the API's camelCase JSON.
    public record PriceQuoteDto(
        [property: System.Text.Json.Serialization.JsonPropertyName("dgbPrice")] decimal DgbPrice);
}
