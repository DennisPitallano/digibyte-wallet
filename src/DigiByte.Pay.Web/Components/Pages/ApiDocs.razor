@page "/docs/api"
@rendermode InteractiveServer
@inject PayApiPublicUrl ApiPublic
@inject NavigationManager Nav

<PageTitle>API reference — DigiPay</PageTitle>

@{
    // Resolve the public API base. If the configured value is absent or points
    // at a non-browser-reachable address (Railway's *.railway.internal, or
    // localhost without a port override in prod) we derive one from the current
    // request: pay.dgbwallet.app → api.pay.dgbwallet.app. This keeps the Scalar
    // link working even when someone forgets to set DigiPay:ApiPublicUrl on the
    // digipay-web Railway service.
    string ResolveApiPublic()
    {
        var cfg = ApiPublic.Value?.TrimEnd('/') ?? "";
        var looksInternal = cfg.Length == 0
            || cfg.Contains(".railway.internal", StringComparison.OrdinalIgnoreCase)
            || cfg.Contains(".internal:", StringComparison.OrdinalIgnoreCase);
        if (!looksInternal) return cfg;

        var uri = new Uri(Nav.BaseUri);
        // Local dev falls back to the configured value (usually http://localhost:5008).
        if (uri.Host is "localhost" or "127.0.0.1" || uri.Host.EndsWith(".local", StringComparison.OrdinalIgnoreCase))
            return cfg;
        // pay.dgbwallet.app → api.pay.dgbwallet.app. Strips a leading "www." if present.
        var host = uri.Host.StartsWith("www.", StringComparison.OrdinalIgnoreCase) ? uri.Host[4..] : uri.Host;
        return $"{uri.Scheme}://api.{host}";
    }
    var apiPublic = ResolveApiPublic();
}

<div class="min-h-dvh flex flex-col bg-slate-50 dark:bg-dgb-950 text-slate-900 dark:text-white font-sans">
    <SiteNav />

    <main class="flex-1 page-enter">
        <article class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
            <h1 class="text-2xl sm:text-4xl font-bold tracking-tight mb-2 slide-up">API reference</h1>
            <p class="text-base sm:text-lg text-slate-600 dark:text-slate-400 leading-relaxed mb-4 slide-up-delay-1">
                DigiPay speaks plain REST. All endpoints live under <InlineCode>/v1/pay</InlineCode>.
                An account (merchant) owns one or more stores; most per-shop config (receive
                address, webhook, session defaults) is scoped to a store.
            </p>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-6 slide-up-delay-1">
                On Node / Python / .NET? Skip the hand-rolling — <a href="/sdks" class="text-dgb-500 hover:underline font-medium">grab a first-party SDK</a>. One-line install, typed, zero deps.
            </p>

            @* Live OpenAPI / Scalar callout — prefer sending integrators to the
               interactive explorer when they just want to poke endpoints. *@
            <div class="mb-10 rounded-2xl border border-dgb-200/70 dark:border-dgb-800 bg-gradient-to-br from-dgb-50 to-white dark:from-dgb-900 dark:to-dgb-950 p-5 sm:p-6">
                <div class="flex items-start gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl bg-dgb-500/10 dark:bg-dgb-500/20 flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-dgb-500" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3M6.75 15h10.5M4.5 4.5h15A1.5 1.5 0 0 1 21 6v12a1.5 1.5 0 0 1-1.5 1.5h-15A1.5 1.5 0 0 1 3 18V6a1.5 1.5 0 0 1 1.5-1.5Z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-base sm:text-lg font-semibold text-slate-900 dark:text-white">Live, interactive reference</h3>
                        <p class="text-sm text-slate-600 dark:text-slate-400 mt-0.5">Every endpoint below is documented as OpenAPI 3.1 and rendered with Scalar — try requests in the browser.</p>
                    </div>
                </div>
                <div class="flex flex-wrap gap-2 mt-4">
                    <a href="@($"{apiPublic}/scalar")" target="_blank" rel="noopener"
                       class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-dgb-500 hover:bg-dgb-600 text-white text-sm font-semibold transition-colors no-underline">
                        Open Scalar explorer
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                        </svg>
                    </a>
                    <a href="@($"{apiPublic}/openapi/v1.json")" target="_blank" rel="noopener"
                       class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-white dark:bg-dgb-800 hover:bg-slate-50 dark:hover:bg-dgb-700 border border-slate-200 dark:border-dgb-700 text-slate-700 dark:text-slate-200 text-sm font-semibold transition-colors no-underline">
                        Download openapi.json
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
                        </svg>
                    </a>
                </div>
            </div>

            <DocsHeading>Authentication</DocsHeading>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mb-3">
                Two token kinds share the same <InlineCode>Authorization: Bearer …</InlineCode> header,
                distinguished by prefix:
            </p>
            <ul class="space-y-1 leading-relaxed text-slate-700 dark:text-slate-300 list-disc pl-5 mb-3">
                <li><InlineCode>dps_…</InlineCode> — <strong>session token</strong> minted when you sign in with Digi-ID from the dashboard. 30-day rolling expiry, revoked on sign-out. Used by the browser.</li>
                <li><InlineCode>dgp_…</InlineCode> — <strong>API key</strong>. Long-lived, N per account, revocable individually. Used by your server / CI / SDK. Create them from the API keys tab.</li>
            </ul>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mb-3">Both look like <InlineCode>{prefix}_{secret}</InlineCode>. Only a SHA-256 hash of the secret is stored server-side; losing the secret means you mint (or revoke + re-create) the key, not your funds.</p>
            <CodeBlock>Authorization: Bearer dgp_@("{prefix}_{secret}")</CodeBlock>

            <DocsHeading>Register (SDK)</DocsHeading>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mb-3">Unauthenticated. Creates an account + its first store in one call and returns the initial API key. Aimed at self-host installs and CLI bootstrapping — interactive users should sign in with Digi-ID from the dashboard instead.</p>

            <Endpoint Method="POST" Path="/v1/pay/merchants">
                <CodeBlock>@("{\n  \"displayName\": \"My Shop\",\n  \"addressOrXpub\": \"dgb1q…\",           // or an xpub6/zpub\n  \"network\": \"mainnet\",                 // optional\n  \"webhookUrl\": \"https://…/digipay\"    // optional, generates webhookSecret\n}")</CodeBlock>
                <p class="leading-relaxed text-slate-700 dark:text-slate-300 mt-3">Response includes <InlineCode>id</InlineCode>, <InlineCode>storeId</InlineCode>, and a one-shot <InlineCode>apiKey</InlineCode>. Save the key — the secret is never retrievable again.</p>
            </Endpoint>

            <DocsHeading>Digi-ID sign-in</DocsHeading>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mb-3">Used by the browser dashboard — servers typically don't need this flow.</p>

            <Endpoint Method="GET" Path="/v1/pay/auth/challenge">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Returns <InlineCode>{ nonce, uri, expiresAt }</InlineCode>. Render <InlineCode>uri</InlineCode> as a QR for the user's DigiByte wallet to sign.</p>
            </Endpoint>

            <Endpoint Method="POST" Path="/v1/pay/auth/callback">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Wallet-driven: POSTs <InlineCode>@("{ address, uri, signature }")</InlineCode>. DigiPay verifies the signature, creates the merchant + Default Store if new, and marks the challenge as signed.</p>
            </Endpoint>

            <Endpoint Method="GET" Path="/v1/pay/auth/poll/{nonce}">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Browser polls this until it flips to <InlineCode>{ status: "signed", merchantId, displayName, token }</InlineCode>. Store the token — it's your Bearer.</p>
            </Endpoint>

            <Endpoint Method="DELETE" Path="/v1/pay/auth/session">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Sign out: invalidates the current <InlineCode>dps_</InlineCode> session token. API keys are untouched.</p>
            </Endpoint>

            <DocsHeading>Account</DocsHeading>

            <Endpoint Method="GET" Path="/v1/pay/me">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Returns the authenticated account: <InlineCode>{ id, displayName, digiIdAddress, createdAt, stores: [ … ] }</InlineCode>.</p>
            </Endpoint>

            <Endpoint Method="PATCH" Path="/v1/pay/me">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0 mb-3">Update the account display name (everything else lives per-store now):</p>
                <CodeBlock>@("{\n  \"displayName\": \"Acme Co\"\n}")</CodeBlock>
            </Endpoint>

            <DocsHeading>Stores</DocsHeading>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mb-3">A store owns its receive address/xpub, webhook URL, default expiry, and sessions. One account can run many stores (multiple shops, tip jars, per-environment setups).</p>

            <Endpoint Method="GET" Path="/v1/pay/stores">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">List all stores owned by the account.</p>
            </Endpoint>

            <Endpoint Method="POST" Path="/v1/pay/stores">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0 mb-3">Create a new store:</p>
                <CodeBlock>@("{\n  \"name\": \"Acme Tips Jar\",\n  \"network\": \"mainnet\"              // optional: mainnet | testnet | regtest\n}")</CodeBlock>
            </Endpoint>

            <Endpoint Method="GET" Path="/v1/pay/stores/{storeId}">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Returns one store. 404 if the store belongs to a different merchant.</p>
            </Endpoint>

            <Endpoint Method="PATCH" Path="/v1/pay/stores/{storeId}">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0 mb-3">Update any subset of the below. Setting <InlineCode>webhookUrl</InlineCode> for the first time auto-generates a webhook secret.</p>
                <CodeBlock>@("{\n  \"name\": \"Main Shop\",\n  \"network\": \"mainnet\",\n  \"addressOrXpub\": \"dgb1q…\",          // or an xpub; empty string clears\n  \"webhookUrl\": \"https://…/digipay\",  // empty string clears + revokes secret\n  \"defaultSessionExpiryMinutes\": 45    // 1..1440\n}")</CodeBlock>
            </Endpoint>

            <Endpoint Method="DELETE" Path="/v1/pay/stores/{storeId}">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Delete a store. Rejects the request if this is the account's only remaining store.</p>
            </Endpoint>

            <Endpoint Method="GET" Path="/v1/pay/stores/{storeId}/donation-address">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Stable address for donation buttons. In xpub mode this is derive index 0 (reserved — invoice sessions start at 1). In address mode it's the configured address.</p>
            </Endpoint>

            <Endpoint Method="POST" Path="/v1/pay/stores/{storeId}/webhook/test">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Fires a synthetic <InlineCode>webhook.test</InlineCode> at the configured URL. Response includes the resulting delivery id + status so you can see what happened without opening the dashboard.</p>
            </Endpoint>

            <DocsHeading>Sessions</DocsHeading>

            <Endpoint Method="POST" Path="/v1/pay/sessions">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0 mb-3">Create a payment session. <InlineCode>storeId</InlineCode> is optional — omit it to use the account's first store.</p>
                <CodeBlock>@("{\n  \"amount\": 12.5,                 // required, DGB\n  \"storeId\": \"sto_…\",             // optional, defaults to first store\n  \"label\": \"Order #4201\",         // optional, shown on checkout\n  \"memo\": \"inv-001\",              // optional, merchant-private\n  \"fiatCurrency\": \"USD\",          // optional\n  \"fiatAmount\": 5.00,             // optional\n  \"expiresInSeconds\": 1800        // optional, overrides store default\n}")</CodeBlock>
                <p class="leading-relaxed text-slate-700 dark:text-slate-300 mt-3">Response includes the derived <InlineCode>address</InlineCode>, <InlineCode>storeId</InlineCode>, a BIP21 <InlineCode>uri</InlineCode>, the hosted <InlineCode>checkoutUrl</InlineCode>, and <InlineCode>expiresAt</InlineCode>.</p>
            </Endpoint>

            <Endpoint Method="GET" Path="/v1/pay/sessions">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">List sessions, newest first. Filters: <InlineCode>?status=pending|seen|paid|confirmed|expired|underpaid</InlineCode>, <InlineCode>?storeId=sto_…</InlineCode>, <InlineCode>?take=1..100</InlineCode> (default 25), <InlineCode>?skip=0..</InlineCode>.</p>
            </Endpoint>

            <Endpoint Method="GET" Path="/v1/pay/sessions/{id}">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Public read of a session's current state. No auth — the id is random and contains no secret. Used by the hosted checkout page.</p>
            </Endpoint>

            <DocsHeading>API keys</DocsHeading>

            <Endpoint Method="GET" Path="/v1/pay/api-keys">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">List your keys. Returns prefix + metadata (created, last used, revoked) — never the raw secret.</p>
            </Endpoint>

            <Endpoint Method="POST" Path="/v1/pay/api-keys">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0 mb-3">Create a new API key. The raw secret is returned <strong>once</strong> in the response as <InlineCode>apiKey</InlineCode>; save it to your secrets manager. DigiPay only stores the hash.</p>
                <CodeBlock>@("{\n  \"label\": \"production\"            // optional, 1..80 chars\n}")</CodeBlock>
            </Endpoint>

            <Endpoint Method="DELETE" Path="/v1/pay/api-keys/{id}">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Revoke a key. Further auth attempts with it return 401. Already-in-flight sessions are unaffected; webhooks continue to fire.</p>
            </Endpoint>

            <DocsHeading>Webhooks</DocsHeading>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mb-3">DigiPay POSTs signed JSON to a store's <InlineCode>webhookUrl</InlineCode> on every session state change. Every attempt is persisted and visible in the dashboard; failures can be replayed manually. Automatic retries / dead-letter aren't in scope yet — treat webhooks as a hint and reconcile via <InlineCode>GET /v1/pay/sessions/{id}</InlineCode> if your flow is money-critical.</p>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mt-3 mb-2">Body:</p>
            <CodeBlock>@("{\n  \"event\": \"session.paid\",\n  \"timestamp\": \"2026-04-19T12:34:56Z\",\n  \"session\": {\n    \"id\": \"ses_…\",\n    \"merchantId\": \"mer_…\",\n    \"storeId\": \"sto_…\",\n    \"address\": \"dgb1q…\",\n    \"amountSatoshis\": 1250000000,\n    \"amount\": 12.5,\n    \"status\": \"paid\",\n    \"receivedSatoshis\": 1250000000,\n    \"confirmations\": 1,\n    \"paidTxid\": \"…\",\n    \"createdAt\": \"…\",\n    \"expiresAt\": \"…\"\n  }\n}")</CodeBlock>

            <h3 class="text-base font-bold mt-6 mb-2 tracking-tight text-slate-900 dark:text-white">Delivery log</h3>

            <Endpoint Method="GET" Path="/v1/pay/stores/{storeId}/webhook-deliveries">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Recent delivery attempts (newest first, <InlineCode>?take=1..100</InlineCode>, default 25). Each row carries status code or error message, duration, response snippet (2KB cap), and attempt number.</p>
            </Endpoint>

            <Endpoint Method="POST" Path="/v1/pay/stores/{storeId}/webhook-deliveries/{deliveryId}/replay">
                <p class="text-sm text-slate-500 dark:text-slate-400 m-0">Re-fire a past delivery using the original session payload. Writes a new row with <InlineCode>attempt</InlineCode> incremented so the audit trail is preserved. Test deliveries (no session) cannot be replayed — fire a fresh test instead.</p>
            </Endpoint>

            <h3 class="text-base font-bold mt-6 mb-2 tracking-tight text-slate-900 dark:text-white">Signature verification</h3>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mb-3">Compute <InlineCode>HMAC_SHA256(secret, rawBody)</InlineCode> as hex, prefix with <InlineCode>sha256=</InlineCode>, and <strong>constant-time</strong> compare against the <InlineCode>X-DigiPay-Signature</InlineCode> header. Never parse JSON before verifying — the signature covers the raw bytes, so any reserialization breaks the check.</p>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mt-4 mb-2"><strong>Node</strong> (Express):</p>
            <CodeBlock>@("const crypto = require('crypto');\n\napp.post('/webhook', express.raw({ type: 'application/json' }), (req, res) => {\n  const expected = 'sha256=' +\n    crypto.createHmac('sha256', process.env.DIGIPAY_SECRET)\n          .update(req.body).digest('hex');\n  const provided = req.headers['x-digipay-signature'];\n  if (!crypto.timingSafeEqual(Buffer.from(expected), Buffer.from(provided))) {\n    return res.status(401).end();\n  }\n  const event = JSON.parse(req.body.toString());\n  // reconcile event.session.id in your database\n  res.status(200).end();\n});")</CodeBlock>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mt-4 mb-2"><strong>Python</strong> (Flask):</p>
            <CodeBlock>@("import hmac, hashlib, os\nfrom flask import Flask, request, abort\n\napp = Flask(__name__)\n\n@app.post('/webhook')\ndef webhook():\n    raw = request.get_data()\n    expected = 'sha256=' + hmac.new(\n        os.environ['DIGIPAY_SECRET'].encode(),\n        raw, hashlib.sha256).hexdigest()\n    provided = request.headers.get('X-DigiPay-Signature', '')\n    if not hmac.compare_digest(expected, provided):\n        abort(401)\n    event = request.get_json()  # now safe\n    # reconcile event['session']['id']\n    return '', 200")</CodeBlock>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mt-4 mb-2"><strong>PHP</strong>:</p>
            <CodeBlock>@("<?php\n$raw = file_get_contents('php://input');\n$expected = 'sha256=' . hash_hmac('sha256', $raw, getenv('DIGIPAY_SECRET'));\n$provided = $_SERVER['HTTP_X_DIGIPAY_SIGNATURE'] ?? '';\nif (!hash_equals($expected, $provided)) {\n    http_response_code(401);\n    exit;\n}\n$event = json_decode($raw, true);\n// reconcile $event['session']['id']\nhttp_response_code(200);")</CodeBlock>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mt-4 mb-2"><strong>C# / ASP.NET Core</strong>:</p>
            <CodeBlock>@("app.MapPost(\"/webhook\", async (HttpRequest req) =>\n{\n    using var reader = new StreamReader(req.Body);\n    var raw = await reader.ReadToEndAsync();\n    var secret = Environment.GetEnvironmentVariable(\"DIGIPAY_SECRET\")!;\n    using var hmac = new HMACSHA256(Encoding.UTF8.GetBytes(secret));\n    var expected = \"sha256=\" + Convert.ToHexString(\n        hmac.ComputeHash(Encoding.UTF8.GetBytes(raw))).ToLowerInvariant();\n    var provided = req.Headers[\"X-DigiPay-Signature\"].ToString();\n    if (!CryptographicOperations.FixedTimeEquals(\n            Encoding.UTF8.GetBytes(expected), Encoding.UTF8.GetBytes(provided)))\n        return Results.Unauthorized();\n    // JsonSerializer.Deserialize<WebhookEvent>(raw) …\n    return Results.Ok();\n});")</CodeBlock>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mt-4 mb-3">Unknown event types? Return <InlineCode>200 OK</InlineCode> and ignore — we add new events over time, and 4xx/5xx responses trigger delivery failure rows in the dashboard. Use <InlineCode>event.event</InlineCode> to branch on <InlineCode>session.paid</InlineCode>, <InlineCode>session.confirmed</InlineCode>, etc.</p>

            <DocsHeading>Embed widget</DocsHeading>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mb-3">
                The JS embed is hosted at <InlineCode>/embed/digipay.js</InlineCode>. ~7 KB, no dependencies, derives its own origin from the script src.
                <a href="/embed/demo.html" target="_blank" class="text-dgb-500 hover:underline">Try it live →</a>
            </p>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mb-2">Programmatic:</p>
            <CodeBlock>@("DigiPay.checkout({ sessionId: 'ses_abc' });  // opens iframe modal\nDigiPay.close();                              // dismiss it\nconst a = DigiPay.button({ address: 'dgb1…', amount: 5, name: 'Shop' });\ndocument.body.appendChild(a);")</CodeBlock>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mt-3 mb-2">Declarative:</p>
            <CodeBlock>@("<button data-digipay-checkout data-session-id=\"ses_abc\">Pay</button>\n<span data-digipay-button data-address=\"dgb1…\" data-amount=\"5\">Tip</span>")</CodeBlock>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300 mt-3">Auto-binds on <InlineCode>DOMContentLoaded</InlineCode>; call <InlineCode>DigiPay.bind(rootEl)</InlineCode> after injecting new elements dynamically.</p>

            <DocsHeading>Status codes</DocsHeading>
            <ul class="space-y-1 leading-relaxed text-slate-700 dark:text-slate-300 list-disc pl-5">
                <li><InlineCode>200</InlineCode> — success.</li>
                <li><InlineCode>400</InlineCode> — validation error, body includes an <InlineCode>error</InlineCode> field.</li>
                <li><InlineCode>401</InlineCode> — missing / invalid Bearer token, or key has been revoked.</li>
                <li><InlineCode>404</InlineCode> — resource not found, or belongs to a different merchant.</li>
                <li><InlineCode>409</InlineCode> — challenge already resolved (Digi-ID flows).</li>
            </ul>

            <DocsHeading>Questions?</DocsHeading>
            <p class="leading-relaxed text-slate-700 dark:text-slate-300">The source is open. Clone the repo, file an issue, or just run DigiPay yourself — it's designed to self-host in a single container backed by SQLite or Postgres.</p>
        </article>
    </main>

    <SiteFooter />
</div>
