@{
    var (icon, iconBg, heading, body) = Status switch
    {
        "confirmed" => ("✓", "bg-emerald-500", "Payment confirmed",
            "The merchant has been notified. You can close this page."),
        "expired"   => ("⏱", "bg-slate-400", "Session expired",
            "This payment window has closed. Go back to the merchant to start a new one."),
        "underpaid" => ("!", "bg-red-500", "Underpaid",
            "The received amount was less than the invoice. The merchant will be in touch."),
        "refunded"  => ("↩", "bg-indigo-500", "Refunded",
            "The merchant has sent the amount back on-chain. Check your wallet."),
        "voided"    => ("⊘", "bg-slate-500", "Cancelled by merchant",
            "The merchant cancelled this invoice before payment. Nothing was charged."),
        _ => ("•", "bg-slate-400", "", ""),
    };
}
<div class="flex flex-col items-center gap-3 py-6 text-center">
    <div class="flex items-center justify-center w-14 h-14 rounded-full text-white text-2xl font-bold @iconBg">@icon</div>
    <h3 class="text-base font-bold text-slate-900 dark:text-white m-0">@heading</h3>
    <p class="text-xs text-slate-500 dark:text-slate-400 max-w-xs m-0">@body</p>
    @if (!string.IsNullOrEmpty(Txid))
    {
        <p class="text-[0.625rem] font-mono text-slate-400 dark:text-slate-500 break-all">@Txid</p>
        @* Buyer-facing permalink. Confirmed sessions are the common case; we also
           expose it for "paid" (1-conf) so the customer can grab proof immediately
           and doesn't need to wait the ~15 min to 6 confs just to print. *@
        @if (!string.IsNullOrEmpty(SessionId))
        {
            <a href="@($"/pay/{SessionId}/receipt")" class="text-xs font-semibold text-dgb-500 hover:text-dgb-600 no-underline">View receipt →</a>
        }
    }

    @* Merchant return flow. Only kicks in for the success state ("confirmed")
       and when the session was created with a returnUrl — null for SDK /
       direct-API merchants that own their own after-payment page. We render
       a prominent button immediately and a 5s auto-redirect via a tiny
       inline script (no Blazor server timer = no SignalR round-trip per tick).
       The button stays clickable so impatient buyers don't have to wait. *@
    @if (Status == "confirmed" && !string.IsNullOrWhiteSpace(ReturnUrl))
    {
        <a href="@ReturnUrl"
           class="mt-2 w-full sm:w-auto text-center py-3 px-5 bg-dgb-500 hover:bg-dgb-600 text-white font-semibold rounded-xl no-underline transition-colors">
            Return to merchant
        </a>
        <p class="text-[0.6875rem] text-slate-500 dark:text-slate-400 m-0">
            Returning automatically in <span data-digipay-return-countdown>5</span>…
        </p>
        <script>
            (function () {
                var url = @(System.Text.Json.JsonSerializer.Serialize(ReturnUrl));
                var counter = document.querySelector('[data-digipay-return-countdown]');
                var remaining = 5;
                var timer = setInterval(function () {
                    remaining -= 1;
                    if (counter) counter.textContent = remaining;
                    if (remaining <= 0) {
                        clearInterval(timer);
                        window.location.href = url;
                    }
                }, 1000);
            })();
        </script>
    }
</div>

@code {
    [Parameter] public string Status { get; set; } = "";
    [Parameter] public string? Txid { get; set; }
    [Parameter] public string? SessionId { get; set; }
    [Parameter] public string? ReturnUrl { get; set; }
}
