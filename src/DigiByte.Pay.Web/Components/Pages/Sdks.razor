            <section class="slide-up-delay-4">
                <h2 class="text-xl font-bold tracking-tight mb-4">Verify a webhook</h2>
                <p class="text-sm text-slate-600 dark:text-slate-400 mb-4 leading-relaxed">
                    Every state change POSTs signed JSON to your <InlineCode>webhookUrl</InlineCode>. The SDKs ship a framework-agnostic verifier — hand it the raw bytes, the <InlineCode>X-DigiPay-Signature</InlineCode> header, and the secret; get back a parsed event or a typed error on mismatch.
                    <strong class="text-slate-900 dark:text-white"> Always verify the raw bytes before your framework parses the body</strong> — reserialization breaks the HMAC.
                </p>
                <div class="grid gap-4 sm:grid-cols-3">
                    <div class="bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl p-4 flex flex-col gap-2">
                        <div class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Node (Express)</div>
                        <CodeBlock>@("import express from 'express';\nimport { verifyWebhook, DigiPayError } from '@dgbwallet/digipay';\n\napp.post('/webhook',\n  express.raw({ type: 'application/json' }),\n  (req, res) => {\n    try {\n      const event = verifyWebhook({\n        rawBody: req.body,\n        signature: req.headers['x-digipay-signature'],\n        secret: process.env.DIGIPAY_SECRET,\n      });\n      if (event.event === 'session.paid') {\n        /* mark paid, fulfil, receipt */\n      }\n      res.status(200).end();\n    } catch (err) {\n      if (err instanceof DigiPayError) res.status(err.status).end();\n    }\n  });")</CodeBlock>
                    </div>
                    <div class="bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl p-4 flex flex-col gap-2">
                        <div class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Python (Flask)</div>
                        <CodeBlock>@("from flask import Flask, request, abort\nfrom digipay import verify_webhook, DigiPayError\n\napp = Flask(__name__)\n\n@app.post('/webhook')\ndef webhook():\n    try:\n        event = verify_webhook(\n            raw_body=request.get_data(),\n            signature=request.headers.get(\n                'X-DigiPay-Signature'),\n            secret=os.environ['DIGIPAY_SECRET'],\n        )\n    except DigiPayError as err:\n        abort(err.status)\n    if event['event'] == 'session.paid':\n        ...\n    return '', 200")</CodeBlock>
                    </div>
                    <div class="bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-2xl p-4 flex flex-col gap-2">
                        <div class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">.NET (ASP.NET Core)</div>
                        <CodeBlock>@("using DigiPay;\n\napp.MapPost(\"/webhook\", async (HttpContext ctx) =>\n{\n    using var ms = new MemoryStream();\n    await ctx.Request.Body.CopyToAsync(ms);\n    try\n    {\n        var evt = WebhookVerifier.Verify(\n            ms.ToArray(),\n            ctx.Request.Headers[\n                \"X-DigiPay-Signature\"].FirstOrDefault(),\n            Environment.GetEnvironmentVariable(\n                \"DIGIPAY_SECRET\")!);\n        if (evt.Event == \"session.paid\") { /* ... */ }\n        return Results.Ok();\n    }\n    catch (DigiPayError err)\n    {\n        return Results.StatusCode(err.Status);\n    }\n});")</CodeBlock>
                    </div>
                </div>
            </section>

