@page "/sdks"
@rendermode InteractiveServer
<PageTitle>SDKs — DigiPay</PageTitle>

<HeadContent>
    @* Progressive-enhancement script for tabs, copy buttons, and live
       version badges. Loads at the tail of <head> so the DOM is ready
       by the time it runs. *@
    <script src="/sdks-page.js" defer></script>
</HeadContent>

<div class="min-h-dvh flex flex-col bg-slate-50 dark:bg-dgb-950 text-slate-900 dark:text-white font-sans">
    <SiteNav />

    <main class="flex-1 page-enter">
        <article class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-12 flex flex-col gap-10">

            @* Hero *@
            <header class="text-center flex flex-col gap-3 slide-up">
                <span class="inline-block self-center px-3 py-1 bg-dgb-500/10 text-dgb-500 rounded-full text-xs font-semibold">
                    Official SDKs · zero external deps · typed
                </span>
                <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">
                    Accept DGB in one line.
                </h1>
                <p class="text-base sm:text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
                    First-party client libraries for <strong>Node.js</strong>, <strong>Python</strong>, and <strong>.NET</strong>.
                    Same surface, same error model, same webhook verifier behaviour — pick the stack you already run.
                </p>
            </header>

            @* Install cards — one per language. Copy button + live version
               badge via sdks-page.js. *@
            <section class="grid gap-3 sm:grid-cols-3 slide-up-delay-1">
                @{
                    // DRY-ing the card markup: each card is (Registry, Package,
                    // Logo, Colour, InstallCmd, Href, SubBadge). Rendered inline
                    // below — a foreach + RenderFragment would have hidden the
                    // bespoke SVG logos, so a tiny repetition wins on clarity.
                }

