            @* Create a session — tabbed so each language gets the full
               container width. Progressive enhancement: without JS, the
               first pane stays open and the rest fall through as plain
               sections (see defaults on hidden attr below). *@
            <section class="slide-up-delay-3" data-tabs>
                <h2 class="text-xl font-bold tracking-tight mb-3">Create a session</h2>
                <div role="tablist" aria-label="Language" class="inline-flex gap-1 p-1 bg-slate-100 dark:bg-dgb-900 rounded-lg mb-3">
                    <button role="tab" aria-selected="true" aria-controls="create-node" tabindex="0"
                            class="px-3 py-1.5 rounded-md text-sm font-medium bg-dgb-500 text-white transition-colors">Node</button>
                    <button role="tab" aria-selected="false" aria-controls="create-python" tabindex="-1"
                            class="px-3 py-1.5 rounded-md text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-dgb-800 transition-colors">Python</button>
                    <button role="tab" aria-selected="false" aria-controls="create-dotnet" tabindex="-1"
                            class="px-3 py-1.5 rounded-md text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-dgb-800 transition-colors">.NET</button>
                </div>
                <div id="create-node" role="tabpanel">
                    <CodeBlock>@("import { DigiPay } from '@dgbwallet/digipay';\n\nconst dp = new DigiPay({ apiKey: process.env.DIGIPAY_KEY });\nconst session = await dp.sessions.create({\n  amount: 5,\n  label: 'Order #1234',\n});\nconsole.log(session.checkoutUrl);")</CodeBlock>
                </div>
                <div id="create-python" role="tabpanel" hidden>
                    <CodeBlock>@("import os\nfrom digipay import DigiPay\n\ndp = DigiPay(api_key=os.environ['DIGIPAY_KEY'])\nsession = dp.sessions.create(\n    amount=5,\n    label='Order #1234',\n)\nprint(session['checkoutUrl'])")</CodeBlock>
                </div>
                <div id="create-dotnet" role="tabpanel" hidden>
                    <CodeBlock>@("using DigiPay;\n\nusing var dp = new DigiPayClient(\n    Environment.GetEnvironmentVariable(\"DIGIPAY_KEY\")!);\n\nvar session = await dp.Sessions.CreateAsync(\n    new CreateSessionRequest {\n        Amount = 5m,\n        Label = \"Order #1234\",\n    });\n\nConsole.WriteLine(session.CheckoutUrl);")</CodeBlock>
                </div>
            </section>

            @* Verify a webhook — same pattern. *@
            <section class="slide-up-delay-4" data-tabs>
                <h2 class="text-xl font-bold tracking-tight mb-3">Verify a webhook</h2>
                <p class="text-sm text-slate-600 dark:text-slate-400 mb-4 leading-relaxed">
                    Every state change POSTs signed JSON to your <InlineCode>webhookUrl</InlineCode>. The SDKs ship a framework-agnostic verifier — hand it the raw bytes, the <InlineCode>X-DigiPay-Signature</InlineCode> header, and the secret; get back a parsed event or a typed error on mismatch.
                    <strong class="text-slate-900 dark:text-white"> Always verify the raw bytes before your framework parses the body</strong> — reserialization breaks the HMAC.
                </p>
                <div role="tablist" aria-label="Framework" class="inline-flex gap-1 p-1 bg-slate-100 dark:bg-dgb-900 rounded-lg mb-3">
                    <button role="tab" aria-selected="true" aria-controls="verify-node" tabindex="0"
                            class="px-3 py-1.5 rounded-md text-sm font-medium bg-dgb-500 text-white transition-colors">Node · Express</button>
                    <button role="tab" aria-selected="false" aria-controls="verify-python" tabindex="-1"
                            class="px-3 py-1.5 rounded-md text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-dgb-800 transition-colors">Python · Flask</button>
                    <button role="tab" aria-selected="false" aria-controls="verify-dotnet" tabindex="-1"
                            class="px-3 py-1.5 rounded-md text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-dgb-800 transition-colors">.NET · ASP.NET Core</button>
                </div>
                <div id="verify-node" role="tabpanel">
                    <CodeBlock>@("import express from 'express';\nimport { verifyWebhook, DigiPayError } from '@dgbwallet/digipay';\n\napp.post('/webhook',\n  express.raw({ type: 'application/json' }),\n  (req, res) => {\n    try {\n      const event = verifyWebhook({\n        rawBody: req.body,\n        signature: req.headers['x-digipay-signature'],\n        secret: process.env.DIGIPAY_SECRET,\n      });\n      if (event.event === 'session.paid') {\n        // mark paid, fulfil, send receipt…\n      }\n      res.status(200).end();\n    } catch (err) {\n      if (err instanceof DigiPayError) res.status(err.status).end();\n    }\n  });")</CodeBlock>
                </div>
                <div id="verify-python" role="tabpanel" hidden>
                    <CodeBlock>@("import os\nfrom flask import Flask, request, abort\nfrom digipay import verify_webhook, DigiPayError\n\napp = Flask(__name__)\n\n@app.post('/webhook')\ndef webhook():\n    try:\n        event = verify_webhook(\n            raw_body=request.get_data(),\n            signature=request.headers.get('X-DigiPay-Signature'),\n            secret=os.environ['DIGIPAY_SECRET'],\n        )\n    except DigiPayError as err:\n        abort(err.status)\n    if event['event'] == 'session.paid':\n        # mark paid, fulfil, send receipt…\n        pass\n    return '', 200")</CodeBlock>
                </div>
                <div id="verify-dotnet" role="tabpanel" hidden>
                    <CodeBlock>@("using DigiPay;\n\napp.MapPost(\"/webhook\", async (HttpContext ctx) =>\n{\n    using var ms = new MemoryStream();\n    await ctx.Request.Body.CopyToAsync(ms);\n    try\n    {\n        var evt = WebhookVerifier.Verify(\n            ms.ToArray(),\n            ctx.Request.Headers[\"X-DigiPay-Signature\"].FirstOrDefault(),\n            Environment.GetEnvironmentVariable(\"DIGIPAY_SECRET\")!);\n        if (evt.Event == \"session.paid\")\n        {\n            // mark paid, fulfil, send receipt…\n        }\n        return Results.Ok();\n    }\n    catch (DigiPayError err)\n    {\n        return Results.StatusCode(err.Status);\n    }\n});")</CodeBlock>
                </div>
            </section>

            @* DigiPayError status cheatsheet — easier to scan as a table
               than as a paragraph, especially for integrators deciding
               retry vs. fail-fast. *@
            <section class="slide-up-delay-5">
                <h2 class="text-xl font-bold tracking-tight mb-3">Error handling</h2>
                <p class="text-sm text-slate-600 dark:text-slate-400 mb-4 leading-relaxed">
                    Every failure raises <InlineCode>DigiPayError</InlineCode> with the HTTP status preserved on <InlineCode>err.status</InlineCode>. Branch on the number, not the message — the message is for humans, the status is for your retry policy.
                </p>
                <div class="overflow-x-auto rounded-xl border border-slate-200 dark:border-dgb-800 bg-white dark:bg-dgb-900">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-left text-slate-500 dark:text-slate-400 border-b border-slate-200 dark:border-dgb-800 bg-slate-50 dark:bg-dgb-900/50">
                                <th class="py-3 px-4 font-semibold">status</th>
                                <th class="py-3 px-4 font-semibold">Meaning</th>
                                <th class="py-3 px-4 font-semibold">Retry?</th>
                            </tr>
                        </thead>
                        <tbody class="[&_td]:py-2.5 [&_td]:px-4 [&_tr:not(:last-child)_td]:border-b [&_tr:not(:last-child)_td]:border-slate-100 dark:[&_tr:not(:last-child)_td]:border-dgb-800/60">
                            <tr><td class="font-mono text-xs">0</td><td>Network / DNS / TLS / timeout</td><td class="text-amber-600 dark:text-amber-400">With backoff</td></tr>
                            <tr><td class="font-mono text-xs">400</td><td>Validation — <InlineCode>err.body.error</InlineCode> has the field</td><td class="text-red-500 dark:text-red-400">No — fix input</td></tr>
                            <tr><td class="font-mono text-xs">401</td><td>Missing or invalid API key</td><td class="text-red-500 dark:text-red-400">No — rotate</td></tr>
                            <tr><td class="font-mono text-xs">404</td><td>Not found or not owned by this merchant</td><td class="text-red-500 dark:text-red-400">No</td></tr>
                            <tr><td class="font-mono text-xs">429</td><td>Rate-limited (sandbox endpoints only)</td><td class="text-amber-600 dark:text-amber-400">Honour <InlineCode>Retry-After</InlineCode></td></tr>
                            <tr><td class="font-mono text-xs">≥ 500</td><td>Server-side</td><td class="text-emerald-600 dark:text-emerald-400">Yes, with backoff</td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

