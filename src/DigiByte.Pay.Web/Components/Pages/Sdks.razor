                        </span>
                        <div class="min-w-0 flex-1">
                            <div class="flex items-center gap-2">
                                <span class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Node.js</span>
                                <span data-version-badge="npm" class="opacity-0 transition-opacity text-[10px] font-mono font-semibold px-1.5 py-0.5 rounded bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300" title="Latest published version"></span>
                            </div>
                            <div class="font-bold text-slate-900 dark:text-white truncate">@("@dgbwallet/digipay")</div>
