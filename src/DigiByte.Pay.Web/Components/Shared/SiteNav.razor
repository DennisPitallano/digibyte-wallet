@inject NavigationManager Nav

@{
    var path = new Uri(Nav.Uri).AbsolutePath.TrimEnd('/');
    string cls(string p) => path == p || (p.Length > 1 && path.StartsWith(p)) ? "is-active" : "";
}

<nav class="dp-nav">
    <div class="dp-nav__inner">
        <a href="/" class="dp-nav__brand"><span class="dp-nav__brand-dot"></span> DigiPay</a>
        <div class="dp-nav__links">
            <a href="/docs" class="@cls("/docs")">How it works</a>
            <a href="/docs/api" class="@cls("/docs/api")">Developers</a>
        </div>
        <a href="/merchant/signin" class="dp-nav__cta">Sign in</a>
    </div>
</nav>
