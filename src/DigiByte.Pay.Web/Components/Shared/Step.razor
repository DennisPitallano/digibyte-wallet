<div class="grid grid-cols-[2.25rem_1fr] gap-4 items-start bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl p-5">
    <div class="w-8 h-8 rounded-full bg-dgb-500 text-white flex items-center justify-center font-bold text-sm">@N</div>
    <div>
        <h3 class="text-base font-bold mb-1.5 text-slate-900 dark:text-white">@Title</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed m-0">@Body</p>
    </div>
</div>

@code {
    [Parameter] public string N { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Body { get; set; } = "";
}
