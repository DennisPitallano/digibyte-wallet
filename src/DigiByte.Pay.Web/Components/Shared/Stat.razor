<div class="bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl p-3 sm:p-4">
    <div class="text-[0.6875rem] uppercase tracking-widest font-bold text-slate-500 dark:text-slate-400">@Label</div>
    <div class="text-2xl font-bold tabular-nums mt-1 text-slate-900 dark:text-white">@Value</div>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
}
