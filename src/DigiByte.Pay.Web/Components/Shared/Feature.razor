<div class="bg-white dark:bg-dgb-900 border border-slate-200 dark:border-dgb-800 rounded-xl p-5 sm:p-6">
    <div class="w-10 h-10 rounded-xl bg-dgb-500/10 text-dgb-500 flex items-center justify-center mb-3">
        <Icon Name="@IconName" Class="w-5 h-5" />
    </div>
    <h3 class="text-base font-bold mb-1.5 text-slate-900 dark:text-white">@Title</h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed m-0">@Body</p>
</div>

@code {
    /// <summary>Name from the Icon component's switch (e.g. "zap", "shield", "bell").</summary>
    [Parameter] public string IconName { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Body { get; set; } = "";
}
