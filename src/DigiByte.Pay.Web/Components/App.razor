<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["css/tailwind.css"]" />
    <link rel="stylesheet" href="@Assets["DigiByte.Pay.Web.styles.css"]" />
    <ImportMap />
    <HeadOutlet />
    @* Theme boot script — must run synchronously in <head> to set data-theme
       on <html> before first paint. Prevents FOUC on the initial SSR render. *@
    <script src="@Assets["theme.js"]"></script>
    @* Auth-state boot — same pattern, sets data-digipay-auth="yes|no" from
       localStorage so the nav can show Dashboard vs Sign-in via CSS alone. *@
    <script src="@Assets["auth-state.js"]"></script>
    <link rel="stylesheet" href="@Assets["auth-state.css"]" />
    @* Checkout countdown — pure JS so the timer works inside the embed iframe
       where Blazor's InteractiveServer circuit can't reliably hydrate. *@
    <script src="@Assets["checkout-countdown.js"]"></script>
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
